{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011zcFa31MTYNtJmEL4nb73c","type":"tool_result","content":"1\t\"\"\"Tests for WorkflowTemplate and TemplateViolation.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\tfrom typing import Any\n6\t\n7\timport pytest\n8\t\n9\tfrom darkfactory.templates import TemplateViolation, WorkflowTemplate\n10\tfrom darkfactory.workflow import AgentTask, BuiltIn, ShellTask, Workflow\n11\t\n12\t\n13\tdef _make_template(**kwargs: Any) -> WorkflowTemplate:\n14\t    \"\"\"Build a WorkflowTemplate with sensible defaults.\"\"\"\n15\t    defaults: dict[str, Any] = dict(\n16\t        name=\"test-template\",\n17\t        description=\"A test template\",\n18\t        open=[BuiltIn(\"ensure_worktree\")],\n19\t        close=[BuiltIn(\"commit\"), BuiltIn(\"push_branch\")],\n20\t        middle_kinds=[AgentTask, ShellTask],\n21\t        middle_required={},\n22\t    )\n23\t    defaults.update(kwargs)\n24\t    return WorkflowTemplate(**defaults)\n25\t\n26\t\n27\tdef _dummy_applies_to(prd: Any, prds: Any) -> bool:\n28\t    return True\n29\t\n30\t\n31\t# ---------- AC-1: task ordering ----------\n32\t\n33\t\n34\tdef test_compose_task_order_is_open_middle_close() -> None:\n35\t    \"\"\"compose() produces [*open, *middle, *close] task ordering.\"\"\"\n36\t    open_task = BuiltIn(\"ensure_worktree\")\n37\t    close_task = BuiltIn(\"push_branch\")\n38\t    middle_task = AgentTask(name=\"implement\")\n39\t\n40\t    tmpl = WorkflowTemplate(\n41\t        name=\"ordered\",\n42\t        description=\"ordering test\",\n43\t        open=[open_task],\n44\t        close=[close_task],\n45\t        middle_kinds=[AgentTask],\n46\t    )\n47\t    wf = tmpl.compose(\n48\t        name=\"my-workflow\",\n49\t        description=\"desc\",\n50\t        applies_to=_dummy_applies_to,\n51\t        priority=5,\n52\t        middle=[middle_task],\n53\t    )\n54\t\n55\t    assert wf.tasks == [open_task, middle_task, close_task]\n56\t\n57\t\n58\tdef test_compose_multiple_open_and_close() -> None:\n59\t    \"\"\"All open and close tasks appear in the correct order.\"\"\"\n60\t    o1 = BuiltIn(\"ensure_worktree\")\n61\t    o2 = BuiltIn(\"set_status\")\n62\t    c1 = BuiltIn(\"commit\")\n63\t    c2 = BuiltIn(\"push_branch\")\n64\t    m1 = AgentTask(name=\"implement\")\n65\t    m2 = ShellTask(name=\"test\", cmd=\"just test\")\n66\t\n67\t    tmpl = WorkflowTemplate(\n68\t        name=\"multi\",\n69\t        description=\"multi open/close\",\n70\t        open=[o1, o2],\n71\t        close=[c1, c2],\n72\t        middle_kinds=[AgentTask, ShellTask],\n73\t    )\n74\t    wf = tmpl.compose(\n75\t        name=\"wf\",\n76\t        description=\"\",\n77\t        applies_to=_dummy_applies_to,\n78\t        priority=0,\n79\t        middle=[m1, m2],\n80\t    )\n81\t\n82\t    assert wf.tasks == [o1, o2, m1, m2, c1, c2]\n83\t\n84\t\n85\tdef test_compose_empty_middle_produces_open_plus_close() -> None:\n86\t    \"\"\"Empty middle is valid when no kinds or requirements are enforced.\"\"\"\n87\t    tmpl = WorkflowTemplate(\n88\t        name=\"empty-middle\",\n89\t        description=\"\",\n90\t        open=[BuiltIn(\"ensure_worktree\")],\n91\t        close=[BuiltIn(\"push_branch\")],\n92\t        middle_kinds=[],\n93\t        middle_required={},\n94\t    )\n95\t    wf = tmpl.compose(\n96\t        name=\"wf\",\n97\t        description=\"\",\n98\t        applies_to=_dummy_applies_to,\n99\t        priority=0,\n100\t        middle=[],\n101\t    )\n102\t    assert len(wf.tasks) == 2\n103\t    assert wf.tasks[0] == BuiltIn(\"ensure_worktree\")\n104\t    assert wf.tasks[1] == BuiltIn(\"push_branch\")\n105\t\n106\t\n107\tdef test_compose_sets_workflow_fields() -> None:\n108\t    \"\"\"Workflow name, description, applies_to, and priority come from compose args.\"\"\"\n109\t    tmpl = _make_template()\n110\t    wf = tmpl.compose(\n111\t        name=\"specific-wf\",\n112\t        description=\"my description\",\n113\t        applies_to=_dummy_applies_to,\n114\t        priority=10,\n115\t        middle=[AgentTask(name=\"implement\")],\n116\t    )\n117\t    assert wf.name == \"specific-wf\"\n118\t    assert wf.description == \"my description\"\n119\t    assert wf.applies_to is _dummy_applies_to\n120\t    assert wf.priority == 10\n121\t\n122\t\n123\t# ---------- AC-2: middle_kinds violation ----------\n124\t\n125\t\n126\tdef test_compose_raises_for_disallowed_kind() -> None:\n127\t    \"\"\"A task not in middle_kinds raises TemplateViolation.\"\"\"\n128\t    tmpl = WorkflowTemplate(\n129\t        name=\"agent-only\",\n130\t        description=\"\",\n131\t        open=[],\n132\t        close=[],\n133\t        middle_kinds=[AgentTask],\n134\t    )\n135\t    shell_task = ShellTask(name=\"test\", cmd=\"just test\")\n136\t    with pytest.raises(TemplateViolation, match=\"not an allowed middle kind\"):\n137\t        tmpl.compose(\n138\t            name=\"wf\",\n139\t            description=\"\",\n140\t            applies_to=_dummy_applies_to,\n141\t            priority=0,\n142\t            middle=[shell_task],\n143\t        )\n144\t\n145\t\n146\tdef test_compose_violation_message_names_allowed_kinds() -> None:\n147\t    \"\"\"TemplateViolation message includes the allowed kind names.\"\"\"\n148\t    tmpl = WorkflowTemplate(\n149\t        name=\"strict\",\n150\t        description=\"\",\n151\t        open=[],\n152\t        close=[],\n153\t        middle_kinds=[AgentTask],\n154\t    )\n155\t    with pytest.raises(TemplateViolation, match=\"AgentTask\"):\n156\t        tmpl.compose(\n157\t            name=\"wf\",\n158\t            description=\"\",\n159\t            applies_to=_dummy_applies_to,\n160\t            priority=0,\n161\t            middle=[ShellTask(name=\"s\", cmd=\"x\")],\n162\t        )\n163\t\n164\t\n165\tdef test_compose_allows_all_listed_kinds() -> None:\n166\t    \"\"\"Tasks that are instances of any listed kind are accepted.\"\"\"\n167\t    tmpl = _make_template(middle_kinds=[AgentTask, ShellTask])\n168\t    wf = tmpl.compose(\n169\t        name=\"wf\",\n170\t        description=\"\",\n171\t        applies_to=_dummy_applies_to,\n172\t        priority=0,\n173\t        middle=[AgentTask(name=\"implement\"), ShellTask(name=\"verify\", cmd=\"just test\")],\n174\t    )\n175\t    # _make_template: 1 open + 2 middle + 2 close = 5\n176\t    assert len(wf.tasks) == 5\n177\t\n178\t\n179\t# ---------- AC-3: middle_required violation ----------\n180\t\n181\t\n182\tdef test_compose_raises_when_required_kind_too_few() -> None:\n183\t    \"\"\"TemplateViolation raised when a required kind appears fewer than min times.\"\"\"\n184\t    tmpl = WorkflowTemplate(\n185\t        name=\"needs-agent\",\n186\t        description=\"\",\n187\t        open=[],\n188\t        close=[],\n189\t        middle_kinds=[AgentTask, ShellTask],\n190\t        middle_required={AgentTask: (1, None)},\n191\t    )\n192\t    with pytest.raises(TemplateViolation, match=\"at least 1 AgentTask\"):\n193\t        tmpl.compose(\n194\t            name=\"wf\",\n195\t            description=\"\",\n196\t            applies_to=_dummy_applies_to,\n197\t            priority=0,\n198\t            middle=[ShellTask(name=\"test\", cmd=\"just test\")],\n199\t        )\n200\t\n201\t\n202\tdef test_compose_raises_when_required_kind_too_many() -> None:\n203\t    \"\"\"TemplateViolation raised when a required kind exceeds max count.\"\"\"\n204\t    tmpl = WorkflowTemplate(\n205\t        name=\"max-one-agent\",\n206\t        description=\"\",\n207\t        open=[],\n208\t        close=[],\n209\t        middle_kinds=[AgentTask, ShellTask],\n210\t        middle_required={AgentTask: (0, 1)},\n211\t    )\n212\t    with pytest.raises(TemplateViolation, match=\"at most 1 AgentTask\"):\n213\t        tmpl.compose(\n214\t            name=\"wf\",\n215\t            description=\"\",\n216\t            applies_to=_dummy_applies_to,\n217\t            priority=0,\n218\t            middle=[AgentTask(name=\"a\"), AgentTask(name=\"b\")],\n219\t        )\n220\t\n221\t\n222\tdef test_compose_raises_too_few_includes_count() -> None:\n223\t    \"\"\"Violation message for too-few includes the actual count.\"\"\"\n224\t    tmpl = WorkflowTemplate(\n225\t        name=\"t\",\n226\t        description=\"\",\n227\t        open=[],\n228\t        close=[],\n229\t        middle_kinds=[AgentTask],\n230\t        middle_required={AgentTask: (2, None)},\n231\t    )\n232\t    with pytest.raises(TemplateViolation, match=\"got 1\"):\n233\t        tmpl.compose(\n234\t            name=\"wf\",\n235\t            description=\"\",\n236\t            applies_to=_dummy_applies_to,\n237\t            priority=0,\n238\t            middle=[AgentTask(name=\"a\")],\n239\t        )\n240\t\n241\t\n242\tdef test_compose_at_exactly_min_succeeds() -> None:\n243\t    \"\"\"Exactly meeting the minimum required count is valid.\"\"\"\n244\t    tmpl = WorkflowTemplate(\n245\t        name=\"t\",\n246\t        description=\"\",\n247\t        open=[],\n248\t        close=[],\n249\t        middle_kinds=[AgentTask],\n250\t        middle_required={AgentTask: (1, None)},\n251\t    )\n252\t    wf = tmpl.compose(\n253\t        name=\"wf\",\n254\t        description=\"\",\n255\t        applies_to=_dummy_applies_to,\n256\t        priority=0,\n257\t        middle=[AgentTask(name=\"a\")],\n258\t    )\n259\t    assert len(wf.tasks) == 1\n260\t\n261\t\n262\tdef test_compose_at_exactly_max_succeeds() -> None:\n263\t    \"\"\"Exactly meeting the maximum allowed count is valid.\"\"\"\n264\t    tmpl = WorkflowTemplate(\n265\t        name=\"t\",\n266\t        description=\"\",\n267\t        open=[],\n268\t        close=[],\n269\t        middle_kinds=[AgentTask],\n270\t        middle_required={AgentTask: (0, 2)},\n271\t    )\n272\t    wf = tmpl.compose(\n273\t        name=\"wf\",\n274\t        description=\"\",\n275\t        applies_to=_dummy_applies_to,\n276\t        priority=0,\n277\t        middle=[AgentTask(name=\"a\"), AgentTask(name=\"b\")],\n278\t    )\n279\t    assert len(wf.tasks) == 2\n280\t\n281\t\n282\t# ---------- AC-4: template_name on composed workflow ----------\n283\t\n284\t\n285\tdef test_compose_sets_template_name() -> None:\n286\t    \"\"\"The composed Workflow has template_name matching the template's name.\"\"\"\n287\t    tmpl = _make_template(name=\"my-template\")\n288\t    wf = tmpl.compose(\n289\t        name=\"wf\",\n290\t        description=\"\",\n291\t        applies_to=_dummy_applies_to,\n292\t        priority=0,\n293\t        middle=[AgentTask(name=\"implement\")],\n294\t    )\n295\t    assert wf.template_name == \"my-template\"\n296\t\n297\t\n298\tdef test_compose_template_name_matches_template_name_field() -> None:\n299\t    \"\"\"template_name always matches the WorkflowTemplate.name field.\"\"\"\n300\t    for tname in [\"prd-implementation\", \"rework\", \"planning\"]:\n301\t        tmpl = _make_template(name=tname)\n302\t        wf = tmpl.compose(\n303\t            name=\"wf\",\n304\t            description=\"\",\n305\t            applies_to=_dummy_applies_to,\n306\t            priority=0,\n307\t            middle=[AgentTask(name=\"implement\")],\n308\t        )\n309\t        assert wf.template_name == tname\n310\t\n311\t\n312\t# ---------- AC-5: Workflow default template_name ----------\n313\t\n314\t\n315\tdef test_workflow_template_name_defaults_to_none() -> None:\n316\t    \"\"\"A Workflow constructed without template_name has template_name=None.\"\"\"\n317\t    wf = Workflow(name=\"bare\", tasks=[BuiltIn(\"ensure_worktree\")])\n318\t    assert wf.template_name is None\n319\t\n320\t\n321\tdef test_workflow_can_be_constructed_without_template_name() -> None:\n322\t    \"\"\"Existing Workflow construction still works unchanged.\"\"\"\n323\t    wf = Workflow(\n324\t        name=\"legacy\",\n325\t        description=\"no template\",\n326\t        tasks=[BuiltIn(\"ensure_worktree\"), AgentTask(name=\"implement\")],\n327\t        priority=1,\n328\t    )\n329\t    assert wf.template_name is None\n330\t    assert len(wf.tasks) == 2\n331\t"}]},"parent_tool_use_id":null,"session_id":"7d98639c-26bc-45d3-9705-9d67800b0669","uuid":"4a484231-cfea-4ab0-8c9f-f469fad22f21","timestamp":"2026-04-09T04:27:00.502Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-227.2-prd-implementation-template/tests/test_workflow_templates.py","content":"\"\"\"Tests for WorkflowTemplate and TemplateViolation.\"\"\"\n\nfrom __future__ import annotations\n\nfrom typing import Any\n\nimport pytest\n\nfrom darkfactory.templates import TemplateViolation, WorkflowTemplate\nfrom darkfactory.workflow import AgentTask, BuiltIn, ShellTask, Workflow\n\n\ndef _make_template(**kwargs: Any) -> WorkflowTemplate:\n    \"\"\"Build a WorkflowTemplate with sensible defaults.\"\"\"\n    defaults: dict[str, Any] = dict(\n        name=\"test-template\",\n        description=\"A test template\",\n        open=[BuiltIn(\"ensure_worktree\")],\n        close=[BuiltIn(\"commit\"), BuiltIn(\"push_branch\")],\n        middle_kinds=[AgentTask, ShellTask],\n        middle_required={},\n    )\n    defaults.update(kwargs)\n    return WorkflowTemplate(**defaults)\n\n\ndef _dummy_applies_to(prd: Any, prds: Any) -> bool:\n    return True\n\n\n# ---------- AC-1: task ordering ----------\n\n\ndef test_compose_task_order_is_open_middle_close() -> None:\n    \"\"\"compose() produces [*open, *middle, *close] task ordering.\"\"\"\n    open_task = BuiltIn(\"ensure_worktree\")\n    close_task = BuiltIn(\"push_branch\")\n    middle_task = AgentTask(name=\"implement\")\n\n    tmpl = WorkflowTemplate(\n        name=\"ordered\",\n        description=\"ordering test\",\n        open=[open_task],\n        close=[close_task],\n        middle_kinds=[AgentTask],\n    )\n    wf = tmpl.compose(\n        name=\"my-workflow\",\n        description=\"desc\",\n        applies_to=_dummy_applies_to,\n        priority=5,\n        middle=[middle_task],\n    )\n\n    assert wf.tasks == [open_task, middle_task, close_task]\n\n\ndef test_compose_multiple_open_and_close() -> None:\n    \"\"\"All open and close tasks appear in the correct order.\"\"\"\n    o1 = BuiltIn(\"ensure_worktree\")\n    o2 = BuiltIn(\"set_status\")\n    c1 = BuiltIn(\"commit\")\n    c2 = BuiltIn(\"push_branch\")\n    m1 = AgentTask(name=\"implement\")\n    m2 = ShellTask(name=\"test\", cmd=\"just test\")\n\n    tmpl = WorkflowTemplate(\n        name=\"multi\",\n        description=\"multi open/close\",\n        open=[o1, o2],\n        close=[c1, c2],\n        middle_kinds=[AgentTask, ShellTask],\n    )\n    wf = tmpl.compose(\n        name=\"wf\",\n        description=\"\",\n        applies_to=_dummy_applies_to,\n        priority=0,\n        middle=[m1, m2],\n    )\n\n    assert wf.tasks == [o1, o2, m1, m2, c1, c2]\n\n\ndef test_compose_empty_middle_produces_open_plus_close() -> None:\n    \"\"\"Empty middle is valid when no kinds or requirements are enforced.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"empty-middle\",\n        description=\"\",\n        open=[BuiltIn(\"ensure_worktree\")],\n        close=[BuiltIn(\"push_branch\")],\n        middle_kinds=[],\n        middle_required={},\n    )\n    wf = tmpl.compose(\n        name=\"wf\",\n        description=\"\",\n        applies_to=_dummy_applies_to,\n        priority=0,\n        middle=[],\n    )\n    assert len(wf.tasks) == 2\n    assert wf.tasks[0] == BuiltIn(\"ensure_worktree\")\n    assert wf.tasks[1] == BuiltIn(\"push_branch\")\n\n\ndef test_compose_sets_workflow_fields() -> None:\n    \"\"\"Workflow name, description, applies_to, and priority come from compose args.\"\"\"\n    tmpl = _make_template()\n    wf = tmpl.compose(\n        name=\"specific-wf\",\n        description=\"my description\",\n        applies_to=_dummy_applies_to,\n        priority=10,\n        middle=[AgentTask(name=\"implement\")],\n    )\n    assert wf.name == \"specific-wf\"\n    assert wf.description == \"my description\"\n    assert wf.applies_to is _dummy_applies_to\n    assert wf.priority == 10\n\n\n# ---------- AC-2: middle_kinds violation ----------\n\n\ndef test_compose_raises_for_disallowed_kind() -> None:\n    \"\"\"A task not in middle_kinds raises TemplateViolation.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"agent-only\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask],\n    )\n    shell_task = ShellTask(name=\"test\", cmd=\"just test\")\n    with pytest.raises(TemplateViolation, match=\"not an allowed middle kind\"):\n        tmpl.compose(\n            name=\"wf\",\n            description=\"\",\n            applies_to=_dummy_applies_to,\n            priority=0,\n            middle=[shell_task],\n        )\n\n\ndef test_compose_violation_message_names_allowed_kinds() -> None:\n    \"\"\"TemplateViolation message includes the allowed kind names.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"strict\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask],\n    )\n    with pytest.raises(TemplateViolation, match=\"AgentTask\"):\n        tmpl.compose(\n            name=\"wf\",\n            description=\"\",\n            applies_to=_dummy_applies_to,\n            priority=0,\n            middle=[ShellTask(name=\"s\", cmd=\"x\")],\n        )\n\n\ndef test_compose_allows_all_listed_kinds() -> None:\n    \"\"\"Tasks that are instances of any listed kind are accepted.\"\"\"\n    tmpl = _make_template(middle_kinds=[AgentTask, ShellTask])\n    wf = tmpl.compose(\n        name=\"wf\",\n        description=\"\",\n        applies_to=_dummy_applies_to,\n        priority=0,\n        middle=[AgentTask(name=\"implement\"), ShellTask(name=\"verify\", cmd=\"just test\")],\n    )\n    # _make_template: 1 open + 2 middle + 2 close = 5\n    assert len(wf.tasks) == 5\n\n\n# ---------- AC-3: middle_required violation ----------\n\n\ndef test_compose_raises_when_required_kind_too_few() -> None:\n    \"\"\"TemplateViolation raised when a required kind appears fewer than min times.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"needs-agent\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask, ShellTask],\n        middle_required={AgentTask: (1, None)},\n    )\n    with pytest.raises(TemplateViolation, match=\"at least 1 AgentTask\"):\n        tmpl.compose(\n            name=\"wf\",\n            description=\"\",\n            applies_to=_dummy_applies_to,\n            priority=0,\n            middle=[ShellTask(name=\"test\", cmd=\"just test\")],\n        )\n\n\ndef test_compose_raises_when_required_kind_too_many() -> None:\n    \"\"\"TemplateViolation raised when a required kind exceeds max count.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"max-one-agent\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask, ShellTask],\n        middle_required={AgentTask: (0, 1)},\n    )\n    with pytest.raises(TemplateViolation, match=\"at most 1 AgentTask\"):\n        tmpl.compose(\n            name=\"wf\",\n            description=\"\",\n            applies_to=_dummy_applies_to,\n            priority=0,\n            middle=[AgentTask(name=\"a\"), AgentTask(name=\"b\")],\n        )\n\n\ndef test_compose_raises_too_few_includes_count() -> None:\n    \"\"\"Violation message for too-few includes the actual count.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"t\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask],\n        middle_required={AgentTask: (2, None)},\n    )\n    with pytest.raises(TemplateViolation, match=\"got 1\"):\n        tmpl.compose(\n            name=\"wf\",\n            description=\"\",\n            applies_to=_dummy_applies_to,\n            priority=0,\n            middle=[AgentTask(name=\"a\")],\n        )\n\n\ndef test_compose_at_exactly_min_succeeds() -> None:\n    \"\"\"Exactly meeting the minimum required count is valid.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"t\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask],\n        middle_required={AgentTask: (1, None)},\n    )\n    wf = tmpl.compose(\n        name=\"wf\",\n        description=\"\",\n        applies_to=_dummy_applies_to,\n        priority=0,\n        middle=[AgentTask(name=\"a\")],\n    )\n    assert len(wf.tasks) == 1\n\n\ndef test_compose_at_exactly_max_succeeds() -> None:\n    \"\"\"Exactly meeting the maximum allowed count is valid.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"t\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask],\n        middle_required={AgentTask: (0, 2)},\n    )\n    wf = tmpl.compose(\n        name=\"wf\",\n        description=\"\",\n        applies_to=_dummy_applies_to,\n        priority=0,\n        middle=[AgentTask(name=\"a\"), AgentTask(name=\"b\")],\n    )\n    assert len(wf.tasks) == 2\n\n\n# ---------- AC-4: template_name on composed workflow ----------\n\n\ndef test_compose_sets_template_name() -> None:\n    \"\"\"The composed Workflow has template_name matching the template's name.\"\"\"\n    tmpl = _make_template(name=\"my-template\")\n    wf = tmpl.compose(\n        name=\"wf\",\n        description=\"\",\n        applies_to=_dummy_applies_to,\n        priority=0,\n        middle=[AgentTask(name=\"implement\")],\n    )\n    assert wf.template_name == \"my-template\"\n\n\ndef test_compose_template_name_matches_template_name_field() -> None:\n    \"\"\"template_name always matches the WorkflowTemplate.name field.\"\"\"\n    for tname in [\"prd-implementation\", \"rework\", \"planning\"]:\n        tmpl = _make_template(name=tname)\n        wf = tmpl.compose(\n            name=\"wf\",\n            description=\"\",\n            applies_to=_dummy_applies_to,\n            priority=0,\n            middle=[AgentTask(name=\"implement\")],\n        )\n        assert wf.template_name == tname\n\n\n# ---------- AC-5: Workflow default template_name ----------\n\n\ndef test_workflow_template_name_defaults_to_none() -> None:\n    \"\"\"A Workflow constructed without template_name has template_name=None.\"\"\"\n    wf = Workflow(name=\"bare\", tasks=[BuiltIn(\"ensure_worktree\")])\n    assert wf.template_name is None\n\n\ndef test_workflow_can_be_constructed_without_template_name() -> None:\n    \"\"\"Existing Workflow construction still works unchanged.\"\"\"\n    wf = Workflow(\n        name=\"legacy\",\n        description=\"no template\",\n        tasks=[BuiltIn(\"ensure_worktree\"), AgentTask(name=\"implement\")],\n        priority=1,\n    )\n    assert wf.template_name is None\n    assert len(wf.tasks) == 2\n","numLines":331,"startLine":1,"totalLines":331}}}
