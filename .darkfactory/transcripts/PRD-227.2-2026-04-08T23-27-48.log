{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01D8s9jPa8T9hztUUq6gu6Tf","type":"tool_result","content":"1\t\"\"\"Tests for prompt template loading and variable substitution.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\tfrom pathlib import Path\n6\t\n7\timport pytest\n8\t\n9\tfrom darkfactory.prd import load_all\n10\tfrom darkfactory.templates import (\n11\t    compose_prompt,\n12\t    load_prompt_files,\n13\t    substitute_placeholders,\n14\t)\n15\tfrom darkfactory.workflow import ExecutionContext, Workflow\n16\t\n17\tfrom .conftest import write_prd\n18\t\n19\t\n20\t# ---------- load_prompt_files ----------\n21\t\n22\t\n23\tdef test_load_single_prompt_file(tmp_path: Path) -> None:\n24\t    wf_dir = tmp_path / \"default\"\n25\t    wf_dir.mkdir()\n26\t    (wf_dir / \"role.md\").write_text(\"# Role\\n\\nYou are an agent.\\n\")\n27\t\n28\t    content = load_prompt_files(wf_dir, [\"role.md\"])\n29\t    assert \"# Role\" in content\n30\t    assert \"You are an agent.\" in content\n31\t\n32\t\n33\tdef test_load_multiple_files_concatenated(tmp_path: Path) -> None:\n34\t    wf_dir = tmp_path / \"default\"\n35\t    wf_dir.mkdir()\n36\t    (wf_dir / \"role.md\").write_text(\"ROLE\\n\")\n37\t    (wf_dir / \"task.md\").write_text(\"TASK\\n\")\n38\t\n39\t    content = load_prompt_files(wf_dir, [\"role.md\", \"task.md\"])\n40\t    # Blank line separator between files\n41\t    assert \"ROLE\\n\\n\\nTASK\\n\" in content or content == \"ROLE\\n\\n\\nTASK\\n\"\n42\t    assert content.index(\"ROLE\") < content.index(\"TASK\")\n43\t\n44\t\n45\tdef test_load_files_from_subdirectory(tmp_path: Path) -> None:\n46\t    wf_dir = tmp_path / \"default\"\n47\t    (wf_dir / \"prompts\").mkdir(parents=True)\n48\t    (wf_dir / \"prompts\" / \"role.md\").write_text(\"nested\\n\")\n49\t\n50\t    content = load_prompt_files(wf_dir, [\"prompts/role.md\"])\n51\t    assert \"nested\" in content\n52\t\n53\t\n54\tdef test_load_missing_file_raises(tmp_path: Path) -> None:\n55\t    wf_dir = tmp_path / \"default\"\n56\t    wf_dir.mkdir()\n57\t    with pytest.raises(FileNotFoundError, match=\"prompt file not found\"):\n58\t        load_prompt_files(wf_dir, [\"nonexistent.md\"])\n59\t\n60\t\n61\tdef test_load_missing_file_error_includes_workflow_name(tmp_path: Path) -> None:\n62\t    \"\"\"The error message should name the workflow for fast debugging.\"\"\"\n63\t    wf_dir = tmp_path / \"ui-component\"\n64\t    wf_dir.mkdir()\n65\t    with pytest.raises(FileNotFoundError, match=\"ui-component\"):\n66\t        load_prompt_files(wf_dir, [\"missing.md\"])\n67\t\n68\t\n69\t# ---------- substitute_placeholders ----------\n70\t\n71\t\n72\tdef test_substitute_known_placeholder() -> None:\n73\t    result = substitute_placeholders(\"hello {{NAME}}\", {\"NAME\": \"world\"})\n74\t    assert result == \"hello world\"\n75\t\n76\t\n77\tdef test_substitute_multiple_placeholders() -> None:\n78\t    template = \"PRD {{PRD_ID}}: {{PRD_TITLE}}\"\n79\t    ctx = {\"PRD_ID\": \"PRD-070\", \"PRD_TITLE\": \"Obsidian filter\"}\n80\t    assert substitute_placeholders(template, ctx) == \"PRD PRD-070: Obsidian filter\"\n81\t\n82\t\n83\tdef test_substitute_unknown_placeholders_left_unchanged() -> None:\n84\t    \"\"\"Unknown placeholders survive intact so prompts can evolve incrementally.\"\"\"\n85\t    template = \"known: {{KNOWN}}, unknown: {{UNKNOWN}}\"\n86\t    result = substitute_placeholders(template, {\"KNOWN\": \"yes\"})\n87\t    assert result == \"known: yes, unknown: {{UNKNOWN}}\"\n88\t\n89\t\n90\tdef test_substitute_empty_context() -> None:\n91\t    \"\"\"Empty context = no substitution, template unchanged.\"\"\"\n92\t    template = \"hello {{NAME}}\"\n93\t    assert substitute_placeholders(template, {}) == \"hello {{NAME}}\"\n94\t\n95\t\n96\tdef test_substitute_coerces_non_string_values() -> None:\n97\t    \"\"\"Integers and Paths should work without caller ceremony.\"\"\"\n98\t    template = \"count: {{N}}, path: {{P}}\"\n99\t    result = substitute_placeholders(template, {\"N\": 42, \"P\": Path(\"/tmp/foo\")})\n100\t    assert \"count: 42\" in result\n101\t    assert \"/tmp/foo\" in result\n102\t\n103\t\n104\tdef test_substitute_literal_single_braces_untouched() -> None:\n105\t    \"\"\"Single-brace ``{ }`` should pass through — only ``{{ }}`` is a placeholder.\"\"\"\n106\t    template = \"a = { key: 'value' }\"\n107\t    assert substitute_placeholders(template, {\"KEY\": \"x\"}) == template\n108\t\n109\t\n110\tdef test_substitute_nested_braces_in_code_blocks() -> None:\n111\t    \"\"\"Triple-plus braces inside prompts (code blocks) are fine.\"\"\"\n112\t    template = \"```js\\nconst x = {{a: 1}};\\n```\"\n113\t    # {{a: 1}} doesn't match PLACEHOLDER_RE (has colon and space), left alone\n114\t    result = substitute_placeholders(template, {})\n115\t    assert result == template\n116\t\n117\t\n118\t# ---------- compose_prompt ----------\n119\t\n120\t\n121\tdef _make_ctx(\n122\t    tmp_prd_dir: Path, workflow_dir: Path\n123\t) -> tuple[Workflow, ExecutionContext]:\n124\t    \"\"\"Build a workflow (with workflow_dir set) and a context for testing compose.\"\"\"\n125\t    write_prd(tmp_prd_dir, \"PRD-070\", \"test-task\")\n126\t    prds = load_all(tmp_prd_dir)\n127\t    wf = Workflow(name=\"default\", workflow_dir=workflow_dir)\n128\t    ctx = ExecutionContext(\n129\t        prd=prds[\"PRD-070\"],\n130\t        repo_root=tmp_prd_dir,\n131\t        workflow=wf,\n132\t        base_ref=\"main\",\n133\t        branch_name=\"prd/PRD-070-test-task\",\n134\t        worktree_path=tmp_prd_dir / \".worktrees\" / \"PRD-070-test-task\",\n135\t    )\n136\t    return wf, ctx\n137\t\n138\t\n139\tdef test_compose_prompt_substitutes_prd_fields(tmp_path: Path) -> None:\n140\t    prompts_dir = tmp_path / \"default\" / \"prompts\"\n141\t    prompts_dir.mkdir(parents=True)\n142\t    (prompts_dir / \"task.md\").write_text(\n143\t        \"Implement {{PRD_ID}}: {{PRD_TITLE}}\\nBranch: {{BRANCH_NAME}}\\n\"\n144\t    )\n145\t\n146\t    prd_dir = tmp_path / \"prds\"\n147\t    prd_dir.mkdir()\n148\t    wf, ctx = _make_ctx(prd_dir, tmp_path / \"default\")\n149\t\n150\t    result = compose_prompt(wf, [\"prompts/task.md\"], ctx)\n151\t    assert \"Implement PRD-070\" in result\n152\t    assert \"Test PRD\" in result  # title from fixture\n153\t    assert \"Branch: prd/PRD-070-test-task\" in result\n154\t\n155\t\n156\tdef test_compose_prompt_substitutes_worktree_path(tmp_path: Path) -> None:\n157\t    prompts_dir = tmp_path / \"default\" / \"prompts\"\n158\t    prompts_dir.mkdir(parents=True)\n159\t    (prompts_dir / \"task.md\").write_text(\"cd {{WORKTREE_PATH}}\\n\")\n160\t\n161\t    prd_dir = tmp_path / \"prds\"\n162\t    prd_dir.mkdir()\n163\t    wf, ctx = _make_ctx(prd_dir, tmp_path / \"default\")\n164\t\n165\t    result = compose_prompt(wf, [\"prompts/task.md\"], ctx)\n166\t    assert \"cd \" in result\n167\t    assert str(ctx.worktree_path) in result\n168\t\n169\t\n170\tdef test_compose_prompt_worktree_empty_when_unset(tmp_path: Path) -> None:\n171\t    prompts_dir = tmp_path / \"default\" / \"prompts\"\n172\t    prompts_dir.mkdir(parents=True)\n173\t    (prompts_dir / \"task.md\").write_text(\"path=[{{WORKTREE_PATH}}]\\n\")\n174\t\n175\t    prd_dir = tmp_path / \"prds\"\n176\t    prd_dir.mkdir()\n177\t    wf, ctx = _make_ctx(prd_dir, tmp_path / \"default\")\n178\t    ctx.worktree_path = None  # override to unset\n179\t\n180\t    result = compose_prompt(wf, [\"prompts/task.md\"], ctx)\n181\t    assert \"path=[]\" in result\n182\t\n183\t\n184\tdef test_compose_prompt_merges_extras(tmp_path: Path) -> None:\n185\t    \"\"\"The extras dict (for things like CHECK_OUTPUT) is merged into context.\"\"\"\n186\t    prompts_dir = tmp_path / \"default\" / \"prompts\"\n187\t    prompts_dir.mkdir(parents=True)\n188\t    (prompts_dir / \"verify.md\").write_text(\n189\t        \"Check failed:\\n{{CHECK_OUTPUT}}\\nFor {{PRD_ID}}.\\n\"\n190\t    )\n191\t\n192\t    prd_dir = tmp_path / \"prds\"\n193\t    prd_dir.mkdir()\n194\t    wf, ctx = _make_ctx(prd_dir, tmp_path / \"default\")\n195\t\n196\t    result = compose_prompt(\n197\t        wf,\n198\t        [\"prompts/verify.md\"],\n199\t        ctx,\n200\t        extras={\"CHECK_OUTPUT\": \"test_foo FAILED\"},\n201\t    )\n202\t    assert \"test_foo FAILED\" in result\n203\t    assert \"For PRD-070\" in result\n204\t\n205\t\n206\tdef test_compose_prompt_extras_override_defaults(tmp_path: Path) -> None:\n207\t    \"\"\"Extras take precedence over the standard PRD-derived context values.\"\"\"\n208\t    prompts_dir = tmp_path / \"default\" / \"prompts\"\n209\t    prompts_dir.mkdir(parents=True)\n210\t    (prompts_dir / \"task.md\").write_text(\"id={{PRD_ID}}\\n\")\n211\t\n212\t    prd_dir = tmp_path / \"prds\"\n213\t    prd_dir.mkdir()\n214\t    wf, ctx = _make_ctx(prd_dir, tmp_path / \"default\")\n215\t\n216\t    result = compose_prompt(wf, [\"prompts/task.md\"], ctx, extras={\"PRD_ID\": \"OVERRIDE\"})\n217\t    assert \"id=OVERRIDE\" in result\n218\t\n219\t\n220\tdef test_compose_prompt_raises_when_workflow_dir_unset(tmp_path: Path) -> None:\n221\t    \"\"\"A Workflow built by hand without workflow_dir can't compose prompts.\"\"\"\n222\t    prd_dir = tmp_path / \"prds\"\n223\t    prd_dir.mkdir()\n224\t    write_prd(prd_dir, \"PRD-070\", \"test\")\n225\t    prds = load_all(prd_dir)\n226\t\n227\t    wf = Workflow(name=\"hand-built\")  # workflow_dir is None\n228\t    ctx = ExecutionContext(\n229\t        prd=prds[\"PRD-070\"],\n230\t        repo_root=prd_dir,\n231\t        workflow=wf,\n232\t        base_ref=\"main\",\n233\t        branch_name=\"prd/PRD-070-test\",\n234\t    )\n235\t    with pytest.raises(ValueError, match=\"no workflow_dir\"):\n236\t        compose_prompt(wf, [\"prompts/task.md\"], ctx)\n237\t\n238\t\n239\tdef test_compose_prompt_concatenates_multiple(tmp_path: Path) -> None:\n240\t    \"\"\"Multiple prompt files are concatenated with blank line separators.\"\"\"\n241\t    prompts_dir = tmp_path / \"default\" / \"prompts\"\n242\t    prompts_dir.mkdir(parents=True)\n243\t    (prompts_dir / \"role.md\").write_text(\"# Role\\nAgent.\\n\")\n244\t    (prompts_dir / \"task.md\").write_text(\"# Task\\nImplement {{PRD_ID}}.\\n\")\n245\t\n246\t    prd_dir = tmp_path / \"prds\"\n247\t    prd_dir.mkdir()\n248\t    wf, ctx = _make_ctx(prd_dir, tmp_path / \"default\")\n249\t\n250\t    result = compose_prompt(wf, [\"prompts/role.md\", \"prompts/task.md\"], ctx)\n251\t    assert \"# Role\" in result\n252\t    assert \"# Task\" in result\n253\t    assert \"PRD-070\" in result\n254\t    assert result.index(\"# Role\") < result.index(\"# Task\")\n255\t"}]},"parent_tool_use_id":null,"session_id":"7d98639c-26bc-45d3-9705-9d67800b0669","uuid":"3f4544b6-e5e3-4ec7-a6b4-aab759b64e04","timestamp":"2026-04-09T04:27:00.035Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-227.2-prd-implementation-template/tests/test_templates.py","content":"\"\"\"Tests for prompt template loading and variable substitution.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\n\nimport pytest\n\nfrom darkfactory.prd import load_all\nfrom darkfactory.templates import (\n    compose_prompt,\n    load_prompt_files,\n    substitute_placeholders,\n)\nfrom darkfactory.workflow import ExecutionContext, Workflow\n\nfrom .conftest import write_prd\n\n\n# ---------- load_prompt_files ----------\n\n\ndef test_load_single_prompt_file(tmp_path: Path) -> None:\n    wf_dir = tmp_path / \"default\"\n    wf_dir.mkdir()\n    (wf_dir / \"role.md\").write_text(\"# Role\\n\\nYou are an agent.\\n\")\n\n    content = load_prompt_files(wf_dir, [\"role.md\"])\n    assert \"# Role\" in content\n    assert \"You are an agent.\" in content\n\n\ndef test_load_multiple_files_concatenated(tmp_path: Path) -> None:\n    wf_dir = tmp_path / \"default\"\n    wf_dir.mkdir()\n    (wf_dir / \"role.md\").write_text(\"ROLE\\n\")\n    (wf_dir / \"task.md\").write_text(\"TASK\\n\")\n\n    content = load_prompt_files(wf_dir, [\"role.md\", \"task.md\"])\n    # Blank line separator between files\n    assert \"ROLE\\n\\n\\nTASK\\n\" in content or content == \"ROLE\\n\\n\\nTASK\\n\"\n    assert content.index(\"ROLE\") < content.index(\"TASK\")\n\n\ndef test_load_files_from_subdirectory(tmp_path: Path) -> None:\n    wf_dir = tmp_path / \"default\"\n    (wf_dir / \"prompts\").mkdir(parents=True)\n    (wf_dir / \"prompts\" / \"role.md\").write_text(\"nested\\n\")\n\n    content = load_prompt_files(wf_dir, [\"prompts/role.md\"])\n    assert \"nested\" in content\n\n\ndef test_load_missing_file_raises(tmp_path: Path) -> None:\n    wf_dir = tmp_path / \"default\"\n    wf_dir.mkdir()\n    with pytest.raises(FileNotFoundError, match=\"prompt file not found\"):\n        load_prompt_files(wf_dir, [\"nonexistent.md\"])\n\n\ndef test_load_missing_file_error_includes_workflow_name(tmp_path: Path) -> None:\n    \"\"\"The error message should name the workflow for fast debugging.\"\"\"\n    wf_dir = tmp_path / \"ui-component\"\n    wf_dir.mkdir()\n    with pytest.raises(FileNotFoundError, match=\"ui-component\"):\n        load_prompt_files(wf_dir, [\"missing.md\"])\n\n\n# ---------- substitute_placeholders ----------\n\n\ndef test_substitute_known_placeholder() -> None:\n    result = substitute_placeholders(\"hello {{NAME}}\", {\"NAME\": \"world\"})\n    assert result == \"hello world\"\n\n\ndef test_substitute_multiple_placeholders() -> None:\n    template = \"PRD {{PRD_ID}}: {{PRD_TITLE}}\"\n    ctx = {\"PRD_ID\": \"PRD-070\", \"PRD_TITLE\": \"Obsidian filter\"}\n    assert substitute_placeholders(template, ctx) == \"PRD PRD-070: Obsidian filter\"\n\n\ndef test_substitute_unknown_placeholders_left_unchanged() -> None:\n    \"\"\"Unknown placeholders survive intact so prompts can evolve incrementally.\"\"\"\n    template = \"known: {{KNOWN}}, unknown: {{UNKNOWN}}\"\n    result = substitute_placeholders(template, {\"KNOWN\": \"yes\"})\n    assert result == \"known: yes, unknown: {{UNKNOWN}}\"\n\n\ndef test_substitute_empty_context() -> None:\n    \"\"\"Empty context = no substitution, template unchanged.\"\"\"\n    template = \"hello {{NAME}}\"\n    assert substitute_placeholders(template, {}) == \"hello {{NAME}}\"\n\n\ndef test_substitute_coerces_non_string_values() -> None:\n    \"\"\"Integers and Paths should work without caller ceremony.\"\"\"\n    template = \"count: {{N}}, path: {{P}}\"\n    result = substitute_placeholders(template, {\"N\": 42, \"P\": Path(\"/tmp/foo\")})\n    assert \"count: 42\" in result\n    assert \"/tmp/foo\" in result\n\n\ndef test_substitute_literal_single_braces_untouched() -> None:\n    \"\"\"Single-brace ``{ }`` should pass through — only ``{{ }}`` is a placeholder.\"\"\"\n    template = \"a = { key: 'value' }\"\n    assert substitute_placeholders(template, {\"KEY\": \"x\"}) == template\n\n\ndef test_substitute_nested_braces_in_code_blocks() -> None:\n    \"\"\"Triple-plus braces inside prompts (code blocks) are fine.\"\"\"\n    template = \"```js\\nconst x = {{a: 1}};\\n```\"\n    # {{a: 1}} doesn't match PLACEHOLDER_RE (has colon and space), left alone\n    result = substitute_placeholders(template, {})\n    assert result == template\n\n\n# ---------- compose_prompt ----------\n\n\ndef _make_ctx(\n    tmp_prd_dir: Path, workflow_dir: Path\n) -> tuple[Workflow, ExecutionContext]:\n    \"\"\"Build a workflow (with workflow_dir set) and a context for testing compose.\"\"\"\n    write_prd(tmp_prd_dir, \"PRD-070\", \"test-task\")\n    prds = load_all(tmp_prd_dir)\n    wf = Workflow(name=\"default\", workflow_dir=workflow_dir)\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-070\"],\n        repo_root=tmp_prd_dir,\n        workflow=wf,\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-070-test-task\",\n        worktree_path=tmp_prd_dir / \".worktrees\" / \"PRD-070-test-task\",\n    )\n    return wf, ctx\n\n\ndef test_compose_prompt_substitutes_prd_fields(tmp_path: Path) -> None:\n    prompts_dir = tmp_path / \"default\" / \"prompts\"\n    prompts_dir.mkdir(parents=True)\n    (prompts_dir / \"task.md\").write_text(\n        \"Implement {{PRD_ID}}: {{PRD_TITLE}}\\nBranch: {{BRANCH_NAME}}\\n\"\n    )\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    wf, ctx = _make_ctx(prd_dir, tmp_path / \"default\")\n\n    result = compose_prompt(wf, [\"prompts/task.md\"], ctx)\n    assert \"Implement PRD-070\" in result\n    assert \"Test PRD\" in result  # title from fixture\n    assert \"Branch: prd/PRD-070-test-task\" in result\n\n\ndef test_compose_prompt_substitutes_worktree_path(tmp_path: Path) -> None:\n    prompts_dir = tmp_path / \"default\" / \"prompts\"\n    prompts_dir.mkdir(parents=True)\n    (prompts_dir / \"task.md\").write_text(\"cd {{WORKTREE_PATH}}\\n\")\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    wf, ctx = _make_ctx(prd_dir, tmp_path / \"default\")\n\n    result = compose_prompt(wf, [\"prompts/task.md\"], ctx)\n    assert \"cd \" in result\n    assert str(ctx.worktree_path) in result\n\n\ndef test_compose_prompt_worktree_empty_when_unset(tmp_path: Path) -> None:\n    prompts_dir = tmp_path / \"default\" / \"prompts\"\n    prompts_dir.mkdir(parents=True)\n    (prompts_dir / \"task.md\").write_text(\"path=[{{WORKTREE_PATH}}]\\n\")\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    wf, ctx = _make_ctx(prd_dir, tmp_path / \"default\")\n    ctx.worktree_path = None  # override to unset\n\n    result = compose_prompt(wf, [\"prompts/task.md\"], ctx)\n    assert \"path=[]\" in result\n\n\ndef test_compose_prompt_merges_extras(tmp_path: Path) -> None:\n    \"\"\"The extras dict (for things like CHECK_OUTPUT) is merged into context.\"\"\"\n    prompts_dir = tmp_path / \"default\" / \"prompts\"\n    prompts_dir.mkdir(parents=True)\n    (prompts_dir / \"verify.md\").write_text(\n        \"Check failed:\\n{{CHECK_OUTPUT}}\\nFor {{PRD_ID}}.\\n\"\n    )\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    wf, ctx = _make_ctx(prd_dir, tmp_path / \"default\")\n\n    result = compose_prompt(\n        wf,\n        [\"prompts/verify.md\"],\n        ctx,\n        extras={\"CHECK_OUTPUT\": \"test_foo FAILED\"},\n    )\n    assert \"test_foo FAILED\" in result\n    assert \"For PRD-070\" in result\n\n\ndef test_compose_prompt_extras_override_defaults(tmp_path: Path) -> None:\n    \"\"\"Extras take precedence over the standard PRD-derived context values.\"\"\"\n    prompts_dir = tmp_path / \"default\" / \"prompts\"\n    prompts_dir.mkdir(parents=True)\n    (prompts_dir / \"task.md\").write_text(\"id={{PRD_ID}}\\n\")\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    wf, ctx = _make_ctx(prd_dir, tmp_path / \"default\")\n\n    result = compose_prompt(wf, [\"prompts/task.md\"], ctx, extras={\"PRD_ID\": \"OVERRIDE\"})\n    assert \"id=OVERRIDE\" in result\n\n\ndef test_compose_prompt_raises_when_workflow_dir_unset(tmp_path: Path) -> None:\n    \"\"\"A Workflow built by hand without workflow_dir can't compose prompts.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"test\")\n    prds = load_all(prd_dir)\n\n    wf = Workflow(name=\"hand-built\")  # workflow_dir is None\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-070\"],\n        repo_root=prd_dir,\n        workflow=wf,\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-070-test\",\n    )\n    with pytest.raises(ValueError, match=\"no workflow_dir\"):\n        compose_prompt(wf, [\"prompts/task.md\"], ctx)\n\n\ndef test_compose_prompt_concatenates_multiple(tmp_path: Path) -> None:\n    \"\"\"Multiple prompt files are concatenated with blank line separators.\"\"\"\n    prompts_dir = tmp_path / \"default\" / \"prompts\"\n    prompts_dir.mkdir(parents=True)\n    (prompts_dir / \"role.md\").write_text(\"# Role\\nAgent.\\n\")\n    (prompts_dir / \"task.md\").write_text(\"# Task\\nImplement {{PRD_ID}}.\\n\")\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    wf, ctx = _make_ctx(prd_dir, tmp_path / \"default\")\n\n    result = compose_prompt(wf, [\"prompts/role.md\", \"prompts/task.md\"], ctx)\n    assert \"# Role\" in result\n    assert \"# Task\" in result\n    assert \"PRD-070\" in result\n    assert result.index(\"# Role\") < result.index(\"# Task\")\n","numLines":255,"startLine":1,"totalLines":255}}}
