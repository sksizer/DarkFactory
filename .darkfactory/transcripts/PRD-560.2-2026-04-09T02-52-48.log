{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LHc1DjZPJ36bKxABfvReS2","type":"tool_result","content":"1425\t    )\n1426\t    builtins.ensure_worktree(ctx)\n1427\t    assert ctx.worktree_path is not None\n1428\t\n1429\t    # Write a fake transcript at the external repo-root location where\n1430\t    # runner._run_agent writes in production.\n1431\t    transcripts_dir = ctx.repo_root / \".harness-transcripts\"\n1432\t    transcripts_dir.mkdir(parents=True, exist_ok=True)\n1433\t    src = transcripts_dir / \"PRD-070.log\"\n1434\t    src.write_text(\"# fake transcript\\ncontent here\\n\", encoding=\"utf-8\")\n1435\t\n1436\t    builtins.commit_transcript(ctx)\n1437\t\n1438\t    # Source should survive (copy semantic, not move).\n1439\t    assert src.exists()\n1440\t    assert src.read_text(encoding=\"utf-8\") == \"# fake transcript\\ncontent here\\n\"\n1441\t\n1442\t    # Destination should exist under .darkfactory/transcripts/\n1443\t    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n1444\t    assert transcript_dir.exists()\n1445\t    logs = list(transcript_dir.glob(\"PRD-070-*.log\"))\n1446\t    assert len(logs) == 1\n1447\t    assert logs[0].read_text(encoding=\"utf-8\") == \"# fake transcript\\ncontent here\\n\"\n1448\t\n1449\t    # File should be staged\n1450\t    result = subprocess.run(\n1451\t        [\"git\", \"diff\", \"--cached\", \"--name-only\"],\n1452\t        cwd=str(ctx.cwd),\n1453\t        check=True,\n1454\t        capture_output=True,\n1455\t        text=True,\n1456\t    )\n1457\t    assert \".darkfactory/transcripts/\" in result.stdout\n1458\t\n1459\t\n1460\tdef test_commit_transcript_multiple_invocations_separate_files(\n1461\t    tmp_git_repo: Path,\n1462\t) -> None:\n1463\t    \"\"\"AC-6: Multiple invocations produce separate timestamped files.\"\"\"\n1464\t    import time\n1465\t\n1466\t    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n1467\t    prd_dir.mkdir(parents=True)\n1468\t    write_prd(prd_dir, \"PRD-070\", \"multi-transcript\")\n1469\t    prds = load_all(prd_dir)\n1470\t\n1471\t    ctx = ExecutionContext(\n1472\t        prd=prds[\"PRD-070\"],\n1473\t        repo_root=tmp_git_repo,\n1474\t        workflow=Workflow(name=\"default\"),\n1475\t        base_ref=\"main\",\n1476\t        branch_name=\"prd/PRD-070-multi-transcript\",\n1477\t        cwd=tmp_git_repo,\n1478\t        dry_run=False,\n1479\t    )\n1480\t    builtins.ensure_worktree(ctx)\n1481\t    assert ctx.worktree_path is not None\n1482\t\n1483\t    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n1484\t    external_dir = ctx.repo_root / \".harness-transcripts\"\n1485\t    external_dir.mkdir(parents=True, exist_ok=True)\n1486\t    src = external_dir / \"PRD-070.log\"\n1487\t\n1488\t    # First invocation\n1489\t    src.write_text(\"first transcript\\n\", encoding=\"utf-8\")\n1490\t    builtins.commit_transcript(ctx)\n1491\t    assert len(list(transcript_dir.glob(\"PRD-070-*.log\"))) == 1\n1492\t\n1493\t    # Wait a second so timestamps differ\n1494\t    time.sleep(1)\n1495\t\n1496\t    # Second invocation (source overwritten by a simulated re-run of the runner)\n1497\t    src.write_text(\"second transcript\\n\", encoding=\"utf-8\")\n1498\t    builtins.commit_transcript(ctx)\n1499\t\n1500\t    logs = sorted(transcript_dir.glob(\"PRD-070-*.log\"))\n1501\t    assert len(logs) == 2, \"Each invocation must produce a separate file\"\n1502\t    # Files should have different names (timestamps)\n1503\t    assert logs[0].name != logs[1].name\n1504\t\n1505\t\n1506\tdef test_commit_transcript_dry_run_noop(tmp_path: Path) -> None:\n1507\t    \"\"\"In dry-run mode, commit_transcript logs but does not move or stage anything.\"\"\"\n1508\t    prd_dir = tmp_path / \"prds\"\n1509\t    prd_dir.mkdir()\n1510\t    write_prd(prd_dir, \"PRD-070\", \"task\")\n1511\t    prds = load_all(prd_dir)\n1512\t\n1513\t    ctx = ExecutionContext(\n1514\t        prd=prds[\"PRD-070\"],\n1515\t        repo_root=tmp_path,\n1516\t        workflow=Workflow(name=\"default\"),\n1517\t        base_ref=\"main\",\n1518\t        branch_name=\"prd/PRD-070-task\",\n1519\t        cwd=tmp_path,\n1520\t        dry_run=True,\n1521\t    )\n1522\t\n1523\t    external_dir = tmp_path / \".harness-transcripts\"\n1524\t    external_dir.mkdir(parents=True, exist_ok=True)\n1525\t    src = external_dir / \"PRD-070.log\"\n1526\t    src.write_text(\"dry run transcript\\n\", encoding=\"utf-8\")\n1527\t\n1528\t    with patch(\"subprocess.run\") as mock_run:\n1529\t        builtins.commit_transcript(ctx)\n1530\t        mock_run.assert_not_called()\n1531\t\n1532\t    # Source file should remain untouched in dry-run\n1533\t    assert src.exists()\n1534\t    assert not (tmp_path / \".darkfactory\" / \"transcripts\").exists()"}]},"parent_tool_use_id":null,"session_id":"34e46cdc-3fb0-4a48-851b-223c92f28d9a","uuid":"8219b06a-f0fa-406a-aa71-7ba695b66b30","timestamp":"2026-04-09T07:51:53.001Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-560.2-update-commit-transcript-extension/tests/test_builtins.py","content":"    )\n    builtins.ensure_worktree(ctx)\n    assert ctx.worktree_path is not None\n\n    # Write a fake transcript at the external repo-root location where\n    # runner._run_agent writes in production.\n    transcripts_dir = ctx.repo_root / \".harness-transcripts\"\n    transcripts_dir.mkdir(parents=True, exist_ok=True)\n    src = transcripts_dir / \"PRD-070.log\"\n    src.write_text(\"# fake transcript\\ncontent here\\n\", encoding=\"utf-8\")\n\n    builtins.commit_transcript(ctx)\n\n    # Source should survive (copy semantic, not move).\n    assert src.exists()\n    assert src.read_text(encoding=\"utf-8\") == \"# fake transcript\\ncontent here\\n\"\n\n    # Destination should exist under .darkfactory/transcripts/\n    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n    assert transcript_dir.exists()\n    logs = list(transcript_dir.glob(\"PRD-070-*.log\"))\n    assert len(logs) == 1\n    assert logs[0].read_text(encoding=\"utf-8\") == \"# fake transcript\\ncontent here\\n\"\n\n    # File should be staged\n    result = subprocess.run(\n        [\"git\", \"diff\", \"--cached\", \"--name-only\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n    assert \".darkfactory/transcripts/\" in result.stdout\n\n\ndef test_commit_transcript_multiple_invocations_separate_files(\n    tmp_git_repo: Path,\n) -> None:\n    \"\"\"AC-6: Multiple invocations produce separate timestamped files.\"\"\"\n    import time\n\n    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n    prd_dir.mkdir(parents=True)\n    write_prd(prd_dir, \"PRD-070\", \"multi-transcript\")\n    prds = load_all(prd_dir)\n\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-070\"],\n        repo_root=tmp_git_repo,\n        workflow=Workflow(name=\"default\"),\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-070-multi-transcript\",\n        cwd=tmp_git_repo,\n        dry_run=False,\n    )\n    builtins.ensure_worktree(ctx)\n    assert ctx.worktree_path is not None\n\n    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n    external_dir = ctx.repo_root / \".harness-transcripts\"\n    external_dir.mkdir(parents=True, exist_ok=True)\n    src = external_dir / \"PRD-070.log\"\n\n    # First invocation\n    src.write_text(\"first transcript\\n\", encoding=\"utf-8\")\n    builtins.commit_transcript(ctx)\n    assert len(list(transcript_dir.glob(\"PRD-070-*.log\"))) == 1\n\n    # Wait a second so timestamps differ\n    time.sleep(1)\n\n    # Second invocation (source overwritten by a simulated re-run of the runner)\n    src.write_text(\"second transcript\\n\", encoding=\"utf-8\")\n    builtins.commit_transcript(ctx)\n\n    logs = sorted(transcript_dir.glob(\"PRD-070-*.log\"))\n    assert len(logs) == 2, \"Each invocation must produce a separate file\"\n    # Files should have different names (timestamps)\n    assert logs[0].name != logs[1].name\n\n\ndef test_commit_transcript_dry_run_noop(tmp_path: Path) -> None:\n    \"\"\"In dry-run mode, commit_transcript logs but does not move or stage anything.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"task\")\n    prds = load_all(prd_dir)\n\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-070\"],\n        repo_root=tmp_path,\n        workflow=Workflow(name=\"default\"),\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-070-task\",\n        cwd=tmp_path,\n        dry_run=True,\n    )\n\n    external_dir = tmp_path / \".harness-transcripts\"\n    external_dir.mkdir(parents=True, exist_ok=True)\n    src = external_dir / \"PRD-070.log\"\n    src.write_text(\"dry run transcript\\n\", encoding=\"utf-8\")\n\n    with patch(\"subprocess.run\") as mock_run:\n        builtins.commit_transcript(ctx)\n        mock_run.assert_not_called()\n\n    # Source file should remain untouched in dry-run\n    assert src.exists()\n    assert not (tmp_path / \".darkfactory\" / \"transcripts\").exists()","numLines":110,"startLine":1425,"totalLines":1535}}}
