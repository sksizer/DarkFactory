{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013t7FhNEAE4r7n7LR8H3hdA","type":"tool_result","content":"1\t\"\"\"Tests for the real builtin implementations.\n2\t\n3\tSplit into three categories:\n4\t\n5\t1. **Registry tests**: the @builtin decorator and BUILTINS dict still\n6\t   work as they did in the stub phase.\n7\t2. **Pure helper tests**: `_worktree_target`, `_extract_acceptance_criteria`,\n8\t   `_pr_body` are unit-testable without any I/O.\n9\t3. **Subprocess-touching tests**: use ``tmp_path`` + ``git init`` for a\n10\t   real tmp repo (for worktree + commit flows) or ``unittest.mock.patch``\n11\t   for ``push_branch`` and ``create_pr`` (since those hit origin/gh).\n12\t\n13\tDry-run mode is tested throughout to confirm builtins log but don't\n14\texecute.\n15\t\"\"\"\n16\t\n17\tfrom __future__ import annotations\n18\t\n19\timport logging\n20\timport subprocess\n21\tfrom pathlib import Path\n22\tfrom unittest.mock import patch\n23\t\n24\timport pytest\n25\t\n26\tfrom darkfactory import builtins\n27\tfrom darkfactory.builtins import (\n28\t    BUILTINS,\n29\t    _branch_exists_local,\n30\t    _branch_exists_remote,\n31\t    _extract_acceptance_criteria,\n32\t    _pr_body,\n33\t    _worktree_target,\n34\t    builtin,\n35\t)\n36\tfrom darkfactory.checks import ResumeStatus\n37\tfrom darkfactory.prd import load_all\n38\tfrom darkfactory.workflow import ExecutionContext, Workflow\n39\t\n40\tfrom .conftest import write_prd\n41\t\n42\t\n43\t# ---------- registry ----------\n44\t\n45\t\n46\tdef test_registry_populated_at_import() -> None:\n47\t    expected = {\n48\t        \"ensure_worktree\",\n49\t        \"set_status\",\n50\t        \"commit\",\n51\t        \"push_branch\",\n52\t        \"create_pr\",\n53\t        \"cleanup_worktree\",\n54\t        \"summarize_agent_run\",\n55\t        \"commit_transcript\",\n56\t    }\n57\t    assert expected <= set(BUILTINS.keys())\n58\t\n59\t\n60\tdef test_each_builtin_is_callable() -> None:\n61\t    for name, func in BUILTINS.items():\n62\t        assert callable(func), f\"{name!r} is not callable\"\n63\t\n64\t\n65\tdef test_builtin_decorator_registers_function() -> None:\n66\t    @builtin(\"_test_dynamic_one\")\n67\t    def _noop(ctx):  # type: ignore[no-untyped-def]\n68\t        return None\n69\t\n70\t    assert \"_test_dynamic_one\" in BUILTINS\n71\t    assert BUILTINS[\"_test_dynamic_one\"] is _noop\n72\t    del BUILTINS[\"_test_dynamic_one\"]\n73\t\n74\t\n75\tdef test_builtin_decorator_rejects_duplicates() -> None:\n76\t    @builtin(\"_test_dynamic_two\")\n77\t    def _first(ctx):  # type: ignore[no-untyped-def]\n78\t        return None\n79\t\n80\t    try:"}]},"parent_tool_use_id":null,"session_id":"b5b3278a-cf88-4c3d-896b-2252b3ec6019","uuid":"93afd586-5035-4ad5-aa90-69178d8f1f23","timestamp":"2026-04-09T02:42:47.577Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-549.2-scaffold-builtins-package/tests/test_builtins.py","content":"\"\"\"Tests for the real builtin implementations.\n\nSplit into three categories:\n\n1. **Registry tests**: the @builtin decorator and BUILTINS dict still\n   work as they did in the stub phase.\n2. **Pure helper tests**: `_worktree_target`, `_extract_acceptance_criteria`,\n   `_pr_body` are unit-testable without any I/O.\n3. **Subprocess-touching tests**: use ``tmp_path`` + ``git init`` for a\n   real tmp repo (for worktree + commit flows) or ``unittest.mock.patch``\n   for ``push_branch`` and ``create_pr`` (since those hit origin/gh).\n\nDry-run mode is tested throughout to confirm builtins log but don't\nexecute.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport subprocess\nfrom pathlib import Path\nfrom unittest.mock import patch\n\nimport pytest\n\nfrom darkfactory import builtins\nfrom darkfactory.builtins import (\n    BUILTINS,\n    _branch_exists_local,\n    _branch_exists_remote,\n    _extract_acceptance_criteria,\n    _pr_body,\n    _worktree_target,\n    builtin,\n)\nfrom darkfactory.checks import ResumeStatus\nfrom darkfactory.prd import load_all\nfrom darkfactory.workflow import ExecutionContext, Workflow\n\nfrom .conftest import write_prd\n\n\n# ---------- registry ----------\n\n\ndef test_registry_populated_at_import() -> None:\n    expected = {\n        \"ensure_worktree\",\n        \"set_status\",\n        \"commit\",\n        \"push_branch\",\n        \"create_pr\",\n        \"cleanup_worktree\",\n        \"summarize_agent_run\",\n        \"commit_transcript\",\n    }\n    assert expected <= set(BUILTINS.keys())\n\n\ndef test_each_builtin_is_callable() -> None:\n    for name, func in BUILTINS.items():\n        assert callable(func), f\"{name!r} is not callable\"\n\n\ndef test_builtin_decorator_registers_function() -> None:\n    @builtin(\"_test_dynamic_one\")\n    def _noop(ctx):  # type: ignore[no-untyped-def]\n        return None\n\n    assert \"_test_dynamic_one\" in BUILTINS\n    assert BUILTINS[\"_test_dynamic_one\"] is _noop\n    del BUILTINS[\"_test_dynamic_one\"]\n\n\ndef test_builtin_decorator_rejects_duplicates() -> None:\n    @builtin(\"_test_dynamic_two\")\n    def _first(ctx):  # type: ignore[no-untyped-def]\n        return None\n\n    try:","numLines":80,"startLine":1,"totalLines":1497}}}
