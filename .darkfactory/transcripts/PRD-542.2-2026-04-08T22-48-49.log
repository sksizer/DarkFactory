gs.styler — it never constructs one itself.\n    # JSON-output paths must NOT call styler.render() — they use plain print().\n    try:\n        repo_root = _find_repo_root(args.prd_dir)\n    except SystemExit:\n        repo_root = None\n    style_config = resolve_style_config(\n        theme=getattr(args, \"theme\", None),\n        icon_set=getattr(args, \"icon_set\", None),\n        no_color=getattr(args, \"no_color\", False),\n        repo_root=repo_root,\n    )\n    args.styler = Styler(style_config)\n\n    func: Any = args.func\n    return int(func(args))\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","structuredPatch":[{"oldStart":56,"oldLines":7,"newStart":56,"newLines":7,"lines":[" }"," "," ","-def _read_config_timeouts(repo_root: Path) -> dict | None:","+def _read_config_timeouts(repo_root: Path) -> dict[str, object] | None:","     \"\"\"Return the ``[timeouts]`` section from ``.darkfactory/config.toml``, or None.\"\"\"","     config_path = repo_root / \".darkfactory\" / \"config.toml\"","     if not config_path.exists():"]}],"userModified":false,"replaceAll":false}}
