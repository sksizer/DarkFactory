{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XHTCnUuN8BoaEYGt3uKg7K","type":"tool_result","content":"1\t\"\"\"Built-in task primitives — re-export hub.\n2\t\n3\tImports every submodule so @builtin-decorated functions register on\n4\tpackage import. Re-exports the public API for backwards compatibility.\n5\t\n6\tBuilt-ins are the deterministic SDLC operations that every workflow\n7\treferences by name: create a worktree, set a PRD's status, make a\n8\tcommit, push a branch, open a PR. They live here (not in individual\n9\tworkflow modules) because they're shared — every workflow uses the\n10\tsame ``commit`` primitive, not a bespoke one.\n11\t\n12\tWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n13\t\n14\t    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n15\t\n16\tThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\n17\tregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\n18\tplus any formatted kwargs.\n19\t\n20\t**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\n21\tanything destructive. In dry-run, we log what we WOULD do at INFO\n22\tlevel and return. This is what powers ``prd plan`` and the default\n23\t``prd run`` (without ``--execute``).\n24\t\n25\t**Subprocess discipline**: all shell commands use ``subprocess.run``\n26\twith an explicit argv list (never ``shell=True``), capture output,\n27\tand check the return code. Git and gh invocations go through\n28\t:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\n29\thandling and dry-run support.\n30\t\"\"\"\n31\t\n32\tfrom __future__ import annotations\n33\t\n34\timport logging\n35\timport re\n36\timport shutil\n37\timport subprocess\n38\tfrom datetime import datetime\n39\tfrom pathlib import Path\n40\t\n41\tfrom filelock import FileLock, Timeout\n42\t\n43\tfrom darkfactory import prd as prd_module\n44\tfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\n45\tfrom darkfactory.builtins._shared import (\n46\t    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n47\t    _run,\n48\t    _scan_for_forbidden_attribution,\n49\t)\n50\tfrom darkfactory.builtins.set_status import set_status  # noqa: F401\n51\tfrom darkfactory.checks import is_resume_safe\n52\t_log = logging.getLogger(__name__)\n53\t\n54\tfrom darkfactory.workflow import ExecutionContext, Status\n55\t\n56\t_log = logging.getLogger(__name__)\n57\t\n58\t# Import submodules to trigger @builtin registration.\n59\tfrom darkfactory.builtins.ensure_worktree import ensure_worktree  # noqa: E402\n60\t\n61\t__all__ = [\n62\t    \"BUILTINS\",\n63\t    \"BuiltInFunc\",\n64\t    \"builtin\",\n65\t    \"_run\",\n66\t    \"_scan_for_forbidden_attribution\",\n67\t    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n68\t    \"ensure_worktree\",\n69\t    \"set_status\",\n70\t    \"commit\",\n71\t    \"push_branch\",\n72\t    \"summarize_agent_run\",\n73\t    \"commit_transcript\",\n74\t    \"create_pr\",\n75\t    \"lint_attribution\",\n76\t    \"cleanup_worktree\",\n77\t]\n78\t\n79\t\n80\t_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n81\t\n82\t\n83\tdef _extract_acceptance_criteria(body: str) -> list[str]:\n84\t    \"\"\"Pull acceptance criteria lines out of a PRD body.\n85\t\n86\t    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n87\t    Returns a list of the criterion strings (without the checkbox\n88\t    prefix). Used by ``create_pr`` to build the PR body's checklist.\n89\t    \"\"\"\n90\t    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n91\t\n92\t\n93\tdef _pr_body(ctx: ExecutionContext) -> str:\n94\t    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n95\t    prd = ctx.prd\n96\t    lines: list[str] = [\n97\t        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n98\t        \"\",\n99\t    ]\n100\t\n101\t    acs = _extract_acceptance_criteria(prd.body)\n102\t    if acs:\n103\t        lines.append(\"## Acceptance criteria\")\n104\t        lines.append(\"\")\n105\t        for ac in acs:\n106\t            lines.append(f\"- [ ] {ac}\")\n107\t        lines.append(\"\")\n108\t\n109\t    lines.append(\"---\")\n110\t    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n111\t    return \"\\n\".join(lines)\n112\t\n113\t\n114\t# ---------- built-in implementations ----------\n115\t\n116\t\n117\t@builtin(\"ensure_worktree\")\n118\tdef ensure_worktree(ctx: ExecutionContext) -> None:\n119\t    \"\"\"Create (or resume) a git worktree for this PRD.\n120\t\n121\t    Target path: ``{repo_root}/.worktrees/{prd_id}-{slug}``. Branch:\n122\t    ``prd/{prd_id}-{slug}`` created from ``ctx.base_ref``. If the\n123\t    worktree already exists (previous run resumed), reuses it without\n124\t    re-creating. Sets ``ctx.worktree_path`` and ``ctx.cwd`` on success.\n125\t\n126\t    In live mode, acquires a per-PRD advisory file lock at\n127\t    ``.worktrees/{prd_id}.lock`` before any mutation so two concurrent\n128\t    ``prd run`` invocations for the same PRD fail fast with a clear\n129\t    message instead of racing. The lock is auto-released by the kernel\n130\t    when the process exits; the runner also releases it explicitly at the\n131\t    end of the run (see ``_release_worktree_lock``).\n132\t    \"\"\"\n133\t    worktree_path = _worktree_target(ctx)\n134\t    branch = ctx.branch_name\n135\t\n136\t    if ctx.dry_run:\n137\t        # Dry-run produces no side effects, so no lock needed.\n138\t        ctx.logger.info(\n139\t            \"[dry-run] git worktree add -b %s %s %s\",\n140\t            branch,\n141\t            worktree_path,\n142\t            ctx.base_ref,\n143\t        )\n144\t        ctx.worktree_path = worktree_path\n145\t        ctx.cwd = worktree_path\n146\t        return\n147\t\n148\t    # Acquire the lock BEFORE the resume-check or any mutation.\n149\t    # The lock file lives at .worktrees/PRD-X.lock and is per-PRD.\n150\t    lock_path = ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}.lock\"\n151\t    lock_path.parent.mkdir(parents=True, exist_ok=True)\n152\t\n153\t    lock = FileLock(str(lock_path))\n154\t    try:\n155\t        lock.acquire(timeout=0)  # non-blocking\n156\t    except Timeout:\n157\t        raise RuntimeError(\n158\t            f\"{ctx.prd.id} is already being worked on by another `prd run` \"\n159\t            f\"process (lock held on {lock_path}). If that process died, \"\n160\t            f\"the lock will auto-release when its file handle is reclaimed. \"\n161\t            f\"On a stuck lock, delete {lock_path} manually.\"\n162\t        ) from None\n163\t\n164\t    ctx._worktree_lock = lock\n165\t\n166\t    # ---- existing logic below, now lock-protected ----\n167\t    if worktree_path.exists():\n168\t        status = is_resume_safe(branch, ctx.repo_root)\n169\t        if not status.safe:\n170\t            lock.release()\n171\t            ctx._worktree_lock = None\n172\t            raise RuntimeError(status.reason)\n173\t        ctx.logger.info(\"resuming existing worktree: %s\", worktree_path)\n174\t        ctx.worktree_path = worktree_path\n175\t        ctx.cwd = worktree_path\n176\t        return\n177\t\n178\t    local_exists = _branch_exists_local(ctx.repo_root, branch)\n179\t    remote_exists = _branch_exists_remote(ctx.repo_root, branch)\n180\t    if local_exists or remote_exists:\n181\t        # Release the lock before raising so the error state is clean.\n182\t        lock.release()\n183\t        ctx._worktree_lock = None\n184\t        raise RuntimeError(\n185\t            f\"branch {branch!r} already exists but worktree {worktree_path} is gone. \"\n186\t            f\"Run `prd cleanup {ctx.prd.id}` to release it.\"\n187\t        )\n188\t\n189\t    # git worktree add -b <branch> <path> <base>\n190\t    # Run from the repo root, not from ctx.cwd (which may not be a git dir yet).\n191\t    subprocess.run(\n192\t        [\n193\t            \"git\",\n194\t            \"-C\",\n195\t            str(ctx.repo_root),\n196\t            \"worktree\",\n197\t            \"add\",\n198\t            \"-b\",\n199\t            branch,\n200\t            str(worktree_path),\n201\t            ctx.base_ref,\n202\t        ],\n203\t        check=True,\n204\t        capture_output=True,\n205\t        text=True,\n206\t    )\n207\t\n208\t    ctx.worktree_path = worktree_path\n209\t    ctx.cwd = worktree_path\n210\t@builtin(\"set_status\")\n211\tdef set_status(ctx: ExecutionContext, *, to: Status) -> None:\n212\t    \"\"\"Rewrite the PRD's ``status:`` frontmatter field inside the worktree.\n213\t\n214\t    Targets the worktree's copy of the PRD file, never the source repo.\n215\t    The source repo's working tree must remain untouched by ``prd run`` —\n216\t    status transitions live on the PRD's worktree branch and only reach\n217\t    the source repo via PR merge (see PRD-213).\n218\t\n219\t    Uses :func:`darkfactory.prd.set_status_at`, which surgically rewrites\n220\t    only the ``status:`` and ``updated:`` lines so the resulting commit\n221\t    diff is two lines, not the whole frontmatter block.\n222\t    \"\"\"\n223\t    if ctx.dry_run:\n224\t        ctx.logger.info(\n225\t            \"[dry-run] set status of %s: %s -> %s (worktree=%s)\",\n226\t            ctx.prd.id,\n227\t            ctx.prd.status,\n228\t            to,\n229\t            ctx.worktree_path,\n230\t        )\n231\t        return\n232\t\n233\t    if ctx.worktree_path is None:\n234\t        raise RuntimeError(\n235\t            \"set_status requires a worktree; ensure_worktree must run first\"\n236\t        )\n237\t\n238\t    relative = ctx.prd.path.relative_to(ctx.repo_root)\n239\t    target = ctx.worktree_path / relative\n240\t    prd_module.set_status_at(target, to)\n241\t    # Mirror the field updates onto the in-memory PRD so subsequent\n242\t    # builtins see the new status without re-loading from disk.\n243\t    ctx.prd.status = to\n244\t    from datetime import date as _date\n245\t\n246\t    ctx.prd.updated = _date.today().isoformat()\n247\t\n248\t\n249\t@builtin(\"commit\")\n250\tdef commit(ctx: ExecutionContext, *, message: str) -> None:\n251\t    \"\"\"Stage all changes and make a commit inside the worktree.\n252\t\n253\t    ``message`` is format-string expanded against the context so\n254\t    ``\"chore(prd): {prd_id} start work\"`` becomes\n255\t    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n256\t    returns without erroring — workflows can safely commit after each\n257\t    logical step without worrying about whether anything changed.\n258\t    \"\"\"\n259\t    formatted = ctx.format_string(message)\n260\t    _scan_for_forbidden_attribution(\n261\t        formatted, source=f\"commit message for {ctx.prd.id}\"\n262\t    )\n263\t\n264\t    if ctx.dry_run:\n265\t        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n266\t        return\n267\t\n268\t    # Stage everything\n269\t    subprocess.run(\n270\t        [\"git\", \"add\", \"-A\"],\n271\t        cwd=str(ctx.cwd),\n272\t        check=True,\n273\t        capture_output=True,\n274\t        text=True,\n275\t    )\n276\t\n277\t    # Check if there's anything to commit\n278\t    diff_result = subprocess.run(\n279\t        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n280\t        cwd=str(ctx.cwd),\n281\t        check=False,\n282\t        capture_output=True,\n283\t        text=True,\n284\t    )\n285\t    if diff_result.returncode == 0:\n286\t        # No staged changes — skip gracefully.\n287\t        ctx.logger.info(\"commit skipped: no changes to commit\")\n288\t        return\n289\t\n290\t    # Commit\n291\t    subprocess.run(\n292\t        [\"git\", \"commit\", \"-m\", formatted],\n293\t        cwd=str(ctx.cwd),\n294\t        check=True,\n295\t        capture_output=True,\n296\t        text=True,\n297\t    )\n298\t\n299\t\n300\t@builtin(\"push_branch\")\n301\tdef push_branch(ctx: ExecutionContext) -> None:\n302\t    \"\"\"Push the current branch to origin with upstream tracking.\n303\t\n304\t    Runs ``git push -u origin {branch}`` inside the worktree. Required\n305\t    before :func:`create_pr` because ``gh pr create --base`` needs the\n306\t    remote to exist.\n307\t    \"\"\"\n308\t    cmd = [\"git\", \"push\", \"-u\", \"origin\", ctx.branch_name]\n309\t\n310\t    if ctx.dry_run:\n311\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n312\t        return\n313\t\n314\t    subprocess.run(\n315\t        cmd,\n316\t        cwd=str(ctx.cwd),\n317\t        check=True,\n318\t        capture_output=True,\n319\t        text=True,\n320\t    )\n321\t\n322\t\n323\tdef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n324\t    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n325\t    if not tool_counts:\n326\t        return \"none\"\n327\t    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n328\t\n329\t\n330\tdef _format_invocations(ctx: ExecutionContext) -> str:\n331\t    \"\"\"Format agent invocation count from context.\"\"\"\n332\t    count = ctx.invoke_count\n333\t    if count == 0:\n334\t        return \"0\"\n335\t    if count == 1:\n336\t        return \"1\"\n337\t    return str(count)\n338\t\n339\t\n340\t@builtin(\"summarize_agent_run\")\n341\tdef summarize_agent_run(ctx: ExecutionContext) -> None:\n342\t    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n343\t    result = ctx.last_invoke_result\n344\t    if result is None:\n345\t        return\n346\t\n347\t    lines = [\n348\t        \"## Harness execution summary\",\n349\t        \"\",\n350\t        f\"- **Workflow:** {ctx.workflow.name}\",\n351\t        f\"- **Model:** {ctx.model or 'unknown'}\",\n352\t        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n353\t        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n354\t        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n355\t    ]\n356\t    ctx.run_summary = \"\\n\".join(lines)\n357\t\n358\t\n359\t@builtin(\"commit_transcript\")\n360\tdef commit_transcript(ctx: ExecutionContext) -> None:\n361\t    \"\"\"Copy agent transcript into the worktree and stage it.\n362\t\n363\t    Source: ``<repo_root>/.harness-transcripts/{prd_id}.log`` written by the\n364\t    runner after each agent invocation (outside any worktree — see\n365\t    ``runner._run_agent``). Destination inside the worktree:\n366\t    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n367\t\n368\t    The runner writes transcripts *outside* every worktree so ``git add -A``\n369\t    can never accidentally sweep them. This builtin is the one place that\n370\t    opts the transcript *into* the worktree — workflows that want the\n371\t    transcript committed alongside the PRD work must include this builtin\n372\t    explicitly. Workflows that omit it leave the transcript at the repo-root\n373\t    path where it survives as a local-only diagnostic.\n374\t\n375\t    Timestamps use the wall-clock at the time this builtin runs, which is\n376\t    unique enough for sequential runs. If no transcript exists (dry-run,\n377\t    or the runner didn't produce one), this is a no-op.\n378\t    \"\"\"\n379\t    src = ctx.repo_root / \".harness-transcripts\" / f\"{ctx.prd.id}.log\"\n380\t    if not src.exists():\n381\t        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n382\t        return\n383\t\n384\t    if ctx.dry_run:\n385\t        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n386\t        dest = (\n387\t            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n388\t        )\n389\t        ctx.logger.info(\"[dry-run] copy %s -> %s && git add\", src, dest)\n390\t        return\n391\t\n392\t    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n393\t    transcript_dir.mkdir(parents=True, exist_ok=True)\n394\t\n395\t    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n396\t    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n397\t\n398\t    # Copy (not move) so the repo-root transcript persists as a local-only\n399\t    # diagnostic even after this builtin runs. If the same PRD is re-run,\n400\t    # the runner overwrites the source file anyway.\n401\t    shutil.copy2(str(src), str(dest))\n402\t\n403\t    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n404\t    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n405\t\n406\t\n407\t@builtin(\"create_pr\")\n408\tdef create_pr(ctx: ExecutionContext) -> None:\n409\t    \"\"\"Open a pull request via ``gh pr create``.\n410\t\n411\t    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n412\t    acceptance criteria plus a link to the PRD file. Base branch:\n413\t    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n414\t    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n415\t    relative to ``ctx.repo_root``.\n416\t    \"\"\"\n417\t    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n418\t    body = _pr_body(ctx)\n419\t    if ctx.run_summary:\n420\t        body += \"\\n\\n\" + ctx.run_summary\n421\t    _scan_for_forbidden_attribution(title, source=f\"PR title for {ctx.prd.id}\")\n422\t    _scan_for_forbidden_attribution(body, source=f\"PR body for {ctx.prd.id}\")\n423\t\n424\t    if ctx.dry_run:\n425\t        ctx.logger.info(\n426\t            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n427\t            ctx.base_ref,\n428\t            title,\n429\t        )\n430\t        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n431\t        return\n432\t\n433\t    # Write the body to a temp file — passing long bodies via --body\n434\t    # can hit argv limits on some systems.\n435\t    import tempfile\n436\t\n437\t    with tempfile.NamedTemporaryFile(\n438\t        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n439\t    ) as body_file:\n440\t        body_file.write(body)\n441\t        body_path = body_file.name\n442\t\n443\t    try:\n444\t        result = subprocess.run(\n445\t            [\n446\t                \"gh\",\n447\t                \"pr\",\n448\t                \"create\",\n449\t                \"--base\",\n450\t                ctx.base_ref,\n451\t                \"--title\",\n452\t                title,\n453\t                \"--body-file\",\n454\t                body_path,\n455\t            ],\n456\t            cwd=str(ctx.cwd),\n457\t            check=True,\n458\t            capture_output=True,\n459\t            text=True,\n460\t        )\n461\t    finally:\n462\t        Path(body_path).unlink(missing_ok=True)\n463\t\n464\t    # gh prints the PR URL to stdout on success.\n465\t    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n466\t    ctx.pr_url = url_line or None\n467\t\n468\t\n469\t@builtin(\"lint_attribution\")\n470\tdef lint_attribution(ctx: ExecutionContext) -> None:\n471\t    \"\"\"Fail if any commit on the branch or the run summary credits Claude/Anthropic.\n472\t\n473\t    Scans:\n474\t\n475\t    - Every commit message in ``{base_ref}..HEAD`` on the current branch\n476\t    - ``ctx.run_summary`` (which feeds the PR body)\n477\t\n478\t    Intended to run after the agent + verification phases and before\n479\t    ``push_branch`` / ``create_pr``, so violations abort the workflow\n480\t    before anything lands on the remote or in a PR. Dry-run is a no-op\n481\t    because there are no real commits to scan.\n482\t    \"\"\"\n483\t    if ctx.dry_run:\n484\t        ctx.logger.info(\"[dry-run] lint_attribution: skipped\")\n485\t        return\n486\t\n487\t    _scan_for_forbidden_attribution(\n488\t        ctx.run_summary or \"\", source=f\"run summary for {ctx.prd.id}\"\n489\t    )\n490\t\n491\t    result = subprocess.run(\n492\t        [\"git\", \"log\", f\"{ctx.base_ref}..HEAD\", \"--format=%H%x00%B%x1e\"],\n493\t        cwd=str(ctx.cwd),\n494\t        check=True,\n495\t        capture_output=True,\n496\t        text=True,\n497\t    )\n498\t    # Record separator \\x1e between commits; field separator \\x00 between\n499\t    # sha and body. Keeps us robust against newlines in commit messages.\n500\t    for entry in result.stdout.split(\"\\x1e\"):\n501\t        entry = entry.strip()\n502\t        if not entry:\n503\t            continue\n504\t        sha, _, body = entry.partition(\"\\x00\")\n505\t        _scan_for_forbidden_attribution(\n506\t            body, source=f\"commit {sha[:12]} on {ctx.branch_name}\"\n507\t        )\n508\t\n509\t    ctx.logger.info(\"lint_attribution: clean\")\n510\t\n511\t\n512\t@builtin(\"cleanup_worktree\")\n513\tdef cleanup_worktree(ctx: ExecutionContext) -> None:\n514\t    \"\"\"Remove the worktree after a successful run.\n515\t\n516\t    Idempotent — if the worktree is already gone, logs and returns.\n517\t    Normally skipped during chain execution so downstream worktrees\n518\t    can base on this branch; called explicitly via ``prd cleanup``\n519\t    after the whole chain is done.\n520\t    \"\"\"\n521\t    if ctx.worktree_path is None:\n522\t        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n523\t        return\n524\t\n525\t    if not ctx.worktree_path.exists():\n526\t        ctx.logger.info(\n527\t            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n528\t        )\n529\t        return\n530\t\n531\t    cmd = [\n532\t        \"git\",\n533\t        \"-C\",\n534\t        str(ctx.repo_root),\n535\t        \"worktree\",\n536\t        \"remove\",\n537\t        str(ctx.worktree_path),\n538\t    ]\n539\t\n540\t    if ctx.dry_run:\n541\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n542\t        return\n543\t\n544\t    subprocess.run(cmd, check=True, capture_output=True, text=True)\n545\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"1f534906-900d-426c-84f5-c086d3be4bd4","uuid":"61ac39c5-306f-42c8-baae-42867f4c181a","timestamp":"2026-04-09T03:20:57.937Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/src/darkfactory/builtins/__init__.py","content":"\"\"\"Built-in task primitives — re-export hub.\n\nImports every submodule so @builtin-decorated functions register on\npackage import. Re-exports the public API for backwards compatibility.\n\nBuilt-ins are the deterministic SDLC operations that every workflow\nreferences by name: create a worktree, set a PRD's status, make a\ncommit, push a branch, open a PR. They live here (not in individual\nworkflow modules) because they're shared — every workflow uses the\nsame ``commit`` primitive, not a bespoke one.\n\nWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n\n    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n\nThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\nregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\nplus any formatted kwargs.\n\n**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\nanything destructive. In dry-run, we log what we WOULD do at INFO\nlevel and return. This is what powers ``prd plan`` and the default\n``prd run`` (without ``--execute``).\n\n**Subprocess discipline**: all shell commands use ``subprocess.run``\nwith an explicit argv list (never ``shell=True``), capture output,\nand check the return code. Git and gh invocations go through\n:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\nhandling and dry-run support.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport re\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom filelock import FileLock, Timeout\n\nfrom darkfactory import prd as prd_module\nfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\nfrom darkfactory.builtins._shared import (\n    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n    _run,\n    _scan_for_forbidden_attribution,\n)\nfrom darkfactory.builtins.set_status import set_status  # noqa: F401\nfrom darkfactory.checks import is_resume_safe\n_log = logging.getLogger(__name__)\n\nfrom darkfactory.workflow import ExecutionContext, Status\n\n_log = logging.getLogger(__name__)\n\n# Import submodules to trigger @builtin registration.\nfrom darkfactory.builtins.ensure_worktree import ensure_worktree  # noqa: E402\n\n__all__ = [\n    \"BUILTINS\",\n    \"BuiltInFunc\",\n    \"builtin\",\n    \"_run\",\n    \"_scan_for_forbidden_attribution\",\n    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n    \"ensure_worktree\",\n    \"set_status\",\n    \"commit\",\n    \"push_branch\",\n    \"summarize_agent_run\",\n    \"commit_transcript\",\n    \"create_pr\",\n    \"lint_attribution\",\n    \"cleanup_worktree\",\n]\n\n\n_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n\n\ndef _extract_acceptance_criteria(body: str) -> list[str]:\n    \"\"\"Pull acceptance criteria lines out of a PRD body.\n\n    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n    Returns a list of the criterion strings (without the checkbox\n    prefix). Used by ``create_pr`` to build the PR body's checklist.\n    \"\"\"\n    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n\n\ndef _pr_body(ctx: ExecutionContext) -> str:\n    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n    prd = ctx.prd\n    lines: list[str] = [\n        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n        \"\",\n    ]\n\n    acs = _extract_acceptance_criteria(prd.body)\n    if acs:\n        lines.append(\"## Acceptance criteria\")\n        lines.append(\"\")\n        for ac in acs:\n            lines.append(f\"- [ ] {ac}\")\n        lines.append(\"\")\n\n    lines.append(\"---\")\n    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n    return \"\\n\".join(lines)\n\n\n# ---------- built-in implementations ----------\n\n\n@builtin(\"ensure_worktree\")\ndef ensure_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Create (or resume) a git worktree for this PRD.\n\n    Target path: ``{repo_root}/.worktrees/{prd_id}-{slug}``. Branch:\n    ``prd/{prd_id}-{slug}`` created from ``ctx.base_ref``. If the\n    worktree already exists (previous run resumed), reuses it without\n    re-creating. Sets ``ctx.worktree_path`` and ``ctx.cwd`` on success.\n\n    In live mode, acquires a per-PRD advisory file lock at\n    ``.worktrees/{prd_id}.lock`` before any mutation so two concurrent\n    ``prd run`` invocations for the same PRD fail fast with a clear\n    message instead of racing. The lock is auto-released by the kernel\n    when the process exits; the runner also releases it explicitly at the\n    end of the run (see ``_release_worktree_lock``).\n    \"\"\"\n    worktree_path = _worktree_target(ctx)\n    branch = ctx.branch_name\n\n    if ctx.dry_run:\n        # Dry-run produces no side effects, so no lock needed.\n        ctx.logger.info(\n            \"[dry-run] git worktree add -b %s %s %s\",\n            branch,\n            worktree_path,\n            ctx.base_ref,\n        )\n        ctx.worktree_path = worktree_path\n        ctx.cwd = worktree_path\n        return\n\n    # Acquire the lock BEFORE the resume-check or any mutation.\n    # The lock file lives at .worktrees/PRD-X.lock and is per-PRD.\n    lock_path = ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}.lock\"\n    lock_path.parent.mkdir(parents=True, exist_ok=True)\n\n    lock = FileLock(str(lock_path))\n    try:\n        lock.acquire(timeout=0)  # non-blocking\n    except Timeout:\n        raise RuntimeError(\n            f\"{ctx.prd.id} is already being worked on by another `prd run` \"\n            f\"process (lock held on {lock_path}). If that process died, \"\n            f\"the lock will auto-release when its file handle is reclaimed. \"\n            f\"On a stuck lock, delete {lock_path} manually.\"\n        ) from None\n\n    ctx._worktree_lock = lock\n\n    # ---- existing logic below, now lock-protected ----\n    if worktree_path.exists():\n        status = is_resume_safe(branch, ctx.repo_root)\n        if not status.safe:\n            lock.release()\n            ctx._worktree_lock = None\n            raise RuntimeError(status.reason)\n        ctx.logger.info(\"resuming existing worktree: %s\", worktree_path)\n        ctx.worktree_path = worktree_path\n        ctx.cwd = worktree_path\n        return\n\n    local_exists = _branch_exists_local(ctx.repo_root, branch)\n    remote_exists = _branch_exists_remote(ctx.repo_root, branch)\n    if local_exists or remote_exists:\n        # Release the lock before raising so the error state is clean.\n        lock.release()\n        ctx._worktree_lock = None\n        raise RuntimeError(\n            f\"branch {branch!r} already exists but worktree {worktree_path} is gone. \"\n            f\"Run `prd cleanup {ctx.prd.id}` to release it.\"\n        )\n\n    # git worktree add -b <branch> <path> <base>\n    # Run from the repo root, not from ctx.cwd (which may not be a git dir yet).\n    subprocess.run(\n        [\n            \"git\",\n            \"-C\",\n            str(ctx.repo_root),\n            \"worktree\",\n            \"add\",\n            \"-b\",\n            branch,\n            str(worktree_path),\n            ctx.base_ref,\n        ],\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n    ctx.worktree_path = worktree_path\n    ctx.cwd = worktree_path\n@builtin(\"set_status\")\ndef set_status(ctx: ExecutionContext, *, to: Status) -> None:\n    \"\"\"Rewrite the PRD's ``status:`` frontmatter field inside the worktree.\n\n    Targets the worktree's copy of the PRD file, never the source repo.\n    The source repo's working tree must remain untouched by ``prd run`` —\n    status transitions live on the PRD's worktree branch and only reach\n    the source repo via PR merge (see PRD-213).\n\n    Uses :func:`darkfactory.prd.set_status_at`, which surgically rewrites\n    only the ``status:`` and ``updated:`` lines so the resulting commit\n    diff is two lines, not the whole frontmatter block.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\n            \"[dry-run] set status of %s: %s -> %s (worktree=%s)\",\n            ctx.prd.id,\n            ctx.prd.status,\n            to,\n            ctx.worktree_path,\n        )\n        return\n\n    if ctx.worktree_path is None:\n        raise RuntimeError(\n            \"set_status requires a worktree; ensure_worktree must run first\"\n        )\n\n    relative = ctx.prd.path.relative_to(ctx.repo_root)\n    target = ctx.worktree_path / relative\n    prd_module.set_status_at(target, to)\n    # Mirror the field updates onto the in-memory PRD so subsequent\n    # builtins see the new status without re-loading from disk.\n    ctx.prd.status = to\n    from datetime import date as _date\n\n    ctx.prd.updated = _date.today().isoformat()\n\n\n@builtin(\"commit\")\ndef commit(ctx: ExecutionContext, *, message: str) -> None:\n    \"\"\"Stage all changes and make a commit inside the worktree.\n\n    ``message`` is format-string expanded against the context so\n    ``\"chore(prd): {prd_id} start work\"`` becomes\n    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n    returns without erroring — workflows can safely commit after each\n    logical step without worrying about whether anything changed.\n    \"\"\"\n    formatted = ctx.format_string(message)\n    _scan_for_forbidden_attribution(\n        formatted, source=f\"commit message for {ctx.prd.id}\"\n    )\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n        return\n\n    # Stage everything\n    subprocess.run(\n        [\"git\", \"add\", \"-A\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n    # Check if there's anything to commit\n    diff_result = subprocess.run(\n        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n        cwd=str(ctx.cwd),\n        check=False,\n        capture_output=True,\n        text=True,\n    )\n    if diff_result.returncode == 0:\n        # No staged changes — skip gracefully.\n        ctx.logger.info(\"commit skipped: no changes to commit\")\n        return\n\n    # Commit\n    subprocess.run(\n        [\"git\", \"commit\", \"-m\", formatted],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n\n@builtin(\"push_branch\")\ndef push_branch(ctx: ExecutionContext) -> None:\n    \"\"\"Push the current branch to origin with upstream tracking.\n\n    Runs ``git push -u origin {branch}`` inside the worktree. Required\n    before :func:`create_pr` because ``gh pr create --base`` needs the\n    remote to exist.\n    \"\"\"\n    cmd = [\"git\", \"push\", \"-u\", \"origin\", ctx.branch_name]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(\n        cmd,\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n\ndef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n    if not tool_counts:\n        return \"none\"\n    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n\n\ndef _format_invocations(ctx: ExecutionContext) -> str:\n    \"\"\"Format agent invocation count from context.\"\"\"\n    count = ctx.invoke_count\n    if count == 0:\n        return \"0\"\n    if count == 1:\n        return \"1\"\n    return str(count)\n\n\n@builtin(\"summarize_agent_run\")\ndef summarize_agent_run(ctx: ExecutionContext) -> None:\n    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n    result = ctx.last_invoke_result\n    if result is None:\n        return\n\n    lines = [\n        \"## Harness execution summary\",\n        \"\",\n        f\"- **Workflow:** {ctx.workflow.name}\",\n        f\"- **Model:** {ctx.model or 'unknown'}\",\n        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n    ]\n    ctx.run_summary = \"\\n\".join(lines)\n\n\n@builtin(\"commit_transcript\")\ndef commit_transcript(ctx: ExecutionContext) -> None:\n    \"\"\"Copy agent transcript into the worktree and stage it.\n\n    Source: ``<repo_root>/.harness-transcripts/{prd_id}.log`` written by the\n    runner after each agent invocation (outside any worktree — see\n    ``runner._run_agent``). Destination inside the worktree:\n    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n\n    The runner writes transcripts *outside* every worktree so ``git add -A``\n    can never accidentally sweep them. This builtin is the one place that\n    opts the transcript *into* the worktree — workflows that want the\n    transcript committed alongside the PRD work must include this builtin\n    explicitly. Workflows that omit it leave the transcript at the repo-root\n    path where it survives as a local-only diagnostic.\n\n    Timestamps use the wall-clock at the time this builtin runs, which is\n    unique enough for sequential runs. If no transcript exists (dry-run,\n    or the runner didn't produce one), this is a no-op.\n    \"\"\"\n    src = ctx.repo_root / \".harness-transcripts\" / f\"{ctx.prd.id}.log\"\n    if not src.exists():\n        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n        return\n\n    if ctx.dry_run:\n        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n        dest = (\n            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n        )\n        ctx.logger.info(\"[dry-run] copy %s -> %s && git add\", src, dest)\n        return\n\n    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n    transcript_dir.mkdir(parents=True, exist_ok=True)\n\n    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n\n    # Copy (not move) so the repo-root transcript persists as a local-only\n    # diagnostic even after this builtin runs. If the same PRD is re-run,\n    # the runner overwrites the source file anyway.\n    shutil.copy2(str(src), str(dest))\n\n    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n\n\n@builtin(\"create_pr\")\ndef create_pr(ctx: ExecutionContext) -> None:\n    \"\"\"Open a pull request via ``gh pr create``.\n\n    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n    acceptance criteria plus a link to the PRD file. Base branch:\n    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n    relative to ``ctx.repo_root``.\n    \"\"\"\n    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n    body = _pr_body(ctx)\n    if ctx.run_summary:\n        body += \"\\n\\n\" + ctx.run_summary\n    _scan_for_forbidden_attribution(title, source=f\"PR title for {ctx.prd.id}\")\n    _scan_for_forbidden_attribution(body, source=f\"PR body for {ctx.prd.id}\")\n\n    if ctx.dry_run:\n        ctx.logger.info(\n            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n            ctx.base_ref,\n            title,\n        )\n        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n        return\n\n    # Write the body to a temp file — passing long bodies via --body\n    # can hit argv limits on some systems.\n    import tempfile\n\n    with tempfile.NamedTemporaryFile(\n        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n    ) as body_file:\n        body_file.write(body)\n        body_path = body_file.name\n\n    try:\n        result = subprocess.run(\n            [\n                \"gh\",\n                \"pr\",\n                \"create\",\n                \"--base\",\n                ctx.base_ref,\n                \"--title\",\n                title,\n                \"--body-file\",\n                body_path,\n            ],\n            cwd=str(ctx.cwd),\n            check=True,\n            capture_output=True,\n            text=True,\n        )\n    finally:\n        Path(body_path).unlink(missing_ok=True)\n\n    # gh prints the PR URL to stdout on success.\n    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n    ctx.pr_url = url_line or None\n\n\n@builtin(\"lint_attribution\")\ndef lint_attribution(ctx: ExecutionContext) -> None:\n    \"\"\"Fail if any commit on the branch or the run summary credits Claude/Anthropic.\n\n    Scans:\n\n    - Every commit message in ``{base_ref}..HEAD`` on the current branch\n    - ``ctx.run_summary`` (which feeds the PR body)\n\n    Intended to run after the agent + verification phases and before\n    ``push_branch`` / ``create_pr``, so violations abort the workflow\n    before anything lands on the remote or in a PR. Dry-run is a no-op\n    because there are no real commits to scan.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] lint_attribution: skipped\")\n        return\n\n    _scan_for_forbidden_attribution(\n        ctx.run_summary or \"\", source=f\"run summary for {ctx.prd.id}\"\n    )\n\n    result = subprocess.run(\n        [\"git\", \"log\", f\"{ctx.base_ref}..HEAD\", \"--format=%H%x00%B%x1e\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n    # Record separator \\x1e between commits; field separator \\x00 between\n    # sha and body. Keeps us robust against newlines in commit messages.\n    for entry in result.stdout.split(\"\\x1e\"):\n        entry = entry.strip()\n        if not entry:\n            continue\n        sha, _, body = entry.partition(\"\\x00\")\n        _scan_for_forbidden_attribution(\n            body, source=f\"commit {sha[:12]} on {ctx.branch_name}\"\n        )\n\n    ctx.logger.info(\"lint_attribution: clean\")\n\n\n@builtin(\"cleanup_worktree\")\ndef cleanup_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Remove the worktree after a successful run.\n\n    Idempotent — if the worktree is already gone, logs and returns.\n    Normally skipped during chain execution so downstream worktrees\n    can base on this branch; called explicitly via ``prd cleanup``\n    after the whole chain is done.\n    \"\"\"\n    if ctx.worktree_path is None:\n        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n        return\n\n    if not ctx.worktree_path.exists():\n        ctx.logger.info(\n            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n        )\n        return\n\n    cmd = [\n        \"git\",\n        \"-C\",\n        str(ctx.repo_root),\n        \"worktree\",\n        \"remove\",\n        str(ctx.worktree_path),\n    ]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(cmd, check=True, capture_output=True, text=True)\n","numLines":545,"startLine":1,"totalLines":545}}}
