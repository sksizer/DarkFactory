{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HvBSqfhkzPg9PWBPgJ8reT","type":"tool_result","content":"1\t\"\"\"Built-in task primitives — re-export hub.\n2\t\n3\tImports every submodule so @builtin-decorated functions register on\n4\tpackage import. Re-exports the public API for backwards compatibility.\n5\t\n6\tBuilt-ins are the deterministic SDLC operations that every workflow\n7\treferences by name: create a worktree, set a PRD's status, make a\n8\tcommit, push a branch, open a PR. They live here (not in individual\n9\tworkflow modules) because they're shared — every workflow uses the\n10\tsame ``commit`` primitive, not a bespoke one.\n11\t\n12\tWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n13\t\n14\t    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n15\t\n16\tThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\n17\tregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\n18\tplus any formatted kwargs.\n19\t\n20\t**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\n21\tanything destructive. In dry-run, we log what we WOULD do at INFO\n22\tlevel and return. This is what powers ``prd plan`` and the default\n23\t``prd run`` (without ``--execute``).\n24\t\n25\t**Subprocess discipline**: all shell commands use ``subprocess.run``\n26\twith an explicit argv list (never ``shell=True``), capture output,\n27\tand check the return code. Git and gh invocations go through\n28\t:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\n29\thandling and dry-run support.\n30\t\"\"\"\n31\t\n32\tfrom __future__ import annotations\n33\t\n34\timport logging\n35\timport re\n36\timport shutil\n37\timport subprocess\n38\tfrom datetime import datetime\n39\tfrom pathlib import Path\n40\t\n41\tfrom filelock import FileLock, Timeout\n42\t\n43\tfrom darkfactory import prd as prd_module\n44\tfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\n45\tfrom darkfactory.builtins._shared import (\n46\t    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n47\t    _run,\n48\t    _scan_for_forbidden_attribution,\n49\t)\n50\tfrom darkfactory.builtins.set_status import set_status  # noqa: F401\n51\tfrom darkfactory.checks import is_resume_safe\n52\t_log = logging.getLogger(__name__)\n53\t\n54\tfrom darkfactory.workflow import ExecutionContext, Status\n55\t\n56\t_log = logging.getLogger(__name__)\n57\t\n58\t# Import submodules to trigger @builtin registration.\n59\tfrom darkfactory.builtins.ensure_worktree import ensure_worktree  # noqa: E402\n60\tfrom darkfactory.builtins.push_branch import push_branch  # noqa: E402\n61\t\n62\t__all__ = [\n63\t    \"BUILTINS\",\n64\t    \"BuiltInFunc\",\n65\t    \"builtin\",\n66\t    \"_run\",\n67\t    \"_scan_for_forbidden_attribution\",\n68\t    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n69\t    \"ensure_worktree\",\n70\t    \"set_status\",\n71\t    \"commit\",\n72\t    \"push_branch\",\n73\t    \"summarize_agent_run\",\n74\t    \"commit_transcript\",\n75\t    \"create_pr\",\n76\t    \"lint_attribution\",\n77\t    \"cleanup_worktree\",\n78\t]\n79\t\n80\t\n81\t_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n82\t\n83\t\n84\tdef _extract_acceptance_criteria(body: str) -> list[str]:\n85\t    \"\"\"Pull acceptance criteria lines out of a PRD body.\n86\t\n87\t    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n88\t    Returns a list of the criterion strings (without the checkbox\n89\t    prefix). Used by ``create_pr`` to build the PR body's checklist.\n90\t    \"\"\"\n91\t    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n92\t\n93\t\n94\tdef _pr_body(ctx: ExecutionContext) -> str:\n95\t    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n96\t    prd = ctx.prd\n97\t    lines: list[str] = [\n98\t        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n99\t        \"\",\n100\t    ]\n101\t\n102\t    acs = _extract_acceptance_criteria(prd.body)\n103\t    if acs:\n104\t        lines.append(\"## Acceptance criteria\")\n105\t        lines.append(\"\")\n106\t        for ac in acs:\n107\t            lines.append(f\"- [ ] {ac}\")\n108\t        lines.append(\"\")\n109\t\n110\t    lines.append(\"---\")\n111\t    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n112\t    return \"\\n\".join(lines)\n113\t\n114\t\n115\t# ---------- built-in implementations ----------\n116\t\n117\t\n118\t\n119\t\n120\t@builtin(\"commit\")\n121\tdef commit(ctx: ExecutionContext, *, message: str) -> None:\n122\t    \"\"\"Stage all changes and make a commit inside the worktree.\n123\t\n124\t    ``message`` is format-string expanded against the context so\n125\t    ``\"chore(prd): {prd_id} start work\"`` becomes\n126\t    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n127\t    returns without erroring — workflows can safely commit after each\n128\t    logical step without worrying about whether anything changed.\n129\t    \"\"\"\n130\t    formatted = ctx.format_string(message)\n131\t    _scan_for_forbidden_attribution(\n132\t        formatted, source=f\"commit message for {ctx.prd.id}\"\n133\t    )\n134\t\n135\t    if ctx.dry_run:\n136\t        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n137\t        return\n138\t\n139\t    # Stage everything\n140\t    subprocess.run(\n141\t        [\"git\", \"add\", \"-A\"],\n142\t        cwd=str(ctx.cwd),\n143\t        check=True,\n144\t        capture_output=True,\n145\t        text=True,\n146\t    )\n147\t\n148\t    # Check if there's anything to commit\n149\t    diff_result = subprocess.run(\n150\t        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"1f534906-900d-426c-84f5-c086d3be4bd4","uuid":"e3f151f6-01cc-4ef8-a172-68eda51ab7ef","timestamp":"2026-04-09T03:23:03.641Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/src/darkfactory/builtins/__init__.py","content":"\"\"\"Built-in task primitives — re-export hub.\n\nImports every submodule so @builtin-decorated functions register on\npackage import. Re-exports the public API for backwards compatibility.\n\nBuilt-ins are the deterministic SDLC operations that every workflow\nreferences by name: create a worktree, set a PRD's status, make a\ncommit, push a branch, open a PR. They live here (not in individual\nworkflow modules) because they're shared — every workflow uses the\nsame ``commit`` primitive, not a bespoke one.\n\nWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n\n    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n\nThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\nregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\nplus any formatted kwargs.\n\n**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\nanything destructive. In dry-run, we log what we WOULD do at INFO\nlevel and return. This is what powers ``prd plan`` and the default\n``prd run`` (without ``--execute``).\n\n**Subprocess discipline**: all shell commands use ``subprocess.run``\nwith an explicit argv list (never ``shell=True``), capture output,\nand check the return code. Git and gh invocations go through\n:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\nhandling and dry-run support.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport re\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom filelock import FileLock, Timeout\n\nfrom darkfactory import prd as prd_module\nfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\nfrom darkfactory.builtins._shared import (\n    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n    _run,\n    _scan_for_forbidden_attribution,\n)\nfrom darkfactory.builtins.set_status import set_status  # noqa: F401\nfrom darkfactory.checks import is_resume_safe\n_log = logging.getLogger(__name__)\n\nfrom darkfactory.workflow import ExecutionContext, Status\n\n_log = logging.getLogger(__name__)\n\n# Import submodules to trigger @builtin registration.\nfrom darkfactory.builtins.ensure_worktree import ensure_worktree  # noqa: E402\nfrom darkfactory.builtins.push_branch import push_branch  # noqa: E402\n\n__all__ = [\n    \"BUILTINS\",\n    \"BuiltInFunc\",\n    \"builtin\",\n    \"_run\",\n    \"_scan_for_forbidden_attribution\",\n    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n    \"ensure_worktree\",\n    \"set_status\",\n    \"commit\",\n    \"push_branch\",\n    \"summarize_agent_run\",\n    \"commit_transcript\",\n    \"create_pr\",\n    \"lint_attribution\",\n    \"cleanup_worktree\",\n]\n\n\n_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n\n\ndef _extract_acceptance_criteria(body: str) -> list[str]:\n    \"\"\"Pull acceptance criteria lines out of a PRD body.\n\n    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n    Returns a list of the criterion strings (without the checkbox\n    prefix). Used by ``create_pr`` to build the PR body's checklist.\n    \"\"\"\n    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n\n\ndef _pr_body(ctx: ExecutionContext) -> str:\n    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n    prd = ctx.prd\n    lines: list[str] = [\n        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n        \"\",\n    ]\n\n    acs = _extract_acceptance_criteria(prd.body)\n    if acs:\n        lines.append(\"## Acceptance criteria\")\n        lines.append(\"\")\n        for ac in acs:\n            lines.append(f\"- [ ] {ac}\")\n        lines.append(\"\")\n\n    lines.append(\"---\")\n    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n    return \"\\n\".join(lines)\n\n\n# ---------- built-in implementations ----------\n\n\n\n\n@builtin(\"commit\")\ndef commit(ctx: ExecutionContext, *, message: str) -> None:\n    \"\"\"Stage all changes and make a commit inside the worktree.\n\n    ``message`` is format-string expanded against the context so\n    ``\"chore(prd): {prd_id} start work\"`` becomes\n    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n    returns without erroring — workflows can safely commit after each\n    logical step without worrying about whether anything changed.\n    \"\"\"\n    formatted = ctx.format_string(message)\n    _scan_for_forbidden_attribution(\n        formatted, source=f\"commit message for {ctx.prd.id}\"\n    )\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n        return\n\n    # Stage everything\n    subprocess.run(\n        [\"git\", \"add\", \"-A\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n    # Check if there's anything to commit\n    diff_result = subprocess.run(\n        [\"git\", \"diff\", \"--cached\", \"--quiet\"],","numLines":150,"startLine":1,"totalLines":393}}}
