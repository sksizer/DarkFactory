{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SGeavDn1LTF3DbGxJ7jNW5","type":"tool_result","content":"1\t\"\"\"Built-in: ensure_worktree — create or resume a git worktree for a PRD.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport logging\n6\timport subprocess\n7\tfrom pathlib import Path\n8\t\n9\tfrom filelock import FileLock, Timeout\n10\t\n11\tfrom darkfactory.builtins._registry import builtin\n12\tfrom darkfactory.checks import is_resume_safe\n13\tfrom darkfactory.workflow import ExecutionContext\n14\t\n15\t_log = logging.getLogger(__name__)\n16\t\n17\t\n18\tdef _worktree_target(ctx: ExecutionContext) -> Path:\n19\t    \"\"\"Compute the worktree path for this PRD under ``.worktrees/``.\n20\t\n21\t    Separated out so tests can assert the path without a whole\n22\t    subprocess invocation.\n23\t    \"\"\"\n24\t    return ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}-{ctx.prd.slug}\"\n25\t\n26\t\n27\tdef _branch_exists_local(repo_root: Path, branch: str) -> bool:\n28\t    \"\"\"Return True if ``branch`` exists in the local repo's refs.\"\"\"\n29\t    result = subprocess.run(\n30\t        [\n31\t            \"git\",\n32\t            \"-C\",\n33\t            str(repo_root),\n34\t            \"rev-parse\",\n35\t            \"--verify\",\n36\t            \"--quiet\",\n37\t            f\"refs/heads/{branch}\",\n38\t        ],\n39\t        capture_output=True,\n40\t        text=True,\n41\t    )\n42\t    return result.returncode == 0\n43\t\n44\t\n45\tdef _branch_exists_remote(repo_root: Path, branch: str) -> bool:\n46\t    \"\"\"Return True if ``branch`` exists on origin.\n47\t\n48\t    Best-effort: returns False (and logs a warning) on timeout or any\n49\t    subprocess error so the caller can fall back to the local check.\n50\t    \"\"\"\n51\t    try:\n52\t        result = subprocess.run(\n53\t            [\n54\t                \"git\",\n55\t                \"-C\",\n56\t                str(repo_root),\n57\t                \"ls-remote\",\n58\t                \"--exit-code\",\n59\t                \"origin\",\n60\t                f\"refs/heads/{branch}\",\n61\t            ],\n62\t            capture_output=True,\n63\t            text=True,\n64\t            timeout=10,\n65\t        )\n66\t    except subprocess.TimeoutExpired:\n67\t        _log.warning(\n68\t            \"git ls-remote timed out checking remote branch %r — skipping remote check\",\n69\t            branch,\n70\t        )\n71\t        return False\n72\t    except Exception as exc:\n73\t        _log.warning(\n74\t            \"git ls-remote failed checking remote branch %r (%s) — skipping remote check\",\n75\t            branch,\n76\t            exc,\n77\t        )\n78\t        return False\n79\t    return result.returncode == 0\n80\t\n81\t\n82\t@builtin(\"ensure_worktree\")\n83\tdef ensure_worktree(ctx: ExecutionContext) -> None:\n84\t    \"\"\"Create (or resume) a git worktree for this PRD.\n85\t\n86\t    Target path: ``{repo_root}/.worktrees/{prd_id}-{slug}``. Branch:\n87\t    ``prd/{prd_id}-{slug}`` created from ``ctx.base_ref``. If the\n88\t    worktree already exists (previous run resumed), reuses it without\n89\t    re-creating. Sets ``ctx.worktree_path`` and ``ctx.cwd`` on success.\n90\t\n91\t    In live mode, acquires a per-PRD advisory file lock at\n92\t    ``.worktrees/{prd_id}.lock`` before any mutation so two concurrent\n93\t    ``prd run`` invocations for the same PRD fail fast with a clear\n94\t    message instead of racing. The lock is auto-released by the kernel\n95\t    when the process exits; the runner also releases it explicitly at the\n96\t    end of the run (see ``_release_worktree_lock``).\n97\t    \"\"\"\n98\t    worktree_path = _worktree_target(ctx)\n99\t    branch = ctx.branch_name\n100\t\n101\t    if ctx.dry_run:\n102\t        # Dry-run produces no side effects, so no lock needed.\n103\t        ctx.logger.info(\n104\t            \"[dry-run] git worktree add -b %s %s %s\",\n105\t            branch,\n106\t            worktree_path,\n107\t            ctx.base_ref,\n108\t        )\n109\t        ctx.worktree_path = worktree_path\n110\t        ctx.cwd = worktree_path\n111\t        return\n112\t\n113\t    # Acquire the lock BEFORE the resume-check or any mutation.\n114\t    # The lock file lives at .worktrees/PRD-X.lock and is per-PRD.\n115\t    lock_path = ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}.lock\"\n116\t    lock_path.parent.mkdir(parents=True, exist_ok=True)\n117\t\n118\t    lock = FileLock(str(lock_path))\n119\t    try:\n120\t        lock.acquire(timeout=0)  # non-blocking\n121\t    except Timeout:\n122\t        raise RuntimeError(\n123\t            f\"{ctx.prd.id} is already being worked on by another `prd run` \"\n124\t            f\"process (lock held on {lock_path}). If that process died, \"\n125\t            f\"the lock will auto-release when its file handle is reclaimed. \"\n126\t            f\"On a stuck lock, delete {lock_path} manually.\"\n127\t        ) from None\n128\t\n129\t    ctx._worktree_lock = lock\n130\t\n131\t    # ---- existing logic below, now lock-protected ----\n132\t    if worktree_path.exists():\n133\t        status = is_resume_safe(branch, ctx.repo_root)\n134\t        if not status.safe:\n135\t            lock.release()\n136\t            ctx._worktree_lock = None\n137\t            raise RuntimeError(status.reason)\n138\t        ctx.logger.info(\"resuming existing worktree: %s\", worktree_path)\n139\t        ctx.worktree_path = worktree_path\n140\t        ctx.cwd = worktree_path\n141\t        return\n142\t\n143\t    local_exists = _branch_exists_local(ctx.repo_root, branch)\n144\t    remote_exists = _branch_exists_remote(ctx.repo_root, branch)\n145\t    if local_exists or remote_exists:\n146\t        # Release the lock before raising so the error state is clean.\n147\t        lock.release()\n148\t        ctx._worktree_lock = None\n149\t        raise RuntimeError(\n150\t            f\"branch {branch!r} already exists but worktree {worktree_path} is gone. \"\n151\t            f\"Run `prd cleanup {ctx.prd.id}` to release it.\"\n152\t        )\n153\t\n154\t    # git worktree add -b <branch> <path> <base>\n155\t    # Run from the repo root, not from ctx.cwd (which may not be a git dir yet).\n156\t    subprocess.run(\n157\t        [\n158\t            \"git\",\n159\t            \"-C\",\n160\t            str(ctx.repo_root),\n161\t            \"worktree\",\n162\t            \"add\",\n163\t            \"-b\",\n164\t            branch,\n165\t            str(worktree_path),\n166\t            ctx.base_ref,\n167\t        ],\n168\t        check=True,\n169\t        capture_output=True,\n170\t        text=True,\n171\t    )\n172\t\n173\t    ctx.worktree_path = worktree_path\n174\t    ctx.cwd = worktree_path\n175\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"1f534906-900d-426c-84f5-c086d3be4bd4","uuid":"ef56b76e-18c6-431a-9edd-b75f5e94e6cf","timestamp":"2026-04-09T03:20:36.104Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/src/darkfactory/builtins/ensure_worktree.py","content":"\"\"\"Built-in: ensure_worktree — create or resume a git worktree for a PRD.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport subprocess\nfrom pathlib import Path\n\nfrom filelock import FileLock, Timeout\n\nfrom darkfactory.builtins._registry import builtin\nfrom darkfactory.checks import is_resume_safe\nfrom darkfactory.workflow import ExecutionContext\n\n_log = logging.getLogger(__name__)\n\n\ndef _worktree_target(ctx: ExecutionContext) -> Path:\n    \"\"\"Compute the worktree path for this PRD under ``.worktrees/``.\n\n    Separated out so tests can assert the path without a whole\n    subprocess invocation.\n    \"\"\"\n    return ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}-{ctx.prd.slug}\"\n\n\ndef _branch_exists_local(repo_root: Path, branch: str) -> bool:\n    \"\"\"Return True if ``branch`` exists in the local repo's refs.\"\"\"\n    result = subprocess.run(\n        [\n            \"git\",\n            \"-C\",\n            str(repo_root),\n            \"rev-parse\",\n            \"--verify\",\n            \"--quiet\",\n            f\"refs/heads/{branch}\",\n        ],\n        capture_output=True,\n        text=True,\n    )\n    return result.returncode == 0\n\n\ndef _branch_exists_remote(repo_root: Path, branch: str) -> bool:\n    \"\"\"Return True if ``branch`` exists on origin.\n\n    Best-effort: returns False (and logs a warning) on timeout or any\n    subprocess error so the caller can fall back to the local check.\n    \"\"\"\n    try:\n        result = subprocess.run(\n            [\n                \"git\",\n                \"-C\",\n                str(repo_root),\n                \"ls-remote\",\n                \"--exit-code\",\n                \"origin\",\n                f\"refs/heads/{branch}\",\n            ],\n            capture_output=True,\n            text=True,\n            timeout=10,\n        )\n    except subprocess.TimeoutExpired:\n        _log.warning(\n            \"git ls-remote timed out checking remote branch %r — skipping remote check\",\n            branch,\n        )\n        return False\n    except Exception as exc:\n        _log.warning(\n            \"git ls-remote failed checking remote branch %r (%s) — skipping remote check\",\n            branch,\n            exc,\n        )\n        return False\n    return result.returncode == 0\n\n\n@builtin(\"ensure_worktree\")\ndef ensure_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Create (or resume) a git worktree for this PRD.\n\n    Target path: ``{repo_root}/.worktrees/{prd_id}-{slug}``. Branch:\n    ``prd/{prd_id}-{slug}`` created from ``ctx.base_ref``. If the\n    worktree already exists (previous run resumed), reuses it without\n    re-creating. Sets ``ctx.worktree_path`` and ``ctx.cwd`` on success.\n\n    In live mode, acquires a per-PRD advisory file lock at\n    ``.worktrees/{prd_id}.lock`` before any mutation so two concurrent\n    ``prd run`` invocations for the same PRD fail fast with a clear\n    message instead of racing. The lock is auto-released by the kernel\n    when the process exits; the runner also releases it explicitly at the\n    end of the run (see ``_release_worktree_lock``).\n    \"\"\"\n    worktree_path = _worktree_target(ctx)\n    branch = ctx.branch_name\n\n    if ctx.dry_run:\n        # Dry-run produces no side effects, so no lock needed.\n        ctx.logger.info(\n            \"[dry-run] git worktree add -b %s %s %s\",\n            branch,\n            worktree_path,\n            ctx.base_ref,\n        )\n        ctx.worktree_path = worktree_path\n        ctx.cwd = worktree_path\n        return\n\n    # Acquire the lock BEFORE the resume-check or any mutation.\n    # The lock file lives at .worktrees/PRD-X.lock and is per-PRD.\n    lock_path = ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}.lock\"\n    lock_path.parent.mkdir(parents=True, exist_ok=True)\n\n    lock = FileLock(str(lock_path))\n    try:\n        lock.acquire(timeout=0)  # non-blocking\n    except Timeout:\n        raise RuntimeError(\n            f\"{ctx.prd.id} is already being worked on by another `prd run` \"\n            f\"process (lock held on {lock_path}). If that process died, \"\n            f\"the lock will auto-release when its file handle is reclaimed. \"\n            f\"On a stuck lock, delete {lock_path} manually.\"\n        ) from None\n\n    ctx._worktree_lock = lock\n\n    # ---- existing logic below, now lock-protected ----\n    if worktree_path.exists():\n        status = is_resume_safe(branch, ctx.repo_root)\n        if not status.safe:\n            lock.release()\n            ctx._worktree_lock = None\n            raise RuntimeError(status.reason)\n        ctx.logger.info(\"resuming existing worktree: %s\", worktree_path)\n        ctx.worktree_path = worktree_path\n        ctx.cwd = worktree_path\n        return\n\n    local_exists = _branch_exists_local(ctx.repo_root, branch)\n    remote_exists = _branch_exists_remote(ctx.repo_root, branch)\n    if local_exists or remote_exists:\n        # Release the lock before raising so the error state is clean.\n        lock.release()\n        ctx._worktree_lock = None\n        raise RuntimeError(\n            f\"branch {branch!r} already exists but worktree {worktree_path} is gone. \"\n            f\"Run `prd cleanup {ctx.prd.id}` to release it.\"\n        )\n\n    # git worktree add -b <branch> <path> <base>\n    # Run from the repo root, not from ctx.cwd (which may not be a git dir yet).\n    subprocess.run(\n        [\n            \"git\",\n            \"-C\",\n            str(ctx.repo_root),\n            \"worktree\",\n            \"add\",\n            \"-b\",\n            branch,\n            str(worktree_path),\n            ctx.base_ref,\n        ],\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n    ctx.worktree_path = worktree_path\n    ctx.cwd = worktree_path\n","numLines":175,"startLine":1,"totalLines":175}}}
