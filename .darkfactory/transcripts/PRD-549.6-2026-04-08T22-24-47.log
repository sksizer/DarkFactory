{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DvQ2cmJ9YNR77zw9dnFigs","type":"tool_result","content":"1\t\"\"\"Built-in task primitives — re-export hub.\n2\t\n3\tImports every submodule so @builtin-decorated functions register on\n4\tpackage import. Re-exports the public API for backwards compatibility.\n5\t\n6\tBuilt-ins are the deterministic SDLC operations that every workflow\n7\treferences by name: create a worktree, set a PRD's status, make a\n8\tcommit, push a branch, open a PR. They live here (not in individual\n9\tworkflow modules) because they're shared — every workflow uses the\n10\tsame ``commit`` primitive, not a bespoke one.\n11\t\n12\tWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n13\t\n14\t    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n15\t\n16\tThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\n17\tregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\n18\tplus any formatted kwargs.\n19\t\n20\t**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\n21\tanything destructive. In dry-run, we log what we WOULD do at INFO\n22\tlevel and return. This is what powers ``prd plan`` and the default\n23\t``prd run`` (without ``--execute``).\n24\t\n25\t**Subprocess discipline**: all shell commands use ``subprocess.run``\n26\twith an explicit argv list (never ``shell=True``), capture output,\n27\tand check the return code. Git and gh invocations go through\n28\t:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\n29\thandling and dry-run support.\n30\t\"\"\"\n31\t\n32\tfrom __future__ import annotations\n33\t\n34\timport logging\n35\timport re\n36\timport shutil\n37\timport subprocess\n38\tfrom datetime import datetime\n39\tfrom pathlib import Path\n40\t\n41\tfrom darkfactory import prd as prd_module\n42\tfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\n43\tfrom darkfactory.builtins._shared import (\n44\t    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n45\t    _run,\n46\t    _scan_for_forbidden_attribution,\n47\t)\n48\tfrom darkfactory.workflow import ExecutionContext, Status\n49\t\n50\t_log = logging.getLogger(__name__)\n51\t\n52\t# Import submodules to trigger @builtin registration.\n53\tfrom darkfactory.builtins.ensure_worktree import ensure_worktree  # noqa: E402\n54\t\n55\t__all__ = [\n56\t    \"BUILTINS\",\n57\t    \"BuiltInFunc\",\n58\t    \"builtin\",\n59\t    \"_run\",\n60\t    \"_scan_for_forbidden_attribution\",\n61\t    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n62\t    \"ensure_worktree\",\n63\t    \"set_status\",\n64\t    \"commit\",\n65\t    \"push_branch\",\n66\t    \"summarize_agent_run\",\n67\t    \"commit_transcript\",\n68\t    \"create_pr\",\n69\t    \"lint_attribution\",\n70\t    \"cleanup_worktree\",\n71\t]\n72\t\n73\t\n74\t_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n75\t\n76\t\n77\tdef _extract_acceptance_criteria(body: str) -> list[str]:\n78\t    \"\"\"Pull acceptance criteria lines out of a PRD body.\n79\t\n80\t    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n81\t    Returns a list of the criterion strings (without the checkbox\n82\t    prefix). Used by ``create_pr`` to build the PR body's checklist.\n83\t    \"\"\"\n84\t    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n85\t\n86\t\n87\tdef _pr_body(ctx: ExecutionContext) -> str:\n88\t    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n89\t    prd = ctx.prd\n90\t    lines: list[str] = [\n91\t        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n92\t        \"\",\n93\t    ]\n94\t\n95\t    acs = _extract_acceptance_criteria(prd.body)\n96\t    if acs:\n97\t        lines.append(\"## Acceptance criteria\")\n98\t        lines.append(\"\")\n99\t        for ac in acs:\n100\t            lines.append(f\"- [ ] {ac}\")\n101\t        lines.append(\"\")\n102\t\n103\t    lines.append(\"---\")\n104\t    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n105\t    return \"\\n\".join(lines)\n106\t\n107\t\n108\t# ---------- built-in implementations ----------\n109\t\n110\t\n111\t@builtin(\"set_status\")\n112\tdef set_status(ctx: ExecutionContext, *, to: Status) -> None:\n113\t    \"\"\"Rewrite the PRD's ``status:`` frontmatter field inside the worktree.\n114\t\n115\t    Targets the worktree's copy of the PRD file, never the source repo.\n116\t    The source repo's working tree must remain untouched by ``prd run`` —\n117\t    status transitions live on the PRD's worktree branch and only reach\n118\t    the source repo via PR merge (see PRD-213).\n119\t\n120\t    Uses :func:`darkfactory.prd.set_status_at`, which surgically rewrites\n121\t    only the ``status:`` and ``updated:`` lines so the resulting commit\n122\t    diff is two lines, not the whole frontmatter block.\n123\t    \"\"\"\n124\t    if ctx.dry_run:\n125\t        ctx.logger.info(\n126\t            \"[dry-run] set status of %s: %s -> %s (worktree=%s)\",\n127\t            ctx.prd.id,\n128\t            ctx.prd.status,\n129\t            to,\n130\t            ctx.worktree_path,\n131\t        )\n132\t        return\n133\t\n134\t    if ctx.worktree_path is None:\n135\t        raise RuntimeError(\n136\t            \"set_status requires a worktree; ensure_worktree must run first\"\n137\t        )\n138\t\n139\t    relative = ctx.prd.path.relative_to(ctx.repo_root)\n140\t    target = ctx.worktree_path / relative\n141\t    prd_module.set_status_at(target, to)\n142\t    # Mirror the field updates onto the in-memory PRD so subsequent\n143\t    # builtins see the new status without re-loading from disk.\n144\t    ctx.prd.status = to\n145\t    from datetime import date as _date\n146\t\n147\t    ctx.prd.updated = _date.today().isoformat()\n148\t\n149\t\n150\t@builtin(\"commit\")\n151\tdef commit(ctx: ExecutionContext, *, message: str) -> None:\n152\t    \"\"\"Stage all changes and make a commit inside the worktree.\n153\t\n154\t    ``message`` is format-string expanded against the context so\n155\t    ``\"chore(prd): {prd_id} start work\"`` becomes\n156\t    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n157\t    returns without erroring — workflows can safely commit after each\n158\t    logical step without worrying about whether anything changed.\n159\t    \"\"\"\n160\t    formatted = ctx.format_string(message)\n161\t    _scan_for_forbidden_attribution(\n162\t        formatted, source=f\"commit message for {ctx.prd.id}\"\n163\t    )\n164\t\n165\t    if ctx.dry_run:\n166\t        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n167\t        return\n168\t\n169\t    # Stage everything\n170\t    subprocess.run(\n171\t        [\"git\", \"add\", \"-A\"],\n172\t        cwd=str(ctx.cwd),\n173\t        check=True,\n174\t        capture_output=True,\n175\t        text=True,\n176\t    )\n177\t\n178\t    # Check if there's anything to commit\n179\t    diff_result = subprocess.run(\n180\t        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n181\t        cwd=str(ctx.cwd),\n182\t        check=False,\n183\t        capture_output=True,\n184\t        text=True,\n185\t    )\n186\t    if diff_result.returncode == 0:\n187\t        # No staged changes — skip gracefully.\n188\t        ctx.logger.info(\"commit skipped: no changes to commit\")\n189\t        return\n190\t\n191\t    # Commit\n192\t    subprocess.run(\n193\t        [\"git\", \"commit\", \"-m\", formatted],\n194\t        cwd=str(ctx.cwd),\n195\t        check=True,\n196\t        capture_output=True,\n197\t        text=True,\n198\t    )\n199\t\n200\t\n201\t@builtin(\"push_branch\")\n202\tdef push_branch(ctx: ExecutionContext) -> None:\n203\t    \"\"\"Push the current branch to origin with upstream tracking.\n204\t\n205\t    Runs ``git push -u origin {branch}`` inside the worktree. Required\n206\t    before :func:`create_pr` because ``gh pr create --base`` needs the\n207\t    remote to exist.\n208\t    \"\"\"\n209\t    cmd = [\"git\", \"push\", \"-u\", \"origin\", ctx.branch_name]\n210\t\n211\t    if ctx.dry_run:\n212\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n213\t        return\n214\t\n215\t    subprocess.run(\n216\t        cmd,\n217\t        cwd=str(ctx.cwd),\n218\t        check=True,\n219\t        capture_output=True,\n220\t        text=True,\n221\t    )\n222\t\n223\t\n224\tdef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n225\t    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n226\t    if not tool_counts:\n227\t        return \"none\"\n228\t    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n229\t\n230\t\n231\tdef _format_invocations(ctx: ExecutionContext) -> str:\n232\t    \"\"\"Format agent invocation count from context.\"\"\"\n233\t    count = ctx.invoke_count\n234\t    if count == 0:\n235\t        return \"0\"\n236\t    if count == 1:\n237\t        return \"1\"\n238\t    return str(count)\n239\t\n240\t\n241\t@builtin(\"summarize_agent_run\")\n242\tdef summarize_agent_run(ctx: ExecutionContext) -> None:\n243\t    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n244\t    result = ctx.last_invoke_result\n245\t    if result is None:\n246\t        return\n247\t\n248\t    lines = [\n249\t        \"## Harness execution summary\",\n250\t        \"\",\n251\t        f\"- **Workflow:** {ctx.workflow.name}\",\n252\t        f\"- **Model:** {ctx.model or 'unknown'}\",\n253\t        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n254\t        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n255\t        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n256\t    ]\n257\t    ctx.run_summary = \"\\n\".join(lines)\n258\t\n259\t\n260\t@builtin(\"commit_transcript\")\n261\tdef commit_transcript(ctx: ExecutionContext) -> None:\n262\t    \"\"\"Copy agent transcript into the worktree and stage it.\n263\t\n264\t    Source: ``<repo_root>/.harness-transcripts/{prd_id}.log`` written by the\n265\t    runner after each agent invocation (outside any worktree — see\n266\t    ``runner._run_agent``). Destination inside the worktree:\n267\t    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n268\t\n269\t    The runner writes transcripts *outside* every worktree so ``git add -A``\n270\t    can never accidentally sweep them. This builtin is the one place that\n271\t    opts the transcript *into* the worktree — workflows that want the\n272\t    transcript committed alongside the PRD work must include this builtin\n273\t    explicitly. Workflows that omit it leave the transcript at the repo-root\n274\t    path where it survives as a local-only diagnostic.\n275\t\n276\t    Timestamps use the wall-clock at the time this builtin runs, which is\n277\t    unique enough for sequential runs. If no transcript exists (dry-run,\n278\t    or the runner didn't produce one), this is a no-op.\n279\t    \"\"\"\n280\t    src = ctx.repo_root / \".harness-transcripts\" / f\"{ctx.prd.id}.log\"\n281\t    if not src.exists():\n282\t        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n283\t        return\n284\t\n285\t    if ctx.dry_run:\n286\t        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n287\t        dest = (\n288\t            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n289\t        )\n290\t        ctx.logger.info(\"[dry-run] copy %s -> %s && git add\", src, dest)\n291\t        return\n292\t\n293\t    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n294\t    transcript_dir.mkdir(parents=True, exist_ok=True)\n295\t\n296\t    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n297\t    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n298\t\n299\t    # Copy (not move) so the repo-root transcript persists as a local-only\n300\t    # diagnostic even after this builtin runs. If the same PRD is re-run,\n301\t    # the runner overwrites the source file anyway.\n302\t    shutil.copy2(str(src), str(dest))\n303\t\n304\t    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n305\t    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n306\t\n307\t\n308\t@builtin(\"create_pr\")\n309\tdef create_pr(ctx: ExecutionContext) -> None:\n310\t    \"\"\"Open a pull request via ``gh pr create``.\n311\t\n312\t    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n313\t    acceptance criteria plus a link to the PRD file. Base branch:\n314\t    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n315\t    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n316\t    relative to ``ctx.repo_root``.\n317\t    \"\"\"\n318\t    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n319\t    body = _pr_body(ctx)\n320\t    if ctx.run_summary:\n321\t        body += \"\\n\\n\" + ctx.run_summary\n322\t    _scan_for_forbidden_attribution(title, source=f\"PR title for {ctx.prd.id}\")\n323\t    _scan_for_forbidden_attribution(body, source=f\"PR body for {ctx.prd.id}\")\n324\t\n325\t    if ctx.dry_run:\n326\t        ctx.logger.info(\n327\t            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n328\t            ctx.base_ref,\n329\t            title,\n330\t        )\n331\t        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n332\t        return\n333\t\n334\t    # Write the body to a temp file — passing long bodies via --body\n335\t    # can hit argv limits on some systems.\n336\t    import tempfile\n337\t\n338\t    with tempfile.NamedTemporaryFile(\n339\t        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n340\t    ) as body_file:\n341\t        body_file.write(body)\n342\t        body_path = body_file.name\n343\t\n344\t    try:\n345\t        result = subprocess.run(\n346\t            [\n347\t                \"gh\",\n348\t                \"pr\",\n349\t                \"create\",\n350\t                \"--base\",\n351\t                ctx.base_ref,\n352\t                \"--title\",\n353\t                title,\n354\t                \"--body-file\",\n355\t                body_path,\n356\t            ],\n357\t            cwd=str(ctx.cwd),\n358\t            check=True,\n359\t            capture_output=True,\n360\t            text=True,\n361\t        )\n362\t    finally:\n363\t        Path(body_path).unlink(missing_ok=True)\n364\t\n365\t    # gh prints the PR URL to stdout on success.\n366\t    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n367\t    ctx.pr_url = url_line or None\n368\t\n369\t\n370\t@builtin(\"lint_attribution\")\n371\tdef lint_attribution(ctx: ExecutionContext) -> None:\n372\t    \"\"\"Fail if any commit on the branch or the run summary credits Claude/Anthropic.\n373\t\n374\t    Scans:\n375\t\n376\t    - Every commit message in ``{base_ref}..HEAD`` on the current branch\n377\t    - ``ctx.run_summary`` (which feeds the PR body)\n378\t\n379\t    Intended to run after the agent + verification phases and before\n380\t    ``push_branch`` / ``create_pr``, so violations abort the workflow\n381\t    before anything lands on the remote or in a PR. Dry-run is a no-op\n382\t    because there are no real commits to scan.\n383\t    \"\"\"\n384\t    if ctx.dry_run:\n385\t        ctx.logger.info(\"[dry-run] lint_attribution: skipped\")\n386\t        return\n387\t\n388\t    _scan_for_forbidden_attribution(\n389\t        ctx.run_summary or \"\", source=f\"run summary for {ctx.prd.id}\"\n390\t    )\n391\t\n392\t    result = subprocess.run(\n393\t        [\"git\", \"log\", f\"{ctx.base_ref}..HEAD\", \"--format=%H%x00%B%x1e\"],\n394\t        cwd=str(ctx.cwd),\n395\t        check=True,\n396\t        capture_output=True,\n397\t        text=True,\n398\t    )\n399\t    # Record separator \\x1e between commits; field separator \\x00 between\n400\t    # sha and body. Keeps us robust against newlines in commit messages.\n401\t    for entry in result.stdout.split(\"\\x1e\"):\n402\t        entry = entry.strip()\n403\t        if not entry:\n404\t            continue\n405\t        sha, _, body = entry.partition(\"\\x00\")\n406\t        _scan_for_forbidden_attribution(\n407\t            body, source=f\"commit {sha[:12]} on {ctx.branch_name}\"\n408\t        )\n409\t\n410\t    ctx.logger.info(\"lint_attribution: clean\")\n411\t\n412\t\n413\t@builtin(\"cleanup_worktree\")\n414\tdef cleanup_worktree(ctx: ExecutionContext) -> None:\n415\t    \"\"\"Remove the worktree after a successful run.\n416\t\n417\t    Idempotent — if the worktree is already gone, logs and returns.\n418\t    Normally skipped during chain execution so downstream worktrees\n419\t    can base on this branch; called explicitly via ``prd cleanup``\n420\t    after the whole chain is done.\n421\t    \"\"\"\n422\t    if ctx.worktree_path is None:\n423\t        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n424\t        return\n425\t\n426\t    if not ctx.worktree_path.exists():\n427\t        ctx.logger.info(\n428\t            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n429\t        )\n430\t        return\n431\t\n432\t    cmd = [\n433\t        \"git\",\n434\t        \"-C\",\n435\t        str(ctx.repo_root),\n436\t        \"worktree\",\n437\t        \"remove\",\n438\t        str(ctx.worktree_path),\n439\t    ]\n440\t\n441\t    if ctx.dry_run:\n442\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n443\t        return\n444\t\n445\t    subprocess.run(cmd, check=True, capture_output=True, text=True)\n446\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"1f534906-900d-426c-84f5-c086d3be4bd4","uuid":"3e591c50-a8e4-45f4-9ff2-c248d000e675","timestamp":"2026-04-09T03:20:31.175Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/src/darkfactory/builtins/__init__.py","content":"\"\"\"Built-in task primitives — re-export hub.\n\nImports every submodule so @builtin-decorated functions register on\npackage import. Re-exports the public API for backwards compatibility.\n\nBuilt-ins are the deterministic SDLC operations that every workflow\nreferences by name: create a worktree, set a PRD's status, make a\ncommit, push a branch, open a PR. They live here (not in individual\nworkflow modules) because they're shared — every workflow uses the\nsame ``commit`` primitive, not a bespoke one.\n\nWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n\n    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n\nThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\nregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\nplus any formatted kwargs.\n\n**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\nanything destructive. In dry-run, we log what we WOULD do at INFO\nlevel and return. This is what powers ``prd plan`` and the default\n``prd run`` (without ``--execute``).\n\n**Subprocess discipline**: all shell commands use ``subprocess.run``\nwith an explicit argv list (never ``shell=True``), capture output,\nand check the return code. Git and gh invocations go through\n:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\nhandling and dry-run support.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport re\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom darkfactory import prd as prd_module\nfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\nfrom darkfactory.builtins._shared import (\n    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n    _run,\n    _scan_for_forbidden_attribution,\n)\nfrom darkfactory.workflow import ExecutionContext, Status\n\n_log = logging.getLogger(__name__)\n\n# Import submodules to trigger @builtin registration.\nfrom darkfactory.builtins.ensure_worktree import ensure_worktree  # noqa: E402\n\n__all__ = [\n    \"BUILTINS\",\n    \"BuiltInFunc\",\n    \"builtin\",\n    \"_run\",\n    \"_scan_for_forbidden_attribution\",\n    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n    \"ensure_worktree\",\n    \"set_status\",\n    \"commit\",\n    \"push_branch\",\n    \"summarize_agent_run\",\n    \"commit_transcript\",\n    \"create_pr\",\n    \"lint_attribution\",\n    \"cleanup_worktree\",\n]\n\n\n_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n\n\ndef _extract_acceptance_criteria(body: str) -> list[str]:\n    \"\"\"Pull acceptance criteria lines out of a PRD body.\n\n    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n    Returns a list of the criterion strings (without the checkbox\n    prefix). Used by ``create_pr`` to build the PR body's checklist.\n    \"\"\"\n    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n\n\ndef _pr_body(ctx: ExecutionContext) -> str:\n    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n    prd = ctx.prd\n    lines: list[str] = [\n        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n        \"\",\n    ]\n\n    acs = _extract_acceptance_criteria(prd.body)\n    if acs:\n        lines.append(\"## Acceptance criteria\")\n        lines.append(\"\")\n        for ac in acs:\n            lines.append(f\"- [ ] {ac}\")\n        lines.append(\"\")\n\n    lines.append(\"---\")\n    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n    return \"\\n\".join(lines)\n\n\n# ---------- built-in implementations ----------\n\n\n@builtin(\"set_status\")\ndef set_status(ctx: ExecutionContext, *, to: Status) -> None:\n    \"\"\"Rewrite the PRD's ``status:`` frontmatter field inside the worktree.\n\n    Targets the worktree's copy of the PRD file, never the source repo.\n    The source repo's working tree must remain untouched by ``prd run`` —\n    status transitions live on the PRD's worktree branch and only reach\n    the source repo via PR merge (see PRD-213).\n\n    Uses :func:`darkfactory.prd.set_status_at`, which surgically rewrites\n    only the ``status:`` and ``updated:`` lines so the resulting commit\n    diff is two lines, not the whole frontmatter block.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\n            \"[dry-run] set status of %s: %s -> %s (worktree=%s)\",\n            ctx.prd.id,\n            ctx.prd.status,\n            to,\n            ctx.worktree_path,\n        )\n        return\n\n    if ctx.worktree_path is None:\n        raise RuntimeError(\n            \"set_status requires a worktree; ensure_worktree must run first\"\n        )\n\n    relative = ctx.prd.path.relative_to(ctx.repo_root)\n    target = ctx.worktree_path / relative\n    prd_module.set_status_at(target, to)\n    # Mirror the field updates onto the in-memory PRD so subsequent\n    # builtins see the new status without re-loading from disk.\n    ctx.prd.status = to\n    from datetime import date as _date\n\n    ctx.prd.updated = _date.today().isoformat()\n\n\n@builtin(\"commit\")\ndef commit(ctx: ExecutionContext, *, message: str) -> None:\n    \"\"\"Stage all changes and make a commit inside the worktree.\n\n    ``message`` is format-string expanded against the context so\n    ``\"chore(prd): {prd_id} start work\"`` becomes\n    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n    returns without erroring — workflows can safely commit after each\n    logical step without worrying about whether anything changed.\n    \"\"\"\n    formatted = ctx.format_string(message)\n    _scan_for_forbidden_attribution(\n        formatted, source=f\"commit message for {ctx.prd.id}\"\n    )\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n        return\n\n    # Stage everything\n    subprocess.run(\n        [\"git\", \"add\", \"-A\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n    # Check if there's anything to commit\n    diff_result = subprocess.run(\n        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n        cwd=str(ctx.cwd),\n        check=False,\n        capture_output=True,\n        text=True,\n    )\n    if diff_result.returncode == 0:\n        # No staged changes — skip gracefully.\n        ctx.logger.info(\"commit skipped: no changes to commit\")\n        return\n\n    # Commit\n    subprocess.run(\n        [\"git\", \"commit\", \"-m\", formatted],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n\n@builtin(\"push_branch\")\ndef push_branch(ctx: ExecutionContext) -> None:\n    \"\"\"Push the current branch to origin with upstream tracking.\n\n    Runs ``git push -u origin {branch}`` inside the worktree. Required\n    before :func:`create_pr` because ``gh pr create --base`` needs the\n    remote to exist.\n    \"\"\"\n    cmd = [\"git\", \"push\", \"-u\", \"origin\", ctx.branch_name]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(\n        cmd,\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n\ndef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n    if not tool_counts:\n        return \"none\"\n    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n\n\ndef _format_invocations(ctx: ExecutionContext) -> str:\n    \"\"\"Format agent invocation count from context.\"\"\"\n    count = ctx.invoke_count\n    if count == 0:\n        return \"0\"\n    if count == 1:\n        return \"1\"\n    return str(count)\n\n\n@builtin(\"summarize_agent_run\")\ndef summarize_agent_run(ctx: ExecutionContext) -> None:\n    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n    result = ctx.last_invoke_result\n    if result is None:\n        return\n\n    lines = [\n        \"## Harness execution summary\",\n        \"\",\n        f\"- **Workflow:** {ctx.workflow.name}\",\n        f\"- **Model:** {ctx.model or 'unknown'}\",\n        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n    ]\n    ctx.run_summary = \"\\n\".join(lines)\n\n\n@builtin(\"commit_transcript\")\ndef commit_transcript(ctx: ExecutionContext) -> None:\n    \"\"\"Copy agent transcript into the worktree and stage it.\n\n    Source: ``<repo_root>/.harness-transcripts/{prd_id}.log`` written by the\n    runner after each agent invocation (outside any worktree — see\n    ``runner._run_agent``). Destination inside the worktree:\n    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n\n    The runner writes transcripts *outside* every worktree so ``git add -A``\n    can never accidentally sweep them. This builtin is the one place that\n    opts the transcript *into* the worktree — workflows that want the\n    transcript committed alongside the PRD work must include this builtin\n    explicitly. Workflows that omit it leave the transcript at the repo-root\n    path where it survives as a local-only diagnostic.\n\n    Timestamps use the wall-clock at the time this builtin runs, which is\n    unique enough for sequential runs. If no transcript exists (dry-run,\n    or the runner didn't produce one), this is a no-op.\n    \"\"\"\n    src = ctx.repo_root / \".harness-transcripts\" / f\"{ctx.prd.id}.log\"\n    if not src.exists():\n        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n        return\n\n    if ctx.dry_run:\n        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n        dest = (\n            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n        )\n        ctx.logger.info(\"[dry-run] copy %s -> %s && git add\", src, dest)\n        return\n\n    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n    transcript_dir.mkdir(parents=True, exist_ok=True)\n\n    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n\n    # Copy (not move) so the repo-root transcript persists as a local-only\n    # diagnostic even after this builtin runs. If the same PRD is re-run,\n    # the runner overwrites the source file anyway.\n    shutil.copy2(str(src), str(dest))\n\n    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n\n\n@builtin(\"create_pr\")\ndef create_pr(ctx: ExecutionContext) -> None:\n    \"\"\"Open a pull request via ``gh pr create``.\n\n    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n    acceptance criteria plus a link to the PRD file. Base branch:\n    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n    relative to ``ctx.repo_root``.\n    \"\"\"\n    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n    body = _pr_body(ctx)\n    if ctx.run_summary:\n        body += \"\\n\\n\" + ctx.run_summary\n    _scan_for_forbidden_attribution(title, source=f\"PR title for {ctx.prd.id}\")\n    _scan_for_forbidden_attribution(body, source=f\"PR body for {ctx.prd.id}\")\n\n    if ctx.dry_run:\n        ctx.logger.info(\n            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n            ctx.base_ref,\n            title,\n        )\n        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n        return\n\n    # Write the body to a temp file — passing long bodies via --body\n    # can hit argv limits on some systems.\n    import tempfile\n\n    with tempfile.NamedTemporaryFile(\n        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n    ) as body_file:\n        body_file.write(body)\n        body_path = body_file.name\n\n    try:\n        result = subprocess.run(\n            [\n                \"gh\",\n                \"pr\",\n                \"create\",\n                \"--base\",\n                ctx.base_ref,\n                \"--title\",\n                title,\n                \"--body-file\",\n                body_path,\n            ],\n            cwd=str(ctx.cwd),\n            check=True,\n            capture_output=True,\n            text=True,\n        )\n    finally:\n        Path(body_path).unlink(missing_ok=True)\n\n    # gh prints the PR URL to stdout on success.\n    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n    ctx.pr_url = url_line or None\n\n\n@builtin(\"lint_attribution\")\ndef lint_attribution(ctx: ExecutionContext) -> None:\n    \"\"\"Fail if any commit on the branch or the run summary credits Claude/Anthropic.\n\n    Scans:\n\n    - Every commit message in ``{base_ref}..HEAD`` on the current branch\n    - ``ctx.run_summary`` (which feeds the PR body)\n\n    Intended to run after the agent + verification phases and before\n    ``push_branch`` / ``create_pr``, so violations abort the workflow\n    before anything lands on the remote or in a PR. Dry-run is a no-op\n    because there are no real commits to scan.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] lint_attribution: skipped\")\n        return\n\n    _scan_for_forbidden_attribution(\n        ctx.run_summary or \"\", source=f\"run summary for {ctx.prd.id}\"\n    )\n\n    result = subprocess.run(\n        [\"git\", \"log\", f\"{ctx.base_ref}..HEAD\", \"--format=%H%x00%B%x1e\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n    # Record separator \\x1e between commits; field separator \\x00 between\n    # sha and body. Keeps us robust against newlines in commit messages.\n    for entry in result.stdout.split(\"\\x1e\"):\n        entry = entry.strip()\n        if not entry:\n            continue\n        sha, _, body = entry.partition(\"\\x00\")\n        _scan_for_forbidden_attribution(\n            body, source=f\"commit {sha[:12]} on {ctx.branch_name}\"\n        )\n\n    ctx.logger.info(\"lint_attribution: clean\")\n\n\n@builtin(\"cleanup_worktree\")\ndef cleanup_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Remove the worktree after a successful run.\n\n    Idempotent — if the worktree is already gone, logs and returns.\n    Normally skipped during chain execution so downstream worktrees\n    can base on this branch; called explicitly via ``prd cleanup``\n    after the whole chain is done.\n    \"\"\"\n    if ctx.worktree_path is None:\n        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n        return\n\n    if not ctx.worktree_path.exists():\n        ctx.logger.info(\n            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n        )\n        return\n\n    cmd = [\n        \"git\",\n        \"-C\",\n        str(ctx.repo_root),\n        \"worktree\",\n        \"remove\",\n        str(ctx.worktree_path),\n    ]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(cmd, check=True, capture_output=True, text=True)\n","numLines":446,"startLine":1,"totalLines":446}}}
