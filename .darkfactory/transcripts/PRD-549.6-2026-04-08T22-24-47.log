{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017pz89KSiue3XhLM9YC34Hq","type":"tool_result","content":"1\t\"\"\"Unit tests for ensure_worktree builtin.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\tfrom pathlib import Path\n6\tfrom unittest.mock import MagicMock, patch\n7\t\n8\timport pytest\n9\t\n10\tfrom darkfactory.builtins.ensure_worktree import (\n11\t    _branch_exists_local,\n12\t    _branch_exists_remote,\n13\t    _worktree_target,\n14\t    ensure_worktree,\n15\t)\n16\t\n17\t\n18\t# ---------- helpers ----------\n19\t\n20\t\n21\tdef _make_ctx(tmp_path: Path, *, dry_run: bool = False) -> MagicMock:\n22\t    \"\"\"Build a minimal ExecutionContext mock for ensure_worktree tests.\"\"\"\n23\t    ctx = MagicMock()\n24\t    ctx.dry_run = dry_run\n25\t    ctx.repo_root = tmp_path\n26\t    ctx.prd.id = \"PRD-001\"\n27\t    ctx.prd.slug = \"test-thing\"\n28\t    ctx.branch_name = \"prd/PRD-001-test-thing\"\n29\t    ctx.base_ref = \"main\"\n30\t    ctx.worktree_path = None\n31\t    ctx.cwd = tmp_path\n32\t    ctx._worktree_lock = None\n33\t    return ctx\n34\t\n35\t\n36\t# ---------- _worktree_target ----------\n37\t\n38\t\n39\tdef test_worktree_target_builds_path(tmp_path: Path) -> None:\n40\t    ctx = _make_ctx(tmp_path)\n41\t    result = _worktree_target(ctx)\n42\t    assert result == tmp_path / \".worktrees\" / \"PRD-001-test-thing\"\n43\t\n44\t\n45\t# ---------- dry-run path ----------\n46\t\n47\t\n48\tdef test_dry_run_sets_worktree_path_and_cwd(tmp_path: Path) -> None:\n49\t    ctx = _make_ctx(tmp_path, dry_run=True)\n50\t    ensure_worktree(ctx)\n51\t    expected = tmp_path / \".worktrees\" / \"PRD-001-test-thing\"\n52\t    assert ctx.worktree_path == expected\n53\t    assert ctx.cwd == expected\n54\t\n55\t\n56\tdef test_dry_run_no_subprocess_calls(tmp_path: Path) -> None:\n57\t    ctx = _make_ctx(tmp_path, dry_run=True)\n58\t    with patch(\"darkfactory.builtins.ensure_worktree.subprocess.run\") as mock_run:\n59\t        ensure_worktree(ctx)\n60\t    mock_run.assert_not_called()\n61\t\n62\t\n63\tdef test_dry_run_logs_command(tmp_path: Path) -> None:\n64\t    ctx = _make_ctx(tmp_path, dry_run=True)\n65\t    ensure_worktree(ctx)\n66\t    ctx.logger.info.assert_called()\n67\t\n68\t\n69\t# ---------- resume existing worktree ----------\n70\t\n71\t\n72\tdef test_resume_existing_worktree(tmp_path: Path) -> None:\n73\t    ctx = _make_ctx(tmp_path)\n74\t    worktree_path = tmp_path / \".worktrees\" / \"PRD-001-test-thing\"\n75\t    worktree_path.mkdir(parents=True)\n76\t\n77\t    resume_status = MagicMock()\n78\t    resume_status.safe = True\n79\t\n80\t    with (\n81\t        patch(\"darkfactory.builtins.ensure_worktree.FileLock\") as mock_lock_cls,\n82\t        patch(\n83\t            \"darkfactory.builtins.ensure_worktree.is_resume_safe\",\n84\t            return_value=resume_status,\n85\t        ),\n86\t    ):\n87\t        mock_lock = MagicMock()\n88\t        mock_lock_cls.return_value = mock_lock\n89\t        ensure_worktree(ctx)\n90\t\n91\t    assert ctx.worktree_path == worktree_path\n92\t    assert ctx.cwd == worktree_path\n93\t\n94\t\n95\tdef test_resume_unsafe_raises(tmp_path: Path) -> None:\n96\t    ctx = _make_ctx(tmp_path)\n97\t    worktree_path = tmp_path / \".worktrees\" / \"PRD-001-test-thing\"\n98\t    worktree_path.mkdir(parents=True)\n99\t\n100\t    resume_status = MagicMock()\n101\t    resume_status.safe = False\n102\t    resume_status.reason = \"branch diverged from main\"\n103\t\n104\t    with (\n105\t        patch(\"darkfactory.builtins.ensure_worktree.FileLock\") as mock_lock_cls,\n106\t        patch(\n107\t            \"darkfactory.builtins.ensure_worktree.is_resume_safe\",\n108\t            return_value=resume_status,\n109\t        ),\n110\t    ):\n111\t        mock_lock = MagicMock()\n112\t        mock_lock_cls.return_value = mock_lock\n113\t        with pytest.raises(RuntimeError, match=\"branch diverged from main\"):\n114\t            ensure_worktree(ctx)\n115\t\n116\t    mock_lock.release.assert_called_once()\n117\t\n118\t\n119\t# ---------- branch-exists error ----------\n120\t\n121\t\n122\tdef test_branch_exists_local_raises(tmp_path: Path) -> None:\n123\t    ctx = _make_ctx(tmp_path)\n124\t\n125\t    with (\n126\t        patch(\"darkfactory.builtins.ensure_worktree.FileLock\") as mock_lock_cls,\n127\t        patch(\n128\t            \"darkfactory.builtins.ensure_worktree._branch_exists_local\",\n129\t            return_value=True,\n130\t        ),\n131\t        patch(\n132\t            \"darkfactory.builtins.ensure_worktree._branch_exists_remote\",\n133\t            return_value=False,\n134\t        ),\n135\t    ):\n136\t        mock_lock = MagicMock()\n137\t        mock_lock_cls.return_value = mock_lock\n138\t        with pytest.raises(RuntimeError, match=\"already exists but worktree\"):\n139\t            ensure_worktree(ctx)\n140\t\n141\t    mock_lock.release.assert_called_once()\n142\t\n143\t\n144\tdef test_branch_exists_remote_raises(tmp_path: Path) -> None:\n145\t    ctx = _make_ctx(tmp_path)\n146\t\n147\t    with (\n148\t        patch(\"darkfactory.builtins.ensure_worktree.FileLock\") as mock_lock_cls,\n149\t        patch(\n150\t            \"darkfactory.builtins.ensure_worktree._branch_exists_local\",\n151\t            return_value=False,\n152\t        ),\n153\t        patch(\n154\t            \"darkfactory.builtins.ensure_worktree._branch_exists_remote\",\n155\t            return_value=True,\n156\t        ),\n157\t    ):\n158\t        mock_lock = MagicMock()\n159\t        mock_lock_cls.return_value = mock_lock\n160\t        with pytest.raises(RuntimeError, match=\"already exists but worktree\"):\n161\t            ensure_worktree(ctx)\n162\t\n163\t    mock_lock.release.assert_called_once()\n164\t\n165\t\n166\t# ---------- successful creation ----------\n167\t\n168\t\n169\tdef test_successful_creation_calls_git_worktree_add(tmp_path: Path) -> None:\n170\t    ctx = _make_ctx(tmp_path)\n171\t\n172\t    with (\n173