{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C4a9TD8EiCA1FEzmaTuCFq","type":"tool_result","content":"1\t\"\"\"Cascade resolver for darkfactory configuration.\n2\t\n3\tMerges settings across all layers:\n4\t  built-in defaults < user config.toml < project config.toml < env vars < CLI flags\n5\t\n6\tUsage::\n7\t\n8\t    from darkfactory.config import resolve_config\n9\t\n10\t    config = resolve_config(project_dir=Path(\".darkfactory\"))\n11\t    print(config.style.theme)\n12\t\"\"\"\n13\t\n14\tfrom __future__ import annotations\n15\t\n16\timport os\n17\timport tomllib\n18\tfrom dataclasses import dataclass, field\n19\tfrom pathlib import Path\n20\t\n21\tfrom darkfactory.paths import user_config_file\n22\t\n23\t\n24\t@dataclass\n25\tclass ModelConfig:\n26\t    \"\"\"Model defaults per capability tier.\"\"\"\n27\t\n28\t    trivial: str = \"haiku\"\n29\t    simple: str = \"sonnet\"\n30\t    moderate: str = \"sonnet\"\n31\t    complex: str = \"opus\"\n32\t\n33\t\n34\t@dataclass\n35\tclass StyleConfig:\n36\t    \"\"\"Style settings: theme, icon set, color suppression.\"\"\"\n37\t\n38\t    theme: str = \"dark\"\n39\t    icon_set: str = \"ascii\"\n40\t    no_color: bool = False\n41\t\n42\t\n43\t@dataclass\n44\tclass Config:\n45\t    \"\"\"Fully resolved configuration object.\"\"\"\n46\t\n47\t    model: ModelConfig = field(default_factory=ModelConfig)\n48\t    style: StyleConfig = field(default_factory=StyleConfig)\n49\t    # Extensible: add TimeoutsConfig, etc.\n50\t\n51\t\n52\tdef _load_toml(path: Path) -> dict:\n53\t    \"\"\"Load a TOML file, returning {} if absent.\"\"\"\n54\t    if not path.is_file():\n55\t        return {}\n56\t    with open(path, \"rb\") as f:\n57\t        return tomllib.load(f)\n58\t\n59\t\n60\tdef _merge_section(target: object, section_data: dict) -> None:\n61\t    \"\"\"Merge a dict into a dataclass, key-by-key (unknown keys are ignored).\"\"\"\n62\t    for key, value in section_data.items():\n63\t        if hasattr(target, key):\n64\t            setattr(target, key, value)\n65\t\n66\t\n67\tdef _apply_env_vars(config: Config, env: dict[str, str]) -> None:\n68\t    \"\"\"Apply DARKFACTORY_<SECTION>_<KEY> env vars to config.\n69\t\n70\t    Examples:\n71\t        DARKFACTORY_MODEL_TRIVIAL  → config.model.trivial\n72\t        DARKFACTORY_STYLE_THEME    → config.style.theme\n73\t        DARKFACTORY_STYLE_NO_COLOR → config.style.no_color (truthy strings)\n74\t    \"\"\"\n75\t    prefix = \"DARKFACTORY_\"\n76\t    for key, value in env.items():\n77\t        if not key.startswith(prefix):\n78\t            continue\n79\t        rest = key[len(prefix) :]\n80\t        parts = rest.split(\"_\", 1)\n81\t        if len(parts) != 2:\n82\t            continue\n83\t        section_name, field_name = parts[0].lower(), parts[1].lower()\n84\t        section = getattr(config, section_name, None)\n85\t        if section is None or not hasattr(section, field_name):\n86\t            continue\n87\t        current = getattr(section, field_name)\n88\t        if isinstance(current, bool):\n89\t            setattr(section, field_name, value.lower() in (\"1\", \"true\", \"yes\"))\n90\t        else:\n91\t            setattr(section, field_name, value)\n92\t\n93\t\n94\tdef resolve_config(\n95\t    project_dir: Path | None = None,\n96\t    env: dict[str, str] | None = None,\n97\t    cli_overrides: dict | None = None,\n98\t) -> Config:\n99\t    \"\"\"Resolve config through the full cascade.\n100\t\n101\t    Precedence (highest wins):\n102\t    1. CLI flags (*cli_overrides*)\n103\t    2. Environment variables (``DARKFACTORY_<SECTION>_<KEY>``)\n104\t    3. Project config — ``<project_dir>/config.toml``\n105\t    4. User config — ``~/.config/darkfactory/config.toml``\n106\t    5. Built-in defaults\n107\t\n108\t    Args:\n109\t        project_dir: Path to the ``.darkfactory/`` directory.\n110\t        env: Environment dict to use (defaults to ``os.environ``).\n111\t        cli_overrides: Nested dict of overrides, e.g.\n112\t            ``{\"style\": {\"theme\": \"light\"}}``.\n113\t    \"\"\"\n114\t    config = Config()\n115\t\n116\t    # Layer 1: user config\n117\t    user_file = user_config_file()\n118\t    if user_file:\n119\t        user_data = _load_toml(user_file)\n120\t        _merge_section(config.model, user_data.get(\"model\", {}))\n121\t        _merge_section(config.style, user_data.get(\"style\", {}))\n122\t\n123\t    # Layer 2: project config\n124\t    if project_dir is not None:\n125\t        proj_file = project_dir / \"config.toml\"\n126\t        proj_data = _load_toml(proj_file)\n127\t        _merge_section(config.model, proj_data.get(\"model\", {}))\n128\t        _merge_section(config.style, proj_data.get(\"style\", {}))\n129\t\n130\t    # Layer 3: env vars\n131\t    env_dict: dict[str, str] = env if env is not None else dict(os.environ)\n132\t    _apply_env_vars(config, env_dict)\n133\t\n134\t    # Layer 4: CLI flags\n135\t    if cli_overrides:\n136\t        for section_name, section_data in cli_overrides.items():\n137\t            if isinstance(section_data, dict):\n138\t                section = getattr(config, section_name, None)\n139\t                if section is not None:\n140\t                    _merge_section(section, section_data)\n141\t\n142\t    return config\n143\t"}]},"parent_tool_use_id":null,"session_id":"4f768b51-6d3f-4c28-b7e2-bf19636d19a7","uuid":"08b68dd8-1e20-4df8-bb00-cd698ce177b1","timestamp":"2026-04-09T04:29:08.490Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-222.6-cascade-resolver-config/src/darkfactory/config.py","content":"\"\"\"Cascade resolver for darkfactory configuration.\n\nMerges settings across all layers:\n  built-in defaults < user config.toml < project config.toml < env vars < CLI flags\n\nUsage::\n\n    from darkfactory.config import resolve_config\n\n    config = resolve_config(project_dir=Path(\".darkfactory\"))\n    print(config.style.theme)\n\"\"\"\n\nfrom __future__ import annotations\n\nimport os\nimport tomllib\nfrom dataclasses import dataclass, field\nfrom pathlib import Path\n\nfrom darkfactory.paths import user_config_file\n\n\n@dataclass\nclass ModelConfig:\n    \"\"\"Model defaults per capability tier.\"\"\"\n\n    trivial: str = \"haiku\"\n    simple: str = \"sonnet\"\n    moderate: str = \"sonnet\"\n    complex: str = \"opus\"\n\n\n@dataclass\nclass StyleConfig:\n    \"\"\"Style settings: theme, icon set, color suppression.\"\"\"\n\n    theme: str = \"dark\"\n    icon_set: str = \"ascii\"\n    no_color: bool = False\n\n\n@dataclass\nclass Config:\n    \"\"\"Fully resolved configuration object.\"\"\"\n\n    model: ModelConfig = field(default_factory=ModelConfig)\n    style: StyleConfig = field(default_factory=StyleConfig)\n    # Extensible: add TimeoutsConfig, etc.\n\n\ndef _load_toml(path: Path) -> dict:\n    \"\"\"Load a TOML file, returning {} if absent.\"\"\"\n    if not path.is_file():\n        return {}\n    with open(path, \"rb\") as f:\n        return tomllib.load(f)\n\n\ndef _merge_section(target: object, section_data: dict) -> None:\n    \"\"\"Merge a dict into a dataclass, key-by-key (unknown keys are ignored).\"\"\"\n    for key, value in section_data.items():\n        if hasattr(target, key):\n            setattr(target, key, value)\n\n\ndef _apply_env_vars(config: Config, env: dict[str, str]) -> None:\n    \"\"\"Apply DARKFACTORY_<SECTION>_<KEY> env vars to config.\n\n    Examples:\n        DARKFACTORY_MODEL_TRIVIAL  → config.model.trivial\n        DARKFACTORY_STYLE_THEME    → config.style.theme\n        DARKFACTORY_STYLE_NO_COLOR → config.style.no_color (truthy strings)\n    \"\"\"\n    prefix = \"DARKFACTORY_\"\n    for key, value in env.items():\n        if not key.startswith(prefix):\n            continue\n        rest = key[len(prefix) :]\n        parts = rest.split(\"_\", 1)\n        if len(parts) != 2:\n            continue\n        section_name, field_name = parts[0].lower(), parts[1].lower()\n        section = getattr(config, section_name, None)\n        if section is None or not hasattr(section, field_name):\n            continue\n        current = getattr(section, field_name)\n        if isinstance(current, bool):\n            setattr(section, field_name, value.lower() in (\"1\", \"true\", \"yes\"))\n        else:\n            setattr(section, field_name, value)\n\n\ndef resolve_config(\n    project_dir: Path | None = None,\n    env: dict[str, str] | None = None,\n    cli_overrides: dict | None = None,\n) -> Config:\n    \"\"\"Resolve config through the full cascade.\n\n    Precedence (highest wins):\n    1. CLI flags (*cli_overrides*)\n    2. Environment variables (``DARKFACTORY_<SECTION>_<KEY>``)\n    3. Project config — ``<project_dir>/config.toml``\n    4. User config — ``~/.config/darkfactory/config.toml``\n    5. Built-in defaults\n\n    Args:\n        project_dir: Path to the ``.darkfactory/`` directory.\n        env: Environment dict to use (defaults to ``os.environ``).\n        cli_overrides: Nested dict of overrides, e.g.\n            ``{\"style\": {\"theme\": \"light\"}}``.\n    \"\"\"\n    config = Config()\n\n    # Layer 1: user config\n    user_file = user_config_file()\n    if user_file:\n        user_data = _load_toml(user_file)\n        _merge_section(config.model, user_data.get(\"model\", {}))\n        _merge_section(config.style, user_data.get(\"style\", {}))\n\n    # Layer 2: project config\n    if project_dir is not None:\n        proj_file = project_dir / \"config.toml\"\n        proj_data = _load_toml(proj_file)\n        _merge_section(config.model, proj_data.get(\"model\", {}))\n        _merge_section(config.style, proj_data.get(\"style\", {}))\n\n    # Layer 3: env vars\n    env_dict: dict[str, str] = env if env is not None else dict(os.environ)\n    _apply_env_vars(config, env_dict)\n\n    # Layer 4: CLI flags\n    if cli_overrides:\n        for section_name, section_data in cli_overrides.items():\n            if isinstance(section_data, dict):\n                section = getattr(config, section_name, None)\n                if section is not None:\n                    _merge_section(section, section_data)\n\n    return config\n","numLines":143,"startLine":1,"totalLines":143}}}
