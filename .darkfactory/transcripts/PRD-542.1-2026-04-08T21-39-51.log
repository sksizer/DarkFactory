{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TyjHNEhmLQumh7RDJoKWae","type":"tool_result","content":"1\t\"\"\"Timeout resolution for agent tasks.\n2\t\n3\tComputes a task timeout in seconds using a priority-ordered resolution chain:\n4\t\n5\t1. CLI override (minutes) — highest priority\n6\t2. PRD frontmatter ``timeout_minutes`` field\n7\t3. Config table lookup (``[timeouts]`` in ``.darkfactory/config.toml``) × capability multiplier\n8\t4. Built-in effort → second defaults × capability multiplier\n9\t\"\"\"\n10\t\n11\tfrom __future__ import annotations\n12\t\n13\tDEFAULT_EFFORT_TIMEOUTS: dict[str, int] = {\n14\t    \"xs\": 300,\n15\t    \"s\": 600,\n16\t    \"m\": 1200,\n17\t    \"l\": 2400,\n18\t    \"xl\": 4500,\n19\t}\n20\t\n21\tCAPABILITY_MULTIPLIERS: dict[str, float] = {\n22\t    \"trivial\": 1.0,\n23\t    \"simple\": 1.0,\n24\t    \"moderate\": 1.25,\n25\t    \"complex\": 1.5,\n26\t}\n27\t\n28\t_DEFAULT_EFFORT = \"s\"\n29\t\n30\t\n31\tdef resolve_timeout(\n32\t    effort: str | None,\n33\t    capability: str | None,\n34\t    timeout_minutes_frontmatter: int | None,\n35\t    config_timeouts: dict | None,\n36\t    cli_override: int | None,\n37\t) -> tuple[int, str]:\n38\t    \"\"\"Return ``(timeout_seconds, source_description)``.\n39\t\n40\t    Parameters\n41\t    ----------\n42\t    effort:\n43\t        PRD effort tier (``xs``, ``s``, ``m``, ``l``, ``xl``).  ``None`` or\n44\t        unrecognised values fall back to ``\"s\"``.\n45\t    capability:\n46\t        PRD capability tier (``trivial``, ``simple``, ``moderate``,\n47\t        ``complex``).  ``None`` or unrecognised values use a multiplier of 1.0.\n48\t    timeout_minutes_frontmatter:\n49\t        Value of the PRD's ``timeout_minutes`` frontmatter field, if set.\n50\t    config_timeouts:\n51\t        The ``[timeouts]`` section from ``.darkfactory/config.toml`` as a dict,\n52\t        or ``None`` if the section is absent.  Effort keys map to *minutes*;\n53\t        a nested ``capability_multipliers`` key (if present) is ignored here\n54\t        because the caller already resolved the section.\n55\t    cli_override:\n56\t        Integer minutes passed via a CLI flag.  Takes precedence over everything.\n57\t\n58\t    Returns\n59\t    -------\n60\t    tuple[int, str]\n61\t        ``(seconds, source)`` where *source* is one of ``\"cli\"``,\n62\t        ``\"prd_frontmatter\"``, ``\"config\"``, or ``\"default\"``.\n63\t    \"\"\"\n64\t    # 1. CLI override.\n65\t    if cli_override is not None:\n66\t        return cli_override * 60, \"cli\"\n67\t\n68\t    # 2. PRD frontmatter.\n69\t    if timeout_minutes_frontmatter is not None:\n70\t        return timeout_minutes_frontmatter * 60, \"prd_frontmatter\"\n71\t\n72\t    # Resolve multiplier (falls back to 1.0 for unknown / missing capability).\n73\t    multiplier = CAPABILITY_MULTIPLIERS.get(capability or \"\", 1.0)\n74\t\n75\t    # Normalise effort — fall back to default for unknown / missing values.\n76\t    normalised_effort = effort if effort in DEFAULT_EFFORT_TIMEOUTS else _DEFAULT_EFFORT\n77\t\n78\t    # 3. Config table.\n79\t    if config_timeouts is not None:\n80\t        # Config stores minutes; capability_multipliers sub-key is a nested dict.\n81\t        config_minutes = config_timeouts.get(normalised_effort)\n82\t        if config_minutes is not None:\n83\t            return int(config_minutes * 60 * multiplier), \"config\"\n84\t\n85\t    # 4. Built-in defaults.\n86\t    base_seconds = DEFAULT_EFFORT_TIMEOUTS[normalised_effort]\n87\t    return int(base_seconds * multiplier), \"default\"\n88\t"}]},"parent_tool_use_id":null,"session_id":"5bf79e0f-af90-478b-bd9a-0fd5cf31481b","uuid":"c54ce2e5-d405-426c-8f2a-f49f41813a54","timestamp":"2026-04-09T02:39:00.809Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-542.1-timeout-resolution-module/src/darkfactory/timeouts.py","content":"\"\"\"Timeout resolution for agent tasks.\n\nComputes a task timeout in seconds using a priority-ordered resolution chain:\n\n1. CLI override (minutes) — highest priority\n2. PRD frontmatter ``timeout_minutes`` field\n3. Config table lookup (``[timeouts]`` in ``.darkfactory/config.toml``) × capability multiplier\n4. Built-in effort → second defaults × capability multiplier\n\"\"\"\n\nfrom __future__ import annotations\n\nDEFAULT_EFFORT_TIMEOUTS: dict[str, int] = {\n    \"xs\": 300,\n    \"s\": 600,\n    \"m\": 1200,\n    \"l\": 2400,\n    \"xl\": 4500,\n}\n\nCAPABILITY_MULTIPLIERS: dict[str, float] = {\n    \"trivial\": 1.0,\n    \"simple\": 1.0,\n    \"moderate\": 1.25,\n    \"complex\": 1.5,\n}\n\n_DEFAULT_EFFORT = \"s\"\n\n\ndef resolve_timeout(\n    effort: str | None,\n    capability: str | None,\n    timeout_minutes_frontmatter: int | None,\n    config_timeouts: dict | None,\n    cli_override: int | None,\n) -> tuple[int, str]:\n    \"\"\"Return ``(timeout_seconds, source_description)``.\n\n    Parameters\n    ----------\n    effort:\n        PRD effort tier (``xs``, ``s``, ``m``, ``l``, ``xl``).  ``None`` or\n        unrecognised values fall back to ``\"s\"``.\n    capability:\n        PRD capability tier (``trivial``, ``simple``, ``moderate``,\n        ``complex``).  ``None`` or unrecognised values use a multiplier of 1.0.\n    timeout_minutes_frontmatter:\n        Value of the PRD's ``timeout_minutes`` frontmatter field, if set.\n    config_timeouts:\n        The ``[timeouts]`` section from ``.darkfactory/config.toml`` as a dict,\n        or ``None`` if the section is absent.  Effort keys map to *minutes*;\n        a nested ``capability_multipliers`` key (if present) is ignored here\n        because the caller already resolved the section.\n    cli_override:\n        Integer minutes passed via a CLI flag.  Takes precedence over everything.\n\n    Returns\n    -------\n    tuple[int, str]\n        ``(seconds, source)`` where *source* is one of ``\"cli\"``,\n        ``\"prd_frontmatter\"``, ``\"config\"``, or ``\"default\"``.\n    \"\"\"\n    # 1. CLI override.\n    if cli_override is not None:\n        return cli_override * 60, \"cli\"\n\n    # 2. PRD frontmatter.\n    if timeout_minutes_frontmatter is not None:\n        return timeout_minutes_frontmatter * 60, \"prd_frontmatter\"\n\n    # Resolve multiplier (falls back to 1.0 for unknown / missing capability).\n    multiplier = CAPABILITY_MULTIPLIERS.get(capability or \"\", 1.0)\n\n    # Normalise effort — fall back to default for unknown / missing values.\n    normalised_effort = effort if effort in DEFAULT_EFFORT_TIMEOUTS else _DEFAULT_EFFORT\n\n    # 3. Config table.\n    if config_timeouts is not None:\n        # Config stores minutes; capability_multipliers sub-key is a nested dict.\n        config_minutes = config_timeouts.get(normalised_effort)\n        if config_minutes is not None:\n            return int(config_minutes * 60 * multiplier), \"config\"\n\n    # 4. Built-in defaults.\n    base_seconds = DEFAULT_EFFORT_TIMEOUTS[normalised_effort]\n    return int(base_seconds * multiplier), \"default\"\n","numLines":88,"startLine":1,"totalLines":88}}}
