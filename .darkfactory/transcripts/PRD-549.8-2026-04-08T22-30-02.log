f test_dry_run_no_subprocess(tmp_path: Path) -> None:\n59\t    ctx = _make_ctx(tmp_path, dry_run=True)\n60\t    transcript_dir = tmp_path / \".harness-transcripts\"\n61\t    transcript_dir.mkdir()\n62\t    (transcript_dir / \"PRD-549.8.log\").write_text(\"transcript content\")\n63\t\n64\t    with patch(\"darkfactory.builtins.commit_transcript.subprocess.run\") as mock_run:\n65\t        commit_transcript(ctx)\n66\t    mock_run.assert_not_called()\n67\t\n68\t\n69\tdef test_dry_run_no_file_created(tmp_path: Path) -> None:\n70\t    ctx = _make_ctx(tmp_path, dry_run=True)\n71\t    transcript_dir = tmp_path / \".harness-transcripts\"\n72\t    transcript_dir.mkdir()\n73\t    (transcript_dir / \"PRD-549.8.log\").write_text(\"transcript content\")\n74\t\n75\t    commit_transcript(ctx)\n76\t\n77\t    dest_dir = tmp_path / \".darkfactory\" / \"transcripts\"\n78\t    assert not dest_dir.exists()\n79\t\n80\t\n81\t# ---------- successful move and stage ----------\n82\t\n83\t\n84\tdef test_successful_run_creates_dest_and_stages(tmp_path: Path) -> None:\n85\t    ctx = _make_ctx(tmp_path, dry_run=False)\n86\t    transcript_dir = tmp_path / \".harness-transcripts\"\n87\t    transcript_dir.mkdir()\n88\t    src = transcript_dir / \"PRD-549.8.log\"\n89\t    src.write_text(\"transcript content\")\n90\t\n91\t    with patch(\"darkfactory.builtins.commit_transcript.subprocess.run\") as mock_run:\n92\t        commit_transcript(ctx)\n93\t\n94\t    # Destination directory should be created\n95\t    dest_dir = tmp_path / \".darkfactory\" / \"transcripts\"\n96\t    assert dest_dir.exists()\n97\t\n98\t    # A file matching the pattern should exist\n99\t    files = list(dest_dir.glob(\"PRD-549.8-*.log\"))\n100\t    assert len(files) == 1\n101\t    assert files[0].read_text() == \"transcript content\"\n102\t\n103\t    # git add should be called\n104\t    mock_run.assert_called_once()\n105\t    call_args = mock_run.call_args[0][0]\n106\t    assert call_args[0] == \"git\"\n107\t    assert call_args[1