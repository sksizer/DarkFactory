{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BXDbHsZoW2GqgYuF2QmQzq","type":"tool_result","content":"1\t\"\"\"Built-in: commit_transcript — copy agent transcript into the worktree and stage it.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport logging\n6\timport shutil\n7\timport subprocess\n8\tfrom datetime import datetime\n9\t\n10\tfrom darkfactory.builtins._registry import builtin\n11\tfrom darkfactory.workflow import ExecutionContext\n12\t\n13\t_log = logging.getLogger(__name__)\n14\t\n15\t\n16\t@builtin(\"commit_transcript\")\n17\tdef commit_transcript(ctx: ExecutionContext) -> None:\n18\t    \"\"\"Copy agent transcript into the worktree and stage it.\n19\t\n20\t    Source: ``<repo_root>/.harness-transcripts/{prd_id}.log`` written by the\n21\t    runner after each agent invocation (outside any worktree — see\n22\t    ``runner._run_agent``). Destination inside the worktree:\n23\t    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n24\t\n25\t    The runner writes transcripts *outside* every worktree so ``git add -A``\n26\t    can never accidentally sweep them. This builtin is the one place that\n27\t    opts the transcript *into* the worktree — workflows that want the\n28\t    transcript committed alongside the PRD work must include this builtin\n29\t    explicitly. Workflows that omit it leave the transcript at the repo-root\n30\t    path where it survives as a local-only diagnostic.\n31\t\n32\t    Timestamps use the wall-clock at the time this builtin runs, which is\n33\t    unique enough for sequential runs. If no transcript exists (dry-run,\n34\t    or the runner didn't produce one), this is a no-op.\n35\t    \"\"\"\n36\t    src = ctx.repo_root / \".harness-transcripts\" / f\"{ctx.prd.id}.log\"\n37\t    if not src.exists():\n38\t        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n39\t        return\n40\t\n41\t    if ctx.dry_run:\n42\t        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n43\t        dest = (\n44\t            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n45\t        )\n46\t        ctx.logger.info(\"[dry-run] copy %s -> %s && git add\", src, dest)\n47\t        return\n48\t\n49\t    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n50\t    transcript_dir.mkdir(parents=True, exist_ok=True)\n51\t\n52\t    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n53\t    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n54\t\n55\t    # Copy (not move) so the repo-root transcript persists as a local-only\n56\t    # diagnostic even after this builtin runs. If the same PRD is re-run,\n57\t    # the runner overwrites the source file anyway.\n58\t    shutil.copy2(str(src), str(dest))\n59\t\n60\t    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n61\t    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n62\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"8c399ad7-96c2-4a07-b000-029b2ffce508","uuid":"138b09bb-500d-41ad-922e-f9040bc11d04","timestamp":"2026-04-09T07:55:27.988Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/src/darkfactory/builtins/commit_transcript.py","content":"\"\"\"Built-in: commit_transcript — copy agent transcript into the worktree and stage it.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport shutil\nimport subprocess\nfrom datetime import datetime\n\nfrom darkfactory.builtins._registry import builtin\nfrom darkfactory.workflow import ExecutionContext\n\n_log = logging.getLogger(__name__)\n\n\n@builtin(\"commit_transcript\")\ndef commit_transcript(ctx: ExecutionContext) -> None:\n    \"\"\"Copy agent transcript into the worktree and stage it.\n\n    Source: ``<repo_root>/.harness-transcripts/{prd_id}.log`` written by the\n    runner after each agent invocation (outside any worktree — see\n    ``runner._run_agent``). Destination inside the worktree:\n    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n\n    The runner writes transcripts *outside* every worktree so ``git add -A``\n    can never accidentally sweep them. This builtin is the one place that\n    opts the transcript *into* the worktree — workflows that want the\n    transcript committed alongside the PRD work must include this builtin\n    explicitly. Workflows that omit it leave the transcript at the repo-root\n    path where it survives as a local-only diagnostic.\n\n    Timestamps use the wall-clock at the time this builtin runs, which is\n    unique enough for sequential runs. If no transcript exists (dry-run,\n    or the runner didn't produce one), this is a no-op.\n    \"\"\"\n    src = ctx.repo_root / \".harness-transcripts\" / f\"{ctx.prd.id}.log\"\n    if not src.exists():\n        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n        return\n\n    if ctx.dry_run:\n        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n        dest = (\n            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n        )\n        ctx.logger.info(\"[dry-run] copy %s -> %s && git add\", src, dest)\n        return\n\n    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n    transcript_dir.mkdir(parents=True, exist_ok=True)\n\n    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n\n    # Copy (not move) so the repo-root transcript persists as a local-only\n    # diagnostic even after this builtin runs. If the same PRD is re-run,\n    # the runner overwrites the source file anyway.\n    shutil.copy2(str(src), str(dest))\n\n    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n","numLines":62,"startLine":1,"totalLines":62}}}
