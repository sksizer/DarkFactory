{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A3cxgqZcBhm28nQo6qfHyD","type":"tool_result","content":"1\t\"\"\"Built-in WorkflowTemplate instances bundled with the harness package.\n2\t\n3\tProvides :data:`PRD_IMPLEMENTATION_TEMPLATE`, the standard PRD implementation\n4\tlifecycle with PRD-224 invariants enforced. Most workflows compose from this\n5\ttemplate rather than building open/close lists from scratch.\n6\t\"\"\"\n7\t\n8\tfrom __future__ import annotations\n9\t\n10\tfrom .templates import WorkflowTemplate\n11\tfrom .workflow import AgentTask, BuiltIn, ShellTask\n12\t\n13\tPRD_IMPLEMENTATION_TEMPLATE = WorkflowTemplate(\n14\t    name=\"prd-implementation\",\n15\t    description=\"Standard PRD implementation lifecycle with enforced invariants.\",\n16\t    open=[\n17\t        BuiltIn(\"ensure_worktree\"),\n18\t        BuiltIn(\"set_status\", kwargs={\"to\": \"in-progress\"}),\n19\t        BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"}),\n20\t    ],\n21\t    middle_kinds=[AgentTask, ShellTask],\n22\t    middle_required={\n23\t        AgentTask: (1, None),\n24\t        ShellTask: (1, None),\n25\t    },\n26\t    close=[\n27\t        BuiltIn(\"summarize_agent_run\"),\n28\t        BuiltIn(\"commit_transcript\"),\n29\t        BuiltIn(\"set_status\", kwargs={\"to\": \"review\"}),\n30\t        BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} ready for review\"}),\n31\t        BuiltIn(\"push_branch\"),\n32\t        BuiltIn(\"create_pr\"),\n33\t    ],\n34\t)\n35\t"}]},"parent_tool_use_id":null,"session_id":"d010088e-6429-4c1e-aa66-519315c26c5c","uuid":"4fb6ce02-7c26-46d8-8612-3e41a8487084","timestamp":"2026-04-09T04:33:46.637Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-227.4-migrate-extraction-workflow/src/darkfactory/templates_builtin.py","content":"\"\"\"Built-in WorkflowTemplate instances bundled with the harness package.\n\nProvides :data:`PRD_IMPLEMENTATION_TEMPLATE`, the standard PRD implementation\nlifecycle with PRD-224 invariants enforced. Most workflows compose from this\ntemplate rather than building open/close lists from scratch.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom .templates import WorkflowTemplate\nfrom .workflow import AgentTask, BuiltIn, ShellTask\n\nPRD_IMPLEMENTATION_TEMPLATE = WorkflowTemplate(\n    name=\"prd-implementation\",\n    description=\"Standard PRD implementation lifecycle with enforced invariants.\",\n    open=[\n        BuiltIn(\"ensure_worktree\"),\n        BuiltIn(\"set_status\", kwargs={\"to\": \"in-progress\"}),\n        BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"}),\n    ],\n    middle_kinds=[AgentTask, ShellTask],\n    middle_required={\n        AgentTask: (1, None),\n        ShellTask: (1, None),\n    },\n    close=[\n        BuiltIn(\"summarize_agent_run\"),\n        BuiltIn(\"commit_transcript\"),\n        BuiltIn(\"set_status\", kwargs={\"to\": \"review\"}),\n        BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} ready for review\"}),\n        BuiltIn(\"push_branch\"),\n        BuiltIn(\"create_pr\"),\n    ],\n)\n","numLines":35,"startLine":1,"totalLines":35}}}
