nt\",\n            prompts=[\"prompts/role.md\", \"prompts/task.md\"],\n            tools=[\n                \"Read\",\n                \"Edit\",\n                \"Write\",\n                \"Glob\",\n                \"Grep\",\n                # Broad bash for filesystem + git + gh against the target repo\n                \"Bash\",\n            ],\n            model_from_capability=True,\n            retries=1,\n            verify_prompts=[\"prompts/verify.md\"],\n        ),\n        # No test/lint ShellTasks — the agent verifies in the target repo.\n    ],\n)\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1573,"cache_read_input_tokens":26734,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1573},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"d010088e-6429-4c1e-aa66-519315c26c5c","uuid":"7965784c-563c-4213-b218-5e605db3b4a2"}
