{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PPRiBRyiG9FNk7c7NH8vEJ","type":"tool_result","content":"1\t\"\"\"Built-in task primitives — re-export hub.\n2\t\n3\tImports every submodule so @builtin-decorated functions register on\n4\tpackage import. Re-exports the public API for backwards compatibility.\n5\t\n6\tBuilt-ins are the deterministic SDLC operations that every workflow\n7\treferences by name: create a worktree, set a PRD's status, make a\n8\tcommit, push a branch, open a PR. They live here (not in individual\n9\tworkflow modules) because they're shared — every workflow uses the\n10\tsame ``commit`` primitive, not a bespoke one.\n11\t\n12\tWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n13\t\n14\t    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n15\t\n16\tThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\n17\tregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\n18\tplus any formatted kwargs.\n19\t\n20\t**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\n21\tanything destructive. In dry-run, we log what we WOULD do at INFO\n22\tlevel and return. This is what powers ``prd plan`` and the default\n23\t``prd run`` (without ``--execute``).\n24\t\n25\t**Subprocess discipline**: all shell commands use ``subprocess.run``\n26\twith an explicit argv list (never ``shell=True``), capture output,\n27\tand check the return code. Git and gh invocations go through\n28\t:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\n29\thandling and dry-run support.\n30\t\"\"\"\n31\t\n32\tfrom __future__ import annotations\n33\t\n34\timport logging\n35\timport re\n36\timport shutil\n37\timport subprocess\n38\tfrom datetime import datetime\n39\tfrom pathlib import Path\n40\t\n41\tfrom filelock import FileLock, Timeout\n42\t\n43\tfrom darkfactory import prd as prd_module\n44\tfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\n45\tfrom darkfactory.builtins._shared import (\n46\t    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n47\t    _run,\n48\t    _scan_for_forbidden_attribution,\n49\t)\n50\tfrom darkfactory.builtins.set_status import set_status  # noqa: F401\n51\tfrom darkfactory.checks import is_resume_safe\n52\t\n53\t_log = logging.getLogger(__name__)\n54\t\n55\tfrom darkfactory.workflow import ExecutionContext, Status\n56\t\n57\t_log = logging.getLogger(__name__)\n58\t\n59\t# Import submodules to trigger @builtin registration.\n60\tfrom darkfactory.builtins.commit import commit  # noqa: E402\n61\tfrom darkfactory.builtins.ensure_worktree import ensure_worktree  # noqa: E402\n62\tfrom darkfactory.builtins.lint_attribution import lint_attribution  # noqa: E402\n63\tfrom darkfactory.builtins.push_branch import push_branch  # noqa: E402\n64\t\n65\t__all__ = [\n66\t    \"BUILTINS\",\n67\t    \"BuiltInFunc\",\n68\t    \"builtin\",\n69\t    \"_run\",\n70\t    \"_scan_for_forbidden_attribution\",\n71\t    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n72\t    \"ensure_worktree\",\n73\t    \"set_status\",\n74\t    \"commit\",\n75\t    \"push_branch\",\n76\t    \"summarize_agent_run\",\n77\t    \"commit_transcript\",\n78\t    \"create_pr\",\n79\t    \"lint_attribution\",\n80\t    \"cleanup_worktree\",\n81\t]\n82\t\n83\t\n84\t_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n85\t\n86\t\n87\tdef _extract_acceptance_criteria(body: str) -> list[str]:\n88\t    \"\"\"Pull acceptance criteria lines out of a PRD body.\n89\t\n90\t    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n91\t    Returns a list of the criterion strings (without the checkbox\n92\t    prefix). Used by ``create_pr`` to build the PR body's checklist.\n93\t    \"\"\"\n94\t    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n95\t\n96\t\n97\tdef _pr_body(ctx: ExecutionContext) -> str:\n98\t    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n99\t    prd = ctx.prd\n100\t    lines: list[str] = [\n101\t        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n102\t        \"\",\n103\t    ]\n104\t\n105\t    acs = _extract_acceptance_criteria(prd.body)\n106\t    if acs:\n107\t        lines.append(\"## Acceptance criteria\")\n108\t        lines.append(\"\")\n109\t        for ac in acs:\n110\t            lines.append(f\"- [ ] {ac}\")\n111\t        lines.append(\"\")\n112\t\n113\t    lines.append(\"---\")\n114\t    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n115\t    return \"\\n\".join(lines)\n116\t\n117\t\n118\t# ---------- built-in implementations ----------\n119\t\n120\t\n121\tdef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n122\t    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n123\t    if not tool_counts:\n124\t        return \"none\"\n125\t    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n126\t\n127\t\n128\tdef _format_invocations(ctx: ExecutionContext) -> str:\n129\t    \"\"\"Format agent invocation count from context.\"\"\"\n130\t    count = ctx.invoke_count\n131\t    if count == 0:\n132\t        return \"0\"\n133\t    if count == 1:\n134\t        return \"1\"\n135\t    return str(count)\n136\t\n137\t\n138\t@builtin(\"summarize_agent_run\")\n139\tdef summarize_agent_run(ctx: ExecutionContext) -> None:\n140\t    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n141\t    result = ctx.last_invoke_result\n142\t    if result is None:\n143\t        return\n144\t\n145\t    lines = [\n146\t        \"## Harness execution summary\",\n147\t        \"\",\n148\t        f\"- **Workflow:** {ctx.workflow.name}\",\n149\t        f\"- **Model:** {ctx.model or 'unknown'}\",\n150\t        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n151\t        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n152\t        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n153\t    ]\n154\t    ctx.run_summary = \"\\n\".join(lines)\n155\t\n156\t\n157\t@builtin(\"commit_transcript\")\n158\tdef commit_transcript(ctx: ExecutionContext) -> None:\n159\t    \"\"\"Copy agent transcript into the worktree and stage it.\n160\t\n161\t    Source: ``<repo_root>/.harness-transcripts/{prd_id}.log`` written by the\n162\t    runner after each agent invocation (outside any worktree — see\n163\t    ``runner._run_agent``). Destination inside the worktree:\n164\t    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n165\t\n166\t    The runner writes transcripts *outside* every worktree so ``git add -A``\n167\t    can never accidentally sweep them. This builtin is the one place that\n168\t    opts the transcript *into* the worktree — workflows that want the\n169\t    transcript committed alongside the PRD work must include this builtin\n170\t    explicitly. Workflows that omit it leave the transcript at the repo-root\n171\t    path where it survives as a local-only diagnostic.\n172\t\n173\t    Timestamps use the wall-clock at the time this builtin runs, which is\n174\t    unique enough for sequential runs. If no transcript exists (dry-run,\n175\t    or the runner didn't produce one), this is a no-op.\n176\t    \"\"\"\n177\t    src = ctx.repo_root / \".harness-transcripts\" / f\"{ctx.prd.id}.log\"\n178\t    if not src.exists():\n179\t        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n180\t        return\n181\t\n182\t    if ctx.dry_run:\n183\t        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n184\t        dest = (\n185\t            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n186\t        )\n187\t        ctx.logger.info(\"[dry-run] copy %s -> %s && git add\", src, dest)\n188\t        return\n189\t\n190\t    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n191\t    transcript_dir.mkdir(parents=True, exist_ok=True)\n192\t\n193\t    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n194\t    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n195\t\n196\t    # Copy (not move) so the repo-root transcript persists as a local-only\n197\t    # diagnostic even after this builtin runs. If the same PRD is re-run,\n198\t    # the runner overwrites the source file anyway.\n199\t    shutil.copy2(str(src), str(dest))\n200\t\n201\t    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n202\t    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n203\t\n204\t\n205\t@builtin(\"create_pr\")\n206\tdef create_pr(ctx: ExecutionContext) -> None:\n207\t    \"\"\"Open a pull request via ``gh pr create``.\n208\t\n209\t    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n210\t    acceptance criteria plus a link to the PRD file. Base branch:\n211\t    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n212\t    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n213\t    relative to ``ctx.repo_root``.\n214\t    \"\"\"\n215\t    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n216\t    body = _pr_body(ctx)\n217\t    if ctx.run_summary:\n218\t        body += \"\\n\\n\" + ctx.run_summary\n219\t    _scan_for_forbidden_attribution(title, source=f\"PR title for {ctx.prd.id}\")\n220\t    _scan_for_forbidden_attribution(body, source=f\"PR body for {ctx.prd.id}\")\n221\t\n222\t    if ctx.dry_run:\n223\t        ctx.logger.info(\n224\t            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n225\t            ctx.base_ref,\n226\t            title,\n227\t        )\n228\t        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n229\t        return\n230\t\n231\t    # Write the body to a temp file — passing long bodies via --body\n232\t    # can hit argv limits on some systems.\n233\t    import tempfile\n234\t\n235\t    with tempfile.NamedTemporaryFile(\n236\t        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n237\t    ) as body_file:\n238\t        body_file.write(body)\n239\t        body_path = body_file.name\n240\t\n241\t    try:\n242\t        result = subprocess.run(\n243\t            [\n244\t                \"gh\",\n245\t                \"pr\",\n246\t                \"create\",\n247\t                \"--base\",\n248\t                ctx.base_ref,\n249\t                \"--title\",\n250\t                title,\n251\t                \"--body-file\",\n252\t                body_path,\n253\t            ],\n254\t            cwd=str(ctx.cwd),\n255\t            check=True,\n256\t            capture_output=True,\n257\t            text=True,\n258\t        )\n259\t    finally:\n260\t        Path(body_path).unlink(missing_ok=True)\n261\t\n262\t    # gh prints the PR URL to stdout on success.\n263\t    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n264\t    ctx.pr_url = url_line or None\n265\t\n266\t\n267\t@builtin(\"cleanup_worktree\")\n268\tdef cleanup_worktree(ctx: ExecutionContext) -> None:\n269\t    \"\"\"Remove the worktree after a successful run.\n270\t\n271\t    Idempotent — if the worktree is already gone, logs and returns.\n272\t    Normally skipped during chain execution so downstream worktrees\n273\t    can base on this branch; called explicitly via ``prd cleanup``\n274\t    after the whole chain is done.\n275\t    \"\"\"\n276\t    if ctx.worktree_path is None:\n277\t        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n278\t        return\n279\t\n280\t    if not ctx.worktree_path.exists():\n281\t        ctx.logger.info(\n282\t            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n283\t        )\n284\t        return\n285\t\n286\t    cmd = [\n287\t        \"git\",\n288\t        \"-C\",\n289\t        str(ctx.repo_root),\n290\t        \"worktree\",\n291\t        \"remove\",\n292\t        str(ctx.worktree_path),\n293\t    ]\n294\t\n295\t    if ctx.dry_run:\n296\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n297\t        return\n298\t\n299\t    subprocess.run(cmd, check=True, capture_output=True, text=True)\n300\t"}]},"parent_tool_use_id":null,"session_id":"090e599a-30bf-4b78-82ac-68954e3e3117","uuid":"cdcdc746-cbf9-4598-9950-8fef282f609d","timestamp":"2026-04-09T03:35:03.153Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-549.10-move-lint-attribution/src/darkfactory/builtins/__init__.py","content":"\"\"\"Built-in task primitives — re-export hub.\n\nImports every submodule so @builtin-decorated functions register on\npackage import. Re-exports the public API for backwards compatibility.\n\nBuilt-ins are the deterministic SDLC operations that every workflow\nreferences by name: create a worktree, set a PRD's status, make a\ncommit, push a branch, open a PR. They live here (not in individual\nworkflow modules) because they're shared — every workflow uses the\nsame ``commit`` primitive, not a bespoke one.\n\nWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n\n    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n\nThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\nregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\nplus any formatted kwargs.\n\n**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\nanything destructive. In dry-run, we log what we WOULD do at INFO\nlevel and return. This is what powers ``prd plan`` and the default\n``prd run`` (without ``--execute``).\n\n**Subprocess discipline**: all shell commands use ``subprocess.run``\nwith an explicit argv list (never ``shell=True``), capture output,\nand check the return code. Git and gh invocations go through\n:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\nhandling and dry-run support.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport re\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom filelock import FileLock, Timeout\n\nfrom darkfactory import prd as prd_module\nfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\nfrom darkfactory.builtins._shared import (\n    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n    _run,\n    _scan_for_forbidden_attribution,\n)\nfrom darkfactory.builtins.set_status import set_status  # noqa: F401\nfrom darkfactory.checks import is_resume_safe\n\n_log = logging.getLogger(__name__)\n\nfrom darkfactory.workflow import ExecutionContext, Status\n\n_log = logging.getLogger(__name__)\n\n# Import submodules to trigger @builtin registration.\nfrom darkfactory.builtins.commit import commit  # noqa: E402\nfrom darkfactory.builtins.ensure_worktree import ensure_worktree  # noqa: E402\nfrom darkfactory.builtins.lint_attribution import lint_attribution  # noqa: E402\nfrom darkfactory.builtins.push_branch import push_branch  # noqa: E402\n\n__all__ = [\n    \"BUILTINS\",\n    \"BuiltInFunc\",\n    \"builtin\",\n    \"_run\",\n    \"_scan_for_forbidden_attribution\",\n    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n    \"ensure_worktree\",\n    \"set_status\",\n    \"commit\",\n    \"push_branch\",\n    \"summarize_agent_run\",\n    \"commit_transcript\",\n    \"create_pr\",\n    \"lint_attribution\",\n    \"cleanup_worktree\",\n]\n\n\n_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n\n\ndef _extract_acceptance_criteria(body: str) -> list[str]:\n    \"\"\"Pull acceptance criteria lines out of a PRD body.\n\n    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n    Returns a list of the criterion strings (without the checkbox\n    prefix). Used by ``create_pr`` to build the PR body's checklist.\n    \"\"\"\n    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n\n\ndef _pr_body(ctx: ExecutionContext) -> str:\n    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n    prd = ctx.prd\n    lines: list[str] = [\n        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n        \"\",\n    ]\n\n    acs = _extract_acceptance_criteria(prd.body)\n    if acs:\n        lines.append(\"## Acceptance criteria\")\n        lines.append(\"\")\n        for ac in acs:\n            lines.append(f\"- [ ] {ac}\")\n        lines.append(\"\")\n\n    lines.append(\"---\")\n    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n    return \"\\n\".join(lines)\n\n\n# ---------- built-in implementations ----------\n\n\ndef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n    if not tool_counts:\n        return \"none\"\n    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n\n\ndef _format_invocations(ctx: ExecutionContext) -> str:\n    \"\"\"Format agent invocation count from context.\"\"\"\n    count = ctx.invoke_count\n    if count == 0:\n        return \"0\"\n    if count == 1:\n        return \"1\"\n    return str(count)\n\n\n@builtin(\"summarize_agent_run\")\ndef summarize_agent_run(ctx: ExecutionContext) -> None:\n    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n    result = ctx.last_invoke_result\n    if result is None:\n        return\n\n    lines = [\n        \"## Harness execution summary\",\n        \"\",\n        f\"- **Workflow:** {ctx.workflow.name}\",\n        f\"- **Model:** {ctx.model or 'unknown'}\",\n        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n    ]\n    ctx.run_summary = \"\\n\".join(lines)\n\n\n@builtin(\"commit_transcript\")\ndef commit_transcript(ctx: ExecutionContext) -> None:\n    \"\"\"Copy agent transcript into the worktree and stage it.\n\n    Source: ``<repo_root>/.harness-transcripts/{prd_id}.log`` written by the\n    runner after each agent invocation (outside any worktree — see\n    ``runner._run_agent``). Destination inside the worktree:\n    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n\n    The runner writes transcripts *outside* every worktree so ``git add -A``\n    can never accidentally sweep them. This builtin is the one place that\n    opts the transcript *into* the worktree — workflows that want the\n    transcript committed alongside the PRD work must include this builtin\n    explicitly. Workflows that omit it leave the transcript at the repo-root\n    path where it survives as a local-only diagnostic.\n\n    Timestamps use the wall-clock at the time this builtin runs, which is\n    unique enough for sequential runs. If no transcript exists (dry-run,\n    or the runner didn't produce one), this is a no-op.\n    \"\"\"\n    src = ctx.repo_root / \".harness-transcripts\" / f\"{ctx.prd.id}.log\"\n    if not src.exists():\n        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n        return\n\n    if ctx.dry_run:\n        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n        dest = (\n            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n        )\n        ctx.logger.info(\"[dry-run] copy %s -> %s && git add\", src, dest)\n        return\n\n    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n    transcript_dir.mkdir(parents=True, exist_ok=True)\n\n    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n\n    # Copy (not move) so the repo-root transcript persists as a local-only\n    # diagnostic even after this builtin runs. If the same PRD is re-run,\n    # the runner overwrites the source file anyway.\n    shutil.copy2(str(src), str(dest))\n\n    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n\n\n@builtin(\"create_pr\")\ndef create_pr(ctx: ExecutionContext) -> None:\n    \"\"\"Open a pull request via ``gh pr create``.\n\n    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n    acceptance criteria plus a link to the PRD file. Base branch:\n    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n    relative to ``ctx.repo_root``.\n    \"\"\"\n    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n    body = _pr_body(ctx)\n    if ctx.run_summary:\n        body += \"\\n\\n\" + ctx.run_summary\n    _scan_for_forbidden_attribution(title, source=f\"PR title for {ctx.prd.id}\")\n    _scan_for_forbidden_attribution(body, source=f\"PR body for {ctx.prd.id}\")\n\n    if ctx.dry_run:\n        ctx.logger.info(\n            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n            ctx.base_ref,\n            title,\n        )\n        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n        return\n\n    # Write the body to a temp file — passing long bodies via --body\n    # can hit argv limits on some systems.\n    import tempfile\n\n    with tempfile.NamedTemporaryFile(\n        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n    ) as body_file:\n        body_file.write(body)\n        body_path = body_file.name\n\n    try:\n        result = subprocess.run(\n            [\n                \"gh\",\n                \"pr\",\n                \"create\",\n                \"--base\",\n                ctx.base_ref,\n                \"--title\",\n                title,\n                \"--body-file\",\n                body_path,\n            ],\n            cwd=str(ctx.cwd),\n            check=True,\n            capture_output=True,\n            text=True,\n        )\n    finally:\n        Path(body_path).unlink(missing_ok=True)\n\n    # gh prints the PR URL to stdout on success.\n    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n    ctx.pr_url = url_line or None\n\n\n@builtin(\"cleanup_worktree\")\ndef cleanup_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Remove the worktree after a successful run.\n\n    Idempotent — if the worktree is already gone, logs and returns.\n    Normally skipped during chain execution so downstream worktrees\n    can base on this branch; called explicitly via ``prd cleanup``\n    after the whole chain is done.\n    \"\"\"\n    if ctx.worktree_path is None:\n        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n        return\n\n    if not ctx.worktree_path.exists():\n        ctx.logger.info(\n            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n        )\n        return\n\n    cmd = [\n        \"git\",\n        \"-C\",\n        str(ctx.repo_root),\n        \"worktree\",\n        \"remove\",\n        str(ctx.worktree_path),\n    ]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(cmd, check=True, capture_output=True, text=True)\n","numLines":300,"startLine":1,"totalLines":300}}}
