{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LW7Gg3R8Lzpda4DEYhCp8X","type":"tool_result","content":"1\t\"\"\"Built-in task primitives — re-export hub.\n2\t\n3\tImports every submodule so @builtin-decorated functions register on\n4\tpackage import. Re-exports the public API for backwards compatibility.\n5\t\n6\tBuilt-ins are the deterministic SDLC operations that every workflow\n7\treferences by name: create a worktree, set a PRD's status, make a\n8\tcommit, push a branch, open a PR. They live here (not in individual\n9\tworkflow modules) because they're shared — every workflow uses the\n10\tsame ``commit`` primitive, not a bespoke one.\n11\t\n12\tWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n13\t\n14\t    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n15\t\n16\tThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\n17\tregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\n18\tplus any formatted kwargs.\n19\t\n20\t**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\n21\tanything destructive. In dry-run, we log what we WOULD do at INFO\n22\tlevel and return. This is what powers ``prd plan`` and the default\n23\t``prd run`` (without ``--execute``).\n24\t\n25\t**Subprocess discipline**: all shell commands use ``subprocess.run``\n26\twith an explicit argv list (never ``shell=True``), capture output,\n27\tand check the return code. Git and gh invocations go through\n28\t:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\n29\thandling and dry-run support.\n30\t\"\"\"\n31\t\n32\tfrom __future__ import annotations\n33\t\n34\timport logging\n35\timport re\n36\timport shutil\n37\timport subprocess\n38\tfrom datetime import datetime\n39\tfrom pathlib import Path\n40\t\n41\tfrom filelock import FileLock, Timeout\n42\t\n43\tfrom darkfactory import prd as prd_module\n44\tfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\n45\tfrom darkfactory.builtins._shared import (\n46\t    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n47\t    _run,\n48\t    _scan_for_forbidden_attribution,\n49\t)\n50\tfrom darkfactory.builtins.set_status import set_status  # noqa: F401\n51\tfrom darkfactory.checks import is_resume_safe\n52\t\n53\t_log = logging.getLogger(__name__)\n54\t\n55\tfrom darkfactory.workflow import ExecutionContext, Status\n56\t\n57\t_log = logging.getLogger(__name__)\n58\t\n59\t# Import submodules to trigger @builtin registration.\n60\tfrom darkfactory.builtins.ensure_worktree import ensure_worktree  # noqa: E402\n61\tfrom darkfactory.builtins.push_branch import push_branch  # noqa: E402\n62\tfrom darkfactory.builtins.summarize_agent_run import summarize_agent_run  # noqa: E402\n63\t\n64\t__all__ = [\n65\t    \"BUILTINS\",\n66\t    \"BuiltInFunc\",\n67\t    \"builtin\",\n68\t    \"_run\",\n69\t    \"_scan_for_forbidden_attribution\",\n70\t    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n71\t    \"ensure_worktree\",\n72\t    \"set_status\",\n73\t    \"commit\",\n74\t    \"push_branch\",\n75\t    \"summarize_agent_run\",\n76\t    \"commit_transcript\",\n77\t    \"create_pr\",\n78\t    \"lint_attribution\",\n79\t    \"cleanup_worktree\",\n80\t]\n81\t\n82\t\n83\t_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n84\t\n85\t\n86\tdef _extract_acceptance_criteria(body: str) -> list[str]:\n87\t    \"\"\"Pull acceptance criteria lines out of a PRD body.\n88\t\n89\t    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n90\t    Returns a list of the criterion strings (without the checkbox\n91\t    prefix). Used by ``create_pr`` to build the PR body's checklist.\n92\t    \"\"\"\n93\t    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n94\t\n95\t\n96\tdef _pr_body(ctx: ExecutionContext) -> str:\n97\t    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n98\t    prd = ctx.prd\n99\t    lines: list[str] = [\n100\t        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n101\t        \"\",\n102\t    ]\n103\t\n104\t    acs = _extract_acceptance_criteria(prd.body)\n105\t    if acs:\n106\t        lines.append(\"## Acceptance criteria\")\n107\t        lines.append(\"\")\n108\t        for ac in acs:\n109\t            lines.append(f\"- [ ] {ac}\")\n110\t        lines.append(\"\")\n111\t\n112\t    lines.append(\"---\")\n113\t    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n114\t    return \"\\n\".join(lines)\n115\t\n116\t\n117\t# ---------- built-in implementations ----------\n118\t\n119\t\n120\t@builtin(\"commit\")\n121\tdef commit(ctx: ExecutionContext, *, message: str) -> None:\n122\t    \"\"\"Stage all changes and make a commit inside the worktree.\n123\t\n124\t    ``message`` is format-string expanded against the context so\n125\t    ``\"chore(prd): {prd_id} start work\"`` becomes\n126\t    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n127\t    returns without erroring — workflows can safely commit after each\n128\t    logical step without worrying about whether anything changed.\n129\t    \"\"\"\n130\t    formatted = ctx.format_string(message)\n131\t    _scan_for_forbidden_attribution(\n132\t        formatted, source=f\"commit message for {ctx.prd.id}\"\n133\t    )\n134\t\n135\t    if ctx.dry_run:\n136\t        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n137\t        return\n138\t\n139\t    # Stage everything\n140\t    subprocess.run(\n141\t        [\"git\", \"add\", \"-A\"],\n142\t        cwd=str(ctx.cwd),\n143\t        check=True,\n144\t        capture_output=True,\n145\t        text=True,\n146\t    )\n147\t\n148\t    # Check if there's anything to commit\n149\t    diff_result = subprocess.run(\n150\t        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n151\t        cwd=str(ctx.cwd),\n152\t        check=False,\n153\t        capture_output=True,\n154\t        text=True,\n155\t    )\n156\t    if diff_result.returncode == 0:\n157\t        # No staged changes — skip gracefully.\n158\t        ctx.logger.info(\"commit skipped: no changes to commit\")\n159\t        return\n160\t\n161\t    # Commit\n162\t    subprocess.run(\n163\t        [\"git\", \"commit\", \"-m\", formatted],\n164\t        cwd=str(ctx.cwd),\n165\t        check=True,\n166\t        capture_output=True,\n167\t        text=True,\n168\t    )\n169\t\n170\t\n171\t@builtin(\"commit_transcript\")\n172\tdef commit_transcript(ctx: ExecutionContext) -> None:\n173\t    \"\"\"Copy agent transcript into the worktree and stage it.\n174\t\n175\t    Source: ``<repo_root>/.harness-transcripts/{prd_id}.log`` written by the\n176\t    runner after each agent invocation (outside any worktree — see\n177\t    ``runner._run_agent``). Destination inside the worktree:\n178\t    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n179\t\n180\t    The runner writes transcripts *outside* every worktree so ``git add -A``\n181\t    can never accidentally sweep them. This builtin is the one place that\n182\t    opts the transcript *into* the worktree — workflows that want the\n183\t    transcript committed alongside the PRD work must include this builtin\n184\t    explicitly. Workflows that omit it leave the transcript at the repo-root\n185\t    path where it survives as a local-only diagnostic.\n186\t\n187\t    Timestamps use the wall-clock at the time this builtin runs, which is\n188\t    unique enough for sequential runs. If no transcript exists (dry-run,\n189\t    or the runner didn't produce one), this is a no-op.\n190\t    \"\"\"\n191\t    src = ctx.repo_root / \".harness-transcripts\" / f\"{ctx.prd.id}.log\"\n192\t    if not src.exists():\n193\t        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n194\t        return\n195\t\n196\t    if ctx.dry_run:\n197\t        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n198\t        dest = (\n199\t            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n200\t        )\n201\t        ctx.logger.info(\"[dry-run] copy %s -> %s && git add\", src, dest)\n202\t        return\n203\t\n204\t    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n205\t    transcript_dir.mkdir(parents=True, exist_ok=True)\n206\t\n207\t    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n208\t    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n209\t\n210\t    # Copy (not move) so the repo-root transcript persists as a local-only\n211\t    # diagnostic even after this builtin runs. If the same PRD is re-run,\n212\t    # the runner overwrites the source file anyway.\n213\t    shutil.copy2(str(src), str(dest))\n214\t\n215\t    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n216\t    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n217\t\n218\t\n219\t@builtin(\"create_pr\")\n220\tdef create_pr(ctx: ExecutionContext) -> None:\n221\t    \"\"\"Open a pull request via ``gh pr create``.\n222\t\n223\t    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n224\t    acceptance criteria plus a link to the PRD file. Base branch:\n225\t    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n226\t    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n227\t    relative to ``ctx.repo_root``.\n228\t    \"\"\"\n229\t    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n230\t    body = _pr_body(ctx)\n231\t    if ctx.run_summary:\n232\t        body += \"\\n\\n\" + ctx.run_summary\n233\t    _scan_for_forbidden_attribution(title, source=f\"PR title for {ctx.prd.id}\")\n234\t    _scan_for_forbidden_attribution(body, source=f\"PR body for {ctx.prd.id}\")\n235\t\n236\t    if ctx.dry_run:\n237\t        ctx.logger.info(\n238\t            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n239\t            ctx.base_ref,\n240\t            title,\n241\t        )\n242\t        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n243\t        return\n244\t\n245\t    # Write the body to a temp file — passing long bodies via --body\n246\t    # can hit argv limits on some systems.\n247\t    import tempfile\n248\t\n249\t    with tempfile.NamedTemporaryFile(\n250\t        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n251\t    ) as body_file:\n252\t        body_file.write(body)\n253\t        body_path = body_file.name\n254\t\n255\t    try:\n256\t        result = subprocess.run(\n257\t            [\n258\t                \"gh\",\n259\t                \"pr\",\n260\t                \"create\",\n261\t                \"--base\",\n262\t                ctx.base_ref,\n263\t                \"--title\",\n264\t                title,\n265\t                \"--body-file\",\n266\t                body_path,\n267\t            ],\n268\t            cwd=str(ctx.cwd),\n269\t            check=True,\n270\t            capture_output=True,\n271\t            text=True,\n272\t        )\n273\t    finally:\n274\t        Path(body_path).unlink(missing_ok=True)\n275\t\n276\t    # gh prints the PR URL to stdout on success.\n277\t    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n278\t    ctx.pr_url = url_line or None\n279\t\n280\t\n281\t@builtin(\"lint_attribution\")\n282\tdef lint_attribution(ctx: ExecutionContext) -> None:\n283\t    \"\"\"Fail if any commit on the branch or the run summary credits Claude/Anthropic.\n284\t\n285\t    Scans:\n286\t\n287\t    - Every commit message in ``{base_ref}..HEAD`` on the current branch\n288\t    - ``ctx.run_summary`` (which feeds the PR body)\n289\t\n290\t    Intended to run after the agent + verification phases and before\n291\t    ``push_branch`` / ``create_pr``, so violations abort the workflow\n292\t    before anything lands on the remote or in a PR. Dry-run is a no-op\n293\t    because there are no real commits to scan.\n294\t    \"\"\"\n295\t    if ctx.dry_run:\n296\t        ctx.logger.info(\"[dry-run] lint_attribution: skipped\")\n297\t        return\n298\t\n299\t    _scan_for_forbidden_attribution(\n300\t        ctx.run_summary or \"\", source=f\"run summary for {ctx.prd.id}\"\n301\t    )\n302\t\n303\t    result = subprocess.run(\n304\t        [\"git\", \"log\", f\"{ctx.base_ref}..HEAD\", \"--format=%H%x00%B%x1e\"],\n305\t        cwd=str(ctx.cwd),\n306\t        check=True,\n307\t        capture_output=True,\n308\t        text=True,\n309\t    )\n310\t    # Record separator \\x1e between commits; field separator \\x00 between\n311\t    # sha and body. Keeps us robust against newlines in commit messages.\n312\t    for entry in result.stdout.split(\"\\x1e\"):\n313\t        entry = entry.strip()\n314\t        if not entry:\n315\t            continue\n316\t        sha, _, body = entry.partition(\"\\x00\")\n317\t        _scan_for_forbidden_attribution(\n318\t            body, source=f\"commit {sha[:12]} on {ctx.branch_name}\"\n319\t        )\n320\t\n321\t    ctx.logger.info(\"lint_attribution: clean\")\n322\t\n323\t\n324\t@builtin(\"cleanup_worktree\")\n325\tdef cleanup_worktree(ctx: ExecutionContext) -> None:\n326\t    \"\"\"Remove the worktree after a successful run.\n327\t\n328\t    Idempotent — if the worktree is already gone, logs and returns.\n329\t    Normally skipped during chain execution so downstream worktrees\n330\t    can base on this branch; called explicitly via ``prd cleanup``\n331\t    after the whole chain is done.\n332\t    \"\"\"\n333\t    if ctx.worktree_path is None:\n334\t        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n335\t        return\n336\t\n337\t    if not ctx.worktree_path.exists():\n338\t        ctx.logger.info(\n339\t            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n340\t        )\n341\t        return\n342\t\n343\t    cmd = [\n344\t        \"git\",\n345\t        \"-C\",\n346\t        str(ctx.repo_root),\n347\t        \"worktree\",\n348\t        \"remove\",\n349\t        str(ctx.worktree_path),\n350\t    ]\n351\t\n352\t    if ctx.dry_run:\n353\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n354\t        return\n355\t\n356\t    subprocess.run(cmd, check=True, capture_output=True, text=True)\n357\t"}]},"parent_tool_use_id":null,"session_id":"6b50696f-4176-4433-85d7-4ed6cbef93a8","uuid":"a2092f81-d8c1-4aff-a0b6-a0db710bed24","timestamp":"2026-04-09T03:26:24.080Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-549.7-move-summarize-agent-run/src/darkfactory/builtins/__init__.py","content":"\"\"\"Built-in task primitives — re-export hub.\n\nImports every submodule so @builtin-decorated functions register on\npackage import. Re-exports the public API for backwards compatibility.\n\nBuilt-ins are the deterministic SDLC operations that every workflow\nreferences by name: create a worktree, set a PRD's status, make a\ncommit, push a branch, open a PR. They live here (not in individual\nworkflow modules) because they're shared — every workflow uses the\nsame ``commit`` primitive, not a bespoke one.\n\nWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n\n    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n\nThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\nregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\nplus any formatted kwargs.\n\n**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\nanything destructive. In dry-run, we log what we WOULD do at INFO\nlevel and return. This is what powers ``prd plan`` and the default\n``prd run`` (without ``--execute``).\n\n**Subprocess discipline**: all shell commands use ``subprocess.run``\nwith an explicit argv list (never ``shell=True``), capture output,\nand check the return code. Git and gh invocations go through\n:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\nhandling and dry-run support.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport re\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom filelock import FileLock, Timeout\n\nfrom darkfactory import prd as prd_module\nfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\nfrom darkfactory.builtins._shared import (\n    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n    _run,\n    _scan_for_forbidden_attribution,\n)\nfrom darkfactory.builtins.set_status import set_status  # noqa: F401\nfrom darkfactory.checks import is_resume_safe\n\n_log = logging.getLogger(__name__)\n\nfrom darkfactory.workflow import ExecutionContext, Status\n\n_log = logging.getLogger(__name__)\n\n# Import submodules to trigger @builtin registration.\nfrom darkfactory.builtins.ensure_worktree import ensure_worktree  # noqa: E402\nfrom darkfactory.builtins.push_branch import push_branch  # noqa: E402\nfrom darkfactory.builtins.summarize_agent_run import summarize_agent_run  # noqa: E402\n\n__all__ = [\n    \"BUILTINS\",\n    \"BuiltInFunc\",\n    \"builtin\",\n    \"_run\",\n    \"_scan_for_forbidden_attribution\",\n    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n    \"ensure_worktree\",\n    \"set_status\",\n    \"commit\",\n    \"push_branch\",\n    \"summarize_agent_run\",\n    \"commit_transcript\",\n    \"create_pr\",\n    \"lint_attribution\",\n    \"cleanup_worktree\",\n]\n\n\n_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n\n\ndef _extract_acceptance_criteria(body: str) -> list[str]:\n    \"\"\"Pull acceptance criteria lines out of a PRD body.\n\n    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n    Returns a list of the criterion strings (without the checkbox\n    prefix). Used by ``create_pr`` to build the PR body's checklist.\n    \"\"\"\n    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n\n\ndef _pr_body(ctx: ExecutionContext) -> str:\n    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n    prd = ctx.prd\n    lines: list[str] = [\n        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n        \"\",\n    ]\n\n    acs = _extract_acceptance_criteria(prd.body)\n    if acs:\n        lines.append(\"## Acceptance criteria\")\n        lines.append(\"\")\n        for ac in acs:\n            lines.append(f\"- [ ] {ac}\")\n        lines.append(\"\")\n\n    lines.append(\"---\")\n    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n    return \"\\n\".join(lines)\n\n\n# ---------- built-in implementations ----------\n\n\n@builtin(\"commit\")\ndef commit(ctx: ExecutionContext, *, message: str) -> None:\n    \"\"\"Stage all changes and make a commit inside the worktree.\n\n    ``message`` is format-string expanded against the context so\n    ``\"chore(prd): {prd_id} start work\"`` becomes\n    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n    returns without erroring — workflows can safely commit after each\n    logical step without worrying about whether anything changed.\n    \"\"\"\n    formatted = ctx.format_string(message)\n    _scan_for_forbidden_attribution(\n        formatted, source=f\"commit message for {ctx.prd.id}\"\n    )\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n        return\n\n    # Stage everything\n    subprocess.run(\n        [\"git\", \"add\", \"-A\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n    # Check if there's anything to commit\n    diff_result = subprocess.run(\n        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n        cwd=str(ctx.cwd),\n        check=False,\n        capture_output=True,\n        text=True,\n    )\n    if diff_result.returncode == 0:\n        # No staged changes — skip gracefully.\n        ctx.logger.info(\"commit skipped: no changes to commit\")\n        return\n\n    # Commit\n    subprocess.run(\n        [\"git\", \"commit\", \"-m\", formatted],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n\n@builtin(\"commit_transcript\")\ndef commit_transcript(ctx: ExecutionContext) -> None:\n    \"\"\"Copy agent transcript into the worktree and stage it.\n\n    Source: ``<repo_root>/.harness-transcripts/{prd_id}.log`` written by the\n    runner after each agent invocation (outside any worktree — see\n    ``runner._run_agent``). Destination inside the worktree:\n    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n\n    The runner writes transcripts *outside* every worktree so ``git add -A``\n    can never accidentally sweep them. This builtin is the one place that\n    opts the transcript *into* the worktree — workflows that want the\n    transcript committed alongside the PRD work must include this builtin\n    explicitly. Workflows that omit it leave the transcript at the repo-root\n    path where it survives as a local-only diagnostic.\n\n    Timestamps use the wall-clock at the time this builtin runs, which is\n    unique enough for sequential runs. If no transcript exists (dry-run,\n    or the runner didn't produce one), this is a no-op.\n    \"\"\"\n    src = ctx.repo_root / \".harness-transcripts\" / f\"{ctx.prd.id}.log\"\n    if not src.exists():\n        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n        return\n\n    if ctx.dry_run:\n        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n        dest = (\n            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n        )\n        ctx.logger.info(\"[dry-run] copy %s -> %s && git add\", src, dest)\n        return\n\n    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n    transcript_dir.mkdir(parents=True, exist_ok=True)\n\n    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n\n    # Copy (not move) so the repo-root transcript persists as a local-only\n    # diagnostic even after this builtin runs. If the same PRD is re-run,\n    # the runner overwrites the source file anyway.\n    shutil.copy2(str(src), str(dest))\n\n    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n\n\n@builtin(\"create_pr\")\ndef create_pr(ctx: ExecutionContext) -> None:\n    \"\"\"Open a pull request via ``gh pr create``.\n\n    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n    acceptance criteria plus a link to the PRD file. Base branch:\n    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n    relative to ``ctx.repo_root``.\n    \"\"\"\n    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n    body = _pr_body(ctx)\n    if ctx.run_summary:\n        body += \"\\n\\n\" + ctx.run_summary\n    _scan_for_forbidden_attribution(title, source=f\"PR title for {ctx.prd.id}\")\n    _scan_for_forbidden_attribution(body, source=f\"PR body for {ctx.prd.id}\")\n\n    if ctx.dry_run:\n        ctx.logger.info(\n            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n            ctx.base_ref,\n            title,\n        )\n        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n        return\n\n    # Write the body to a temp file — passing long bodies via --body\n    # can hit argv limits on some systems.\n    import tempfile\n\n    with tempfile.NamedTemporaryFile(\n        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n    ) as body_file:\n        body_file.write(body)\n        body_path = body_file.name\n\n    try:\n        result = subprocess.run(\n            [\n                \"gh\",\n                \"pr\",\n                \"create\",\n                \"--base\",\n                ctx.base_ref,\n                \"--title\",\n                title,\n                \"--body-file\",\n                body_path,\n            ],\n            cwd=str(ctx.cwd),\n            check=True,\n            capture_output=True,\n            text=True,\n        )\n    finally:\n        Path(body_path).unlink(missing_ok=True)\n\n    # gh prints the PR URL to stdout on success.\n    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n    ctx.pr_url = url_line or None\n\n\n@builtin(\"lint_attribution\")\ndef lint_attribution(ctx: ExecutionContext) -> None:\n    \"\"\"Fail if any commit on the branch or the run summary credits Claude/Anthropic.\n\n    Scans:\n\n    - Every commit message in ``{base_ref}..HEAD`` on the current branch\n    - ``ctx.run_summary`` (which feeds the PR body)\n\n    Intended to run after the agent + verification phases and before\n    ``push_branch`` / ``create_pr``, so violations abort the workflow\n    before anything lands on the remote or in a PR. Dry-run is a no-op\n    because there are no real commits to scan.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] lint_attribution: skipped\")\n        return\n\n    _scan_for_forbidden_attribution(\n        ctx.run_summary or \"\", source=f\"run summary for {ctx.prd.id}\"\n    )\n\n    result = subprocess.run(\n        [\"git\", \"log\", f\"{ctx.base_ref}..HEAD\", \"--format=%H%x00%B%x1e\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n    # Record separator \\x1e between commits; field separator \\x00 between\n    # sha and body. Keeps us robust against newlines in commit messages.\n    for entry in result.stdout.split(\"\\x1e\"):\n        entry = entry.strip()\n        if not entry:\n            continue\n        sha, _, body = entry.partition(\"\\x00\")\n        _scan_for_forbidden_attribution(\n            body, source=f\"commit {sha[:12]} on {ctx.branch_name}\"\n        )\n\n    ctx.logger.info(\"lint_attribution: clean\")\n\n\n@builtin(\"cleanup_worktree\")\ndef cleanup_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Remove the worktree after a successful run.\n\n    Idempotent — if the worktree is already gone, logs and returns.\n    Normally skipped during chain execution so downstream worktrees\n    can base on this branch; called explicitly via ``prd cleanup``\n    after the whole chain is done.\n    \"\"\"\n    if ctx.worktree_path is None:\n        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n        return\n\n    if not ctx.worktree_path.exists():\n        ctx.logger.info(\n            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n        )\n        return\n\n    cmd = [\n        \"git\",\n        \"-C\",\n        str(ctx.repo_root),\n        \"worktree\",\n        \"remove\",\n        str(ctx.worktree_path),\n    ]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(cmd, check=True, capture_output=True, text=True)\n","numLines":357,"startLine":1,"totalLines":357}}}
