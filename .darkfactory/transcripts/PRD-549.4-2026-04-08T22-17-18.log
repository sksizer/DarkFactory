{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ERHa9cvUcPVKV7vkiMcwJ7","type":"tool_result","content":"1\t\"\"\"Built-in task primitives — re-export hub.\n2\t\n3\tImports every submodule so @builtin-decorated functions register on\n4\tpackage import. Re-exports the public API for backwards compatibility.\n5\t\n6\tBuilt-ins are the deterministic SDLC operations that every workflow\n7\treferences by name: create a worktree, set a PRD's status, make a\n8\tcommit, push a branch, open a PR. They live here (not in individual\n9\tworkflow modules) because they're shared — every workflow uses the\n10\tsame ``commit`` primitive, not a bespoke one.\n11\t\n12\tWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n13\t\n14\t    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n15\t\n16\tThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\n17\tregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\n18\tplus any formatted kwargs.\n19\t\n20\t**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\n21\tanything destructive. In dry-run, we log what we WOULD do at INFO\n22\tlevel and return. This is what powers ``prd plan`` and the default\n23\t``prd run`` (without ``--execute``).\n24\t\n25\t**Subprocess discipline**: all shell commands use ``subprocess.run``\n26\twith an explicit argv list (never ``shell=True``), capture output,\n27\tand check the return code. Git and gh invocations go through\n28\t:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\n29\thandling and dry-run support.\n30\t\"\"\"\n31\t\n32\tfrom __future__ import annotations\n33\t\n34\timport logging\n35\timport re\n36\timport shutil\n37\timport subprocess\n38\tfrom datetime import datetime\n39\tfrom pathlib import Path\n40\t\n41\tfrom filelock import FileLock, Timeout\n42\t\n43\tfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\n44\tfrom darkfactory.builtins._shared import (\n45\t    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n46\t    _run,\n47\t    _scan_for_forbidden_attribution,\n48\t)\n49\tfrom darkfactory.checks import is_resume_safe\n50\tfrom darkfactory.workflow import ExecutionContext\n51\t\n52\t_log = logging.getLogger(__name__)\n53\t\n54\t# Import submodules to trigger @builtin registration and re-export public names.\n55\tfrom darkfactory.builtins.set_status import set_status  # noqa: F401\n56\t\n57\t__all__ = [\n58\t    \"BUILTINS\",\n59\t    \"BuiltInFunc\",\n60\t    \"builtin\",\n61\t    \"_run\",\n62\t    \"_scan_for_forbidden_attribution\",\n63\t    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n64\t    \"ensure_worktree\",\n65\t    \"set_status\",\n66\t    \"commit\",\n67\t    \"push_branch\",\n68\t    \"summarize_agent_run\",\n69\t    \"commit_transcript\",\n70\t    \"create_pr\",\n71\t    \"lint_attribution\",\n72\t    \"cleanup_worktree\",\n73\t]\n74\t\n75\t\n76\t# ---------- internal helpers ----------\n77\t\n78\t\n79\tdef _worktree_target(ctx: ExecutionContext) -> Path:\n80\t    \"\"\"Compute the worktree path for this PRD under ``.worktrees/``.\n81\t\n82\t    Separated out so tests can assert the path without a whole\n83\t    subprocess invocation.\n84\t    \"\"\"\n85\t    return ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}-{ctx.prd.slug}\"\n86\t\n87\t\n88\tdef _branch_exists_local(repo_root: Path, branch: str) -> bool:\n89\t    \"\"\"Return True if ``branch`` exists in the local repo's refs.\"\"\"\n90\t    result = subprocess.run(\n91\t        [\n92\t            \"git\",\n93\t            \"-C\",\n94\t            str(repo_root),\n95\t            \"rev-parse\",\n96\t            \"--verify\",\n97\t            \"--quiet\",\n98\t            f\"refs/heads/{branch}\",\n99\t        ],\n100\t        capture_output=True,\n101\t        text=True,\n102\t    )\n103\t    return result.returncode == 0\n104\t\n105\t\n106\tdef _branch_exists_remote(repo_root: Path, branch: str) -> bool:\n107\t    \"\"\"Return True if ``branch`` exists on origin.\n108\t\n109\t    Best-effort: returns False (and logs a warning) on timeout or any\n110\t    subprocess error so the caller can fall back to the local check.\n111\t    \"\"\"\n112\t    try:\n113\t        result = subprocess.run(\n114\t            [\n115\t                \"git\",\n116\t                \"-C\",\n117\t                str(repo_root),\n118\t                \"ls-remote\",\n119\t                \"--exit-code\",\n120\t                \"origin\",\n121\t                f\"refs/heads/{branch}\",\n122\t            ],\n123\t            capture_output=True,\n124\t            text=True,\n125\t            timeout=10,\n126\t        )\n127\t    except subprocess.TimeoutExpired:\n128\t        _log.warning(\n129\t            \"git ls-remote timed out checking remote branch %r — skipping remote check\",\n130\t            branch,\n131\t        )\n132\t        return False\n133\t    except Exception as exc:\n134\t        _log.warning(\n135\t            \"git ls-remote failed checking remote branch %r (%s) — skipping remote check\",\n136\t            branch,\n137\t            exc,\n138\t        )\n139\t        return False\n140\t    return result.returncode == 0\n141\t\n142\t\n143\t_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n144\t\n145\t\n146\tdef _extract_acceptance_criteria(body: str) -> list[str]:\n147\t    \"\"\"Pull acceptance criteria lines out of a PRD body.\n148\t\n149\t    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n150\t    Returns a list of the criterion strings (without the checkbox\n151\t    prefix). Used by ``create_pr`` to build the PR body's checklist.\n152\t    \"\"\"\n153\t    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n154\t\n155\t\n156\tdef _pr_body(ctx: ExecutionContext) -> str:\n157\t    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n158\t    prd = ctx.prd\n159\t    lines: list[str] = [\n160\t        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n161\t        \"\",\n162\t    ]\n163\t\n164\t    acs = _extract_acceptance_criteria(prd.body)\n165\t    if acs:\n166\t        lines.append(\"## Acceptance criteria\")\n167\t        lines.append(\"\")\n168\t        for ac in acs:\n169\t            lines.append(f\"- [ ] {ac}\")\n170\t        lines.append(\"\")\n171\t\n172\t    lines.append(\"---\")\n173\t    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n174\t    return \"\\n\".join(lines)\n175\t\n176\t\n177\t# ---------- built-in implementations ----------\n178\t\n179\t\n180\t@builtin(\"ensure_worktree\")\n181\tdef ensure_worktree(ctx: ExecutionContext) -> None:\n182\t    \"\"\"Create (or resume) a git worktree for this PRD.\n183\t\n184\t    Target path: ``{repo_root}/.worktrees/{prd_id}-{slug}``. Branch:\n185\t    ``prd/{prd_id}-{slug}`` created from ``ctx.base_ref``. If the\n186\t    worktree already exists (previous run resumed), reuses it without\n187\t    re-creating. Sets ``ctx.worktree_path`` and ``ctx.cwd`` on success.\n188\t\n189\t    In live mode, acquires a per-PRD advisory file lock at\n190\t    ``.worktrees/{prd_id}.lock`` before any mutation so two concurrent\n191\t    ``prd run`` invocations for the same PRD fail fast with a clear\n192\t    message instead of racing. The lock is auto-released by the kernel\n193\t    when the process exits; the runner also releases it explicitly at the\n194\t    end of the run (see ``_release_worktree_lock``).\n195\t    \"\"\"\n196\t    worktree_path = _worktree_target(ctx)\n197\t    branch = ctx.branch_name\n198\t\n199\t    if ctx.dry_run:\n200\t        # Dry-run produces no side effects, so no lock needed.\n201\t        ctx.logger.info(\n202\t            \"[dry-run] git worktree add -b %s %s %s\",\n203\t            branch,\n204\t            worktree_path,\n205\t            ctx.base_ref,\n206\t        )\n207\t        ctx.worktree_path = worktree_path\n208\t        ctx.cwd = worktree_path\n209\t        return\n210\t\n211\t    # Acquire the lock BEFORE the resume-check or any mutation.\n212\t    # The lock file lives at .worktrees/PRD-X.lock and is per-PRD.\n213\t    lock_path = ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}.lock\"\n214\t    lock_path.parent.mkdir(parents=True, exist_ok=True)\n215\t\n216\t    lock = FileLock(str(lock_path))\n217\t    try:\n218\t        lock.acquire(timeout=0)  # non-blocking\n219\t    except Timeout:\n220\t        raise RuntimeError(\n221\t            f\"{ctx.prd.id} is already being worked on by another `prd run` \"\n222\t            f\"process (lock held on {lock_path}). If that process died, \"\n223\t            f\"the lock will auto-release when its file handle is reclaimed. \"\n224\t            f\"On a stuck lock, delete {lock_path} manually.\"\n225\t        ) from None\n226\t\n227\t    ctx._worktree_lock = lock\n228\t\n229\t    # ---- existing logic below, now lock-protected ----\n230\t    if worktree_path.exists():\n231\t        status = is_resume_safe(branch, ctx.repo_root)\n232\t        if not status.safe:\n233\t            lock.release()\n234\t            ctx._worktree_lock = None\n235\t            raise RuntimeError(status.reason)\n236\t        ctx.logger.info(\"resuming existing worktree: %s\", worktree_path)\n237\t        ctx.worktree_path = worktree_path\n238\t        ctx.cwd = worktree_path\n239\t        return\n240\t\n241\t    local_exists = _branch_exists_local(ctx.repo_root, branch)\n242\t    remote_exists = _branch_exists_remote(ctx.repo_root, branch)\n243\t    if local_exists or remote_exists:\n244\t        # Release the lock before raising so the error state is clean.\n245\t        lock.release()\n246\t        ctx._worktree_lock = None\n247\t        raise RuntimeError(\n248\t            f\"branch {branch!r} already exists but worktree {worktree_path} is gone. \"\n249\t            f\"Run `prd cleanup {ctx.prd.id}` to release it.\"\n250\t        )\n251\t\n252\t    # git worktree add -b <branch> <path> <base>\n253\t    # Run from the repo root, not from ctx.cwd (which may not be a git dir yet).\n254\t    subprocess.run(\n255\t        [\n256\t            \"git\",\n257\t            \"-C\",\n258\t            str(ctx.repo_root),\n259\t            \"worktree\",\n260\t            \"add\",\n261\t            \"-b\",\n262\t            branch,\n263\t            str(worktree_path),\n264\t            ctx.base_ref,\n265\t        ],\n266\t        check=True,\n267\t        capture_output=True,\n268\t        text=True,\n269\t    )\n270\t\n271\t    ctx.worktree_path = worktree_path\n272\t    ctx.cwd = worktree_path\n273\t\n274\t\n275\t@builtin(\"commit\")\n276\tdef commit(ctx: ExecutionContext, *, message: str) -> None:\n277\t    \"\"\"Stage all changes and make a commit inside the worktree.\n278\t\n279\t    ``message`` is format-string expanded against the context so\n280\t    ``\"chore(prd): {prd_id} start work\"`` becomes\n281\t    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n282\t    returns without erroring — workflows can safely commit after each\n283\t    logical step without worrying about whether anything changed.\n284\t    \"\"\"\n285\t    formatted = ctx.format_string(message)\n286\t    _scan_for_forbidden_attribution(\n287\t        formatted, source=f\"commit message for {ctx.prd.id}\"\n288\t    )\n289\t\n290\t    if ctx.dry_run:\n291\t        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n292\t        return\n293\t\n294\t    # Stage everything\n295\t    subprocess.run(\n296\t        [\"git\", \"add\", \"-A\"],\n297\t        cwd=str(ctx.cwd),\n298\t        check=True,\n299\t        capture_output=True,\n300\t        text=True,\n301\t    )\n302\t\n303\t    # Check if there's anything to commit\n304\t    diff_result = subprocess.run(\n305\t        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n306\t        cwd=str(ctx.cwd),\n307\t        check=False,\n308\t        capture_output=True,\n309\t        text=True,\n310\t    )\n311\t    if diff_result.returncode == 0:\n312\t        # No staged changes — skip gracefully.\n313\t        ctx.logger.info(\"commit skipped: no changes to commit\")\n314\t        return\n315\t\n316\t    # Commit\n317\t    subprocess.run(\n318\t        [\"git\", \"commit\", \"-m\", formatted],\n319\t        cwd=str(ctx.cwd),\n320\t        check=True,\n321\t        capture_output=True,\n322\t        text=True,\n323\t    )\n324\t\n325\t\n326\t@builtin(\"push_branch\")\n327\tdef push_branch(ctx: ExecutionContext) -> None:\n328\t    \"\"\"Push the current branch to origin with upstream tracking.\n329\t\n330\t    Runs ``git push -u origin {branch}`` inside the worktree. Required\n331\t    before :func:`create_pr` because ``gh pr create --base`` needs the\n332\t    remote to exist.\n333\t    \"\"\"\n334\t    cmd = [\"git\", \"push\", \"-u\", \"origin\", ctx.branch_name]\n335\t\n336\t    if ctx.dry_run:\n337\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n338\t        return\n339\t\n340\t    subprocess.run(\n341\t        cmd,\n342\t        cwd=str(ctx.cwd),\n343\t        check=True,\n344\t        capture_output=True,\n345\t        text=True,\n346\t    )\n347\t\n348\t\n349\tdef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n350\t    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n351\t    if not tool_counts:\n352\t        return \"none\"\n353\t    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n354\t\n355\t\n356\tdef _format_invocations(ctx: ExecutionContext) -> str:\n357\t    \"\"\"Format agent invocation count from context.\"\"\"\n358\t    count = ctx.invoke_count\n359\t    if count == 0:\n360\t        return \"0\"\n361\t    if count == 1:\n362\t        return \"1\"\n363\t    return str(count)\n364\t\n365\t\n366\t@builtin(\"summarize_agent_run\")\n367\tdef summarize_agent_run(ctx: ExecutionContext) -> None:\n368\t    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n369\t    result = ctx.last_invoke_result\n370\t    if result is None:\n371\t        return\n372\t\n373\t    lines = [\n374\t        \"## Harness execution summary\",\n375\t        \"\",\n376\t        f\"- **Workflow:** {ctx.workflow.name}\",\n377\t        f\"- **Model:** {ctx.model or 'unknown'}\",\n378\t        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n379\t        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n380\t        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n381\t    ]\n382\t    ctx.run_summary = \"\\n\".join(lines)\n383\t\n384\t\n385\t@builtin(\"commit_transcript\")\n386\tdef commit_transcript(ctx: ExecutionContext) -> None:\n387\t    \"\"\"Move agent transcript to .darkfactory/transcripts/ and stage it.\n388\t\n389\t    Source: ``.harness-agent-output.log`` written by the runner after each\n390\t    agent invocation. Destination:\n391\t    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n392\t\n393\t    Timestamps use the wall-clock at the time this builtin runs, which is\n394\t    unique enough for sequential runs. If no transcript exists (dry-run,\n395\t    or the runner didn't produce one), this is a no-op.\n396\t    \"\"\"\n397\t    src = ctx.cwd / \".harness-agent-output.log\"\n398\t    if not src.exists():\n399\t        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n400\t        return\n401\t\n402\t    if ctx.dry_run:\n403\t        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n404\t        dest = (\n405\t            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n406\t        )\n407\t        ctx.logger.info(\"[dry-run] move %s -> %s && git add\", src, dest)\n408\t        return\n409\t\n410\t    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n411\t    transcript_dir.mkdir(parents=True, exist_ok=True)\n412\t\n413\t    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n414\t    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n415\t\n416\t    shutil.move(str(src), str(dest))\n417\t\n418\t    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n419\t    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n420\t\n421\t\n422\t@builtin(\"create_pr\")\n423\tdef create_pr(ctx: ExecutionContext) -> None:\n424\t    \"\"\"Open a pull request via ``gh pr create``.\n425\t\n426\t    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n427\t    acceptance criteria plus a link to the PRD file. Base branch:\n428\t    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n429\t    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n430\t    relative to ``ctx.repo_root``.\n431\t    \"\"\"\n432\t    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n433\t    body = _pr_body(ctx)\n434\t    if ctx.run_summary:\n435\t        body += \"\\n\\n\" + ctx.run_summary\n436\t    _scan_for_forbidden_attribution(title, source=f\"PR title for {ctx.prd.id}\")\n437\t    _scan_for_forbidden_attribution(body, source=f\"PR body for {ctx.prd.id}\")\n438\t\n439\t    if ctx.dry_run:\n440\t        ctx.logger.info(\n441\t            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n442\t            ctx.base_ref,\n443\t            title,\n444\t        )\n445\t        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n446\t        return\n447\t\n448\t    # Write the body to a temp file — passing long bodies via --body\n449\t    # can hit argv limits on some systems.\n450\t    import tempfile\n451\t\n452\t    with tempfile.NamedTemporaryFile(\n453\t        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n454\t    ) as body_file:\n455\t        body_file.write(body)\n456\t        body_path = body_file.name\n457\t\n458\t    try:\n459\t        result = subprocess.run(\n460\t            [\n461\t                \"gh\",\n462\t                \"pr\",\n463\t                \"create\",\n464\t                \"--base\",\n465\t                ctx.base_ref,\n466\t                \"--title\",\n467\t                title,\n468\t                \"--body-file\",\n469\t                body_path,\n470\t            ],\n471\t            cwd=str(ctx.cwd),\n472\t            check=True,\n473\t            capture_output=True,\n474\t            text=True,\n475\t        )\n476\t    finally:\n477\t        Path(body_path).unlink(missing_ok=True)\n478\t\n479\t    # gh prints the PR URL to stdout on success.\n480\t    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n481\t    ctx.pr_url = url_line or None\n482\t\n483\t\n484\t@builtin(\"lint_attribution\")\n485\tdef lint_attribution(ctx: ExecutionContext) -> None:\n486\t    \"\"\"Fail if any commit on the branch or the run summary credits Claude/Anthropic.\n487\t\n488\t    Scans:\n489\t\n490\t    - Every commit message in ``{base_ref}..HEAD`` on the current branch\n491\t    - ``ctx.run_summary`` (which feeds the PR body)\n492\t\n493\t    Intended to run after the agent + verification phases and before\n494\t    ``push_branch`` / ``create_pr``, so violations abort the workflow\n495\t    before anything lands on the remote or in a PR. Dry-run is a no-op\n496\t    because there are no real commits to scan.\n497\t    \"\"\"\n498\t    if ctx.dry_run:\n499\t        ctx.logger.info(\"[dry-run] lint_attribution: skipped\")\n500\t        return\n501\t\n502\t    _scan_for_forbidden_attribution(\n503\t        ctx.run_summary or \"\", source=f\"run summary for {ctx.prd.id}\"\n504\t    )\n505\t\n506\t    result = subprocess.run(\n507\t        [\"git\", \"log\", f\"{ctx.base_ref}..HEAD\", \"--format=%H%x00%B%x1e\"],\n508\t        cwd=str(ctx.cwd),\n509\t        check=True,\n510\t        capture_output=True,\n511\t        text=True,\n512\t    )\n513\t    # Record separator \\x1e between commits; field separator \\x00 between\n514\t    # sha and body. Keeps us robust against newlines in commit messages.\n515\t    for entry in result.stdout.split(\"\\x1e\"):\n516\t        entry = entry.strip()\n517\t        if not entry:\n518\t            continue\n519\t        sha, _, body = entry.partition(\"\\x00\")\n520\t        _scan_for_forbidden_attribution(\n521\t            body, source=f\"commit {sha[:12]} on {ctx.branch_name}\"\n522\t        )\n523\t\n524\t    ctx.logger.info(\"lint_attribution: clean\")\n525\t\n526\t\n527\t@builtin(\"cleanup_worktree\")\n528\tdef cleanup_worktree(ctx: ExecutionContext) -> None:\n529\t    \"\"\"Remove the worktree after a successful run.\n530\t\n531\t    Idempotent — if the worktree is already gone, logs and returns.\n532\t    Normally skipped during chain execution so downstream worktrees\n533\t    can base on this branch; called explicitly via ``prd cleanup``\n534\t    after the whole chain is done.\n535\t    \"\"\"\n536\t    if ctx.worktree_path is None:\n537\t        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n538\t        return\n539\t\n540\t    if not ctx.worktree_path.exists():\n541\t        ctx.logger.info(\n542\t            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n543\t        )\n544\t        return\n545\t\n546\t    cmd = [\n547\t        \"git\",\n548\t        \"-C\",\n549\t        str(ctx.repo_root),\n550\t        \"worktree\",\n551\t        \"remove\",\n552\t        str(ctx.worktree_path),\n553\t    ]\n554\t\n555\t    if ctx.dry_run:\n556\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n557\t        return\n558\t\n559\t    subprocess.run(cmd, check=True, capture_output=True, text=True)\n560\t"}]},"parent_tool_use_id":null,"session_id":"c4afb51e-b2d8-4585-8ae9-a5d434b76abc","uuid":"d89a2fb9-c112-4df3-805c-5d1c83ca3f6b","timestamp":"2026-04-09T03:16:54.703Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-549.4-move-set-status/src/darkfactory/builtins/__init__.py","content":"\"\"\"Built-in task primitives — re-export hub.\n\nImports every submodule so @builtin-decorated functions register on\npackage import. Re-exports the public API for backwards compatibility.\n\nBuilt-ins are the deterministic SDLC operations that every workflow\nreferences by name: create a worktree, set a PRD's status, make a\ncommit, push a branch, open a PR. They live here (not in individual\nworkflow modules) because they're shared — every workflow uses the\nsame ``commit`` primitive, not a bespoke one.\n\nWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n\n    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n\nThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\nregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\nplus any formatted kwargs.\n\n**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\nanything destructive. In dry-run, we log what we WOULD do at INFO\nlevel and return. This is what powers ``prd plan`` and the default\n``prd run`` (without ``--execute``).\n\n**Subprocess discipline**: all shell commands use ``subprocess.run``\nwith an explicit argv list (never ``shell=True``), capture output,\nand check the return code. Git and gh invocations go through\n:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\nhandling and dry-run support.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport re\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom filelock import FileLock, Timeout\n\nfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\nfrom darkfactory.builtins._shared import (\n    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n    _run,\n    _scan_for_forbidden_attribution,\n)\nfrom darkfactory.checks import is_resume_safe\nfrom darkfactory.workflow import ExecutionContext\n\n_log = logging.getLogger(__name__)\n\n# Import submodules to trigger @builtin registration and re-export public names.\nfrom darkfactory.builtins.set_status import set_status  # noqa: F401\n\n__all__ = [\n    \"BUILTINS\",\n    \"BuiltInFunc\",\n    \"builtin\",\n    \"_run\",\n    \"_scan_for_forbidden_attribution\",\n    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n    \"ensure_worktree\",\n    \"set_status\",\n    \"commit\",\n    \"push_branch\",\n    \"summarize_agent_run\",\n    \"commit_transcript\",\n    \"create_pr\",\n    \"lint_attribution\",\n    \"cleanup_worktree\",\n]\n\n\n# ---------- internal helpers ----------\n\n\ndef _worktree_target(ctx: ExecutionContext) -> Path:\n    \"\"\"Compute the worktree path for this PRD under ``.worktrees/``.\n\n    Separated out so tests can assert the path without a whole\n    subprocess invocation.\n    \"\"\"\n    return ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}-{ctx.prd.slug}\"\n\n\ndef _branch_exists_local(repo_root: Path, branch: str) -> bool:\n    \"\"\"Return True if ``branch`` exists in the local repo's refs.\"\"\"\n    result = subprocess.run(\n        [\n            \"git\",\n            \"-C\",\n            str(repo_root),\n            \"rev-parse\",\n            \"--verify\",\n            \"--quiet\",\n            f\"refs/heads/{branch}\",\n        ],\n        capture_output=True,\n        text=True,\n    )\n    return result.returncode == 0\n\n\ndef _branch_exists_remote(repo_root: Path, branch: str) -> bool:\n    \"\"\"Return True if ``branch`` exists on origin.\n\n    Best-effort: returns False (and logs a warning) on timeout or any\n    subprocess error so the caller can fall back to the local check.\n    \"\"\"\n    try:\n        result = subprocess.run(\n            [\n                \"git\",\n                \"-C\",\n                str(repo_root),\n                \"ls-remote\",\n                \"--exit-code\",\n                \"origin\",\n                f\"refs/heads/{branch}\",\n            ],\n            capture_output=True,\n            text=True,\n            timeout=10,\n        )\n    except subprocess.TimeoutExpired:\n        _log.warning(\n            \"git ls-remote timed out checking remote branch %r — skipping remote check\",\n            branch,\n        )\n        return False\n    except Exception as exc:\n        _log.warning(\n            \"git ls-remote failed checking remote branch %r (%s) — skipping remote check\",\n            branch,\n            exc,\n        )\n        return False\n    return result.returncode == 0\n\n\n_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n\n\ndef _extract_acceptance_criteria(body: str) -> list[str]:\n    \"\"\"Pull acceptance criteria lines out of a PRD body.\n\n    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n    Returns a list of the criterion strings (without the checkbox\n    prefix). Used by ``create_pr`` to build the PR body's checklist.\n    \"\"\"\n    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n\n\ndef _pr_body(ctx: ExecutionContext) -> str:\n    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n    prd = ctx.prd\n    lines: list[str] = [\n        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n        \"\",\n    ]\n\n    acs = _extract_acceptance_criteria(prd.body)\n    if acs:\n        lines.append(\"## Acceptance criteria\")\n        lines.append(\"\")\n        for ac in acs:\n            lines.append(f\"- [ ] {ac}\")\n        lines.append(\"\")\n\n    lines.append(\"---\")\n    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n    return \"\\n\".join(lines)\n\n\n# ---------- built-in implementations ----------\n\n\n@builtin(\"ensure_worktree\")\ndef ensure_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Create (or resume) a git worktree for this PRD.\n\n    Target path: ``{repo_root}/.worktrees/{prd_id}-{slug}``. Branch:\n    ``prd/{prd_id}-{slug}`` created from ``ctx.base_ref``. If the\n    worktree already exists (previous run resumed), reuses it without\n    re-creating. Sets ``ctx.worktree_path`` and ``ctx.cwd`` on success.\n\n    In live mode, acquires a per-PRD advisory file lock at\n    ``.worktrees/{prd_id}.lock`` before any mutation so two concurrent\n    ``prd run`` invocations for the same PRD fail fast with a clear\n    message instead of racing. The lock is auto-released by the kernel\n    when the process exits; the runner also releases it explicitly at the\n    end of the run (see ``_release_worktree_lock``).\n    \"\"\"\n    worktree_path = _worktree_target(ctx)\n    branch = ctx.branch_name\n\n    if ctx.dry_run:\n        # Dry-run produces no side effects, so no lock needed.\n        ctx.logger.info(\n            \"[dry-run] git worktree add -b %s %s %s\",\n            branch,\n            worktree_path,\n            ctx.base_ref,\n        )\n        ctx.worktree_path = worktree_path\n        ctx.cwd = worktree_path\n        return\n\n    # Acquire the lock BEFORE the resume-check or any mutation.\n    # The lock file lives at .worktrees/PRD-X.lock and is per-PRD.\n    lock_path = ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}.lock\"\n    lock_path.parent.mkdir(parents=True, exist_ok=True)\n\n    lock = FileLock(str(lock_path))\n    try:\n        lock.acquire(timeout=0)  # non-blocking\n    except Timeout:\n        raise RuntimeError(\n            f\"{ctx.prd.id} is already being worked on by another `prd run` \"\n            f\"process (lock held on {lock_path}). If that process died, \"\n            f\"the lock will auto-release when its file handle is reclaimed. \"\n            f\"On a stuck lock, delete {lock_path} manually.\"\n        ) from None\n\n    ctx._worktree_lock = lock\n\n    # ---- existing logic below, now lock-protected ----\n    if worktree_path.exists():\n        status = is_resume_safe(branch, ctx.repo_root)\n        if not status.safe:\n            lock.release()\n            ctx._worktree_lock = None\n            raise RuntimeError(status.reason)\n        ctx.logger.info(\"resuming existing worktree: %s\", worktree_path)\n        ctx.worktree_path = worktree_path\n        ctx.cwd = worktree_path\n        return\n\n    local_exists = _branch_exists_local(ctx.repo_root, branch)\n    remote_exists = _branch_exists_remote(ctx.repo_root, branch)\n    if local_exists or remote_exists:\n        # Release the lock before raising so the error state is clean.\n        lock.release()\n        ctx._worktree_lock = None\n        raise RuntimeError(\n            f\"branch {branch!r} already exists but worktree {worktree_path} is gone. \"\n            f\"Run `prd cleanup {ctx.prd.id}` to release it.\"\n        )\n\n    # git worktree add -b <branch> <path> <base>\n    # Run from the repo root, not from ctx.cwd (which may not be a git dir yet).\n    subprocess.run(\n        [\n            \"git\",\n            \"-C\",\n            str(ctx.repo_root),\n            \"worktree\",\n            \"add\",\n            \"-b\",\n            branch,\n            str(worktree_path),\n            ctx.base_ref,\n        ],\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n    ctx.worktree_path = worktree_path\n    ctx.cwd = worktree_path\n\n\n@builtin(\"commit\")\ndef commit(ctx: ExecutionContext, *, message: str) -> None:\n    \"\"\"Stage all changes and make a commit inside the worktree.\n\n    ``message`` is format-string expanded against the context so\n    ``\"chore(prd): {prd_id} start work\"`` becomes\n    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n    returns without erroring — workflows can safely commit after each\n    logical step without worrying about whether anything changed.\n    \"\"\"\n    formatted = ctx.format_string(message)\n    _scan_for_forbidden_attribution(\n        formatted, source=f\"commit message for {ctx.prd.id}\"\n    )\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n        return\n\n    # Stage everything\n    subprocess.run(\n        [\"git\", \"add\", \"-A\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n    # Check if there's anything to commit\n    diff_result = subprocess.run(\n        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n        cwd=str(ctx.cwd),\n        check=False,\n        capture_output=True,\n        text=True,\n    )\n    if diff_result.returncode == 0:\n        # No staged changes — skip gracefully.\n        ctx.logger.info(\"commit skipped: no changes to commit\")\n        return\n\n    # Commit\n    subprocess.run(\n        [\"git\", \"commit\", \"-m\", formatted],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n\n@builtin(\"push_branch\")\ndef push_branch(ctx: ExecutionContext) -> None:\n    \"\"\"Push the current branch to origin with upstream tracking.\n\n    Runs ``git push -u origin {branch}`` inside the worktree. Required\n    before :func:`create_pr` because ``gh pr create --base`` needs the\n    remote to exist.\n    \"\"\"\n    cmd = [\"git\", \"push\", \"-u\", \"origin\", ctx.branch_name]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(\n        cmd,\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n\ndef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n    if not tool_counts:\n        return \"none\"\n    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n\n\ndef _format_invocations(ctx: ExecutionContext) -> str:\n    \"\"\"Format agent invocation count from context.\"\"\"\n    count = ctx.invoke_count\n    if count == 0:\n        return \"0\"\n    if count == 1:\n        return \"1\"\n    return str(count)\n\n\n@builtin(\"summarize_agent_run\")\ndef summarize_agent_run(ctx: ExecutionContext) -> None:\n    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n    result = ctx.last_invoke_result\n    if result is None:\n        return\n\n    lines = [\n        \"## Harness execution summary\",\n        \"\",\n        f\"- **Workflow:** {ctx.workflow.name}\",\n        f\"- **Model:** {ctx.model or 'unknown'}\",\n        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n    ]\n    ctx.run_summary = \"\\n\".join(lines)\n\n\n@builtin(\"commit_transcript\")\ndef commit_transcript(ctx: ExecutionContext) -> None:\n    \"\"\"Move agent transcript to .darkfactory/transcripts/ and stage it.\n\n    Source: ``.harness-agent-output.log`` written by the runner after each\n    agent invocation. Destination:\n    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n\n    Timestamps use the wall-clock at the time this builtin runs, which is\n    unique enough for sequential runs. If no transcript exists (dry-run,\n    or the runner didn't produce one), this is a no-op.\n    \"\"\"\n    src = ctx.cwd / \".harness-agent-output.log\"\n    if not src.exists():\n        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n        return\n\n    if ctx.dry_run:\n        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n        dest = (\n            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n        )\n        ctx.logger.info(\"[dry-run] move %s -> %s && git add\", src, dest)\n        return\n\n    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n    transcript_dir.mkdir(parents=True, exist_ok=True)\n\n    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n\n    shutil.move(str(src), str(dest))\n\n    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n\n\n@builtin(\"create_pr\")\ndef create_pr(ctx: ExecutionContext) -> None:\n    \"\"\"Open a pull request via ``gh pr create``.\n\n    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n    acceptance criteria plus a link to the PRD file. Base branch:\n    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n    relative to ``ctx.repo_root``.\n    \"\"\"\n    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n    body = _pr_body(ctx)\n    if ctx.run_summary:\n        body += \"\\n\\n\" + ctx.run_summary\n    _scan_for_forbidden_attribution(title, source=f\"PR title for {ctx.prd.id}\")\n    _scan_for_forbidden_attribution(body, source=f\"PR body for {ctx.prd.id}\")\n\n    if ctx.dry_run:\n        ctx.logger.info(\n            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n            ctx.base_ref,\n            title,\n        )\n        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n        return\n\n    # Write the body to a temp file — passing long bodies via --body\n    # can hit argv limits on some systems.\n    import tempfile\n\n    with tempfile.NamedTemporaryFile(\n        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n    ) as body_file:\n        body_file.write(body)\n        body_path = body_file.name\n\n    try:\n        result = subprocess.run(\n            [\n                \"gh\",\n                \"pr\",\n                \"create\",\n                \"--base\",\n                ctx.base_ref,\n                \"--title\",\n                title,\n                \"--body-file\",\n                body_path,\n            ],\n            cwd=str(ctx.cwd),\n            check=True,\n            capture_output=True,\n            text=True,\n        )\n    finally:\n        Path(body_path).unlink(missing_ok=True)\n\n    # gh prints the PR URL to stdout on success.\n    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n    ctx.pr_url = url_line or None\n\n\n@builtin(\"lint_attribution\")\ndef lint_attribution(ctx: ExecutionContext) -> None:\n    \"\"\"Fail if any commit on the branch or the run summary credits Claude/Anthropic.\n\n    Scans:\n\n    - Every commit message in ``{base_ref}..HEAD`` on the current branch\n    - ``ctx.run_summary`` (which feeds the PR body)\n\n    Intended to run after the agent + verification phases and before\n    ``push_branch`` / ``create_pr``, so violations abort the workflow\n    before anything lands on the remote or in a PR. Dry-run is a no-op\n    because there are no real commits to scan.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] lint_attribution: skipped\")\n        return\n\n    _scan_for_forbidden_attribution(\n        ctx.run_summary or \"\", source=f\"run summary for {ctx.prd.id}\"\n    )\n\n    result = subprocess.run(\n        [\"git\", \"log\", f\"{ctx.base_ref}..HEAD\", \"--format=%H%x00%B%x1e\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n    # Record separator \\x1e between commits; field separator \\x00 between\n    # sha and body. Keeps us robust against newlines in commit messages.\n    for entry in result.stdout.split(\"\\x1e\"):\n        entry = entry.strip()\n        if not entry:\n            continue\n        sha, _, body = entry.partition(\"\\x00\")\n        _scan_for_forbidden_attribution(\n            body, source=f\"commit {sha[:12]} on {ctx.branch_name}\"\n        )\n\n    ctx.logger.info(\"lint_attribution: clean\")\n\n\n@builtin(\"cleanup_worktree\")\ndef cleanup_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Remove the worktree after a successful run.\n\n    Idempotent — if the worktree is already gone, logs and returns.\n    Normally skipped during chain execution so downstream worktrees\n    can base on this branch; called explicitly via ``prd cleanup``\n    after the whole chain is done.\n    \"\"\"\n    if ctx.worktree_path is None:\n        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n        return\n\n    if not ctx.worktree_path.exists():\n        ctx.logger.info(\n            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n        )\n        return\n\n    cmd = [\n        \"git\",\n        \"-C\",\n        str(ctx.repo_root),\n        \"worktree\",\n        \"remove\",\n        str(ctx.worktree_path),\n    ]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(cmd, check=True, capture_output=True, text=True)\n","numLines":560,"startLine":1,"totalLines":560}}}
