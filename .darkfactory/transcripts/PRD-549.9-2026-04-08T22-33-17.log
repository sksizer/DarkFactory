{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RunMAXEG483KpqwpuZtX6A","type":"tool_result","content":"1\t\"\"\"Built-in task primitives — re-export hub.\n2\t\n3\tImports every submodule so @builtin-decorated functions register on\n4\tpackage import. Re-exports the public API for backwards compatibility.\n5\t\n6\tBuilt-ins are the deterministic SDLC operations that every workflow\n7\treferences by name: create a worktree, set a PRD's status, make a\n8\tcommit, push a branch, open a PR. They live here (not in individual\n9\tworkflow modules) because they're shared — every workflow uses the\n10\tsame ``commit`` primitive, not a bespoke one.\n11\t\n12\tWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n13\t\n14\t    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n15\t\n16\tThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\n17\tregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\n18\tplus any formatted kwargs.\n19\t\n20\t**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\n21\tanything destructive. In dry-run, we log what we WOULD do at INFO\n22\tlevel and return. This is what powers ``prd plan`` and the default\n23\t``prd run`` (without ``--execute``).\n24\t\n25\t**Subprocess discipline**: all shell commands use ``subprocess.run``\n26\twith an explicit argv list (never ``shell=True``), capture output,\n27\tand check the return code. Git and gh invocations go through\n28\t:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\n29\thandling and dry-run support.\n30\t\"\"\"\n31\t\n32\tfrom __future__ import annotations\n33\t\n34\timport logging\n35\timport shutil\n36\timport subprocess\n37\tfrom datetime import datetime\n38\tfrom pathlib import Path\n39\t\n40\tfrom filelock import FileLock, Timeout\n41\t\n42\tfrom darkfactory import prd as prd_module\n43\tfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\n44\tfrom darkfactory.builtins._shared import (\n45\t    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n46\t    _run,\n47\t    _scan_for_forbidden_attribution,\n48\t)\n49\tfrom darkfactory.builtins.set_status import set_status  # noqa: F401\n50\tfrom darkfactory.checks import is_resume_safe\n51\t\n52\t_log = logging.getLogger(__name__)\n53\t\n54\tfrom darkfactory.workflow import ExecutionContext, Status\n55\t\n56\t_log = logging.getLogger(__name__)\n57\t\n58\t# Import submodules to trigger @builtin registration.\n59\tfrom darkfactory.builtins.commit import commit  # noqa: E402\n60\tfrom darkfactory.builtins.create_pr import create_pr  # noqa: E402\n61\tfrom darkfactory.builtins.ensure_worktree import ensure_worktree  # noqa: E402\n62\tfrom darkfactory.builtins.push_branch import push_branch  # noqa: E402\n63\t\n64\t__all__ = [\n65\t    \"BUILTINS\",\n66\t    \"BuiltInFunc\",\n67\t    \"builtin\",\n68\t    \"_run\",\n69\t    \"_scan_for_forbidden_attribution\",\n70\t    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n71\t    \"ensure_worktree\",\n72\t    \"set_status\",\n73\t    \"commit\",\n74\t    \"push_branch\",\n75\t    \"summarize_agent_run\",\n76\t    \"commit_transcript\",\n77\t    \"create_pr\",\n78\t    \"lint_attribution\",\n79\t    \"cleanup_worktree\",\n80\t]\n81\t\n82\t\n83\t# ---------- built-in implementations ----------\n84\t\n85\t\n86\tdef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n87\t    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n88\t    if not tool_counts:\n89\t        return \"none\"\n90\t    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n91\t\n92\t\n93\tdef _format_invocations(ctx: ExecutionContext) -> str:\n94\t    \"\"\"Format agent invocation count from context.\"\"\"\n95\t    count = ctx.invoke_count\n96\t    if count == 0:\n97\t        return \"0\"\n98\t    if count == 1:\n99\t        return \"1\"\n100\t    return str(count)\n101\t\n102\t\n103\t@builtin(\"summarize_agent_run\")\n104\tdef summarize_agent_run(ctx: ExecutionContext) -> None:\n105\t    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n106\t    result = ctx.last_invoke_result\n107\t    if result is None:\n108\t        return\n109\t\n110\t    lines = [\n111\t        \"## Harness execution summary\",\n112\t        \"\",\n113\t        f\"- **Workflow:** {ctx.workflow.name}\",\n114\t        f\"- **Model:** {ctx.model or 'unknown'}\",\n115\t        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n116\t        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n117\t        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n118\t    ]\n119\t    ctx.run_summary = \"\\n\".join(lines)\n120\t\n121\t\n122\t@builtin(\"commit_transcript\")\n123\tdef commit_transcript(ctx: ExecutionContext) -> None:\n124\t    \"\"\"Copy agent transcript into the worktree and stage it.\n125\t\n126\t    Source: ``<repo_root>/.harness-transcripts/{prd_id}.log`` written by the\n127\t    runner after each agent invocation (outside any worktree — see\n128\t    ``runner._run_agent``). Destination inside the worktree:\n129\t    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n130\t\n131\t    The runner writes transcripts *outside* every worktree so ``git add -A``\n132\t    can never accidentally sweep them. This builtin is the one place that\n133\t    opts the transcript *into* the worktree — workflows that want the\n134\t    transcript committed alongside the PRD work must include this builtin\n135\t    explicitly. Workflows that omit it leave the transcript at the repo-root\n136\t    path where it survives as a local-only diagnostic.\n137\t\n138\t    Timestamps use the wall-clock at the time this builtin runs, which is\n139\t    unique enough for sequential runs. If no transcript exists (dry-run,\n140\t    or the runner didn't produce one), this is a no-op.\n141\t    \"\"\"\n142\t    src = ctx.repo_root / \".harness-transcripts\" / f\"{ctx.prd.id}.log\"\n143\t    if not src.exists():\n144\t        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n145\t        return\n146\t\n147\t    if ctx.dry_run:\n148\t        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n149\t        dest = (\n150\t            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n151\t        )\n152\t        ctx.logger.info(\"[dry-run] copy %s -> %s && git add\", src, dest)\n153\t        return\n154\t\n155\t    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n156\t    transcript_dir.mkdir(parents=True, exist_ok=True)\n157\t\n158\t    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n159\t    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n160\t\n161\t    # Copy (not move) so the repo-root transcript persists as a local-only\n162\t    # diagnostic even after this builtin runs. If the same PRD is re-run,\n163\t    # the runner overwrites the source file anyway.\n164\t    shutil.copy2(str(src), str(dest))\n165\t\n166\t    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n167\t    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n168\t\n169\t\n170\t@builtin(\"lint_attribution\")\n171\tdef lint_attribution(ctx: ExecutionContext) -> None:\n172\t    \"\"\"Fail if any commit on the branch or the run summary credits Claude/Anthropic.\n173\t\n174\t    Scans:\n175\t\n176\t    - Every commit message in ``{base_ref}..HEAD`` on the current branch\n177\t    - ``ctx.run_summary`` (which feeds the PR body)\n178\t\n179\t    Intended to run after the agent + verification phases and before\n180\t    ``push_branch`` / ``create_pr``, so violations abort the workflow\n181\t    before anything lands on the remote or in a PR. Dry-run is a no-op\n182\t    because there are no real commits to scan.\n183\t    \"\"\"\n184\t    if ctx.dry_run:\n185\t        ctx.logger.info(\"[dry-run] lint_attribution: skipped\")\n186\t        return\n187\t\n188\t    _scan_for_forbidden_attribution(\n189\t        ctx.run_summary or \"\", source=f\"run summary for {ctx.prd.id}\"\n190\t    )\n191\t\n192\t    result = subprocess.run(\n193\t        [\"git\", \"log\", f\"{ctx.base_ref}..HEAD\", \"--format=%H%x00%B%x1e\"],\n194\t        cwd=str(ctx.cwd),\n195\t        check=True,\n196\t        capture_output=True,\n197\t        text=True,\n198\t    )\n199\t    # Record separator \\x1e between commits; field separator \\x00 between\n200\t    # sha and body. Keeps us robust against newlines in commit messages.\n201\t    for entry in result.stdout.split(\"\\x1e\"):\n202\t        entry = entry.strip()\n203\t        if not entry:\n204\t            continue\n205\t        sha, _, body = entry.partition(\"\\x00\")\n206\t        _scan_for_forbidden_attribution(\n207\t            body, source=f\"commit {sha[:12]} on {ctx.branch_name}\"\n208\t        )\n209\t\n210\t    ctx.logger.info(\"lint_attribution: clean\")\n211\t\n212\t\n213\t@builtin(\"cleanup_worktree\")\n214\tdef cleanup_worktree(ctx: ExecutionContext) -> None:\n215\t    \"\"\"Remove the worktree after a successful run.\n216\t\n217\t    Idempotent — if the worktree is already gone, logs and returns.\n218\t    Normally skipped during chain execution so downstream worktrees\n219\t    can base on this branch; called explicitly via ``prd cleanup``\n220\t    after the whole chain is done.\n221\t    \"\"\"\n222\t    if ctx.worktree_path is None:\n223\t        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n224\t        return\n225\t\n226\t    if not ctx.worktree_path.exists():\n227\t        ctx.logger.info(\n228\t            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n229\t        )\n230\t        return\n231\t\n232\t    cmd = [\n233\t        \"git\",\n234\t        \"-C\",\n235\t        str(ctx.repo_root),\n236\t        \"worktree\",\n237\t        \"remove\",\n238\t        str(ctx.worktree_path),\n239\t    ]\n240\t\n241\t    if ctx.dry_run:\n242\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n243\t        return\n244\t\n245\t    subprocess.run(cmd, check=True, capture_output=True, text=True)\n246\t"}]},"parent_tool_use_id":null,"session_id":"bbf602c4-ad39-43c7-84d1-732663ab0f4d","uuid":"de3e707f-ed3d-431d-859a-1cd8cb8ee536","timestamp":"2026-04-09T03:32:24.336Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-549.9-move-create-pr/src/darkfactory/builtins/__init__.py","content":"\"\"\"Built-in task primitives — re-export hub.\n\nImports every submodule so @builtin-decorated functions register on\npackage import. Re-exports the public API for backwards compatibility.\n\nBuilt-ins are the deterministic SDLC operations that every workflow\nreferences by name: create a worktree, set a PRD's status, make a\ncommit, push a branch, open a PR. They live here (not in individual\nworkflow modules) because they're shared — every workflow uses the\nsame ``commit`` primitive, not a bespoke one.\n\nWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n\n    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n\nThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\nregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\nplus any formatted kwargs.\n\n**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\nanything destructive. In dry-run, we log what we WOULD do at INFO\nlevel and return. This is what powers ``prd plan`` and the default\n``prd run`` (without ``--execute``).\n\n**Subprocess discipline**: all shell commands use ``subprocess.run``\nwith an explicit argv list (never ``shell=True``), capture output,\nand check the return code. Git and gh invocations go through\n:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\nhandling and dry-run support.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom filelock import FileLock, Timeout\n\nfrom darkfactory import prd as prd_module\nfrom darkfactory.builtins._registry import BUILTINS, BuiltInFunc, builtin\nfrom darkfactory.builtins._shared import (\n    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n    _run,\n    _scan_for_forbidden_attribution,\n)\nfrom darkfactory.builtins.set_status import set_status  # noqa: F401\nfrom darkfactory.checks import is_resume_safe\n\n_log = logging.getLogger(__name__)\n\nfrom darkfactory.workflow import ExecutionContext, Status\n\n_log = logging.getLogger(__name__)\n\n# Import submodules to trigger @builtin registration.\nfrom darkfactory.builtins.commit import commit  # noqa: E402\nfrom darkfactory.builtins.create_pr import create_pr  # noqa: E402\nfrom darkfactory.builtins.ensure_worktree import ensure_worktree  # noqa: E402\nfrom darkfactory.builtins.push_branch import push_branch  # noqa: E402\n\n__all__ = [\n    \"BUILTINS\",\n    \"BuiltInFunc\",\n    \"builtin\",\n    \"_run\",\n    \"_scan_for_forbidden_attribution\",\n    \"_FORBIDDEN_ATTRIBUTION_PATTERNS\",\n    \"ensure_worktree\",\n    \"set_status\",\n    \"commit\",\n    \"push_branch\",\n    \"summarize_agent_run\",\n    \"commit_transcript\",\n    \"create_pr\",\n    \"lint_attribution\",\n    \"cleanup_worktree\",\n]\n\n\n# ---------- built-in implementations ----------\n\n\ndef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n    if not tool_counts:\n        return \"none\"\n    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n\n\ndef _format_invocations(ctx: ExecutionContext) -> str:\n    \"\"\"Format agent invocation count from context.\"\"\"\n    count = ctx.invoke_count\n    if count == 0:\n        return \"0\"\n    if count == 1:\n        return \"1\"\n    return str(count)\n\n\n@builtin(\"summarize_agent_run\")\ndef summarize_agent_run(ctx: ExecutionContext) -> None:\n    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n    result = ctx.last_invoke_result\n    if result is None:\n        return\n\n    lines = [\n        \"## Harness execution summary\",\n        \"\",\n        f\"- **Workflow:** {ctx.workflow.name}\",\n        f\"- **Model:** {ctx.model or 'unknown'}\",\n        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n    ]\n    ctx.run_summary = \"\\n\".join(lines)\n\n\n@builtin(\"commit_transcript\")\ndef commit_transcript(ctx: ExecutionContext) -> None:\n    \"\"\"Copy agent transcript into the worktree and stage it.\n\n    Source: ``<repo_root>/.harness-transcripts/{prd_id}.log`` written by the\n    runner after each agent invocation (outside any worktree — see\n    ``runner._run_agent``). Destination inside the worktree:\n    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n\n    The runner writes transcripts *outside* every worktree so ``git add -A``\n    can never accidentally sweep them. This builtin is the one place that\n    opts the transcript *into* the worktree — workflows that want the\n    transcript committed alongside the PRD work must include this builtin\n    explicitly. Workflows that omit it leave the transcript at the repo-root\n    path where it survives as a local-only diagnostic.\n\n    Timestamps use the wall-clock at the time this builtin runs, which is\n    unique enough for sequential runs. If no transcript exists (dry-run,\n    or the runner didn't produce one), this is a no-op.\n    \"\"\"\n    src = ctx.repo_root / \".harness-transcripts\" / f\"{ctx.prd.id}.log\"\n    if not src.exists():\n        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n        return\n\n    if ctx.dry_run:\n        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n        dest = (\n            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n        )\n        ctx.logger.info(\"[dry-run] copy %s -> %s && git add\", src, dest)\n        return\n\n    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n    transcript_dir.mkdir(parents=True, exist_ok=True)\n\n    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n\n    # Copy (not move) so the repo-root transcript persists as a local-only\n    # diagnostic even after this builtin runs. If the same PRD is re-run,\n    # the runner overwrites the source file anyway.\n    shutil.copy2(str(src), str(dest))\n\n    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n\n\n@builtin(\"lint_attribution\")\ndef lint_attribution(ctx: ExecutionContext) -> None:\n    \"\"\"Fail if any commit on the branch or the run summary credits Claude/Anthropic.\n\n    Scans:\n\n    - Every commit message in ``{base_ref}..HEAD`` on the current branch\n    - ``ctx.run_summary`` (which feeds the PR body)\n\n    Intended to run after the agent + verification phases and before\n    ``push_branch`` / ``create_pr``, so violations abort the workflow\n    before anything lands on the remote or in a PR. Dry-run is a no-op\n    because there are no real commits to scan.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] lint_attribution: skipped\")\n        return\n\n    _scan_for_forbidden_attribution(\n        ctx.run_summary or \"\", source=f\"run summary for {ctx.prd.id}\"\n    )\n\n    result = subprocess.run(\n        [\"git\", \"log\", f\"{ctx.base_ref}..HEAD\", \"--format=%H%x00%B%x1e\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n    # Record separator \\x1e between commits; field separator \\x00 between\n    # sha and body. Keeps us robust against newlines in commit messages.\n    for entry in result.stdout.split(\"\\x1e\"):\n        entry = entry.strip()\n        if not entry:\n            continue\n        sha, _, body = entry.partition(\"\\x00\")\n        _scan_for_forbidden_attribution(\n            body, source=f\"commit {sha[:12]} on {ctx.branch_name}\"\n        )\n\n    ctx.logger.info(\"lint_attribution: clean\")\n\n\n@builtin(\"cleanup_worktree\")\ndef cleanup_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Remove the worktree after a successful run.\n\n    Idempotent — if the worktree is already gone, logs and returns.\n    Normally skipped during chain execution so downstream worktrees\n    can base on this branch; called explicitly via ``prd cleanup``\n    after the whole chain is done.\n    \"\"\"\n    if ctx.worktree_path is None:\n        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n        return\n\n    if not ctx.worktree_path.exists():\n        ctx.logger.info(\n            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n        )\n        return\n\n    cmd = [\n        \"git\",\n        \"-C\",\n        str(ctx.repo_root),\n        \"worktree\",\n        \"remove\",\n        str(ctx.worktree_path),\n    ]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(cmd, check=True, capture_output=True, text=True)\n","numLines":246,"startLine":1,"totalLines":246}}}
