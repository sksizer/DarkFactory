{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014UjRDAwfhZCgbUTUAZF2Mk","type":"tool_result","content":"1\t\"\"\"Tests for system_builtins — set_status_bulk, system_load_prds_by_status, system_check_merged.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport logging\n6\tfrom pathlib import Path\n7\tfrom subprocess import CompletedProcess\n8\tfrom unittest.mock import patch\n9\t\n10\timport pytest\n11\t\n12\tfrom darkfactory.builtins.system_builtins import (\n13\t    SYSTEM_BUILTINS,\n14\t    set_status_bulk,\n15\t    system_check_merged,\n16\t    system_load_prds_by_status,\n17\t    system_mark_done,\n18\t    system_load_review_prds,\n19\t)\n20\tfrom darkfactory.prd import parse_prd\n21\tfrom darkfactory.system import SystemContext, SystemOperation\n22\t\n23\tfrom tests.conftest import write_prd\n24\t\n25\t\n26\t# ---------- helpers ----------\n27\t\n28\t\n29\tdef _make_op() -> SystemOperation:\n30\t    return SystemOperation(name=\"test-op\", description=\"test\", tasks=[])\n31\t\n32\t\n33\tdef _make_ctx(\n34\t    tmp_path: Path,\n35\t    prds: dict | None = None,\n36\t    *,\n37\t    dry_run: bool = False,\n38\t    targets: list[str] | None = None,\n39\t    shared_state: dict | None = None,\n40\t) -> SystemContext:\n41\t    ctx = SystemContext(\n42\t        repo_root=tmp_path,\n43\t        prds=prds or {},\n44\t        operation=_make_op(),\n45\t        cwd=tmp_path,\n46\t        dry_run=dry_run,\n47\t        targets=targets or [],\n48\t    )\n49\t    if shared_state:\n50\t        ctx._shared_state.update(shared_state)\n51\t    return ctx\n52\t\n53\t\n54\tdef _write_and_parse(\n55\t    tmp_path: Path, prd_id: str, slug: str, **kwargs: object\n56\t) -> object:\n57\t    \"\"\"Write a PRD fixture to disk and parse it back.\"\"\"\n58\t    write_prd(tmp_path, prd_id, slug, **kwargs)\n59\t    return parse_prd(tmp_path / f\"{prd_id}-{slug}.md\")\n60\t\n61\t\n62\t# ---------- SYSTEM_BUILTINS registry ----------\n63\t\n64\t\n65\tdef test_all_expected_builtins_registered() -> None:\n66\t    expected = {\n67\t        \"set_status_bulk\",\n68\t        \"system_load_review_prds\",\n69\t        \"system_load_prds_by_status\",\n70\t        \"system_check_merged\",\n71\t        \"system_mark_done\",\n72\t    }\n73\t    assert expected.issubset(set(SYSTEM_BUILTINS.keys()))\n74\t\n75\t\n76\tdef test_builtins_are_callable() -> None:\n77\t    for name, fn in SYSTEM_BUILTINS.items():\n78\t        assert callable(fn), f\"SYSTEM_BUILTINS[{name!r}] is not callable\"\n79\t\n80\t\n81\t# ---------- set_status_bulk — normal writes ----------\n82\t\n83\t\n84\tdef test_set_status_bulk_updates_multiple_prds(tmp_path: Path) -> None:\n85\t    prd1 = _write_and_parse(tmp_path, \"PRD-1\", \"alpha\", status=\"review\")\n86\t    prd2 = _write_and_parse(tmp_path, \"PRD-2\", \"beta\", status=\"review\")\n87\t    prds = {\"PRD-1\": prd1, \"PRD-2\": prd2}\n88\t    ctx = _make_ctx(tmp_path, prds, targets=[\"PRD-1\", \"PRD-2\"])\n89\t\n90\t    with patch(\n91\t        \"darkfactory.builtins.system_builtins.prd_module.set_status\"\n92\t    ) as mock_set:\n93\t        set_status_bulk(ctx, status=\"done\")\n94\t\n95\t    assert mock_set.call_count == 2\n96\t    called_ids = {call_args[0][0].id for call_args in mock_set.call_args_list}\n97\t    assert called_ids == {\"PRD-1\", \"PRD-2\"}\n98\t    called_statuses = {call_args[0][1] for call_args in mock_set.call_args_list}\n99\t    assert called_statuses == {\"done\"}\n100\t\n101\t\n102\tdef test_set_status_bulk_updates_correct_status_value(tmp_path: Path) -> None:\n103\t    prd = _write_and_parse(tmp_path, \"PRD-10\", \"gamma\", status=\"review\")\n104\t    ctx = _make_ctx(tmp_path, {\"PRD-10\": prd}, targets=[\"PRD-10\"])\n105\t\n106\t    with patch(\n107\t        \"darkfactory.builtins.system_builtins.prd_module.set_status\"\n108\t    ) as mock_set:\n109\t        set_status_bulk(ctx, status=\"done\")\n110\t\n111\t    mock_set.assert_called_once_with(prd, \"done\")\n112\t\n113\t\n114\t# ---------- set_status_bulk — dry-run ----------\n115\t\n116\t\n117\tdef test_set_status_bulk_dry_run_skips_writes(tmp_path: Path) -> None:\n118\t    prd = _write_and_parse(tmp_path, \"PRD-20\", \"delta\", status=\"review\")\n119\t    ctx = _make_ctx(tmp_path, {\"PRD-20\": prd}, dry_run=True, targets=[\"PRD-20\"])\n120\t\n121\t    with patch(\n122\t        \"darkfactory.builtins.system_builtins.prd_module.set_status\"\n123\t    ) as mock_set:\n124\t        set_status_bulk(ctx, status=\"done\")\n125\t\n126\t    mock_set.assert_not_called()\n127\t\n128\t\n129\tdef test_set_status_bulk_dry_run_logs(\n130\t    tmp_path: Path, caplog: pytest.LogCaptureFixture\n131\t) -> None:\n132\t    prd = _write_and_parse(tmp_path, \"PRD-21\", \"epsilon\", status=\"review\")\n133\t    ctx = _make_ctx(tmp_path, {\"PRD-21\": prd}, dry_run=True, targets=[\"PRD-21\"])\n134\t\n135\t    with caplog.at_level(logging.INFO, logger=\"darkfactory.system\"):\n136\t        set_status_bulk(ctx, status=\"done\")\n137\t\n138\t    assert any(\"dry-run\" in rec.message for rec in caplog.records)\n139\t\n140\t\n141\t# ---------- set_status_bulk — idempotency ----------\n142\t\n143\t\n144\tdef test_set_status_bulk_skips_already_done_prds(tmp_path: Path) -> None:\n145\t    prd = _write_and_parse(tmp_path, \"PRD-30\", \"zeta\", status=\"done\")\n146\t    ctx = _make_ctx(tmp_path, {\"PRD-30\": prd}, targets=[\"PRD-30\"])\n147\t\n148\t    with patch(\n149\t        \"darkfactory.builtins.system_builtins.prd_module.set_status\"\n150\t    ) as mock_set:\n151\t        set_status_bulk(ctx, status=\"done\")\n152\t\n153\t    mock_set.assert_not_called()\n154\t\n155\t\n156\tdef test_set_status_bulk_partial_idempotency(tmp_path: Path) -> None:\n157\t    \"\"\"Only PRDs not already at the target status should be written.\"\"\"\n158\t    prd_done = _write_and_parse(tmp_path, \"PRD-31\", \"eta\", status=\"done\")\n159\t    prd_review = _write_and_parse(tmp_path, \"PRD-32\", \"theta\", status=\"review\")\n160\t    prds = {\"PRD-31\": prd_done, \"PRD-32\": prd_review}\n161\t    ctx = _make_ctx(tmp_path, prds, targets=[\"PRD-31\", \"PRD-32\"])\n162\t\n163\t    with patch(\n164\t        \"darkfactory.builtins.system_builtins.prd_module.set_status\"\n165\t    ) as mock_set:\n166\t        set_status_bulk(ctx, status=\"done\")\n167\t\n168\t    # Only PRD-32 should be updated; PRD-31 is already \"done\"\n169\t    mock_set.assert_called_once()\n170\t    assert mock_set.call_args[0][0].id == \"PRD-32\"\n171\t\n172\t\n173\tdef test_set_status_bulk_missing_prd_id_warns(\n174\t    tmp_path: Path, caplog: pytest.LogCaptureFixture\n175\t) -> None:\n176\t    ctx = _make_ctx(tmp_path, {}, targets=[\"PRD-999\"])\n177\t\n178\t    with caplog.at_level(logging.WARNING, logger=\"darkfactory.system\"):\n179\t        set_status_bulk(ctx, status=\"done\")\n180\t\n181\t    assert any(\"PRD-999\" in rec.message for rec in caplog.records)\n182\t\n183\t\n184\t# ---------- system_load_prds_by_status ----------\n185\t\n186\t\n187\tdef test_system_load_prds_by_status_filters_correctly(tmp_path: Path) -> None:\n188\t    prd_review1 = _write_and_parse(tmp_path, \"PRD-40\", \"iota\", status=\"review\")\n189\t    prd_review2 = _write_and_parse(tmp_path, \"PRD-41\", \"kappa\", status=\"review\")\n190\t    prd_done = _write_and_parse(tmp_path, \"PRD-42\", \"lambda\", status=\"done\")\n191\t    prds = {\"PRD-40\": prd_review1, \"PRD-41\": prd_review2, \"PRD-42\": prd_done}\n192\t    ctx = _make_ctx(tmp_path, prds)\n193\t\n194\t    system_load_prds_by_status(ctx, status=\"review\")\n195\t\n196\t    assert set(ctx._shared_state[\"candidates\"]) == {\"PRD-40\", \"PRD-41\"}\n197\t\n198\t\n199\tdef test_system_load_prds_by_status_empty_result(tmp_path: Path) -> None:\n200\t    prd = _write_and_parse(tmp_path, \"PRD-50\", \"mu\", status=\"done\")\n201\t    ctx = _make_ctx(tmp_path, {\"PRD-50\": prd})\n202\t\n203\t    system_load_prds_by_status(ctx, status=\"ready\")\n204\t\n205\t    assert ctx._shared_state[\"candidates\"] == []\n206\t\n207\t\n208\tdef test_system_load_prds_by_status_stores_in_shared_state(tmp_path: Path) -> None:\n209\t    prd = _write_and_parse(tmp_path, \"PRD-51\", \"nu\", status=\"ready\")\n210\t    ctx = _make_ctx(tmp_path, {\"PRD-51\": prd})\n211\t\n212\t    system_load_prds_by_status(ctx, status=\"ready\")\n213\t\n214\t    assert \"candidates\" in ctx._shared_state\n215\t    assert \"PRD-51\" in ctx._shared_state[\"candidates\"]\n216\t\n217\t\n218\tdef test_system_load_review_prds_uses_review_status(tmp_path: Path) -> None:\n219\t    prd_review = _write_and_parse(tmp_path, \"PRD-52\", \"xi\", status=\"review\")\n220\t    prd_ready = _write_and_parse(tmp_path, \"PRD-53\", \"omicron\", status=\"ready\")\n221\t    prds = {\"PRD-52\": prd_review, \"PRD-53\": prd_ready}\n222\t    ctx = _make_ctx(tmp_path, prds)\n223\t\n224\t    system_load_review_prds(ctx)\n225\t\n226\t    assert ctx._shared_state[\"candidates\"] == [\"PRD-52\"]\n227\t\n228\t\n229\t# ---------- system_check_merged — standard merge ----------\n230\t\n231\t\n232\tdef _make_completed(stdout: str = \"\", returncode: int = 0) -> CompletedProcess:  # type: ignore[type-arg]\n233\t    return CompletedProcess(args=[], returncode=returncode, stdout=stdout, stderr=\"\")\n234\t\n235\t\n236\tdef test_system_check_merged_standard_merge(tmp_path: Path) -> None:\n237\t    prd = _write_and_parse(tmp_path, \"PRD-60\", \"pi\", status=\"review\")\n238\t    ctx = _make_ctx(\n239\t        tmp_path,\n240\t        {\"PRD-60\": prd},\n241\t        shared_state={\"candidates\": [\"PRD-60\"]},\n242\t    )\n243\t\n244\t    def fake_run(cmd: list[str], **kwargs: object) -> CompletedProcess:  # type: ignore[type-arg]\n245\t        # local branch --merged check returns a match\n246\t        if \"--list\" in cmd and \"-r\" not in cmd:\n247\t            return _make_completed(stdout=\"  prd/PRD-60-pi\\n\")\n248\t        return _make_completed(stdout=\"\")\n249\t\n250\t    with patch(\n251\t        \"darkfactory.builtins.system_builtins.subprocess.run\", side_effect=fake_run\n252\t    ):\n253\t        system_check_merged(ctx)\n254\t\n255\t    assert \"PRD-60\" in ctx.targets\n256\t    assert any(\"PRD-60\" in line and \"standard\" in line for line in ctx.report)\n257\t\n258\t\n259\tdef test_system_check_merged_remote_standard_merge(tmp_path: Path) -> None:\n260\t    prd = _write_and_parse(tmp_path, \"PRD-61\", \"rho\", status=\"review\")\n261\t    ctx = _make_ctx(\n262\t        tmp_path,\n263\t        {\"PRD-61\": prd},\n264\t        shared_state={\"candidates\": [\"PRD-61\"]},\n265\t    )\n266\t\n267\t    def fake_run(cmd: list[str], **kwargs: object) -> CompletedProcess:  # type: ignore[type-arg]\n268\t        # local check returns nothing, remote check returns a match\n269\t        if \"-r\" in cmd and \"--list\" in cmd:\n270\t            return _make_completed(stdout=\"  origin/prd/PRD-61-rho\\n\")\n271\t        return _make_completed(stdout=\"\")\n272\t\n273\t    with patch(\n274\t        \"darkfactory.builtins.system_builtins.subprocess.run\", side_effect=fake_run\n275\t    ):\n276\t        system_check_merged(ctx)\n277\t\n278\t    assert \"PRD-61\" in ctx.targets\n279\t\n280\t\n281\t# ---------- system_check_merged — squash-and-merge ----------\n282\t\n283\t\n284\tdef test_system_check_merged_squash_merge(tmp_path: Path) -> None:\n285\t    prd = _write_and_parse(tmp_path, \"PRD-70\", \"sigma\", status=\"review\")\n286\t    ctx = _make_ctx(\n287\t        tmp_path,\n288\t        {\"PRD-70\": prd},\n289\t        shared_state={\"candidates\": [\"PRD-70\"]},\n290\t    )\n291\t\n292\t    def fake_run(cmd: list[str], **kwargs: object) -> CompletedProcess:  # type: ignore[type-arg]\n293\t        # branch --merged checks return nothing\n294\t        if \"--merged\" in cmd:\n295\t            return _make_completed(stdout=\"\")\n296\t        # git log --grep finds the branch name in commit history\n297\t        if \"--grep\" in \" \".join(cmd) or any(\"--grep\" in arg for arg in cmd):\n298\t            return _make_completed(stdout=\"abc1234 Squash merge prd/PRD-70-sigma\\n\")\n299\t        return _make_completed(stdout=\"\")\n300\t\n301\t    with patch(\n302\t        \"darkfactory.builtins.system_builtins.subprocess.run\", side_effect=fake_run\n303\t    ):\n304\t        system_check_merged(ctx)\n305\t\n306\t    assert \"PRD-70\" in ctx.targets\n307\t    assert any(\"PRD-70\" in line and \"squash\" in line for line in ctx.report)\n308\t\n309\t\n310\t# ---------- system_check_merged — not merged ----------\n311\t\n312\t\n313\tdef test_system_check_merged_not_merged(tmp_path: Path) -> None:\n314\t    prd = _write_and_parse(tmp_path, \"PRD-80\", \"tau\", status=\"review\")\n315\t    ctx = _make_ctx(\n316\t        tmp_path,\n317\t        {\"PRD-80\": prd},\n318\t        shared_state={\"candidates\": [\"PRD-80\"]},\n319\t    )\n320\t\n321\t    with patch(\n322\t        \"darkfactory.builtins.system_builtins.subprocess.run\",\n323\t        return_value=_make_completed(stdout=\"\"),\n324\t    ):\n325\t        system_check_merged(ctx)\n326\t\n327\t    assert \"PRD-80\" not in ctx.targets\n328\t    assert any(\"PRD-80\" in line and \"not merged\" in line for line in ctx.report)\n329\t\n330\t\n331\tdef test_system_check_merged_populates_targets_only_with_merged(tmp_path: Path) -> None:\n332\t    prd_merged = _write_and_parse(tmp_path, \"PRD-81\", \"upsilon\", status=\"review\")\n333\t    prd_not = _write_and_parse(tmp_path, \"PRD-82\", \"phi\", status=\"review\")\n334\t    prds = {\"PRD-81\": prd_merged, \"PRD-82\": prd_not}\n335\t    ctx = _make_ctx(\n336\t        tmp_path,\n337\t        prds,\n338\t        shared_state={\"candidates\": [\"PRD-81\", \"PRD-82\"]},\n339\t    )\n340\t\n341\t    def fake_run(cmd: list[str], **kwargs: object) -> CompletedProcess:  # type: ignore[type-arg]\n342\t        # Only PRD-81's branch shows as merged (local branch check)\n343\t        if \"--merged\" in cmd and \"prd/PRD-81-upsilon\" in \" \".join(cmd):\n344\t            return _make_completed(stdout=\"  prd/PRD-81-upsilon\\n\")\n345\t        return _make_completed(stdout=\"\")\n346\t\n347\t    with patch(\n348\t        \"darkfactory.builtins.system_builtins.subprocess.run\", side_effect=fake_run\n349\t    ):\n350\t        system_check_merged(ctx)\n351\t\n352\t    assert ctx.targets == [\"PRD-81\"]\n353\t\n354\t\n355\t# ---------- system_check_merged — dry-run ----------\n356\t\n357\t\n358\tdef test_system_check_merged_dry_run_no_subprocess(tmp_path: Path) -> None:\n359\t    prd = _write_and_parse(tmp_path, \"PRD-90\", \"chi\", status=\"review\")\n360\t    ctx = _make_ctx(\n361\t        tmp_path,\n362\t        {\"PRD-90\": prd},\n363\t        dry_run=True,\n364\t        shared_state={\"candidates\": [\"PRD-90\"]},\n365\t    )\n366\t\n367\t    with patch(\"darkfactory.builtins.system_builtins.subprocess.run\") as mock_run:\n368\t        system_check_merged(ctx)\n369\t\n370\t    mock_run.assert_not_called()\n371\t\n372\t\n373\tdef test_system_check_merged_dry_run_logs(\n374\t    tmp_path: Path, caplog: pytest.LogCaptureFixture\n375\t) -> None:\n376\t    prd = _write_and_parse(tmp_path, \"PRD-91\", \"psi\", status=\"review\")\n377\t    ctx = _make_ctx(\n378\t        tmp_path,\n379\t        {\"PRD-91\": prd},\n380\t        dry_run=True,\n381\t        shared_state={\"candidates\": [\"PRD-91\"]},\n382\t    )\n383\t\n384\t    with caplog.at_level(logging.INFO, logger=\"darkfactory.system\"):\n385\t        system_check_merged(ctx)\n386\t\n387\t    assert any(\"dry-run\" in rec.message for rec in caplog.records)\n388\t\n389\t\n390\t# ---------- system_check_merged — missing PRD ----------\n391\t\n392\t\n393\tdef test_system_check_merged_missing_prd_skips(tmp_path: Path) -> None:\n394\t    ctx = _make_ctx(tmp_path, {}, shared_state={\"candidates\": [\"PRD-999\"]})\n395\t\n396\t    with patch(\"darkfactory.builtins.system_builtins.subprocess.run\") as mock_run:\n397\t        system_check_merged(ctx)\n398\t\n399\t    mock_run.assert_not_called()\n400\t    assert any(\"PRD-999\" in line for line in ctx.report)\n401\t\n402\t\n403\t# ---------- system_mark_done ----------\n404\t\n405\t\n406\tdef test_system_mark_done_calls_set_status_bulk_with_done(tmp_path: Path) -> None:\n407\t    prd = _write_and_parse(tmp_path, \"PRD-100\", \"omega\", status=\"review\")\n408\t    ctx = _make_ctx(tmp_path, {\"PRD-100\": prd}, targets=[\"PRD-100\"])\n409\t\n410\t    with patch(\n411\t        \"darkfactory.builtins.system_builtins.prd_module.set_status\"\n412\t    ) as mock_set:\n413\t        system_mark_done(ctx)\n414\t\n415\t    mock_set.assert_called_once_with(prd, \"done\")\n416\t"}]},"parent_tool_use_id":null,"session_id":"614d1815-e76d-4e65-ae9f-42cfd919deb1","uuid":"67ab353d-1b59-4a22-bd68-d355695d3be5","timestamp":"2026-04-09T08:16:03.082Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-223.3-bulk-mutation-builtins/tests/test_system_builtins.py","content":"\"\"\"Tests for system_builtins — set_status_bulk, system_load_prds_by_status, system_check_merged.\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nfrom pathlib import Path\nfrom subprocess import CompletedProcess\nfrom unittest.mock import patch\n\nimport pytest\n\nfrom darkfactory.builtins.system_builtins import (\n    SYSTEM_BUILTINS,\n    set_status_bulk,\n    system_check_merged,\n    system_load_prds_by_status,\n    system_mark_done,\n    system_load_review_prds,\n)\nfrom darkfactory.prd import parse_prd\nfrom darkfactory.system import SystemContext, SystemOperation\n\nfrom tests.conftest import write_prd\n\n\n# ---------- helpers ----------\n\n\ndef _make_op() -> SystemOperation:\n    return SystemOperation(name=\"test-op\", description=\"test\", tasks=[])\n\n\ndef _make_ctx(\n    tmp_path: Path,\n    prds: dict | None = None,\n    *,\n    dry_run: bool = False,\n    targets: list[str] | None = None,\n    shared_state: dict | None = None,\n) -> SystemContext:\n    ctx = SystemContext(\n        repo_root=tmp_path,\n        prds=prds or {},\n        operation=_make_op(),\n        cwd=tmp_path,\n        dry_run=dry_run,\n        targets=targets or [],\n    )\n    if shared_state:\n        ctx._shared_state.update(shared_state)\n    return ctx\n\n\ndef _write_and_parse(\n    tmp_path: Path, prd_id: str, slug: str, **kwargs: object\n) -> object:\n    \"\"\"Write a PRD fixture to disk and parse it back.\"\"\"\n    write_prd(tmp_path, prd_id, slug, **kwargs)\n    return parse_prd(tmp_path / f\"{prd_id}-{slug}.md\")\n\n\n# ---------- SYSTEM_BUILTINS registry ----------\n\n\ndef test_all_expected_builtins_registered() -> None:\n    expected = {\n        \"set_status_bulk\",\n        \"system_load_review_prds\",\n        \"system_load_prds_by_status\",\n        \"system_check_merged\",\n        \"system_mark_done\",\n    }\n    assert expected.issubset(set(SYSTEM_BUILTINS.keys()))\n\n\ndef test_builtins_are_callable() -> None:\n    for name, fn in SYSTEM_BUILTINS.items():\n        assert callable(fn), f\"SYSTEM_BUILTINS[{name!r}] is not callable\"\n\n\n# ---------- set_status_bulk — normal writes ----------\n\n\ndef test_set_status_bulk_updates_multiple_prds(tmp_path: Path) -> None:\n    prd1 = _write_and_parse(tmp_path, \"PRD-1\", \"alpha\", status=\"review\")\n    prd2 = _write_and_parse(tmp_path, \"PRD-2\", \"beta\", status=\"review\")\n    prds = {\"PRD-1\": prd1, \"PRD-2\": prd2}\n    ctx = _make_ctx(tmp_path, prds, targets=[\"PRD-1\", \"PRD-2\"])\n\n    with patch(\n        \"darkfactory.builtins.system_builtins.prd_module.set_status\"\n    ) as mock_set:\n        set_status_bulk(ctx, status=\"done\")\n\n    assert mock_set.call_count == 2\n    called_ids = {call_args[0][0].id for call_args in mock_set.call_args_list}\n    assert called_ids == {\"PRD-1\", \"PRD-2\"}\n    called_statuses = {call_args[0][1] for call_args in mock_set.call_args_list}\n    assert called_statuses == {\"done\"}\n\n\ndef test_set_status_bulk_updates_correct_status_value(tmp_path: Path) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-10\", \"gamma\", status=\"review\")\n    ctx = _make_ctx(tmp_path, {\"PRD-10\": prd}, targets=[\"PRD-10\"])\n\n    with patch(\n        \"darkfactory.builtins.system_builtins.prd_module.set_status\"\n    ) as mock_set:\n        set_status_bulk(ctx, status=\"done\")\n\n    mock_set.assert_called_once_with(prd, \"done\")\n\n\n# ---------- set_status_bulk — dry-run ----------\n\n\ndef test_set_status_bulk_dry_run_skips_writes(tmp_path: Path) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-20\", \"delta\", status=\"review\")\n    ctx = _make_ctx(tmp_path, {\"PRD-20\": prd}, dry_run=True, targets=[\"PRD-20\"])\n\n    with patch(\n        \"darkfactory.builtins.system_builtins.prd_module.set_status\"\n    ) as mock_set:\n        set_status_bulk(ctx, status=\"done\")\n\n    mock_set.assert_not_called()\n\n\ndef test_set_status_bulk_dry_run_logs(\n    tmp_path: Path, caplog: pytest.LogCaptureFixture\n) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-21\", \"epsilon\", status=\"review\")\n    ctx = _make_ctx(tmp_path, {\"PRD-21\": prd}, dry_run=True, targets=[\"PRD-21\"])\n\n    with caplog.at_level(logging.INFO, logger=\"darkfactory.system\"):\n        set_status_bulk(ctx, status=\"done\")\n\n    assert any(\"dry-run\" in rec.message for rec in caplog.records)\n\n\n# ---------- set_status_bulk — idempotency ----------\n\n\ndef test_set_status_bulk_skips_already_done_prds(tmp_path: Path) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-30\", \"zeta\", status=\"done\")\n    ctx = _make_ctx(tmp_path, {\"PRD-30\": prd}, targets=[\"PRD-30\"])\n\n    with patch(\n        \"darkfactory.builtins.system_builtins.prd_module.set_status\"\n    ) as mock_set:\n        set_status_bulk(ctx, status=\"done\")\n\n    mock_set.assert_not_called()\n\n\ndef test_set_status_bulk_partial_idempotency(tmp_path: Path) -> None:\n    \"\"\"Only PRDs not already at the target status should be written.\"\"\"\n    prd_done = _write_and_parse(tmp_path, \"PRD-31\", \"eta\", status=\"done\")\n    prd_review = _write_and_parse(tmp_path, \"PRD-32\", \"theta\", status=\"review\")\n    prds = {\"PRD-31\": prd_done, \"PRD-32\": prd_review}\n    ctx = _make_ctx(tmp_path, prds, targets=[\"PRD-31\", \"PRD-32\"])\n\n    with patch(\n        \"darkfactory.builtins.system_builtins.prd_module.set_status\"\n    ) as mock_set:\n        set_status_bulk(ctx, status=\"done\")\n\n    # Only PRD-32 should be updated; PRD-31 is already \"done\"\n    mock_set.assert_called_once()\n    assert mock_set.call_args[0][0].id == \"PRD-32\"\n\n\ndef test_set_status_bulk_missing_prd_id_warns(\n    tmp_path: Path, caplog: pytest.LogCaptureFixture\n) -> None:\n    ctx = _make_ctx(tmp_path, {}, targets=[\"PRD-999\"])\n\n    with caplog.at_level(logging.WARNING, logger=\"darkfactory.system\"):\n        set_status_bulk(ctx, status=\"done\")\n\n    assert any(\"PRD-999\" in rec.message for rec in caplog.records)\n\n\n# ---------- system_load_prds_by_status ----------\n\n\ndef test_system_load_prds_by_status_filters_correctly(tmp_path: Path) -> None:\n    prd_review1 = _write_and_parse(tmp_path, \"PRD-40\", \"iota\", status=\"review\")\n    prd_review2 = _write_and_parse(tmp_path, \"PRD-41\", \"kappa\", status=\"review\")\n    prd_done = _write_and_parse(tmp_path, \"PRD-42\", \"lambda\", status=\"done\")\n    prds = {\"PRD-40\": prd_review1, \"PRD-41\": prd_review2, \"PRD-42\": prd_done}\n    ctx = _make_ctx(tmp_path, prds)\n\n    system_load_prds_by_status(ctx, status=\"review\")\n\n    assert set(ctx._shared_state[\"candidates\"]) == {\"PRD-40\", \"PRD-41\"}\n\n\ndef test_system_load_prds_by_status_empty_result(tmp_path: Path) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-50\", \"mu\", status=\"done\")\n    ctx = _make_ctx(tmp_path, {\"PRD-50\": prd})\n\n    system_load_prds_by_status(ctx, status=\"ready\")\n\n    assert ctx._shared_state[\"candidates\"] == []\n\n\ndef test_system_load_prds_by_status_stores_in_shared_state(tmp_path: Path) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-51\", \"nu\", status=\"ready\")\n    ctx = _make_ctx(tmp_path, {\"PRD-51\": prd})\n\n    system_load_prds_by_status(ctx, status=\"ready\")\n\n    assert \"candidates\" in ctx._shared_state\n    assert \"PRD-51\" in ctx._shared_state[\"candidates\"]\n\n\ndef test_system_load_review_prds_uses_review_status(tmp_path: Path) -> None:\n    prd_review = _write_and_parse(tmp_path, \"PRD-52\", \"xi\", status=\"review\")\n    prd_ready = _write_and_parse(tmp_path, \"PRD-53\", \"omicron\", status=\"ready\")\n    prds = {\"PRD-52\": prd_review, \"PRD-53\": prd_ready}\n    ctx = _make_ctx(tmp_path, prds)\n\n    system_load_review_prds(ctx)\n\n    assert ctx._shared_state[\"candidates\"] == [\"PRD-52\"]\n\n\n# ---------- system_check_merged — standard merge ----------\n\n\ndef _make_completed(stdout: str = \"\", returncode: int = 0) -> CompletedProcess:  # type: ignore[type-arg]\n    return CompletedProcess(args=[], returncode=returncode, stdout=stdout, stderr=\"\")\n\n\ndef test_system_check_merged_standard_merge(tmp_path: Path) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-60\", \"pi\", status=\"review\")\n    ctx = _make_ctx(\n        tmp_path,\n        {\"PRD-60\": prd},\n        shared_state={\"candidates\": [\"PRD-60\"]},\n    )\n\n    def fake_run(cmd: list[str], **kwargs: object) -> CompletedProcess:  # type: ignore[type-arg]\n        # local branch --merged check returns a match\n        if \"--list\" in cmd and \"-r\" not in cmd:\n            return _make_completed(stdout=\"  prd/PRD-60-pi\\n\")\n        return _make_completed(stdout=\"\")\n\n    with patch(\n        \"darkfactory.builtins.system_builtins.subprocess.run\", side_effect=fake_run\n    ):\n        system_check_merged(ctx)\n\n    assert \"PRD-60\" in ctx.targets\n    assert any(\"PRD-60\" in line and \"standard\" in line for line in ctx.report)\n\n\ndef test_system_check_merged_remote_standard_merge(tmp_path: Path) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-61\", \"rho\", status=\"review\")\n    ctx = _make_ctx(\n        tmp_path,\n        {\"PRD-61\": prd},\n        shared_state={\"candidates\": [\"PRD-61\"]},\n    )\n\n    def fake_run(cmd: list[str], **kwargs: object) -> CompletedProcess:  # type: ignore[type-arg]\n        # local check returns nothing, remote check returns a match\n        if \"-r\" in cmd and \"--list\" in cmd:\n            return _make_completed(stdout=\"  origin/prd/PRD-61-rho\\n\")\n        return _make_completed(stdout=\"\")\n\n    with patch(\n        \"darkfactory.builtins.system_builtins.subprocess.run\", side_effect=fake_run\n    ):\n        system_check_merged(ctx)\n\n    assert \"PRD-61\" in ctx.targets\n\n\n# ---------- system_check_merged — squash-and-merge ----------\n\n\ndef test_system_check_merged_squash_merge(tmp_path: Path) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-70\", \"sigma\", status=\"review\")\n    ctx = _make_ctx(\n        tmp_path,\n        {\"PRD-70\": prd},\n        shared_state={\"candidates\": [\"PRD-70\"]},\n    )\n\n    def fake_run(cmd: list[str], **kwargs: object) -> CompletedProcess:  # type: ignore[type-arg]\n        # branch --merged checks return nothing\n        if \"--merged\" in cmd:\n            return _make_completed(stdout=\"\")\n        # git log --grep finds the branch name in commit history\n        if \"--grep\" in \" \".join(cmd) or any(\"--grep\" in arg for arg in cmd):\n            return _make_completed(stdout=\"abc1234 Squash merge prd/PRD-70-sigma\\n\")\n        return _make_completed(stdout=\"\")\n\n    with patch(\n        \"darkfactory.builtins.system_builtins.subprocess.run\", side_effect=fake_run\n    ):\n        system_check_merged(ctx)\n\n    assert \"PRD-70\" in ctx.targets\n    assert any(\"PRD-70\" in line and \"squash\" in line for line in ctx.report)\n\n\n# ---------- system_check_merged — not merged ----------\n\n\ndef test_system_check_merged_not_merged(tmp_path: Path) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-80\", \"tau\", status=\"review\")\n    ctx = _make_ctx(\n        tmp_path,\n        {\"PRD-80\": prd},\n        shared_state={\"candidates\": [\"PRD-80\"]},\n    )\n\n    with patch(\n        \"darkfactory.builtins.system_builtins.subprocess.run\",\n        return_value=_make_completed(stdout=\"\"),\n    ):\n        system_check_merged(ctx)\n\n    assert \"PRD-80\" not in ctx.targets\n    assert any(\"PRD-80\" in line and \"not merged\" in line for line in ctx.report)\n\n\ndef test_system_check_merged_populates_targets_only_with_merged(tmp_path: Path) -> None:\n    prd_merged = _write_and_parse(tmp_path, \"PRD-81\", \"upsilon\", status=\"review\")\n    prd_not = _write_and_parse(tmp_path, \"PRD-82\", \"phi\", status=\"review\")\n    prds = {\"PRD-81\": prd_merged, \"PRD-82\": prd_not}\n    ctx = _make_ctx(\n        tmp_path,\n        prds,\n        shared_state={\"candidates\": [\"PRD-81\", \"PRD-82\"]},\n    )\n\n    def fake_run(cmd: list[str], **kwargs: object) -> CompletedProcess:  # type: ignore[type-arg]\n        # Only PRD-81's branch shows as merged (local branch check)\n        if \"--merged\" in cmd and \"prd/PRD-81-upsilon\" in \" \".join(cmd):\n            return _make_completed(stdout=\"  prd/PRD-81-upsilon\\n\")\n        return _make_completed(stdout=\"\")\n\n    with patch(\n        \"darkfactory.builtins.system_builtins.subprocess.run\", side_effect=fake_run\n    ):\n        system_check_merged(ctx)\n\n    assert ctx.targets == [\"PRD-81\"]\n\n\n# ---------- system_check_merged — dry-run ----------\n\n\ndef test_system_check_merged_dry_run_no_subprocess(tmp_path: Path) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-90\", \"chi\", status=\"review\")\n    ctx = _make_ctx(\n        tmp_path,\n        {\"PRD-90\": prd},\n        dry_run=True,\n        shared_state={\"candidates\": [\"PRD-90\"]},\n    )\n\n    with patch(\"darkfactory.builtins.system_builtins.subprocess.run\") as mock_run:\n        system_check_merged(ctx)\n\n    mock_run.assert_not_called()\n\n\ndef test_system_check_merged_dry_run_logs(\n    tmp_path: Path, caplog: pytest.LogCaptureFixture\n) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-91\", \"psi\", status=\"review\")\n    ctx = _make_ctx(\n        tmp_path,\n        {\"PRD-91\": prd},\n        dry_run=True,\n        shared_state={\"candidates\": [\"PRD-91\"]},\n    )\n\n    with caplog.at_level(logging.INFO, logger=\"darkfactory.system\"):\n        system_check_merged(ctx)\n\n    assert any(\"dry-run\" in rec.message for rec in caplog.records)\n\n\n# ---------- system_check_merged — missing PRD ----------\n\n\ndef test_system_check_merged_missing_prd_skips(tmp_path: Path) -> None:\n    ctx = _make_ctx(tmp_path, {}, shared_state={\"candidates\": [\"PRD-999\"]})\n\n    with patch(\"darkfactory.builtins.system_builtins.subprocess.run\") as mock_run:\n        system_check_merged(ctx)\n\n    mock_run.assert_not_called()\n    assert any(\"PRD-999\" in line for line in ctx.report)\n\n\n# ---------- system_mark_done ----------\n\n\ndef test_system_mark_done_calls_set_status_bulk_with_done(tmp_path: Path) -> None:\n    prd = _write_and_parse(tmp_path, \"PRD-100\", \"omega\", status=\"review\")\n    ctx = _make_ctx(tmp_path, {\"PRD-100\": prd}, targets=[\"PRD-100\"])\n\n    with patch(\n        \"darkfactory.builtins.system_builtins.prd_module.set_status\"\n    ) as mock_set:\n        system_mark_done(ctx)\n\n    mock_set.assert_called_once_with(prd, \"done\")\n","numLines":416,"startLine":1,"totalLines":416}}}
