{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015dc12su3mRCSigN6qskbQD","type":"tool_result","content":"1\t\"\"\"System-operation builtins — bulk mutation and status helpers.\n2\t\n3\tThese builtins operate on :class:`~darkfactory.system.SystemContext` rather\n4\tthan the per-PRD :class:`~darkfactory.workflow.ExecutionContext` used by\n5\tworkflow builtins.  They are registered in :data:`SYSTEM_BUILTINS`, a\n6\tparallel registry that the system runner dispatches against.\n7\t\"\"\"\n8\t\n9\tfrom __future__ import annotations\n10\t\n11\timport subprocess\n12\tfrom typing import Callable\n13\t\n14\tfrom darkfactory import prd as prd_module\n15\tfrom darkfactory.system import SystemContext\n16\t\n17\tSYSTEM_BUILTINS: dict[str, Callable[..., None]] = {}\n18\t\"\"\"Global registry mapping system builtin name to its implementing function.\n19\t\n20\tPopulated at import time via the :func:`_register` decorator.  The system\n21\trunner looks up names here when dispatching a :class:`~darkfactory.workflow.BuiltIn`\n22\ttask inside a :class:`~darkfactory.system.SystemOperation`.\n23\t\"\"\"\n24\t\n25\t\n26\tdef _register(name: str) -> Callable[[Callable[..., None]], Callable[..., None]]:\n27\t    def decorator(fn: Callable[..., None]) -> Callable[..., None]:\n28\t        if name in SYSTEM_BUILTINS:\n29\t            raise ValueError(f\"duplicate system builtin registration for {name!r}\")\n30\t        SYSTEM_BUILTINS[name] = fn\n31\t        return fn\n32\t\n33\t    return decorator\n34\t\n35\t\n36\t@_register(\"set_status_bulk\")\n37\tdef set_status_bulk(ctx: SystemContext, *, status: str) -> None:\n38\t    \"\"\"Update the status field of every PRD id in ``ctx.targets``.\n39\t\n40\t    Respects ``ctx.dry_run`` — in dry-run mode the function logs what would\n41\t    change without writing to disk.  Idempotent: PRDs whose status is already\n42\t    ``status`` are skipped silently.\n43\t    \"\"\"\n44\t    for prd_id in ctx.targets:\n45\t        prd = ctx.prds.get(prd_id)\n46\t        if prd is None:\n47\t            ctx.logger.warning(\n48\t                \"set_status_bulk: %s not found in loaded PRDs, skipping\", prd_id\n49\t            )\n50\t            continue\n51\t\n52\t        if prd.status == status:\n53\t            ctx.logger.debug(\n54\t                \"set_status_bulk: %s already has status %r, skipping\", prd_id, status\n55\t            )\n56\t            continue\n57\t\n58\t        if ctx.dry_run:\n59\t            ctx.logger.info(\n60\t                \"[dry-run] set status of %s: %s -> %s (path=%s)\",\n61\t                prd_id,\n62\t                prd.status,\n63\t                status,\n64\t                prd.path,\n65\t            )\n66\t            continue\n67\t\n68\t        prd_module.set_status(prd, status)\n69\t        ctx.logger.info(\"set_status_bulk: %s -> %s\", prd_id, status)\n70\t\n71\t\n72\t@_register(\"system_load_review_prds\")\n73\tdef system_load_review_prds(ctx: SystemContext) -> None:\n74\t    \"\"\"Convenience wrapper: load PRDs with status ``\"review\"`` into candidates.\"\"\"\n75\t    system_load_prds_by_status(ctx, status=\"review\")\n76\t\n77\t\n78\t@_register(\"system_load_prds_by_status\")\n79\tdef system_load_prds_by_status(ctx: SystemContext, *, status: str) -> None:\n80\t    \"\"\"Filter ``ctx.prds`` by ``status`` and store matching ids in shared state.\n81\t\n82\t    The result is stored at ``ctx._shared_state['candidates']`` as a list of\n83\t    PRD id strings.  Downstream tasks (e.g. :func:`system_check_merged`) read\n84\t    this key to know which PRDs to examine.\n85\t    \"\"\"\n86\t    candidates = [prd_id for prd_id, prd in ctx.prds.items() if prd.status == status]\n87\t    ctx._shared_state[\"candidates\"] = candidates\n88\t    ctx.logger.info(\n89\t        \"system_load_prds_by_status: found %d PRD(s) with status=%r\",\n90\t        len(candidates),\n91\t        status,\n92\t    )\n93\t\n94\t\n95\tdef _branch_name(prd: prd_module.PRD) -> str:\n96\t    \"\"\"Return the expected branch name for a PRD: ``prd/{id}-{slug}``.\"\"\"\n97\t    return f\"prd/{prd.id}-{prd.slug}\"\n98\t\n99\t\n100\tdef _is_merged_standard(repo_root: str, branch: str) -> bool:\n101\t    \"\"\"Return True if ``branch`` (local or remote) is listed in ``git branch --merged main``.\"\"\"\n102\t    # Check local branch merged into main\n103\t    result = subprocess.run(\n104\t        [\"git\", \"branch\", \"--merged\", \"main\", \"--list\", branch],\n105\t        cwd=repo_root,\n106\t        capture_output=True,\n107\t        text=True,\n108\t    )\n109\t    if result.returncode == 0 and result.stdout.strip():\n110\t        return True\n111\t    # Check remote branch\n112\t    result = subprocess.run(\n113\t        [\"git\", \"branch\", \"-r\", \"--merged\", \"main\", \"--list\", f\"origin/{branch}\"],\n114\t        cwd=repo_root,\n115\t        capture_output=True,\n116\t        text=True,\n117\t    )\n118\t    return result.returncode == 0 and bool(result.stdout.strip())\n119\t\n120\t\n121\tdef _is_merged_squash(repo_root: str, branch: str) -> bool:\n122\t    \"\"\"Return True if any commit on main references ``branch`` in its message.\n123\t\n124\t    GitHub's squash-and-merge includes the branch name in the commit message\n125\t    (e.g. ``\"Fix stuff (#42)\"`` with the branch name in the PR body / title).\n126\t    A more reliable signal is the ``prd/PRD-X-slug`` pattern that GitHub\n127\t    appends to squash-merge commit messages when auto-generated.\n128\t    \"\"\"\n129\t    result = subprocess.run(\n130\t        [\"git\", \"log\", \"main\", \"--oneline\", f\"--grep={branch}\"],\n131\t        cwd=repo_root,\n132\t        capture_output=True,\n133\t        text=True,\n134\t    )\n135\t    return result.returncode == 0 and bool(result.stdout.strip())\n136\t\n137\t\n138\t@_register(\"system_check_merged\")\n139\tdef system_check_merged(ctx: SystemContext) -> None:\n140\t    \"\"\"Check which candidate PRDs have had their branch merged to main.\n141\t\n142\t    Reads ``ctx._shared_state['candidates']`` (populated by\n143\t    :func:`system_load_prds_by_status`).  For each candidate, checks:\n144\t\n145\t    1. Standard merge commit — branch appears in ``git branch --merged main``.\n146\t    2. Squash-and-merge — branch name appears in ``git log main``.\n147\t\n148\t    Populates ``ctx.targets`` with the ids of confirmed-merged PRDs and\n149\t    appends human-readable lines to ``ctx.report``.\n150\t    \"\"\"\n151\t    candidates: list[str] = ctx._shared_state.get(\"candidates\", [])\n152\t    repo_root = str(ctx.repo_root)\n153\t    confirmed: list[str] = []\n154\t\n155\t    for prd_id in candidates:\n156\t        prd = ctx.prds.get(prd_id)\n157\t        if prd is None:\n158\t            ctx.report.append(f\"{prd_id}: not found in loaded PRDs — skipped\")\n159\t            continue\n160\t\n161\t        branch = _branch_name(prd)\n162\t\n163\t        if ctx.dry_run:\n164\t            ctx.logger.info(\n165\t                \"[dry-run] would check merged status for %s (branch=%s)\", prd_id, branch\n166\t            )\n167\t            ctx.report.append(f\"{prd_id}: [dry-run] would check branch {branch}\")\n168\t            continue\n169\t\n170\t        if _is_merged_standard(repo_root, branch):\n171\t            confirmed.append(prd_id)\n172\t            ctx.report.append(f\"{prd_id}: merged (standard merge, branch={branch})\")\n173\t        elif _is_merged_squash(repo_root, branch):\n174\t            confirmed.append(prd_id)\n175\t            ctx.report.append(f\"{prd_id}: merged (squash-and-merge, branch={branch})\")\n176\t        else:\n177\t            ctx.report.append(f\"{prd_id}: not merged (branch={branch})\")\n178\t\n179\t    ctx.targets = confirmed\n180\t\n181\t\n182\t@_register(\"system_mark_done\")\n183\tdef system_mark_done(ctx: SystemContext) -> None:\n184\t    \"\"\"Set status to ``\"done\"`` for all PRDs in ``ctx.targets``.\"\"\"\n185\t    set_status_bulk(ctx, status=\"done\")\n186\t"}]},"parent_tool_use_id":null,"session_id":"614d1815-e76d-4e65-ae9f-42cfd919deb1","uuid":"c023d5d7-b965-46e5-98b8-acf7f2de8b48","timestamp":"2026-04-09T08:16:03.237Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-223.3-bulk-mutation-builtins/src/darkfactory/builtins/system_builtins.py","content":"\"\"\"System-operation builtins — bulk mutation and status helpers.\n\nThese builtins operate on :class:`~darkfactory.system.SystemContext` rather\nthan the per-PRD :class:`~darkfactory.workflow.ExecutionContext` used by\nworkflow builtins.  They are registered in :data:`SYSTEM_BUILTINS`, a\nparallel registry that the system runner dispatches against.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport subprocess\nfrom typing import Callable\n\nfrom darkfactory import prd as prd_module\nfrom darkfactory.system import SystemContext\n\nSYSTEM_BUILTINS: dict[str, Callable[..., None]] = {}\n\"\"\"Global registry mapping system builtin name to its implementing function.\n\nPopulated at import time via the :func:`_register` decorator.  The system\nrunner looks up names here when dispatching a :class:`~darkfactory.workflow.BuiltIn`\ntask inside a :class:`~darkfactory.system.SystemOperation`.\n\"\"\"\n\n\ndef _register(name: str) -> Callable[[Callable[..., None]], Callable[..., None]]:\n    def decorator(fn: Callable[..., None]) -> Callable[..., None]:\n        if name in SYSTEM_BUILTINS:\n            raise ValueError(f\"duplicate system builtin registration for {name!r}\")\n        SYSTEM_BUILTINS[name] = fn\n        return fn\n\n    return decorator\n\n\n@_register(\"set_status_bulk\")\ndef set_status_bulk(ctx: SystemContext, *, status: str) -> None:\n    \"\"\"Update the status field of every PRD id in ``ctx.targets``.\n\n    Respects ``ctx.dry_run`` — in dry-run mode the function logs what would\n    change without writing to disk.  Idempotent: PRDs whose status is already\n    ``status`` are skipped silently.\n    \"\"\"\n    for prd_id in ctx.targets:\n        prd = ctx.prds.get(prd_id)\n        if prd is None:\n            ctx.logger.warning(\n                \"set_status_bulk: %s not found in loaded PRDs, skipping\", prd_id\n            )\n            continue\n\n        if prd.status == status:\n            ctx.logger.debug(\n                \"set_status_bulk: %s already has status %r, skipping\", prd_id, status\n            )\n            continue\n\n        if ctx.dry_run:\n            ctx.logger.info(\n                \"[dry-run] set status of %s: %s -> %s (path=%s)\",\n                prd_id,\n                prd.status,\n                status,\n                prd.path,\n            )\n            continue\n\n        prd_module.set_status(prd, status)\n        ctx.logger.info(\"set_status_bulk: %s -> %s\", prd_id, status)\n\n\n@_register(\"system_load_review_prds\")\ndef system_load_review_prds(ctx: SystemContext) -> None:\n    \"\"\"Convenience wrapper: load PRDs with status ``\"review\"`` into candidates.\"\"\"\n    system_load_prds_by_status(ctx, status=\"review\")\n\n\n@_register(\"system_load_prds_by_status\")\ndef system_load_prds_by_status(ctx: SystemContext, *, status: str) -> None:\n    \"\"\"Filter ``ctx.prds`` by ``status`` and store matching ids in shared state.\n\n    The result is stored at ``ctx._shared_state['candidates']`` as a list of\n    PRD id strings.  Downstream tasks (e.g. :func:`system_check_merged`) read\n    this key to know which PRDs to examine.\n    \"\"\"\n    candidates = [prd_id for prd_id, prd in ctx.prds.items() if prd.status == status]\n    ctx._shared_state[\"candidates\"] = candidates\n    ctx.logger.info(\n        \"system_load_prds_by_status: found %d PRD(s) with status=%r\",\n        len(candidates),\n        status,\n    )\n\n\ndef _branch_name(prd: prd_module.PRD) -> str:\n    \"\"\"Return the expected branch name for a PRD: ``prd/{id}-{slug}``.\"\"\"\n    return f\"prd/{prd.id}-{prd.slug}\"\n\n\ndef _is_merged_standard(repo_root: str, branch: str) -> bool:\n    \"\"\"Return True if ``branch`` (local or remote) is listed in ``git branch --merged main``.\"\"\"\n    # Check local branch merged into main\n    result = subprocess.run(\n        [\"git\", \"branch\", \"--merged\", \"main\", \"--list\", branch],\n        cwd=repo_root,\n        capture_output=True,\n        text=True,\n    )\n    if result.returncode == 0 and result.stdout.strip():\n        return True\n    # Check remote branch\n    result = subprocess.run(\n        [\"git\", \"branch\", \"-r\", \"--merged\", \"main\", \"--list\", f\"origin/{branch}\"],\n        cwd=repo_root,\n        capture_output=True,\n        text=True,\n    )\n    return result.returncode == 0 and bool(result.stdout.strip())\n\n\ndef _is_merged_squash(repo_root: str, branch: str) -> bool:\n    \"\"\"Return True if any commit on main references ``branch`` in its message.\n\n    GitHub's squash-and-merge includes the branch name in the commit message\n    (e.g. ``\"Fix stuff (#42)\"`` with the branch name in the PR body / title).\n    A more reliable signal is the ``prd/PRD-X-slug`` pattern that GitHub\n    appends to squash-merge commit messages when auto-generated.\n    \"\"\"\n    result = subprocess.run(\n        [\"git\", \"log\", \"main\", \"--oneline\", f\"--grep={branch}\"],\n        cwd=repo_root,\n        capture_output=True,\n        text=True,\n    )\n    return result.returncode == 0 and bool(result.stdout.strip())\n\n\n@_register(\"system_check_merged\")\ndef system_check_merged(ctx: SystemContext) -> None:\n    \"\"\"Check which candidate PRDs have had their branch merged to main.\n\n    Reads ``ctx._shared_state['candidates']`` (populated by\n    :func:`system_load_prds_by_status`).  For each candidate, checks:\n\n    1. Standard merge commit — branch appears in ``git branch --merged main``.\n    2. Squash-and-merge — branch name appears in ``git log main``.\n\n    Populates ``ctx.targets`` with the ids of confirmed-merged PRDs and\n    appends human-readable lines to ``ctx.report``.\n    \"\"\"\n    candidates: list[str] = ctx._shared_state.get(\"candidates\", [])\n    repo_root = str(ctx.repo_root)\n    confirmed: list[str] = []\n\n    for prd_id in candidates:\n        prd = ctx.prds.get(prd_id)\n        if prd is None:\n            ctx.report.append(f\"{prd_id}: not found in loaded PRDs — skipped\")\n            continue\n\n        branch = _branch_name(prd)\n\n        if ctx.dry_run:\n            ctx.logger.info(\n                \"[dry-run] would check merged status for %s (branch=%s)\", prd_id, branch\n            )\n            ctx.report.append(f\"{prd_id}: [dry-run] would check branch {branch}\")\n            continue\n\n        if _is_merged_standard(repo_root, branch):\n            confirmed.append(prd_id)\n            ctx.report.append(f\"{prd_id}: merged (standard merge, branch={branch})\")\n        elif _is_merged_squash(repo_root, branch):\n            confirmed.append(prd_id)\n            ctx.report.append(f\"{prd_id}: merged (squash-and-merge, branch={branch})\")\n        else:\n            ctx.report.append(f\"{prd_id}: not merged (branch={branch})\")\n\n    ctx.targets = confirmed\n\n\n@_register(\"system_mark_done\")\ndef system_mark_done(ctx: SystemContext) -> None:\n    \"\"\"Set status to ``\"done\"`` for all PRDs in ``ctx.targets``.\"\"\"\n    set_status_bulk(ctx, status=\"done\")\n","numLines":186,"startLine":1,"totalLines":186}}}
