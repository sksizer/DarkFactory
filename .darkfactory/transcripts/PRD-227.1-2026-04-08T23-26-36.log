{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YcATf7jHoHQtJLrD8jxR3p","type":"tool_result","content":"1\t\"\"\"Tests for WorkflowTemplate and TemplateViolation.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\timport pytest\n6\t\n7\tfrom darkfactory.templates import TemplateViolation, WorkflowTemplate\n8\tfrom darkfactory.workflow import AgentTask, BuiltIn, ShellTask, Workflow\n9\t\n10\t\n11\tdef _make_template(**kwargs) -> WorkflowTemplate:\n12\t    \"\"\"Build a WorkflowTemplate with sensible defaults.\"\"\"\n13\t    defaults = dict(\n14\t        name=\"test-template\",\n15\t        description=\"A test template\",\n16\t        open=[BuiltIn(\"ensure_worktree\")],\n17\t        close=[BuiltIn(\"commit\"), BuiltIn(\"push_branch\")],\n18\t        middle_kinds=[AgentTask, ShellTask],\n19\t        middle_required={},\n20\t    )\n21\t    defaults.update(kwargs)\n22\t    return WorkflowTemplate(**defaults)\n23\t\n24\t\n25\tdef _dummy_applies_to(prd, prds):\n26\t    return True\n27\t\n28\t\n29\t# ---------- AC-1: task ordering ----------\n30\t\n31\t\n32\tdef test_compose_task_order_is_open_middle_close() -> None:\n33\t    \"\"\"compose() produces [*open, *middle, *close] task ordering.\"\"\"\n34\t    open_task = BuiltIn(\"ensure_worktree\")\n35\t    close_task = BuiltIn(\"push_branch\")\n36\t    middle_task = AgentTask(name=\"implement\")\n37\t\n38\t    tmpl = WorkflowTemplate(\n39\t        name=\"ordered\",\n40\t        description=\"ordering test\",\n41\t        open=[open_task],\n42\t        close=[close_task],\n43\t        middle_kinds=[AgentTask],\n44\t    )\n45\t    wf = tmpl.compose(\n46\t        name=\"my-workflow\",\n47\t        description=\"desc\",\n48\t        applies_to=_dummy_applies_to,\n49\t        priority=5,\n50\t        middle=[middle_task],\n51\t    )\n52\t\n53\t    assert wf.tasks == [open_task, middle_task, close_task]\n54\t\n55\t\n56\tdef test_compose_multiple_open_and_close() -> None:\n57\t    \"\"\"All open and close tasks appear in the correct order.\"\"\"\n58\t    o1 = BuiltIn(\"ensure_worktree\")\n59\t    o2 = BuiltIn(\"set_status\")\n60\t    c1 = BuiltIn(\"commit\")\n61\t    c2 = BuiltIn(\"push_branch\")\n62\t    m1 = AgentTask(name=\"implement\")\n63\t    m2 = ShellTask(name=\"test\", cmd=\"just test\")\n64\t\n65\t    tmpl = WorkflowTemplate(\n66\t        name=\"multi\",\n67\t        description=\"multi open/close\",\n68\t        open=[o1, o2],\n69\t        close=[c1, c2],\n70\t        middle_kinds=[AgentTask, ShellTask],\n71\t    )\n72\t    wf = tmpl.compose(\n73\t        name=\"wf\",\n74\t        description=\"\",\n75\t        applies_to=_dummy_applies_to,\n76\t        priority=0,\n77\t        middle=[m1, m2],\n78\t    )\n79\t\n80\t    assert wf.tasks == [o1, o2, m1, m2, c1, c2]\n81\t\n82\t\n83\tdef test_compose_empty_middle_produces_open_plus_close() -> None:\n84\t    \"\"\"Empty middle is valid when no kinds or requirements are enforced.\"\"\"\n85\t    tmpl = WorkflowTemplate(\n86\t        name=\"empty-middle\",\n87\t        description=\"\",\n88\t        open=[BuiltIn(\"ensure_worktree\")],\n89\t        close=[BuiltIn(\"push_branch\")],\n90\t        middle_kinds=[],\n91\t        middle_required={},\n92\t    )\n93\t    wf = tmpl.compose(\n94\t        name=\"wf\",\n95\t        description=\"\",\n96\t        applies_to=_dummy_applies_to,\n97\t        priority=0,\n98\t        middle=[],\n99\t    )\n100\t    assert len(wf.tasks) == 2\n101\t    assert wf.tasks[0] == BuiltIn(\"ensure_worktree\")\n102\t    assert wf.tasks[1] == BuiltIn(\"push_branch\")\n103\t\n104\t\n105\tdef test_compose_sets_workflow_fields() -> None:\n106\t    \"\"\"Workflow name, description, applies_to, and priority come from compose args.\"\"\"\n107\t    tmpl = _make_template()\n108\t    wf = tmpl.compose(\n109\t        name=\"specific-wf\",\n110\t        description=\"my description\",\n111\t        applies_to=_dummy_applies_to,\n112\t        priority=10,\n113\t        middle=[AgentTask(name=\"implement\")],\n114\t    )\n115\t    assert wf.name == \"specific-wf\"\n116\t    assert wf.description == \"my description\"\n117\t    assert wf.applies_to is _dummy_applies_to\n118\t    assert wf.priority == 10\n119\t\n120\t\n121\t# ---------- AC-2: middle_kinds violation ----------\n122\t\n123\t\n124\tdef test_compose_raises_for_disallowed_kind() -> None:\n125\t    \"\"\"A task not in middle_kinds raises TemplateViolation.\"\"\"\n126\t    tmpl = WorkflowTemplate(\n127\t        name=\"agent-only\",\n128\t        description=\"\",\n129\t        open=[],\n130\t        close=[],\n131\t        middle_kinds=[AgentTask],\n132\t    )\n133\t    shell_task = ShellTask(name=\"test\", cmd=\"just test\")\n134\t    with pytest.raises(TemplateViolation, match=\"not an allowed middle kind\"):\n135\t        tmpl.compose(\n136\t            name=\"wf\",\n137\t            description=\"\",\n138\t            applies_to=_dummy_applies_to,\n139\t            priority=0,\n140\t            middle=[shell_task],\n141\t        )\n142\t\n143\t\n144\tdef test_compose_violation_message_names_allowed_kinds() -> None:\n145\t    \"\"\"TemplateViolation message includes the allowed kind names.\"\"\"\n146\t    tmpl = WorkflowTemplate(\n147\t        name=\"strict\",\n148\t        description=\"\",\n149\t        open=[],\n150\t        close=[],\n151\t        middle_kinds=[AgentTask],\n152\t    )\n153\t    with pytest.raises(TemplateViolation, match=\"AgentTask\"):\n154\t        tmpl.compose(\n155\t            name=\"wf\",\n156\t            description=\"\",\n157\t            applies_to=_dummy_applies_to,\n158\t            priority=0,\n159\t            middle=[ShellTask(name=\"s\", cmd=\"x\")],\n160\t        )\n161\t\n162\t\n163\tdef test_compose_allows_all_listed_kinds() -> None:\n164\t    \"\"\"Tasks that are instances of any listed kind are accepted.\"\"\"\n165\t    tmpl = _make_template(middle_kinds=[AgentTask, ShellTask])\n166\t    wf = tmpl.compose(\n167\t        name=\"wf\",\n168\t        description=\"\",\n169\t        applies_to=_dummy_applies_to,\n170\t        priority=0,\n171\t        middle=[AgentTask(name=\"implement\"), ShellTask(name=\"verify\", cmd=\"just test\")],\n172\t    )\n173\t    # _make_template: 1 open + 2 middle + 2 close = 5\n174\t    assert len(wf.tasks) == 5\n175\t\n176\t\n177\t# ---------- AC-3: middle_required violation ----------\n178\t\n179\t\n180\tdef test_compose_raises_when_required_kind_too_few() -> None:\n181\t    \"\"\"TemplateViolation raised when a required kind appears fewer than min times.\"\"\"\n182\t    tmpl = WorkflowTemplate(\n183\t        name=\"needs-agent\",\n184\t        description=\"\",\n185\t        open=[],\n186\t        close=[],\n187\t        middle_kinds=[AgentTask, ShellTask],\n188\t        middle_required={AgentTask: (1, None)},\n189\t    )\n190\t    with pytest.raises(TemplateViolation, match=\"at least 1 AgentTask\"):\n191\t        tmpl.compose(\n192\t            name=\"wf\",\n193\t            description=\"\",\n194\t            applies_to=_dummy_applies_to,\n195\t            priority=0,\n196\t            middle=[ShellTask(name=\"test\", cmd=\"just test\")],\n197\t        )\n198\t\n199\t\n200\tdef test_compose_raises_when_required_kind_too_many() -> None:\n201\t    \"\"\"TemplateViolation raised when a required kind exceeds max count.\"\"\"\n202\t    tmpl = WorkflowTemplate(\n203\t        name=\"max-one-agent\",\n204\t        description=\"\",\n205\t        open=[],\n206\t        close=[],\n207\t        middle_kinds=[AgentTask, ShellTask],\n208\t        middle_required={AgentTask: (0, 1)},\n209\t    )\n210\t    with pytest.raises(TemplateViolation, match=\"at most 1 AgentTask\"):\n211\t        tmpl.compose(\n212\t            name=\"wf\",\n213\t            description=\"\",\n214\t            applies_to=_dummy_applies_to,\n215\t            priority=0,\n216\t            middle=[AgentTask(name=\"a\"), AgentTask(name=\"b\")],\n217\t        )\n218\t\n219\t\n220\tdef test_compose_raises_too_few_includes_count() -> None:\n221\t    \"\"\"Violation message for too-few includes the actual count.\"\"\"\n222\t    tmpl = WorkflowTemplate(\n223\t        name=\"t\",\n224\t        description=\"\",\n225\t        open=[],\n226\t        close=[],\n227\t        middle_kinds=[AgentTask],\n228\t        middle_required={AgentTask: (2, None)},\n229\t    )\n230\t    with pytest.raises(TemplateViolation, match=\"got 1\"):\n231\t        tmpl.compose(\n232\t            name=\"wf\",\n233\t            description=\"\",\n234\t            applies_to=_dummy_applies_to,\n235\t            priority=0,\n236\t            middle=[AgentTask(name=\"a\")],\n237\t        )\n238\t\n239\t\n240\tdef test_compose_at_exactly_min_succeeds() -> None:\n241\t    \"\"\"Exactly meeting the minimum required count is valid.\"\"\"\n242\t    tmpl = WorkflowTemplate(\n243\t        name=\"t\",\n244\t        description=\"\",\n245\t        open=[],\n246\t        close=[],\n247\t        middle_kinds=[AgentTask],\n248\t        middle_required={AgentTask: (1, None)},\n249\t    )\n250\t    wf = tmpl.compose(\n251\t        name=\"wf\",\n252\t        description=\"\",\n253\t        applies_to=_dummy_applies_to,\n254\t        priority=0,\n255\t        middle=[AgentTask(name=\"a\")],\n256\t    )\n257\t    assert len(wf.tasks) == 1\n258\t\n259\t\n260\tdef test_compose_at_exactly_max_succeeds() -> None:\n261\t    \"\"\"Exactly meeting the maximum allowed count is valid.\"\"\"\n262\t    tmpl = WorkflowTemplate(\n263\t        name=\"t\",\n264\t        description=\"\",\n265\t        open=[],\n266\t        close=[],\n267\t        middle_kinds=[AgentTask],\n268\t        middle_required={AgentTask: (0, 2)},\n269\t    )\n270\t    wf = tmpl.compose(\n271\t        name=\"wf\",\n272\t        description=\"\",\n273\t        applies_to=_dummy_applies_to,\n274\t        priority=0,\n275\t        middle=[AgentTask(name=\"a\"), AgentTask(name=\"b\")],\n276\t    )\n277\t    assert len(wf.tasks) == 2\n278\t\n279\t\n280\t# ---------- AC-4: template_name on composed workflow ----------\n281\t\n282\t\n283\tdef test_compose_sets_template_name() -> None:\n284\t    \"\"\"The composed Workflow has template_name matching the template's name.\"\"\"\n285\t    tmpl = _make_template(name=\"my-template\")\n286\t    wf = tmpl.compose(\n287\t        name=\"wf\",\n288\t        description=\"\",\n289\t        applies_to=_dummy_applies_to,\n290\t        priority=0,\n291\t        middle=[AgentTask(name=\"implement\")],\n292\t    )\n293\t    assert wf.template_name == \"my-template\"\n294\t\n295\t\n296\tdef test_compose_template_name_matches_template_name_field() -> None:\n297\t    \"\"\"template_name always matches the WorkflowTemplate.name field.\"\"\"\n298\t    for tname in [\"prd-implementation\", \"rework\", \"planning\"]:\n299\t        tmpl = _make_template(name=tname)\n300\t        wf = tmpl.compose(\n301\t            name=\"wf\",\n302\t            description=\"\",\n303\t            applies_to=_dummy_applies_to,\n304\t            priority=0,\n305\t            middle=[AgentTask(name=\"implement\")],\n306\t        )\n307\t        assert wf.template_name == tname\n308\t\n309\t\n310\t# ---------- AC-5: Workflow default template_name ----------\n311\t\n312\t\n313\tdef test_workflow_template_name_defaults_to_none() -> None:\n314\t    \"\"\"A Workflow constructed without template_name has template_name=None.\"\"\"\n315\t    wf = Workflow(name=\"bare\", tasks=[BuiltIn(\"ensure_worktree\")])\n316\t    assert wf.template_name is None\n317\t\n318\t\n319\tdef test_workflow_can_be_constructed_without_template_name() -> None:\n320\t    \"\"\"Existing Workflow construction still works unchanged.\"\"\"\n321\t    wf = Workflow(\n322\t        name=\"legacy\",\n323\t        description=\"no template\",\n324\t        tasks=[BuiltIn(\"ensure_worktree\"), AgentTask(name=\"implement\")],\n325\t        priority=1,\n326\t    )\n327\t    assert wf.template_name is None\n328\t    assert len(wf.tasks) == 2\n329\t"}]},"parent_tool_use_id":null,"session_id":"e4352282-d879-48c0-8576-4c0cf87cccd9","uuid":"fad6702b-def9-4660-b123-08a2b866d10d","timestamp":"2026-04-09T04:25:33.775Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-227.1-core-workflow-template/tests/test_workflow_templates.py","content":"\"\"\"Tests for WorkflowTemplate and TemplateViolation.\"\"\"\n\nfrom __future__ import annotations\n\nimport pytest\n\nfrom darkfactory.templates import TemplateViolation, WorkflowTemplate\nfrom darkfactory.workflow import AgentTask, BuiltIn, ShellTask, Workflow\n\n\ndef _make_template(**kwargs) -> WorkflowTemplate:\n    \"\"\"Build a WorkflowTemplate with sensible defaults.\"\"\"\n    defaults = dict(\n        name=\"test-template\",\n        description=\"A test template\",\n        open=[BuiltIn(\"ensure_worktree\")],\n        close=[BuiltIn(\"commit\"), BuiltIn(\"push_branch\")],\n        middle_kinds=[AgentTask, ShellTask],\n        middle_required={},\n    )\n    defaults.update(kwargs)\n    return WorkflowTemplate(**defaults)\n\n\ndef _dummy_applies_to(prd, prds):\n    return True\n\n\n# ---------- AC-1: task ordering ----------\n\n\ndef test_compose_task_order_is_open_middle_close() -> None:\n    \"\"\"compose() produces [*open, *middle, *close] task ordering.\"\"\"\n    open_task = BuiltIn(\"ensure_worktree\")\n    close_task = BuiltIn(\"push_branch\")\n    middle_task = AgentTask(name=\"implement\")\n\n    tmpl = WorkflowTemplate(\n        name=\"ordered\",\n        description=\"ordering test\",\n        open=[open_task],\n        close=[close_task],\n        middle_kinds=[AgentTask],\n    )\n    wf = tmpl.compose(\n        name=\"my-workflow\",\n        description=\"desc\",\n        applies_to=_dummy_applies_to,\n        priority=5,\n        middle=[middle_task],\n    )\n\n    assert wf.tasks == [open_task, middle_task, close_task]\n\n\ndef test_compose_multiple_open_and_close() -> None:\n    \"\"\"All open and close tasks appear in the correct order.\"\"\"\n    o1 = BuiltIn(\"ensure_worktree\")\n    o2 = BuiltIn(\"set_status\")\n    c1 = BuiltIn(\"commit\")\n    c2 = BuiltIn(\"push_branch\")\n    m1 = AgentTask(name=\"implement\")\n    m2 = ShellTask(name=\"test\", cmd=\"just test\")\n\n    tmpl = WorkflowTemplate(\n        name=\"multi\",\n        description=\"multi open/close\",\n        open=[o1, o2],\n        close=[c1, c2],\n        middle_kinds=[AgentTask, ShellTask],\n    )\n    wf = tmpl.compose(\n        name=\"wf\",\n        description=\"\",\n        applies_to=_dummy_applies_to,\n        priority=0,\n        middle=[m1, m2],\n    )\n\n    assert wf.tasks == [o1, o2, m1, m2, c1, c2]\n\n\ndef test_compose_empty_middle_produces_open_plus_close() -> None:\n    \"\"\"Empty middle is valid when no kinds or requirements are enforced.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"empty-middle\",\n        description=\"\",\n        open=[BuiltIn(\"ensure_worktree\")],\n        close=[BuiltIn(\"push_branch\")],\n        middle_kinds=[],\n        middle_required={},\n    )\n    wf = tmpl.compose(\n        name=\"wf\",\n        description=\"\",\n        applies_to=_dummy_applies_to,\n        priority=0,\n        middle=[],\n    )\n    assert len(wf.tasks) == 2\n    assert wf.tasks[0] == BuiltIn(\"ensure_worktree\")\n    assert wf.tasks[1] == BuiltIn(\"push_branch\")\n\n\ndef test_compose_sets_workflow_fields() -> None:\n    \"\"\"Workflow name, description, applies_to, and priority come from compose args.\"\"\"\n    tmpl = _make_template()\n    wf = tmpl.compose(\n        name=\"specific-wf\",\n        description=\"my description\",\n        applies_to=_dummy_applies_to,\n        priority=10,\n        middle=[AgentTask(name=\"implement\")],\n    )\n    assert wf.name == \"specific-wf\"\n    assert wf.description == \"my description\"\n    assert wf.applies_to is _dummy_applies_to\n    assert wf.priority == 10\n\n\n# ---------- AC-2: middle_kinds violation ----------\n\n\ndef test_compose_raises_for_disallowed_kind() -> None:\n    \"\"\"A task not in middle_kinds raises TemplateViolation.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"agent-only\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask],\n    )\n    shell_task = ShellTask(name=\"test\", cmd=\"just test\")\n    with pytest.raises(TemplateViolation, match=\"not an allowed middle kind\"):\n        tmpl.compose(\n            name=\"wf\",\n            description=\"\",\n            applies_to=_dummy_applies_to,\n            priority=0,\n            middle=[shell_task],\n        )\n\n\ndef test_compose_violation_message_names_allowed_kinds() -> None:\n    \"\"\"TemplateViolation message includes the allowed kind names.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"strict\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask],\n    )\n    with pytest.raises(TemplateViolation, match=\"AgentTask\"):\n        tmpl.compose(\n            name=\"wf\",\n            description=\"\",\n            applies_to=_dummy_applies_to,\n            priority=0,\n            middle=[ShellTask(name=\"s\", cmd=\"x\")],\n        )\n\n\ndef test_compose_allows_all_listed_kinds() -> None:\n    \"\"\"Tasks that are instances of any listed kind are accepted.\"\"\"\n    tmpl = _make_template(middle_kinds=[AgentTask, ShellTask])\n    wf = tmpl.compose(\n        name=\"wf\",\n        description=\"\",\n        applies_to=_dummy_applies_to,\n        priority=0,\n        middle=[AgentTask(name=\"implement\"), ShellTask(name=\"verify\", cmd=\"just test\")],\n    )\n    # _make_template: 1 open + 2 middle + 2 close = 5\n    assert len(wf.tasks) == 5\n\n\n# ---------- AC-3: middle_required violation ----------\n\n\ndef test_compose_raises_when_required_kind_too_few() -> None:\n    \"\"\"TemplateViolation raised when a required kind appears fewer than min times.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"needs-agent\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask, ShellTask],\n        middle_required={AgentTask: (1, None)},\n    )\n    with pytest.raises(TemplateViolation, match=\"at least 1 AgentTask\"):\n        tmpl.compose(\n            name=\"wf\",\n            description=\"\",\n            applies_to=_dummy_applies_to,\n            priority=0,\n            middle=[ShellTask(name=\"test\", cmd=\"just test\")],\n        )\n\n\ndef test_compose_raises_when_required_kind_too_many() -> None:\n    \"\"\"TemplateViolation raised when a required kind exceeds max count.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"max-one-agent\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask, ShellTask],\n        middle_required={AgentTask: (0, 1)},\n    )\n    with pytest.raises(TemplateViolation, match=\"at most 1 AgentTask\"):\n        tmpl.compose(\n            name=\"wf\",\n            description=\"\",\n            applies_to=_dummy_applies_to,\n            priority=0,\n            middle=[AgentTask(name=\"a\"), AgentTask(name=\"b\")],\n        )\n\n\ndef test_compose_raises_too_few_includes_count() -> None:\n    \"\"\"Violation message for too-few includes the actual count.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"t\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask],\n        middle_required={AgentTask: (2, None)},\n    )\n    with pytest.raises(TemplateViolation, match=\"got 1\"):\n        tmpl.compose(\n            name=\"wf\",\n            description=\"\",\n            applies_to=_dummy_applies_to,\n            priority=0,\n            middle=[AgentTask(name=\"a\")],\n        )\n\n\ndef test_compose_at_exactly_min_succeeds() -> None:\n    \"\"\"Exactly meeting the minimum required count is valid.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"t\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask],\n        middle_required={AgentTask: (1, None)},\n    )\n    wf = tmpl.compose(\n        name=\"wf\",\n        description=\"\",\n        applies_to=_dummy_applies_to,\n        priority=0,\n        middle=[AgentTask(name=\"a\")],\n    )\n    assert len(wf.tasks) == 1\n\n\ndef test_compose_at_exactly_max_succeeds() -> None:\n    \"\"\"Exactly meeting the maximum allowed count is valid.\"\"\"\n    tmpl = WorkflowTemplate(\n        name=\"t\",\n        description=\"\",\n        open=[],\n        close=[],\n        middle_kinds=[AgentTask],\n        middle_required={AgentTask: (0, 2)},\n    )\n    wf = tmpl.compose(\n        name=\"wf\",\n        description=\"\",\n        applies_to=_dummy_applies_to,\n        priority=0,\n        middle=[AgentTask(name=\"a\"), AgentTask(name=\"b\")],\n    )\n    assert len(wf.tasks) == 2\n\n\n# ---------- AC-4: template_name on composed workflow ----------\n\n\ndef test_compose_sets_template_name() -> None:\n    \"\"\"The composed Workflow has template_name matching the template's name.\"\"\"\n    tmpl = _make_template(name=\"my-template\")\n    wf = tmpl.compose(\n        name=\"wf\",\n        description=\"\",\n        applies_to=_dummy_applies_to,\n        priority=0,\n        middle=[AgentTask(name=\"implement\")],\n    )\n    assert wf.template_name == \"my-template\"\n\n\ndef test_compose_template_name_matches_template_name_field() -> None:\n    \"\"\"template_name always matches the WorkflowTemplate.name field.\"\"\"\n    for tname in [\"prd-implementation\", \"rework\", \"planning\"]:\n        tmpl = _make_template(name=tname)\n        wf = tmpl.compose(\n            name=\"wf\",\n            description=\"\",\n            applies_to=_dummy_applies_to,\n            priority=0,\n            middle=[AgentTask(name=\"implement\")],\n        )\n        assert wf.template_name == tname\n\n\n# ---------- AC-5: Workflow default template_name ----------\n\n\ndef test_workflow_template_name_defaults_to_none() -> None:\n    \"\"\"A Workflow constructed without template_name has template_name=None.\"\"\"\n    wf = Workflow(name=\"bare\", tasks=[BuiltIn(\"ensure_worktree\")])\n    assert wf.template_name is None\n\n\ndef test_workflow_can_be_constructed_without_template_name() -> None:\n    \"\"\"Existing Workflow construction still works unchanged.\"\"\"\n    wf = Workflow(\n        name=\"legacy\",\n        description=\"no template\",\n        tasks=[BuiltIn(\"ensure_worktree\"), AgentTask(name=\"implement\")],\n        priority=1,\n    )\n    assert wf.template_name is None\n    assert len(wf.tasks) == 2\n","numLines":329,"startLine":1,"totalLines":329}}}
