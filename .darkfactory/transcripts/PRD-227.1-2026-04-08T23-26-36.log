{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BDWL7sNmKyangrjMfpqDj9","type":"tool_result","content":"188\t    middle_required: dict[type, tuple[int, int | None]] = field(default_factory=dict)\n189\t\n190\t    def compose(\n191\t        self,\n192\t        name: str,\n193\t        description: str,\n194\t        applies_to: Callable,\n195\t        priority: int,\n196\t        middle: list,\n197\t    ) -> Workflow:\n198\t        \"\"\"Validate ``middle`` and return a complete :class:`Workflow`.\n199\t\n200\t        Parameters match :class:`Workflow` constructor arguments for the\n201\t        caller-supplied fields. ``tasks`` and ``template_name`` are set\n202\t        by this method.\n203\t\n204\t        Raises :class:`TemplateViolation` if any task in ``middle`` is\n205\t        not an instance of one of ``middle_kinds``, or if the count of\n206\t        any required kind falls outside the ``middle_required`` bounds.\n207\t        \"\"\"\n208\t        self._validate_middle(middle)\n209\t        return Workflow(\n210\t            name=name,\n211\t            description=description,\n212\t            applies_to=applies_to,\n213\t            priority=priority,\n214\t            tasks=[*self.open, *middle, *self.close],\n215\t            template_name=self.name,\n216\t        )\n217\t\n218\t    def _validate_middle(self, middle: list) -> None:\n219\t        if self.middle_kinds:\n220\t            for task in middle:\n221\t                if not isinstance(task, tuple(self.middle_kinds)):\n222\t                    raise TemplateViolation(\n223\t                        f\"Task {task!r} is not an allowed middle kind \"\n224\t                        f\"(allowed: {[k.__name__ for k in self.middle_kinds]})\"\n225\t                    )\n226\t        for kind, (min_count, max_count) in self.middle_required.items():\n227\t            actual = sum(1 for t in middle if isinstance(t, kind))"}]},"parent_tool_use_id":null,"session_id":"e4352282-d879-48c0-8576-4c0cf87cccd9","uuid":"52fae0f7-1940-43eb-80a6-ae6b2effb1bd","timestamp":"2026-04-09T04:25:33.391Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-227.1-core-workflow-template/src/darkfactory/templates.py","content":"    middle_required: dict[type, tuple[int, int | None]] = field(default_factory=dict)\n\n    def compose(\n        self,\n        name: str,\n        description: str,\n        applies_to: Callable,\n        priority: int,\n        middle: list,\n    ) -> Workflow:\n        \"\"\"Validate ``middle`` and return a complete :class:`Workflow`.\n\n        Parameters match :class:`Workflow` constructor arguments for the\n        caller-supplied fields. ``tasks`` and ``template_name`` are set\n        by this method.\n\n        Raises :class:`TemplateViolation` if any task in ``middle`` is\n        not an instance of one of ``middle_kinds``, or if the count of\n        any required kind falls outside the ``middle_required`` bounds.\n        \"\"\"\n        self._validate_middle(middle)\n        return Workflow(\n            name=name,\n            description=description,\n            applies_to=applies_to,\n            priority=priority,\n            tasks=[*self.open, *middle, *self.close],\n            template_name=self.name,\n        )\n\n    def _validate_middle(self, middle: list) -> None:\n        if self.middle_kinds:\n            for task in middle:\n                if not isinstance(task, tuple(self.middle_kinds)):\n                    raise TemplateViolation(\n                        f\"Task {task!r} is not an allowed middle kind \"\n                        f\"(allowed: {[k.__name__ for k in self.middle_kinds]})\"\n                    )\n        for kind, (min_count, max_count) in self.middle_required.items():\n            actual = sum(1 for t in middle if isinstance(t, kind))","numLines":40,"startLine":188,"totalLines":238}}}
