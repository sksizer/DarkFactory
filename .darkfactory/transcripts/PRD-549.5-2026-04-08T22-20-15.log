ult.returncode = 0\n57\t        return result\n58\t\n59\t    with patch(\"darkfactory.builtins.commit.subprocess.run\", side_effect=fake_run):\n60\t        commit(ctx, message=\"chore: test\")\n61\t\n62\t    ctx.logger.info.assert_called_with(\"commit skipped: no changes to commit\")\n63\t\n64\t\n65\tdef test_empty_diff_does_not_call_git_commit(tmp_path: Path) -> None:\n66\t    ctx = _make_ctx(tmp_path)\n67\t    calls: list[list[str]] = []\n68\t\n69\t    def fake_run(cmd, **kwargs):\n70\t        calls.append(list(cmd))\n71\t        result = MagicMock()\n72\t        result.returncode = 0\n73\t        return result\n74\t\n75\t    with patch(\"darkfactory.builtins.commit.subprocess.run\", side_effect=fake_run):\n76\t        commit(ctx, message=\"chore: test\")\n77\t\n78\t    assert not any(\"commit\" in c and \"-m\" in c for c in calls)\n79\t\n80\t\n81\t# ---------- successful commit ----------\n82\t\n83\t\n84\tdef test_successful_commit_calls_git_add_then_commit(tmp_path: Path) -> None:\n85\t    ctx = _make_ctx(tmp_path)\n86\t    calls: list[list[str]] = []\n87\t\n88\t    def fake_run(cmd, **kwargs):\n89\t        calls.append(list(cmd))\n90\t        result = MagicMock()\n91\t        # diff --cached --quiet returns 1 when there ARE staged changes\n92\t        result.returncode = 1 if cmd[:3] == [\"git\", \"diff\", \"--cached\"] else 0\n93\t        return result\n94\t\n95\t    with patch(\"darkfactory.builtins.commit.subprocess.run\", side_effect=fake_run):\n96\t        commit(ctx, message=\"chore: my commit\")\n97\t\n98\t    assert calls[0] == [\"git\", \"add\", \"-A\"]\n99\t    assert calls[2] == [\"git\", \"commit\", \"-m\", \"chore: my commit\"]\n100\t\n101\t\n102\tdef test_successful_commit_uses_formatted_message(tmp_path: Path) -> None:\n103\t    ctx = _make_ctx(tmp_path)\n104\t    ctx.format_string.side_effect = lambda s: s.replace(\"{prd_id}\", \"PRD-042\")\n105\t    committed_messages: list[str] = []\n106\t\n107\t    def fake_run(cmd, **kwargs):\n108\t        r