{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016hpLUMKEg7aDVa1dJew1FU","type":"tool_result","content":"The file /Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-549.5-move-commit/src/darkfactory/builtins/commit_test.py has been updated successfully. (file state is current in your context — no need to Read it back)"}]},"parent_tool_use_id":null,"session_id":"542c4aca-109c-4072-b495-a039fe406f1c","uuid":"6f3ecec7-cb28-4471-a287-6f535431273f","timestamp":"2026-04-09T03:19:52.569Z","tool_use_result":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-549.5-move-commit/src/darkfactory/builtins/commit_test.py","oldString":"    def fake_run(cmd, **kwargs):\n        result = MagicMock()\n        result.returncode = 1 if cmd[:3] == [\"git\", \"diff\", \"--cached\"] else 0\n        if \"commit\" in cmd and \"-m\" in cmd:","newString":"    def fake_run(cmd: list[str], **kwargs: object) -> MagicMock:\n        result = MagicMock()\n        result.returncode = 1 if cmd[:3] == [\"git\", \"diff\", \"--cached\"] else 0\n        if \"commit\" in cmd and \"-m\" in cmd:","originalFile":"\"\"\"Unit tests for commit builtin.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\nfrom unittest.mock import MagicMock, patch\n\nimport pytest\n\nfrom darkfactory.builtins.commit import commit\n\n\n# ---------- helpers ----------\n\n\ndef _make_ctx(tmp_path: Path, *, dry_run: bool = False) -> MagicMock:\n    \"\"\"Build a minimal ExecutionContext mock for commit tests.\"\"\"\n    ctx = MagicMock()\n    ctx.dry_run = dry_run\n    ctx.cwd = tmp_path\n    ctx.prd.id = \"PRD-001\"\n    ctx.format_string.side_effect = lambda s: s\n    return ctx\n\n\n# ---------- dry-run path ----------\n\n\ndef test_dry_run_logs_and_returns_without_subprocess(tmp_path: Path) -> None:\n    ctx = _make_ctx(tmp_path, dry_run=True)\n    with patch(\"darkfactory.builtins.commit.subprocess.run\") as mock_run:\n        commit(ctx, message=\"chore: test commit\")\n    mock_run.assert_not_called()\n    ctx.logger.info.assert_called()\n\n\ndef test_dry_run_logs_formatted_message(tmp_path: Path) -> None:\n    ctx = _make_ctx(tmp_path, dry_run=True)\n    ctx.format_string.side_effect = lambda s: s.replace(\"{prd_id}\", \"PRD-001\")\n    commit(ctx, message=\"chore(prd): {prd_id} start work\")\n    log_call = ctx.logger.info.call_args\n    assert \"PRD-001\" in str(log_call)\n\n\n# ---------- empty diff (no changes to commit) ----------\n\n\ndef test_empty_diff_skips_commit(tmp_path: Path) -> None:\n    ctx = _make_ctx(tmp_path)\n\n    def fake_run(cmd: list[str], **kwargs: object) -> MagicMock:\n        result = MagicMock()\n        if cmd[:3] == [\"git\", \"diff\", \"--cached\"]:\n            result.returncode = 0  # nothing staged\n        else:\n            result.returncode = 0\n        return result\n\n    with patch(\"darkfactory.builtins.commit.subprocess.run\", side_effect=fake_run):\n        commit(ctx, message=\"chore: test\")\n\n    ctx.logger.info.assert_called_with(\"commit skipped: no changes to commit\")\n\n\ndef test_empty_diff_does_not_call_git_commit(tmp_path: Path) -> None:\n    ctx = _make_ctx(tmp_path)\n    calls: list[list[str]] = []\n\n    def fake_run(cmd: list[str], **kwargs: object) -> MagicMock:\n        calls.append(list(cmd))\n        result = MagicMock()\n        result.returncode = 0\n        return result\n\n    with patch(\"darkfactory.builtins.commit.subprocess.run\", side_effect=fake_run):\n        commit(ctx, message=\"chore: test\")\n\n    assert not any(\"commit\" in c and \"-m\" in c for c in calls)\n\n\n# ---------- successful commit ----------\n\n\ndef test_successful_commit_calls_git_add_then_commit(tmp_path: Path) -> None:\n    ctx = _make_ctx(tmp_path)\n    calls: list[list[str]] = []\n\n    def fake_run(cmd: list[str], **kwargs: object) -> MagicMock:\n        calls.append(list(cmd))\n        result = MagicMock()\n        # diff --cached --quiet returns 1 when there ARE staged changes\n        result.returncode = 1 if cmd[:3] == [\"git\", \"diff\", \"--cached\"] else 0\n        return result\n\n    with patch(\"darkfactory.builtins.commit.subprocess.run\", side_effect=fake_run):\n        commit(ctx, message=\"chore: my commit\")\n\n    assert calls[0] == [\"git\", \"add\", \"-A\"]\n    assert calls[2] == [\"git\", \"commit\", \"-m\", \"chore: my commit\"]\n\n\ndef test_successful_commit_uses_formatted_message(tmp_path: Path) -> None:\n    ctx = _make_ctx(tmp_path)\n    ctx.format_string.side_effect = lambda s: s.replace(\"{prd_id}\", \"PRD-042\")\n    committed_messages: list[str] = []\n\n    def fake_run(cmd, **kwargs):\n        result = MagicMock()\n        result.returncode = 1 if cmd[:3] == [\"git\", \"diff\", \"--cached\"] else 0\n        if \"commit\" in cmd and \"-m\" in cmd:\n            idx = cmd.index(\"-m\")\n            committed_messages.append(cmd[idx + 1])\n        return result\n\n    with patch(\"darkfactory.builtins.commit.subprocess.run\", side_effect=fake_run):\n        commit(ctx, message=\"chore(prd): {prd_id} start work\")\n\n    assert committed_messages == [\"chore(prd): PRD-042 start work\"]\n\n\n# ---------- forbidden attribution ----------\n\n\ndef test_forbidden_attribution_raises_before_subprocess(tmp_path: Path) -> None:\n    ctx = _make_ctx(tmp_path)\n    ctx.format_string.side_effect = lambda s: s\n\n    with patch(\"darkfactory.builtins.commit.subprocess.run\") as mock_run:\n        with pytest.raises(RuntimeError, match=\"forbidden attribution\"):\n            commit(\n                ctx,\n                message=\"chore: fix Co-Authored-By: Claude Code <noreply@anthropic.com>\",\n            )\n\n    mock_run.assert_not_called()\n\n\ndef test_forbidden_attribution_raises_in_dry_run(tmp_path: Path) -> None:\n    ctx = _make_ctx(tmp_path, dry_run=True)\n    ctx.format_string.side_effect = lambda s: s\n\n    with pytest.raises(RuntimeError, match=\"forbidden attribution\"):\n        commit(\n            ctx,\n            message=\"chore: fix Co-Authored-By: Claude Code <noreply@anthropic.com>\",\n        )\n","structuredPatch":[{"oldStart":104,"oldLines":7,"newStart":104,"newLines":7,"lines":["     ctx.format_string.side_effect = lambda s: s.replace(\"{prd_id}\", \"PRD-042\")","     committed_messages: list[str] = []"," ","-    def fake_run(cmd, **kwargs):","+    def fake_run(cmd: list[str], **kwargs: object) -> MagicMock:","         result = MagicMock()","         result.returncode = 1 if cmd[:3] == [\"git\", \"diff\", \"--cached\"] else 0","         if \"commit\" in cmd and \"-m\" in cmd:"]}],"userModified":false,"replaceAll":false}}
