{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01373PUzHcpRXuy6MwXtKnWz","type":"tool_result","content":"0\tfrom __future__ import annotations\n1\t\n2\timport re\n3\timport subprocess\n4\t\n5\tfrom darkfactory.workflow import ExecutionContext\n6\t\n7\t\n8\tdef _run(\n9\t    ctx: ExecutionContext,\n10\t    cmd: list[str],\n11\t    *,\n12\t    check: bool = True,\n13\t    capture: bool = False,\n14\t) -> subprocess.CompletedProcess[str]:\n15\t    \"\"\"Run a subprocess command inside ``ctx.cwd`` with dry-run support.\n16\t\n17\t    In dry-run mode, logs the command at INFO level and returns a fake\n18\t    ``CompletedProcess`` with exit code 0. In live mode, runs the\n19\t    command for real and raises ``subprocess.CalledProcessError`` on\n20\t    non-zero exit when ``check=True``.\n21\t\n22\t    Using an explicit argv list (not a shell string) prevents shell\n23\t    injection entirely — callers don't get to interpolate variables\n24\t    into a command line, they build the argv themselves.\n25\t    \"\"\"\n26\t    if ctx.dry_run:\n27\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n28\t        return subprocess.CompletedProcess(args=cmd, returncode=0, stdout=\"\", stderr=\"\")\n29\t\n30\t    return subprocess.run(\n31\t        cmd,\n32\t        cwd=str(ctx.cwd),\n33\t        check=check,\n34\t        capture_output=capture,\n35\t        text=True,\n36\t    )\n37\t\n38\t\n39\t# ----- attribution lint -----"}]},"parent_tool_use_id":null,"session_id":"6a3db6e8-ce1a-4c6b-ad07-39bb96d60951","uuid":"9768744e-e35d-4e1d-95bc-4d8d807d6078","timestamp":"2026-04-09T07:57:12.542Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-556.1-scaffold-cli-package/src/darkfactory/builtins/_shared.py","content":"from __future__ import annotations\n\nimport re\nimport subprocess\n\nfrom darkfactory.workflow import ExecutionContext\n\n\ndef _run(\n    ctx: ExecutionContext,\n    cmd: list[str],\n    *,\n    check: bool = True,\n    capture: bool = False,\n) -> subprocess.CompletedProcess[str]:\n    \"\"\"Run a subprocess command inside ``ctx.cwd`` with dry-run support.\n\n    In dry-run mode, logs the command at INFO level and returns a fake\n    ``CompletedProcess`` with exit code 0. In live mode, runs the\n    command for real and raises ``subprocess.CalledProcessError`` on\n    non-zero exit when ``check=True``.\n\n    Using an explicit argv list (not a shell string) prevents shell\n    injection entirely — callers don't get to interpolate variables\n    into a command line, they build the argv themselves.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return subprocess.CompletedProcess(args=cmd, returncode=0, stdout=\"\", stderr=\"\")\n\n    return subprocess.run(\n        cmd,\n        cwd=str(ctx.cwd),\n        check=check,\n        capture_output=capture,\n        text=True,\n    )\n\n\n# ----- attribution lint -----","numLines":40,"startLine":0,"totalLines":72}}}
