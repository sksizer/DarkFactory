{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017vM5vWAZp7Y93sXC4d8EQr","type":"tool_result","content":"1000\t    5. The remote's default branch via ``origin/HEAD``\n1001\t    6. Last resort: ``main`` (callers will hit a real error later if it's\n1002\t       missing too)\n1003\t\n1004\t    The user's current branch is **not** consulted. PRDs are independent\n1005\t    units of work and should base on the project's default branch unless\n1006\t    the user says otherwise. Stacking onto a feature branch is the\n1007\t    exception, not the rule, and requires an explicit ``--base`` flag.\n1008\t    \"\"\"\n1009\t    if explicit:\n1010\t        return explicit\n1011\t\n1012\t    env_override = os.environ.get(\"DARKFACTORY_BASE_REF\")\n1013\t    if env_override:\n1014\t        return env_override\n1015\t\n1016\t    for candidate in (\"main\", \"master\"):\n1017\t        result = subprocess.run(\n1018\t            [\n1019\t                \"git\",\n1020\t                \"-C\",\n1021\t                str(repo_root),\n1022\t                \"rev-parse\",\n1023\t                \"--verify\",\n1024\t                \"--quiet\",\n1025\t                f\"refs/heads/{candidate}\",\n1026\t            ],\n1027\t            capture_output=True,\n1028\t            text=True,\n1029\t        )\n1030\t        if result.returncode == 0:\n1031\t            return candidate\n1032\t\n1033\t    # Try remote's default branch (e.g. for fresh clones with no local main)\n1034\t    try:\n1035\t        result = subprocess.run(\n1036\t            [\"git\", \"-C\", str(repo_root), \"symbolic-ref\", \"refs/remotes/origin/HEAD\"],\n1037\t            check=True,\n1038\t            capture_output=True,\n1039\t            text=True,\n1040\t        )\n1041\t        # Output looks like \"refs/remotes/origin/main\"\n1042\t        return result.stdout.strip().rsplit(\"/\", 1)[-1]\n1043\t    except subprocess.CalledProcessError:\n1044\t        pass\n1045\t\n1046\t    return \"main\"\n1047\t\n1048\t\n1049\tdef _check_runnable(prd: PRD, prds: dict[str, PRD]) -> str | None:\n1050\t    \"\"\"Return an error string if the PRD can't be run, else None.\"\"\"\n1051\t    if prd.status == \"done\":\n1052\t        return f\"{prd.id} is already done\"\n1053\t    if prd.status == \"cancelled\":\n1054\t        return f\"{prd.id} is cancelled\"\n1055\t    if not graph.is_actionable(prd, prds):\n1056\t        missing = graph.missing_deps(prd, prds)\n1057\t        if missing:\n1058\t            return f\"{prd.id} depends on missing PRDs: {', '.join(missing)}\"\n1059\t        unfinished = [\n1060\t            dep_id\n1061\t            for dep_id in prd.depends_on\n1062\t            if dep_id in prds and prds[dep_id].status != \"done\"\n1063\t        ]\n1064\t        if unfinished:\n1065\t            return f\"{prd.id} has unfinished dependencies: \" + \", \".join(\n1066\t                f\"{d} ({prds[d].status})\" for d in unfinished\n1067\t            )\n1068\t        return f\"{prd.id} status is {prd.status!r}, not 'ready'\"\n1069\t    if not containment.is_runnable(prd, prds):\n1070\t        return (\n1071\t            f\"{prd.id} is an epic/feature with children; \"\n1072\t            \"use the planning workflow or run its task descendants instead\"\n1073\t        )\n1074\t    return None\n1075\t\n1076\t\n1077\tdef cmd_plan(args: argparse.Namespace) -> int:\n1078\t    \"\"\"Show the execution plan for a PRD without touching anything.\n1079\t\n1080\t    Resolves the workflow, computes the branch name + base ref + model,\n1081\t    and prints the ordered task list with descriptions. No git\n1082\t    operations, no subprocess, no agent invocation.\n1083\t    \"\"\"\n1084\t    prds = _load(args.prd_dir)\n1085\t    if args.prd_id not in prds:\n1086\t        raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n1087\t    prd = prds[args.prd_id]\n1088\t\n1089\t    workflows = _load_workflows_or_fail(args.workflows_dir)\n1090\t\n1091\t    # Resolve workflow (respecting --workflow override).\n1092\t    if args.workflow:\n1093\t        if args.workflow not in workflows:\n1094\t            raise SystemExit(f\"unknown workflow: {args.workflow}\")\n1095\t        workflow = workflows[args.workflow]\n1096\t    else:\n1097\t        try:\n1098\t            workflow = assign.assign_workflow(prd, prds, workflows)\n1099\t        except KeyError as exc:\n1100\t            raise SystemExit(str(exc))\n1101\t\n1102\t    branch = _compute_branch_name(prd)\n1103\t    repo_root = _find_repo_root(args.prd_dir)\n1104\t    base_ref = _resolve_base_ref(args.base, repo_root)\n1105\t\n1106\t    # Note any runnability issues as warnings (plan still shows, but\n1107\t    # the user gets a heads-up that `prd run --execute` would refuse).\n1108\t    runnable_error = _check_runnable(prd, prds)\n1109\t\n1110\t    if args.json:\n1111\t        payload: dict[str, object] = {\n1112\t            \"prd\": {\n1113\t                \"id\": prd.id,\n1114\t                \"title\": prd.title,\n1115\t                \"kind\": prd.kind,\n1116\t                \"status\": prd.status,\n1117\t                \"capability\": prd.capability,\n1118\t            },\n1119\t            \"workflow\": {\n1120\t                \"name\": workflow.name,\n1121\t                \"description\": workflow.description,\n1122\t                \"priority\": workflow.priority,\n1123\t            },\n1124\t            \"branch\": branch,\n1125\t            \"base_ref\": base_ref,\n1126\t            \"default_model\": capability_to_model(prd.capability),\n1127\t            \"tasks\": [_describe_task(task, prd, args.model) for task in workflow.tasks],\n1128\t            \"runnable_error\": runnable_error,\n1129\t        }\n1130\t        print(json.dumps(payload, indent=2))\n1131\t        return 0\n1132\t\n1133\t    print(f\"# Plan for {prd.id}: {prd.title}\")\n1134\t    print()\n1135\t    print(f\"  kind:       {prd.kind}\")\n1136\t    print(f\"  status:     {prd.status}\")\n1137\t    print(\n1138\t        f\"  capability: {prd.capability} -> default model {capability_to_model(prd.capability)}\"\n1139\t    )\n1140\t    print()\n1141\t    print(f\"  workflow:   {workflow.name} (priority {workflow.priority})\")\n1142\t    if workflow.description:\n1143\t        print(f\"  — {workflow.description}\")\n1144\t    print()\n1145\t    print(f\"  branch:     {branch}\")\n1146\t    print(f\"  base ref:   {base_ref}\")\n1147\t    print()\n1148\t    print(f\"  tasks ({len(workflow.tasks)}):\")\n1149\t    for i, task in enumerate(workflow.tasks, start=1):\n1150\t        print(f\"    {i:>2}. {_describe_task(task, prd, args.model)}\")\n1151\t\n1152\t    if runnable_error:\n1153\t        print()\n1154\t        print(f\"  ⚠ NOT RUNNABLE: {runnable_error}\")\n1155\t        print(\"    (`prd run --execute` would refuse this PRD)\")\n1156\t    return 0\n1157\t\n1158\t\n1159\tdef _is_graph_target(prd: PRD, prds: dict[str, PRD]) -> bool:\n1160\t    \"\"\"True if ``prd run`` should walk the DAG rather than run a single PRD.\n1161\t\n1162\t    Routes through the graph executor when the target has children (epic\n1163\t    or feature with decomposition) or any unfinished ``depends_on`` —\n1164\t    both cases require multi-PRD orchestration. A plain ready leaf with\n1165\t    all deps satisfied goes through the legacy single-PRD path.\n1166\t    \"\"\"\n1167\t    if not containment.is_leaf(prd, prds):\n1168\t        return True\n1169\t    for dep_id in prd.depends_on:\n1170\t        dep = prds.get(dep_id)\n1171\t        if dep is None:\n1172\t            continue\n1173\t        if dep.status != \"done\":\n1174\t            return True\n1175\t    return False\n1176\t\n1177\t\n1178\tdef cmd_run(args: argparse.Namespace) -> int:\n1179\t    \"\"\"Run a workflow against a PRD. Defaults to dry-run; opt in via --execute.\n1180\t\n1181\t    - **Single leaf with deps satisfied:** legacy path — one worktree,\n1182\t      one workflow run.\n1183\t    - **Epic/feature with children, or leaf with unmet deps:** graph\n1184\t      execution — walks the DAG in topological order, running each\n1185\t      actionable leaf in its own worktree. Sequential only (PRD-220).\n1186\t      Parallel fan-out is PRD-551.\n1187\t    \"\"\"\n1188\t    prds = _load(args.prd_dir)\n1189\t    if args.prd_id not in prds:\n1190\t        raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n1191\t    prd = prds[args.prd_id]\n1192\t\n1193\t    workflows = _load_workflows_or_fail(args.workflows_dir)\n1194\t\n1195\t    repo_root = _find_repo_root(args.prd_dir)\n1196\t    base_ref = _resolve_base_ref(args.base, repo_root)\n1197\t    dry_run = not args.execute\n1198\t    styler: Styler = args.styler\n1199\t"}]},"parent_tool_use_id":null,"session_id":"6a3db6e8-ce1a-4c6b-ad07-39bb96d60951","uuid":"75675fc2-12a8-43b4-9f6e-d2e8211307d8","timestamp":"2026-04-09T07:55:21.839Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-556.1-scaffold-cli-package/src/darkfactory/cli.py","content":"    5. The remote's default branch via ``origin/HEAD``\n    6. Last resort: ``main`` (callers will hit a real error later if it's\n       missing too)\n\n    The user's current branch is **not** consulted. PRDs are independent\n    units of work and should base on the project's default branch unless\n    the user says otherwise. Stacking onto a feature branch is the\n    exception, not the rule, and requires an explicit ``--base`` flag.\n    \"\"\"\n    if explicit:\n        return explicit\n\n    env_override = os.environ.get(\"DARKFACTORY_BASE_REF\")\n    if env_override:\n        return env_override\n\n    for candidate in (\"main\", \"master\"):\n        result = subprocess.run(\n            [\n                \"git\",\n                \"-C\",\n                str(repo_root),\n                \"rev-parse\",\n                \"--verify\",\n                \"--quiet\",\n                f\"refs/heads/{candidate}\",\n            ],\n            capture_output=True,\n            text=True,\n        )\n        if result.returncode == 0:\n            return candidate\n\n    # Try remote's default branch (e.g. for fresh clones with no local main)\n    try:\n        result = subprocess.run(\n            [\"git\", \"-C\", str(repo_root), \"symbolic-ref\", \"refs/remotes/origin/HEAD\"],\n            check=True,\n            capture_output=True,\n            text=True,\n        )\n        # Output looks like \"refs/remotes/origin/main\"\n        return result.stdout.strip().rsplit(\"/\", 1)[-1]\n    except subprocess.CalledProcessError:\n        pass\n\n    return \"main\"\n\n\ndef _check_runnable(prd: PRD, prds: dict[str, PRD]) -> str | None:\n    \"\"\"Return an error string if the PRD can't be run, else None.\"\"\"\n    if prd.status == \"done\":\n        return f\"{prd.id} is already done\"\n    if prd.status == \"cancelled\":\n        return f\"{prd.id} is cancelled\"\n    if not graph.is_actionable(prd, prds):\n        missing = graph.missing_deps(prd, prds)\n        if missing:\n            return f\"{prd.id} depends on missing PRDs: {', '.join(missing)}\"\n        unfinished = [\n            dep_id\n            for dep_id in prd.depends_on\n            if dep_id in prds and prds[dep_id].status != \"done\"\n        ]\n        if unfinished:\n            return f\"{prd.id} has unfinished dependencies: \" + \", \".join(\n                f\"{d} ({prds[d].status})\" for d in unfinished\n            )\n        return f\"{prd.id} status is {prd.status!r}, not 'ready'\"\n    if not containment.is_runnable(prd, prds):\n        return (\n            f\"{prd.id} is an epic/feature with children; \"\n            \"use the planning workflow or run its task descendants instead\"\n        )\n    return None\n\n\ndef cmd_plan(args: argparse.Namespace) -> int:\n    \"\"\"Show the execution plan for a PRD without touching anything.\n\n    Resolves the workflow, computes the branch name + base ref + model,\n    and prints the ordered task list with descriptions. No git\n    operations, no subprocess, no agent invocation.\n    \"\"\"\n    prds = _load(args.prd_dir)\n    if args.prd_id not in prds:\n        raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n    prd = prds[args.prd_id]\n\n    workflows = _load_workflows_or_fail(args.workflows_dir)\n\n    # Resolve workflow (respecting --workflow override).\n    if args.workflow:\n        if args.workflow not in workflows:\n            raise SystemExit(f\"unknown workflow: {args.workflow}\")\n        workflow = workflows[args.workflow]\n    else:\n        try:\n            workflow = assign.assign_workflow(prd, prds, workflows)\n        except KeyError as exc:\n            raise SystemExit(str(exc))\n\n    branch = _compute_branch_name(prd)\n    repo_root = _find_repo_root(args.prd_dir)\n    base_ref = _resolve_base_ref(args.base, repo_root)\n\n    # Note any runnability issues as warnings (plan still shows, but\n    # the user gets a heads-up that `prd run --execute` would refuse).\n    runnable_error = _check_runnable(prd, prds)\n\n    if args.json:\n        payload: dict[str, object] = {\n            \"prd\": {\n                \"id\": prd.id,\n                \"title\": prd.title,\n                \"kind\": prd.kind,\n                \"status\": prd.status,\n                \"capability\": prd.capability,\n            },\n            \"workflow\": {\n                \"name\": workflow.name,\n                \"description\": workflow.description,\n                \"priority\": workflow.priority,\n            },\n            \"branch\": branch,\n            \"base_ref\": base_ref,\n            \"default_model\": capability_to_model(prd.capability),\n            \"tasks\": [_describe_task(task, prd, args.model) for task in workflow.tasks],\n            \"runnable_error\": runnable_error,\n        }\n        print(json.dumps(payload, indent=2))\n        return 0\n\n    print(f\"# Plan for {prd.id}: {prd.title}\")\n    print()\n    print(f\"  kind:       {prd.kind}\")\n    print(f\"  status:     {prd.status}\")\n    print(\n        f\"  capability: {prd.capability} -> default model {capability_to_model(prd.capability)}\"\n    )\n    print()\n    print(f\"  workflow:   {workflow.name} (priority {workflow.priority})\")\n    if workflow.description:\n        print(f\"  — {workflow.description}\")\n    print()\n    print(f\"  branch:     {branch}\")\n    print(f\"  base ref:   {base_ref}\")\n    print()\n    print(f\"  tasks ({len(workflow.tasks)}):\")\n    for i, task in enumerate(workflow.tasks, start=1):\n        print(f\"    {i:>2}. {_describe_task(task, prd, args.model)}\")\n\n    if runnable_error:\n        print()\n        print(f\"  ⚠ NOT RUNNABLE: {runnable_error}\")\n        print(\"    (`prd run --execute` would refuse this PRD)\")\n    return 0\n\n\ndef _is_graph_target(prd: PRD, prds: dict[str, PRD]) -> bool:\n    \"\"\"True if ``prd run`` should walk the DAG rather than run a single PRD.\n\n    Routes through the graph executor when the target has children (epic\n    or feature with decomposition) or any unfinished ``depends_on`` —\n    both cases require multi-PRD orchestration. A plain ready leaf with\n    all deps satisfied goes through the legacy single-PRD path.\n    \"\"\"\n    if not containment.is_leaf(prd, prds):\n        return True\n    for dep_id in prd.depends_on:\n        dep = prds.get(dep_id)\n        if dep is None:\n            continue\n        if dep.status != \"done\":\n            return True\n    return False\n\n\ndef cmd_run(args: argparse.Namespace) -> int:\n    \"\"\"Run a workflow against a PRD. Defaults to dry-run; opt in via --execute.\n\n    - **Single leaf with deps satisfied:** legacy path — one worktree,\n      one workflow run.\n    - **Epic/feature with children, or leaf with unmet deps:** graph\n      execution — walks the DAG in topological order, running each\n      actionable leaf in its own worktree. Sequential only (PRD-220).\n      Parallel fan-