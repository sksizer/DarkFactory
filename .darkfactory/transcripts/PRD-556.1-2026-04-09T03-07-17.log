{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QerDcnH6iZPMtFmVmvPNhM","type":"tool_result","content":"1\t\"\"\"Unit tests for shared helpers: _run and _scan_for_forbidden_attribution.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\tfrom pathlib import Path\n6\t\n7\timport pytest\n8\t\n9\tfrom darkfactory.builtins._shared import (\n10\t    _FORBIDDEN_ATTRIBUTION_PATTERNS,\n11\t    _run,\n12\t    _scan_for_forbidden_attribution,\n13\t)\n14\t\n15\t\n16\t# ---------- _scan_for_forbidden_attribution ----------\n17\t\n18\t\n19\tdef test_scan_empty_text_is_noop() -> None:\n20\t    # Should not raise.\n21\t    _scan_for_forbidden_attribution(\"\", source=\"test\")\n22\t\n23\t\n24\tdef test_scan_clean_text_is_noop() -> None:\n25\t    _scan_for_forbidden_attribution(\"chore(prd): PRD-070 start work\", source=\"test\")\n26\t\n27\t\n28\tdef test_scan_raises_on_co_authored_by_claude() -> None:\n29\t    with pytest.raises(RuntimeError, match=\"forbidden attribution\"):\n30\t        _scan_for_forbidden_attribution(\n31\t            \"Some commit\\n\\nCo-Authored-By: Claude Sonnet <noreply@anthropic.com>\",\n32\t            source=\"commit PRD-070\",\n33\t        )\n34\t\n35\t\n36\tdef test_scan_raises_on_co_authored_by_anthropic_email() -> None:\n37\t    with pytest.raises(RuntimeError, match=\"forbidden attribution\"):\n38\t        _scan_for_forbidden_attribution(\n39\t            \"Some commit\\n\\nCo-Authored-By: Bot <bot@anthropic.com>\",\n40\t            source=\"commit PRD-070\",\n41\t        )\n42\t\n43\t\n44\tdef test_scan_raises_on_generated_with_claude_code() -> None:\n45\t    with pytest.raises(RuntimeError, match=\"forbidden attribution\"):\n46\t        _scan_for_forbidden_attribution(\n47\t            \"Generated with Claude Code\",\n48\t            source=\"PR body\",\n49\t        )\n50\t\n51\t\n52\tdef test_scan_raises_on_robot_emoji_generated_with() -> None:\n53\t    with pytest.raises(RuntimeError, match=\"forbidden attribution\"):\n54\t        _scan_for_forbidden_attribution(\n55\t            \"🤖 Generated with something\",\n56\t            source=\"PR body\",\n57\t        )\n58\t\n59\t\n60\tdef test_scan_error_message_includes_source() -> None:\n61\t    with pytest.raises(RuntimeError, match=\"my-source\"):\n62\t        _scan_for_forbidden_attribution(\n63\t            \"Co-Authored-By: Claude\",\n64\t            source=\"my-source\",\n65\t        )\n66\t\n67\t\n68\tdef test_forbidden_attribution_patterns_is_tuple() -> None:\n69\t    assert isinstance(_FORBIDDEN_ATTRIBUTION_PATTERNS, tuple)\n70\t    assert len(_FORBIDDEN_ATTRIBUTION_PATTERNS) > 0\n71\t\n72\t\n73\t# ---------- _run (dry-run only — no subprocess required) ----------\n74\t\n75\t\n76\tdef test_run_dry_run_returns_zero_returncode(tmp_path: Path) -> None:\n77\t    from unittest.mock import MagicMock\n78\t\n79\t    ctx = MagicMock()\n80\t    ctx.dry_run = True\n81\t    ctx.cwd = tmp_path\n82\t\n83\t    result = _run(ctx, [\"git\", \"status\"])\n84\t    assert result.returncode == 0\n85\t\n86\t\n87\tdef test_run_dry_run_returns_empty_stdout(tmp_path: Path) -> None:\n88\t    from unittest.mock import MagicMock\n89\t\n90\t    ctx = MagicMock()\n91\t    ctx.dry_run = True\n92\t    ctx.cwd = tmp_path\n93\t\n94\t    result = _run(ctx, [\"git\", \"status\"])\n95\t    assert result.stdout == \"\"\n96\t    assert result.stderr == \"\"\n97\t\n98\t\n99\tdef test_run_dry_run_logs_command(tmp_path: Path) -> None:\n100\t    from unittest.mock import MagicMock\n101\t\n102\t    ctx = MagicMock()\n103\t    ctx.dry_run = True\n104\t    ctx.cwd = tmp_path\n105\t\n106\t    _run(ctx, [\"git\", \"status\", \"--short\"])\n107\t    ctx.logger.info.assert_called_once()\n108\t    call_args = ctx.logger.info.call_args[0]\n109\t    assert \"git status --short\" in call_args[1]\n110\t"}]},"parent_tool_use_id":null,"session_id":"6a3db6e8-ce1a-4c6b-ad07-39bb96d60951","uuid":"2e16216f-84a2-403b-ae56-48693e0a3898","timestamp":"2026-04-09T07:55:54.279Z","to