k {prd_id} done \"\n1549\t            f\"(auto-reconciled from merged PR #{pr['number']}) [skip ci]\"\n1550\t        )\n1551\t    return f\"chore(prd): reconcile {len(candidates)} merged PRD statuses [skip ci]\"\n1552\t\n1553\t\n1554\tdef _commit_to_main(\n1555\t    candidates: list[tuple[Path, dict[str, Any]]],\n1556\t    repo_root: Path,\n1557\t) -> None:\n1558\t    \"\"\"Stage changed PRD files and commit directly to main.\"\"\"\n1559\t    files = [str(c[0]) for c in candidates]\n1560\t    subprocess.run([\"git\", \"-C\", str(repo_root), \"add\"] + files, check=True)\n1561\t    msg = _build_reconcile_commit_msg(candidates)\n1562\t    subprocess.run(\n1563\t        [\"git\", \"-C\", str(repo_root), \"commit\", \"-m\", msg],\n1564\t        check=True,\n1565\t    )\n1566\t\n1567\t\n1568\tdef _create_reconcile_pr(\n1569\t    candidates: list[tuple[Path, dict[str, Any]]],\n1570\t    repo_root: Path,\n1571\t) -> None:\n1572\t    \"\"\"Create a PR with the reconciled status changes.\"\"\"\n1573\t    branch = \"prd/reconcile-status\"\n1574\t    subprocess.run(\n1575\t        [\"git\", \"-C\", str(repo_root), \"checkout\", \"-b\", branch],\n1576\t        check=True,\n1577\t    )\n1578\t    files = [str(c[0]) for c in candidates]\n1579\t    subprocess.run([\"git\", \"-C\", str(repo_root), \"add\"] + files, check=True)\n1580\t    msg = _build_reconcile_commit_msg(candidates)\n1581\t    subprocess.run(\n1582\t        [\"git\", \"-C\", str(repo_root), \"commit\", \"-m\", msg],\n1583\t        check=True,\n1584\t    )\n1585\t    subprocess.run(\n1586\t        [\"git\", \"-C\", str(repo_root), \"push\", \"-u\", \"origin\", branch],\n1587\t        check=True,\n1588\t    )\n1589\t    subprocess.run(\n1590\t        [\n1591\t            \"gh\",\n1592\t            \"pr\",\n1593\t            \"create\",\n1594\t            \"--title\",\n1595\t            msg,\n1596\t            \"--body\",\n1597\t            \"Auto-reconciled by `prd reconcile`\",\n1598\t        ],\n1599\t        check