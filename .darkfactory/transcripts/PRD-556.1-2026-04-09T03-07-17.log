{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F84vk4vDiN8ksr5r4Ah7Cp","type":"tool_result","content":"200\t        \"blocks\": [],\n201\t        \"impacts\": [],\n202\t        \"workflow\": None,\n203\t        \"assignee\": None,\n204\t        \"reviewers\": [],\n205\t        \"target_version\": None,\n206\t        \"created\": today,\n207\t        \"updated\": today,\n208\t        \"tags\": [],\n209\t    }\n210\t\n211\t    body = DRAFT_TEMPLATE_BODY.format(title=args.title)\n212\t    content = f\"---\\n{dump_frontmatter(frontmatter)}---\\n\\n{body}\"\n213\t\n214\t    args.prd_dir.mkdir(parents=True, exist_ok=True)\n215\t    path.write_text(content, encoding=\"utf-8\")\n216\t    print(f\"Created {path}\")\n217\t\n218\t    if args.open:\n219\t        editor = os.environ.get(\"EDITOR\", \"\")\n220\t        if editor:\n221\t            subprocess.run([editor, str(path)], check=False)\n222\t\n223\t    return 0\n224\t\n225\t\n226\tdef cmd_status(args: argparse.Namespace) -> int:\n227\t    prds = _load(args.prd_dir)\n228\t    counts = Counter(prd.status for prd in prds.values())\n229\t    actionable = sorted(\n230\t        (prd for prd in prds.values() if graph.is_actionable(prd, prds)),\n231\t        key=_action_sort_key,\n232\t    )\n233\t    runnable = [prd for prd in actionable if containment.is_runnable(prd, prds)]\n234\t\n235\t    if args.json:\n236\t        out = {\n237\t            \"total\": len(prds),\n238\t            \"by_status\": dict(counts),\n239\t            \"actionable\": len(actionable),\n240\t            \"runnable\": len(runnable),\n241\t            \"next\": [\n242\t                {\n243\t                    \"id\": p.id,\n244\t                    \"title\": p.title,\n245\t                    \"priority\": p.priority,\n246\t                    \"effort\": p.effort,\n247\t                }\n248\t                for p in runnable[:5]\n249\t            ],\n250\t        }\n251\t        print(json.dumps(out, indent=2))\n252\t        return 0\n253\t\n254\t    print(f\"PRDs — {len(prds)} total\")\n255\t    for status in (\n256\t        \"done\",\n257\t        \"review\",\n258\t        \"in-progress\",\n259\t        \"ready\",\n260\t        \"blocked\",\n261\t        \"draft\",\n262\t        \"cancelled\",\n263\t    ):\n264\t        n = counts.get(status, 0)\n265\t        if n:\n266\t            print(f\"  {status:14} {n}\")\n267\t    print(f\"\\n  actionable: {len(actionable)}   runnable: {len(runnable)}\")\n268\t    if runnable:\n269\t        print(\"\\nNext runnable (top 5):\")\n270\t        for prd in runnable[:5]:\n271\t            print(\n272\t                f\"  {prd.id:14} [{prd.kind}/{prd.effort}/{prd.capability}]  {prd.title}\"\n273\t            )\n274\t\n275\t    try:\n276\t        repo_root = _find_repo_root(args.prd_dir)\n277\t        stale = find_stale_worktrees(repo_root)\n278\t        if stale:\n279\t            print(\n280\t                f\"\\n{len(stale)} worktrees for merged PRDs\"\n281\t                \" (run 'prd cleanup --merged' to remove)\"\n282\t            )\n283\t    except (SystemExit, Exception):  # noqa: BLE001 — best-effort outside a git repo\n284\t        pass\n285\t\n286\t    return 0\n287\t\n288\t\n289\tdef _remove_worktree(worktree: StaleWorktree, repo_root: Path) -> None:\n290\t    \"\"\"Remove a worktree directory and delete the local branch.\"\"\"\n291\t    subprocess.run(\n292\t        [\"git\", \"worktree\", \"remove\", \"--force\", str(worktree.worktree_path)],\n293\t        cwd=repo_root,\n294\t        check=True,\n295\t    )\n296\t    subprocess.run(\n297\t        [\"git\", \"branch\", \"-D\", worktree.branch.removeprefix(\"prd/\")],\n298\t        cwd=repo_root,\n299\t        capture_output=True,\n300\t    )\n301\t\n302\t\n303\tdef _find_worktree_for_prd(prd_id: str, repo_root: Path) -> StaleWorktree | None:\n304\t    \"\"\"Find the worktree entry for the given PRD id, regardless of PR state.\"\"\"\n305\t    worktrees_dir = repo_root / \".worktrees\"\n306\t    if not worktrees_dir.exists():\n307\t        return None\n308\t    for entry in sorted(worktrees_dir.iterdir()):\n309\t        if not entry.is_dir():\n310\t            continue\n311\t        name = entry.name\n312\t        m = re.match(r\"^(PRD-[\\d.]+)\", name)\n313\t        if not m:\n314\t            continue\n315\t        if m.group(1) != prd_id:\n316\t            continue\n317\t        branch = f\"prd/{name}\"\n318\t        pr_state = checks._get_pr_state(branch, repo_root)\n319\t        return StaleWorktree(\n320\t            prd_id=prd_id,\n321\t            branch=branch,\n322\t            worktree_path=entry,\n323\t            pr_state=pr_state,\n324\t        )\n325\t    return None\n326\t\n327\t\n328\tdef _find_orphaned_branch(prd_id: str, repo_root: Path) -> str | None:\n329\t    \"\"\"Find a local branch for *prd_id* when the worktree dir is gone.\"\"\"\n330\t    result = subprocess.run(\n331\t        [\"git\", \"branch\", \"--list\", f\"prd/{prd_id}-*\"],\n332\t        cwd=repo_root,\n333\t        capture_output=True,\n334\t        text=True,\n335\t    )\n336\t    for line in result.stdout.splitlines():\n337\t        branch = line.strip().lstrip(\"* \")\n338\t        if branch:\n339\t            return branch\n340\t    return None\n341\t\n342\t\n343\tdef _orphaned_branch_commit_count(\n344\t    branch: str, repo_root: Path, base: str = \"main\"\n345\t) -> int:\n346\t    \"\"\"Count commits on *branch* ahead of *base*.\"\"\"\n347\t    result = subprocess.run(\n348\t        [\"git\", \"rev-list\", \"--count\", f\"{base}..{branch}\"],\n349\t        cwd=repo_root,\n350\t        capture_output=True,\n351\t        text=True,\n352\t    )\n353\t    if result.returncode == 0:\n354\t        return int(result.stdout.strip() or \"0\")\n355\t    return 0\n356\t\n357\t\n358\tdef _cleanup_single(prd_id: str, force: bool, repo_root: Path) -> int:\n359\t    worktree = _find_worktree_for_prd(prd_id, repo_root)\n360\t    if worktree is None:\n361\t      