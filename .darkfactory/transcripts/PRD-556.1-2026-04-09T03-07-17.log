{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XyhqAX3hYrpU17E1qruoy4","type":"tool_result","content":"0\t\"\"\"Command-line interface for the darkfactory PRD harness.\n1\t\n2\tUsage::\n3\t\n4\t    uv run prd <subcommand> [options]\n5\t\n6\tDefaults: PRDs live in ``prds/`` and workflows in ``workflows/`` at the\n7\trepo root. Override via ``--prd-dir`` and ``--workflows-dir``.\n8\t\n9\tThis should have minimial logic; the subcommand implementations can call into\n10\tspecific modules for the heavy lifting.\n11\t\"\"\"\n12\t\n13\tfrom __future__ import annotations\n14\t\n15\timport argparse\n16\timport json\n17\timport logging\n18\timport os\n19\timport re\n20\timport subprocess\n21\timport sys\n22\timport tomllib\n23\tfrom collections import Counter\n24\tfrom datetime import date\n25\tfrom pathlib import Path\n26\tfrom typing import Any\n27\t\n28\tfrom . import assign, checks, containment, graph, impacts\n29\tfrom .discovery import resolve_project_root\n30\tfrom .checks import StaleWorktree, find_stale_worktrees, is_safe_to_remove\n31\tfrom .graph_execution import RunEvent, execute_graph, plan_execution\n32\tfrom .invoke import capability_to_model\n33\tfrom .loader import load_workflows\n34\tfrom .prd import (\n35\t    PRD,\n36\t    PRD_ID_RE,\n37\t    dump_frontmatter,\n38\t    load_all,\n39\t    normalize_list_field_at,\n40\t    parse_id_sort_key,\n41\t    set_workflow,\n42\t    update_frontmatter_field_at,\n43\t)\n44\tfrom .runner import _compute_branch_name, _pick_model, run_workflow\n45\tfrom .style import Element, Styler, resolve_style_config\n46\tfrom .workflow import AgentTask, BuiltIn, ShellTask, Task, Workflow\n47\t\n48\t# Priority/effort orderings used for sorting actionable lists.\n49\tPRIORITY_ORDER: dict[str, int] = {\"critical\": 0, \"high\": 1, \"medium\": 2, \"low\": 3}\n50\tEFFORT_ORDER: dict[str, int] = {\"xs\": 0, \"s\": 1, \"m\": 2, \"l\": 3, \"xl\": 4}\n51\tCAPABILITY_ORDER: dict[str, int] = {\n52\t    \"trivial\": 0,\n53\t    \"simple\": 1,\n54\t    \"moderate\": 2,\n55\t    \"complex\": 3,\n56\t}\n57\t\n58\t\n59\tdef _read_config_timeouts(repo_root: Path) -> dict[str, object] | None:\n60\t    \"\"\"Return the ``[timeouts]`` section from ``.darkfactory/config.toml``, or None.\"\"\"\n61\t    config_path = repo_root / \".darkfactory\" / \"config.toml\"\n62\t    if not config_path.exists():\n63\t        return None\n64\t    try:\n65\t        with open(config_path, \"rb\") as fh:\n66\t            data = tomllib.load(fh)\n67\t        section = data.get(\"timeouts\")\n68\t        return section if isinstance(section, dict) else None\n69\t    except Exception:  # noqa: BLE001\n70\t        return None\n71\t\n72\t\n73\tdef _find_repo_root(start: Path) -> Path:\n74\t    \"\"\"Walk up from ``start`` until a ``.git`` directory is found.\n75\t\n76\t    Used for git-specific operations (worktrees, tracked files, branches).\n77\t    Project discovery uses ``resolve_project_root`` from ``discovery`` instead.\n78\t    \"\"\"\n79\t    current = start.resolve()\n80\t    while current != current.parent:\n81\t        if (current / \".git\").exists():\n82\t            return current\n83\t        current = current.parent\n84\t    raise SystemExit(f\"could not locate git repo root from {start}\")\n85\t\n86\t\n87\tdef _load_workflows_or_fail(workflows_dir: Path) -> dict[str, Workflow]:\n88\t    \"\"\"Load built-in and project-level workflows.\n89\t\n90\t    Built-in (system) workflows ship inside the package and are always\n91\t    available. ``workflows_dir`` is the optional project-level layer\n92\t    (``<project>/.darkfactory/workflows/``); if it doesn't exist we just\n93\t    return the built-ins.\n94\t    \"\"\"\n95\t    return load_workflows(workflows_dir if workflows_dir.exists() else None)\n96\t\n97\t\n98\tdef _action_sort_key(prd: PRD) -> tuple[int, int, tuple[int, ...]]:\n99\t    \"\"\"Sort key for actionable lists: priority, effort, natural id.\"\"\"\n100\t    return (\n101\t        PRIORITY_ORDER.get(prd.priority, 99),\n102\t        EFFORT_ORDER.get(prd.effort, 99),\n103\t        parse_id_sort_key(prd.id),\n104\t    )\n105\t\n106\t\n107\tdef _load(prd_dir: Path) -> dict[str, PRD]:\n108\t    if not prd_dir.exists():\n109\t        raise SystemExit(f\"PRD directory not found: {prd_dir}\")\n110\t    return load_all(prd_dir)\n111\t\n112\t\n113\t# ---------- subcommand implementations ----------\n114\t\n115\t\n116\tdef _slugify(title: str) -> str:\n117\t    \"\"\"Convert a title to kebab-case slug.\"\"\"\n118\t    slug = re.sub(r\"[^a-zA-Z0-9\\s-]\", \"\", title.lower())\n119\t    slug = re.sub(r\"\\s+\", \"-\", slug.strip())\n120\t    return slug or \"untitled\"\n121\t\n122\t\n123\tdef _next_flat_prd_id(prds: dict[str, PRD]) -> str:\n124\t    \"\"\"Find the next unused flat PRD id (PRD-NNN) above the existing max.\"\"\"\n125\t    flat_ids = [\n126\t        int(pid.removeprefix(\"PRD-\")) for pid in prds if re.match(r\"^PRD-\\d+$\", pid)\n127\t    ]\n128\t    next_n = (max(flat_ids) + 1) if flat_ids else 1\n129\t    return f\"PRD-{next_n:03d}\"\n130\t\n131\t\n132\tDRAFT_TEMPLATE_BODY = \"\"\"# {title}\n133\t\n134\t## Summary\n135\t\n136\t<!-- 1-3 sentence elevator pitch. What does this deliver and why does it matter? -->\n137\t\n138\t## Motivation\n139\t\n140\t<!-- What problem does this solve? Who benefits? What happens if we don't build it? -->\n141\t\n142\t## Requirements\n143\t\n144\t### Functional\n145\t\n146\t1. ...\n147\t\n148\t### Non-Functional\n149\t\n150\t1. ...\n151\t\n152\t## Technical Approach\n153\t\n154\t<!-- High-level design: affected modules, data flow, key libraries. -->\n155\t\n156\t## Acceptance Criteria\n157\t\n158\t- [ ] AC-1: ...\n159\t\n160\t## Open Questions\n161\t\n162\t<!-- Tag each with OPEN | RESOLVED | DEFERRED -->\n163\t\n164\t## References\n165\t\n166\t\"\"\"\n167\t\n168\t\n169\tdef cmd_new(args: argparse.Namespace) -> int:\n170\t    prds = load_all(args.prd_dir) if args.prd_dir.exists() else {}\n171\t\n172\t    # Pick ID\n173\t    if args.id:\n174\t        if not PRD_ID_RE.match(args.id):\n175\t            raise SystemExit(f\"invalid PRD id: {args.id!r}\")\n176\t        if args.id in prds:\n177\t            raise SystemExit(f\"PRD id {args.id!r} already exists\")\n178\t        new_id = args.id\n179\t    else:\n180\t        new_id = _next_flat_prd_id(prds)\n181\t\n182\t    slug = _slugify(args.title)\n183\t    filename = f\"{new_id}-{slug}.md\"\n184\t    path = args.prd_dir / filename\n185\t    if path.exists():\n186\t        raise SystemExit(f\"file already exists: {path}\")\n187\t\n188\t    today = date.today().isoformat()\n189\t    frontmatter = {\n190\t        \"id\": new_id,\n191\t        \"title\": args.title,\n192\t        \"kind\": args.kind,\n193\t        \"status\": \"draft\",\n194\t        \"priority\": args.priority,\n195\t        \"effort\": args.effort,\n196\t        \"capability\": args.capability,\n197\t        \"parent\": None,\n198\t        \"depends_on\": [],\n199\t        \"blocks\": [],"}]},"parent_tool_use_id":null,"session_id":"6a3db6e8-ce1a-4c6b-ad07-39bb96d60951","uuid":"5ef295c9-b5dd-4925-958d-17bf905ec435","timestamp":"2026-04-09T07:55:03.060Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-556.1-scaffold-cli-package/src/darkfactory/cli.py","content":"\"\"\"Command-line interface for the darkfactory PRD harness.\n\nUsage::\n\n    uv run prd <subcommand> [options]\n\nDefaults: PRDs live in ``prds/`` and workflows in ``workflows/`` at the\nrepo root. Override via ``--prd-dir`` and ``--workflows-dir``.\n\nThis should have minimial logic; the subcommand implementations can call into\nspecific modules for the heavy lifting.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport logging\nimport os\nimport re\nimport subprocess\nimport sys\nimport tomllib\nfrom collections import Counter\nfrom datetime import date\nfrom pathlib import Path\nfrom typing import Any\n\nfrom . import assign, checks, containment, graph, impacts\nfrom .discovery import resolve_project_root\nfrom .checks import StaleWorktree, find_stale_worktrees, is_safe_to_remove\nfrom .graph_execution import RunEvent, execute_graph, plan_execution\nfrom .invoke import capability_to_model\nfrom .loader import load_workflows\nfrom .prd import (\n    PRD,\n    PRD_ID_RE,\n    dump_frontmatter,\n    load_all,\n    normalize_list_field_at,\n    parse_id_sort_key,\n    set_workflow,\n    update_frontmatter_field_at,\n)\nfrom .runner import _compute_branch_name, _pick_model, run_workflow\nfrom .style import Element, Styler, resolve_style_config\nfrom .workflow import AgentTask, BuiltIn, ShellTask, Task, Workflow\n\n# Priority/effort orderings used for sorting actionable lists.\nPRIORITY_ORDER: dict[str, int] = {\"critical\": 0, \"high\": 1, \"medium\": 2, \"low\": 3}\nEFFORT_ORDER: dict[str, int] = {\"xs\": 0, \"s\": 1, \"m\": 2, \"l\": 3, \"xl\": 4}\nCAPABILITY_ORDER: dict[str, int] = {\n    \"trivial\": 0,\n    \"simple\": 1,\n    \"moderate\": 2,\n    \"complex\": 3,\n}\n\n\ndef _read_config_timeouts(repo_root: Path) -> dict[str, object] | None:\n    \"\"\"Return the ``[timeouts]`` section from ``.darkfactory/config.toml``, or None.\"\"\"\n    config_path = repo_root / \".darkfactory\" / \"config.toml\"\n    if not config_path.exists():\n        return None\n    try:\n        with open(config_path, \"rb\") as fh:\n            data = tomllib.load(fh)\n        section = data.get(\"timeouts\")\n        return section if isinstance(section, dict) else None\n    except Exception:  # noqa: BLE001\n        return None\n\n\ndef _find_repo_root(start: Path) -> Path:\n    \"\"\"Walk up from ``start`` until a ``.git`` directory is found.\n\n    Used for git-specific operations (worktrees, tracked files, branches).\n    Project discovery uses ``resolve_project_root`` from ``discovery`` instead.\n    \"\"\"\n    current = start.resolve()\n    while current != current.parent:\n        if (current / \".git\").exists():\n            return current\n        current = current.parent\n    raise SystemExit(f\"could not locate git repo root from {start}\")\n\n\ndef _load_workflows_or_fail(workflows_dir: Path) -> dict[str, Workflow]:\n    \"\"\"Load built-in and project-level workflows.\n\n    Built-in (system) workflows ship inside the package and are always\n    available. ``workflows_dir`` is the optional project-level layer\n    (``<project>/.darkfactory/workflows/``); if it doesn't exist we just\n    return the built-ins.\n    \"\"\"\n    return load_workflows(workflows_dir if workflows_dir.exists() else None)\n\n\ndef _action_sort_key(prd: PRD) -> tuple[int, int, tuple[int, ...]]:\n    \"\"\"Sort key for actionable lists: priority, effort, natural id.\"\"\"\n    return (\n        PRIORITY_ORDER.get(prd.priority, 99),\n        EFFORT_ORDER.get(prd.effort, 99),\n        parse_id_sort_key(prd.id),\n    )\n\n\ndef _load(prd_dir: Path) -> dict[str, PRD]:\n    if not prd_dir.exists():\n        raise SystemExit(f\"PRD directory not found: {prd_dir}\")\n    return load_all(prd_dir)\n\n\n# ---------- subcommand implementations ----------\n\n\ndef _slugify(title: str) -> str:\n    \"\"\"Convert a title to kebab-case slug.\"\"\"\n    slug = re.sub(r\"[^a-zA-Z0-9\\s-]\", \"\", title.lower())\n    slug = re.sub(r\"\\s+\", \"-\", slug.strip())\n    return slug or \"untitled\"\n\n\ndef _next_flat_prd_id(prds: dict[str, PRD]) -> str:\n    \"\"\"Find the next unused flat PRD id (PRD-NNN) above the existing max.\"\"\"\n    flat_ids = [\n        int(pid.removeprefix(\"PRD-\")) for pid in prds if re.match(r\"^PRD-\\d+$\", pid)\n    ]\n    next_n = (max(flat_ids) + 1) if flat_ids else 1\n    return f\"PRD-{next_n:03d}\"\n\n\nDRAFT_TEMPLATE_BODY = \"\"\"# {title}\n\n## Summary\n\n<!-- 1-3 sentence elevator pitch. What does this deliver and why does it matter? -->\n\n## Motivation\n\n<!-- What problem does this solve? Who benefits? What happens if we don't build it? -->\n\n## Requirements\n\n### Functional\n\n1. ...\n\n### Non-Functional\n\n1. ...\n\n## Technical Approach\n\n<!-- High-level design: affected modules, data flow, key libraries. -->\n\n## Acceptance Criteria\n\n- [ ] AC-1: ...\n\n## Open Questions\n\n<!-- Tag each with OPEN | RESOLVED | DEFERRED -->\n\n## References\n\n\"\"\"\n\n\ndef cmd_new(args: argparse.Namespace) -> int:\n    prds = load_all(args.prd_dir) if args.prd_dir.exists() else {}\n\n    # Pick ID\n    if args.id:\n        if not PRD_ID_RE.match(args.id):\n            raise SystemExit(f\"invalid PRD id: {args.id!r}\")\n        if args.id in prds:\n            raise SystemExit(f\"PRD id {args.id!r} already exists\")\n        new_id = args.id\n    else:\n        new_id = _next_flat_prd_id(prds)\n\n    slug = _slugify(args.title)\n    filename = f\"{new_id}-{slug}.md\"\n    path = args.prd_dir / filename\n    if path.exists():\n        raise SystemExit(f\"file already exists: {path}\")\n\n    today = date.today().isoformat()\n    frontmatter = {\n        \"id\": new_id,\n        \"title\": args.title,\n        \"kind\": args.kind,\n        \"status\": \"draft\",\n        \"priority\": args.priority,\n        \"effort\": args.effort,\n        \"capability\": args.capability,\n        \"parent\": None,\n        \"depends_on\": [],\n        \"blocks\": [],","numLines":200,"startLine":0,"totalLines":2003}}}
