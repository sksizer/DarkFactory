{
  "name": "darkfactory",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . && eslint .",
    "lint:biome": "biome check .",
    "lint:eslint": "eslint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "build": "bun build src/index.ts --compile --outfile dist/darkfactory",
    "build:lib": "tsc"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "js-yaml": "^4.1.0",
    "ts-pattern": "^5.6.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.3.12",
    "@types/js-yaml": "^4.0.9",
    "eslint": "^9.0.0",
    "jiti": "^2.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  }
}
