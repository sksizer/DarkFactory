{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01RCFMzNjUveuPScTZUPGhQP","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011hAwWMs1FJ8LkiRTwrNxrj","name":"Read","input":{"file_path":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-228-planning-workflow-initial/src/darkfactory/loader.py","limit":100},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":2712,"cache_read_input_tokens":48529,"cache_creation":{"ephemeral_5m_input_tokens":2712,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017x74usEsvHbE9fPYD9WHc8","session_id":"139194c3-2b15-46fb-ae47-01a4e87ddf0a","uuid":"c1e1bb90-d3d0-4912-9c08-4a5fbe71b143"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011hAwWMs1FJ8LkiRTwrNxrj","type":"tool_result","content":"1\t\"\"\"Dynamic workflow discovery.\n2\t\n3\tThe harness discovers workflows at runtime by scanning a directory for\n4\tsubdirectories that contain a ``workflow.py`` module. Each matching\n5\tmodule is imported and expected to expose a top-level ``workflow``\n6\tattribute that is a :class:`~darkfactory.workflow.Workflow` instance.\n7\t\n8\tThis lets workflow authors drop a new workflow into\n9\t``tools/prd-harness/workflows/<name>/`` without editing any registry\n10\tor manifest — the loader picks it up automatically. The authored\n11\t``workflow.py`` can import from ``darkfactory.workflow`` and\n12\t``darkfactory.builtins`` just like any normal Python module.\n13\t\n14\tImport errors in one workflow.py don't block the others — we log the\n15\terror and skip. Duplicate workflow *names* (two modules both exporting\n16\t``workflow = Workflow(name=\"foo\")``) are a hard error since they'd\n17\tmake the assignment logic ambiguous.\n18\t\"\"\"\n19\t\n20\tfrom __future__ import annotations\n21\t\n22\timport importlib.util\n23\timport logging\n24\timport sys\n25\tfrom pathlib import Path\n26\t\n27\tfrom .workflow import Workflow\n28\t\n29\tlogger = logging.getLogger(\"darkfactory.loader\")\n30\t\n31\t\n32\tdef load_workflows(workflows_dir: Path) -> dict[str, Workflow]:\n33\t    \"\"\"Scan ``workflows_dir`` for workflow modules and return a name->Workflow dict.\n34\t\n35\t    Each direct subdirectory is inspected for a ``workflow.py`` file. When\n36\t    found, the module is loaded via ``importlib`` with a unique synthetic\n37\t    module name (to avoid collisions with other harness workflows that\n38\t    might share a package name) and registered in ``sys.modules`` so\n39\t    relative imports inside the workflow module resolve correctly.\n40\t\n41\t    After import, the module must expose a top-level ``workflow``\n42\t    attribute that is a :class:`Workflow` instance. The loader sets\n43\t    ``workflow.workflow_dir`` to the subdirectory path so\n44\t    ``AgentTask.prompts`` paths can be resolved relative to it at\n45\t    runtime.\n46\t\n47\t    Returns an empty dict if ``workflows_dir`` doesn't exist — this is\n48\t    not an error; the caller can start with no workflows and add them\n49\t    later.\n50\t\n51\t    Raises ``ValueError`` on duplicate workflow names. Import errors in\n52\t    individual workflow modules are logged at WARNING level and the\n53\t    module is skipped; the rest of the scan continues.\n54\t    \"\"\"\n55\t    workflows: dict[str, Workflow] = {}\n56\t\n57\t    if not workflows_dir.exists() or not workflows_dir.is_dir():\n58\t        logger.debug(\"workflows directory not found: %s\", workflows_dir)\n59\t        return workflows\n60\t\n61\t    for subdir in sorted(workflows_dir.iterdir()):\n62\t        if (\n63\t            not subdir.is_dir()\n64\t            or subdir.name.startswith(\"_\")\n65\t            or subdir.name.startswith(\".\")\n66\t        ):\n67\t            continue\n68\t        workflow_file = subdir / \"workflow.py\"\n69\t        if not workflow_file.exists():\n70\t            continue\n71\t\n72\t        try:\n73\t            wf = _load_workflow_module(workflow_file, subdir)\n74\t        except Exception as exc:  # noqa: BLE001 — we want to log *any* failure\n75\t            logger.warning(\"failed to load workflow from %s: %s\", workflow_file, exc)\n76\t            continue\n77\t\n78\t        if wf.name in workflows:\n79\t            existing = workflows[wf.name].workflow_dir\n80\t            raise ValueError(\n81\t                f\"duplicate workflow name {wf.name!r}: \"\n82\t                f\"defined in both {existing} and {subdir}\"\n83\t            )\n84\t        workflows[wf.name] = wf\n85\t\n86\t    return workflows\n87\t\n88\t\n89\tdef _load_workflow_module(workflow_file: Path, subdir: Path) -> Workflow:\n90\t    \"\"\"Import a single workflow.py and return the Workflow instance it exports.\n91\t\n92\t    Uses a synthetic module name derived from the subdirectory so two\n93\t    workflows with independent-but-identical module-level imports don't\n94\t    collide in ``sys.modules``.\n95\t\n96\t    Raises ``ImportError`` if the file can't be compiled, ``AttributeError``\n97\t    if the module has no top-level ``workflow``, and ``TypeError`` if\n98\t    ``workflow`` is not a :class:`Workflow` instance.\n99\t    \"\"\"\n100\t    module_name = f\"_darkfactory_workflow_{subdir.name}\"\n[result-id: r23]"}]},"parent_tool_use_id":"toolu_017x74usEsvHbE9fPYD9WHc8","session_id":"139194c3-2b15-46fb-ae47-01a4e87ddf0a","uuid":"0d0a64ce-6bcb-429c-9ee7-ec0dda70defd","timestamp":"2026-04-08T14:41:50.096Z"}
