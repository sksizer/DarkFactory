{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HfEbZxaDxkkVgrCv9Zo3Vy","type":"tool_result","content":"0\t\"\"\"Command-line interface for the darkfactory PRD harness.\n1\t\n2\tUsage::\n3\t\n4\t    uv run prd <subcommand> [options]\n5\t\n6\tDefaults: PRDs live in ``prds/`` and workflows in ``workflows/`` at the\n7\trepo root. Override via ``--prd-dir`` and ``--workflows-dir``.\n8\t\"\"\"\n9\t\n10\tfrom __future__ import annotations\n11\t\n12\timport argparse\n13\timport json\n14\timport logging\n15\timport os\n16\timport re\n17\timport subprocess\n18\timport sys\n19\tfrom collections import Counter\n20\tfrom datetime import date\n21\tfrom pathlib import Path\n22\tfrom typing import Any\n23\t\n24\tfrom . import assign, containment, graph, impacts\n25\tfrom .invoke import capability_to_model\n26\tfrom .loader import load_workflows\n27\tfrom .prd import (\n28\t    PRD,\n29\t    PRD_ID_RE,\n30\t    dump_frontmatter,\n31\t    load_all,\n32\t    normalize_list_field_at,\n33\t    parse_id_sort_key,\n34\t    set_workflow,\n35\t)\n36\tfrom .runner import _compute_branch_name, _pick_model, run_workflow\n37\tfrom .workflow import AgentTask, BuiltIn, ShellTask, Task, Workflow\n38\t\n39\t# Priority/effort orderings used for sorting actionable lists.\n40\tPRIORITY_ORDER: dict[str, int] = {\"critical\": 0, \"high\": 1, \"medium\": 2, \"low\": 3}\n41\tEFFORT_ORDER: dict[str, int] = {\"xs\": 0, \"s\": 1, \"m\": 2, \"l\": 3, \"xl\": 4}\n42\tCAPABILITY_ORDER: dict[str, int] = {\n43\t    \"trivial\": 0,\n44\t    \"simple\": 1,\n45\t    \"moderate\": 2,\n46\t    \"complex\": 3,\n47\t}\n48\t\n49\t\n50\tdef _find_repo_root(start: Path) -> Path:\n51\t    \"\"\"Walk up from ``start`` until a ``.git`` directory is found.\"\"\"\n52\t    current = start.resolve()\n53\t    while current != current.parent:\n54\t        if (current / \".git\").exists():\n55\t            return current\n56\t        current = current.parent\n57\t    raise SystemExit(f\"could not locate git repo root from {start}\")\n58\t\n59\t\n60\tdef _default_prd_dir() -> Path:\n61\t    \"\"\"Locate ``prds/`` at the repo root.\n62\t\n63\t    darkfactory ships its own PRDs under ``prds/`` rather than the\n64\t    nested ``docs/prd/`` layout the harness used inside pumice.\n65\t    Overridable via ``--prd-dir`` for repos that prefer a different\n66\t    location.\n67\t    \"\"\"\n68\t    repo = _find_repo_root(Path.cwd())\n69\t    return repo / \"prds\"\n70\t\n71\t\n72\tdef _default_workflows_dir() -> Path:\n73\t    \"\"\"Locate ``workflows/`` at the repo root.\n74\t\n75\t    All built-in workflows ship under this path. Overridable via\n76\t    ``--workflows-dir``.\n77\t    \"\"\"\n78\t    repo = _find_repo_root(Path.cwd())\n79\t    return repo / \"workflows\"\n80\t\n81\t\n82\tdef _load_workflows_or_fail(workflows_dir: Path) -> dict[str, Workflow]:\n83\t    \"\"\"Load workflows with a user-friendly error if the directory is missing.\"\"\"\n84\t    if not workflows_dir.exists():\n85\t        raise SystemExit(f\"workflows directory not found: {workflows_dir}\")\n86\t    return load_workflows(workflows_dir)\n87\t\n88\t\n89\tdef _action_sort_key(prd: PRD) -> tuple[int, int, tuple[int, ...]]:\n90\t    \"\"\"Sort key for actionable lists: priority, effort, natural id.\"\"\"\n91\t    return (\n92\t        PRIORITY_ORDER.get(prd.priority, 99),\n93\t        EFFORT_ORDER.get(prd.effort, 99),\n94\t        parse_id_sort_key(prd.id),\n95\t    )\n96\t\n97\t\n98\tdef _load(prd_dir: Path) -> dict[str, PRD]:\n99\t    if not prd_dir.exists():"}]},"parent_tool_use_id":null,"session_id":"039dac53-8768-4168-80ec-28db6edffc9b","uuid":"2337d44e-cdd3-4dd0-b7a2-5b61635c3a70","timestamp":"2026-04-08T12:56:44.576Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-510-prd-new-subcommand/src/darkfactory/cli.py","content":"\"\"\"Command-line interface for the darkfactory PRD harness.\n\nUsage::\n\n    uv run prd <subcommand> [options]\n\nDefaults: PRDs live in ``prds/`` and workflows in ``workflows/`` at the\nrepo root. Override via ``--prd-dir`` and ``--workflows-dir``.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport logging\nimport os\nimport re\nimport subprocess\nimport sys\nfrom collections import Counter\nfrom datetime import date\nfrom pathlib import Path\nfrom typing import Any\n\nfrom . import assign, containment, graph, impacts\nfrom .invoke import capability_to_model\nfrom .loader import load_workflows\nfrom .prd import (\n    PRD,\n    PRD_ID_RE,\n    dump_frontmatter,\n    load_all,\n    normalize_list_field_at,\n    parse_id_sort_key,\n    set_workflow,\n)\nfrom .runner import _compute_branch_name, _pick_model, run_workflow\nfrom .workflow import AgentTask, BuiltIn, ShellTask, Task, Workflow\n\n# Priority/effort orderings used for sorting actionable lists.\nPRIORITY_ORDER: dict[str, int] = {\"critical\": 0, \"high\": 1, \"medium\": 2, \"low\": 3}\nEFFORT_ORDER: dict[str, int] = {\"xs\": 0, \"s\": 1, \"m\": 2, \"l\": 3, \"xl\": 4}\nCAPABILITY_ORDER: dict[str, int] = {\n    \"trivial\": 0,\n    \"simple\": 1,\n    \"moderate\": 2,\n    \"complex\": 3,\n}\n\n\ndef _find_repo_root(start: Path) -> Path:\n    \"\"\"Walk up from ``start`` until a ``.git`` directory is found.\"\"\"\n    current = start.resolve()\n    while current != current.parent:\n        if (current / \".git\").exists():\n            return current\n        current = current.parent\n    raise SystemExit(f\"could not locate git repo root from {start}\")\n\n\ndef _default_prd_dir() -> Path:\n    \"\"\"Locate ``prds/`` at the repo root.\n\n    darkfactory ships its own PRDs under ``prds/`` rather than the\n    nested ``docs/prd/`` layout the harness used inside pumice.\n    Overridable via ``--prd-dir`` for repos that prefer a different\n    location.\n    \"\"\"\n    repo = _find_repo_root(Path.cwd())\n    return repo / \"prds\"\n\n\ndef _default_workflows_dir() -> Path:\n    \"\"\"Locate ``workflows/`` at the repo root.\n\n    All built-in workflows ship under this path. Overridable via\n    ``--workflows-dir``.\n    \"\"\"\n    repo = _find_repo_root(Path.cwd())\n    return repo / \"workflows\"\n\n\ndef _load_workflows_or_fail(workflows_dir: Path) -> dict[str, Workflow]:\n    \"\"\"Load workflows with a user-friendly error if the directory is missing.\"\"\"\n    if not workflows_dir.exists():\n        raise SystemExit(f\"workflows directory not found: {workflows_dir}\")\n    return load_workflows(workflows_dir)\n\n\ndef _action_sort_key(prd: PRD) -> tuple[int, int, tuple[int, ...]]:\n    \"\"\"Sort key for actionable lists: priority, effort, natural id.\"\"\"\n    return (\n        PRIORITY_ORDER.get(prd.priority, 99),\n        EFFORT_ORDER.get(prd.effort, 99),\n        parse_id_sort_key(prd.id),\n    )\n\n\ndef _load(prd_dir: Path) -> dict[str, PRD]:\n    if not prd_dir.exists():","numLines":100,"startLine":0,"totalLines":1133}}}
