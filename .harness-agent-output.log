{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0177pqxPFK8pT6RaByoRXeTq","type":"tool_result","content":"1\t\"\"\"Tests for the containment tree.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\tfrom pathlib import Path\n6\t\n7\tfrom darkfactory import containment\n8\tfrom darkfactory.prd import load_all\n9\t\n10\tfrom .conftest import write_prd\n11\t\n12\t\n13\tdef test_children(tmp_prd_dir: Path) -> None:\n14\t    write_prd(tmp_prd_dir, \"PRD-001\", \"epic\", kind=\"epic\")\n15\t    write_prd(tmp_prd_dir, \"PRD-010\", \"feat-a\", parent=\"PRD-001\")\n16\t    write_prd(tmp_prd_dir, \"PRD-011\", \"feat-b\", parent=\"PRD-001\")\n17\t    write_prd(tmp_prd_dir, \"PRD-020\", \"other-feat\", parent=None)\n18\t    prds = load_all(tmp_prd_dir)\n19\t    kids = containment.children(\"PRD-001\", prds)\n20\t    assert [k.id for k in kids] == [\"PRD-010\", \"PRD-011\"]\n21\t\n22\t\n23\tdef test_descendants_recurses(tmp_prd_dir: Path) -> None:\n24\t    write_prd(tmp_prd_dir, \"PRD-001\", \"epic\", kind=\"epic\")\n25\t    write_prd(tmp_prd_dir, \"PRD-010\", \"feat\", kind=\"feature\", parent=\"PRD-001\")\n26\t    write_prd(tmp_prd_dir, \"PRD-070\", \"task-a\", kind=\"task\", parent=\"PRD-010\")\n27\t    write_prd(tmp_prd_dir, \"PRD-071\", \"task-b\", kind=\"task\", parent=\"PRD-010\")\n28\t    prds = load_all(tmp_prd_dir)\n29\t    desc = containment.descendants(\"PRD-001\", prds)\n30\t    assert {p.id for p in desc} == {\"PRD-010\", \"PRD-070\", \"PRD-071\"}\n31\t\n32\t\n33\tdef test_ancestors_walks_up(tmp_prd_dir: Path) -> None:\n34\t    write_prd(tmp_prd_dir, \"PRD-001\", \"epic\", kind=\"epic\")\n35\t    write_prd(tmp_prd_dir, \"PRD-010\", \"feat\", kind=\"feature\", parent=\"PRD-001\")\n36\t    write_prd(tmp_prd_dir, \"PRD-070\", \"task\", kind=\"task\", parent=\"PRD-010\")\n37\t    prds = load_all(tmp_prd_dir)\n38\t    chain = containment.ancestors(\"PRD-070\", prds)\n39\t    assert [a.id for a in chain] == [\"PRD-010\", \"PRD-001\"]\n40\t\n41\t\n42\tdef test_roots(tmp_prd_dir: Path) -> None:\n43\t    write_prd(tmp_prd_dir, \"PRD-001\", \"epic1\", kind=\"epic\")\n44\t    write_prd(tmp_prd_dir, \"PRD-002\", \"epic2\", kind=\"epic\")\n45\t    write_prd(tmp_prd_dir, \"PRD-010\", \"feat\", kind=\"feature\", parent=\"PRD-001\")\n46\t    prds = load_all(tmp_prd_dir)\n47\t    rs = containment.roots(prds)\n48\t    assert {r.id for r in rs} == {\"PRD-001\", \"PRD-002\"}\n49\t\n50\t\n51\tdef test_is_leaf(tmp_prd_dir: Path) -> None:\n52\t    write_prd(tmp_prd_dir, \"PRD-001\", \"epic\", kind=\"epic\")\n53\t    write_prd(tmp_prd_dir, \"PRD-010\", \"feat\", kind=\"feature\", parent=\"PRD-001\")\n54\t    prds = load_all(tmp_prd_dir)\n55\t    assert containment.is_leaf(prds[\"PRD-010\"], prds)\n56\t    assert not containment.is_leaf(prds[\"PRD-001\"], prds)\n57\t\n58\t\n59\tdef test_is_fully_decomposed_true(tmp_prd_dir: Path) -> None:\n60\t    write_prd(tmp_prd_dir, \"PRD-001\", \"epic\", kind=\"epic\")\n61\t    write_prd(tmp_prd_dir, \"PRD-070\", \"task\", kind=\"task\", parent=\"PRD-001\")\n62\t    prds = load_all(tmp_prd_dir)\n63\t    assert containment.is_fully_decomposed(prds[\"PRD-001\"], prds)\n64\t\n65\t\n66\tdef test_is_fully_decomposed_false_no_tasks(tmp_prd_dir: Path) -> None:\n67\t    write_prd(tmp_prd_dir, \"PRD-001\", \"epic\", kind=\"epic\")\n68\t    write_prd(tmp_prd_dir, \"PRD-010\", \"feat\", kind=\"feature\", parent=\"PRD-001\")\n69\t    prds = load_all(tmp_prd_dir)\n70\t    assert not containment.is_fully_decomposed(prds[\"PRD-001\"], prds)\n71\t\n72\t\n73\tdef test_is_runnable_task_kind(tmp_prd_dir: Path) -> None:\n74\t    write_prd(tmp_prd_dir, \"PRD-001\", \"task\", kind=\"task\")\n75\t    prds = load_all(tmp_prd_dir)\n76\t    assert containment.is_runnable(prds[\"PRD-001\"], prds)\n77\t\n78\t\n79\tdef test_is_runnable_leaf_feature(tmp_prd_dir: Path) -> None:\n80\t    write_prd(tmp_prd_dir, \"PRD-001\", \"feat\", kind=\"feature\")\n81\t    prds = load_all(tmp_prd_dir)\n82\t    assert containment.is_runnable(prds[\"PRD-001\"], prds)\n83\t\n84\t\n85\tdef test_is_runnable_epic_with_children_is_not(tmp_prd_dir: Path) -> None:\n86\t    write_prd(tmp_prd_dir, \"PRD-001\", \"epic\", kind=\"epic\")\n87\t    write_prd(tmp_prd_dir, \"PRD-010\", \"feat\", kind=\"feature\", parent=\"PRD-001\")\n88\t    prds = load_all(tmp_prd_dir)\n89\t    assert not containment.is_runnable(prds[\"PRD-001\"], prds)\n90\t\n[result-id: r20]"}]},"parent_tool_use_id":"toolu_017x74usEsvHbE9fPYD9WHc8","session_id":"139194c3-2b15-46fb-ae47-01a4e87ddf0a","uuid":"35033a22-3c7b-4a14-9239-604c2b3036fc","timestamp":"2026-04-08T14:41:46.705Z"}
