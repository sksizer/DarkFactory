{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012EEUiZrLgA8VBbF8TUwCMW","type":"tool_result","content":"1\t\"\"\"Command-line interface for the darkfactory PRD harness.\n2\t\n3\tUsage::\n4\t\n5\t    uv run prd <subcommand> [options]\n6\t\n7\tDefaults: PRDs live in ``prds/`` and workflows in ``workflows/`` at the\n8\trepo root. Override via ``--prd-dir`` and ``--workflows-dir``.\n9\t\n10\tThis should have minimial logic; the subcommand implementations can call into\n11\tspecific modules for the heavy lifting.\n12\t\"\"\"\n13\t\n14\tfrom __future__ import annotations\n15\t\n16\timport argparse\n17\timport json\n18\timport logging\n19\timport os\n20\timport re\n21\timport subprocess\n22\timport sys\n23\tfrom collections import Counter\n24\tfrom datetime import date\n25\tfrom pathlib import Path\n26\tfrom typing import Any\n27\t\n28\tfrom . import assign, containment, graph, impacts\n29\tfrom .invoke import capability_to_model\n30\tfrom .loader import load_workflows\n31\tfrom .prd import (\n32\t    PRD,\n33\t    PRD_ID_RE,\n34\t    dump_frontmatter,\n35\t    load_all,\n36\t    normalize_list_field_at,\n37\t    parse_id_sort_key,\n38\t    set_workflow,\n39\t)\n40\tfrom .runner import _compute_branch_name, _pick_model, run_workflow\n41\tfrom .style import Element, Styler, resolve_style_config\n42\tfrom .workflow import AgentTask, BuiltIn, ShellTask, Task, Workflow\n43\t\n44\t# Priority/effort orderings used for sorting actionable lists.\n45\tPRIORITY_ORDER: dict[str, int] = {\"critical\": 0, \"high\": 1, \"medium\": 2, \"low\": 3}\n46\tEFFORT_ORDER: dict[str, int] = {\"xs\": 0, \"s\": 1, \"m\": 2, \"l\": 3, \"xl\": 4}\n47\tCAPABILITY_ORDER: dict[str, int] = {\n48\t    \"trivial\": 0,\n49\t    \"simple\": 1,\n50\t    \"moderate\": 2,\n51\t    \"complex\": 3,\n52\t}\n53\t\n54\t\n55\tdef _find_repo_root(start: Path) -> Path:\n56\t    \"\"\"Walk up from ``start`` until a ``.git`` directory is found.\"\"\"\n57\t    current = start.resolve()\n58\t    while current != current.parent:\n59\t        if (current / \".git\").exists():\n60\t            return current\n61\t        current = current.parent\n62\t    raise SystemExit(f\"could not locate git repo root from {start}\")\n63\t\n64\t\n65\tdef _default_prd_dir() -> Path:\n66\t    \"\"\"Locate ``prds/`` at the repo root.\n67\t\n68\t    darkfactory ships its own PRDs under ``prds/`` rather than the\n69\t    nested ``docs/prd/`` layout the harness used inside pumice.\n70\t    Overridable via ``--prd-dir`` for repos that prefer a different\n71\t    location.\n72\t    \"\"\"\n73\t    repo = _find_repo_root(Path.cwd())\n74\t    return repo / \"prds\"\n75\t\n76\t\n77\tdef _default_workflows_dir() -> Path:\n78\t    \"\"\"Locate ``workflows/`` at the repo root.\n79\t\n80\t    All built-in workflows ship under this path. Overridable via\n81\t    ``--workflows-dir``.\n82\t    \"\"\"\n83\t    repo = _find_repo_root(Path.cwd())\n84\t    return repo / \"workflows\"\n85\t\n86\t\n87\tdef _load_workflows_or_fail(workflows_dir: Path) -> dict[str, Workflow]:\n88\t    \"\"\"Load workflows with a user-friendly error if the directory is missing.\"\"\"\n89\t    if not workflows_dir.exists():\n90\t        raise SystemExit(f\"workflows directory not found: {workflows_dir}\")\n91\t    return load_workflows(workflows_dir)\n92\t\n93\t\n94\tdef _action_sort_key(prd: PRD) -> tuple[int, int, tuple[int, ...]]:\n95\t    \"\"\"Sort key for actionable lists: priority, effort, natural id.\"\"\"\n96\t    return (\n97\t        PRIORITY_ORDER.get(prd.priority, 99),\n98\t        EFFORT_ORDER.get(prd.effort, 99),\n99\t        parse_id_sort_key(prd.id),\n100\t    )\n[result-id: r6]"}]},"parent_tool_use_id":"toolu_017x74usEsvHbE9fPYD9WHc8","session_id":"139194c3-2b15-46fb-ae47-01a4e87ddf0a","uuid":"5843597a-e362-4ecd-bf53-f417d9d196d2","timestamp":"2026-04-08T14:41:31.917Z"}
