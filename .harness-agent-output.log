otations\nimport subprocess\nfrom darkfactory.builtins._registry import builtin\nfrom darkfactory.builtins._shared import _scan_for_forbidden_attribution\nfrom darkfactory.workflow import ExecutionContext\n\n@builtin(\"commit\")\ndef commit(ctx: ExecutionContext, *, message: str) -> None: ...\n```\n\n### `src/darkfactory/builtins/commit_test.py`\n\n- Dry-run logs the formatted message without subprocess calls\n- Empty diff (returncode 0 from `git diff --cached --quiet`) skips commit\n- Successful commit calls `git add -A` then `git commit -m`\n- Forbidden attribution pattern in message raises `RuntimeError`\n\n## Acceptance Criteria\n\n- [ ] AC-1: `src/darkfactory/builtins/commit.py` contains the `commit` function.\n- [ ] AC-2: `commit_test.py` covers dry-run, empty diff, successful commit, and forbidden attribution.\n- [ ] AC-3: `commit` is no longer defined in `builtins/__init__.py`.\n- [ ] AC-4: `from darkfactory.builtins import commit` still works.\n- [ ] AC-5: All tests pass. `just test`, `just lint`, `just typecheck`, `just format-check` all clean.\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":276,"cache_read_input_tokens":44614,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":276},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"fdfb98d4-32e9-4fa7-a46c-bf4d30fd4fa2","uuid":"abb4cded-c013-4948-a342-5f4cbfc8557e"}
