{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01M6fkPtXEp6PxoKPmoSVJJd","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011xzH4EotPDpZc3nkeQBWQt","name":"Read","input":{"file_path":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-228-planning-workflow-initial/workflows/default/workflow.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":7,"cache_creation_input_tokens":3774,"cache_read_input_tokens":15273,"cache_creation":{"ephemeral_5m_input_tokens":3774,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_017x74usEsvHbE9fPYD9WHc8","session_id":"139194c3-2b15-46fb-ae47-01a4e87ddf0a","uuid":"bb291f57-48a3-4b1e-9292-188856cbfbd2"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011xzH4EotPDpZc3nkeQBWQt","type":"tool_result","content":"1\t\"\"\"Default workflow — the catchall implementation recipe for any PRD.\n2\t\n3\tMatches every PRD (``applies_to`` returns True, ``priority=0``), so\n4\tthe assignment logic uses this workflow whenever no other workflow's\n5\tpredicate fires and the PRD's frontmatter doesn't pin something\n6\tspecific.\n7\t\n8\tThe task list is the canonical SDLC shape every implementation workflow\n9\tfollows:\n10\t\n11\t1. Create the worktree\n12\t2. Mark PRD in-progress + commit the status change\n13\t3. Invoke Claude Code to write the actual implementation\n14\t4. Run the project's test + lint commands (with retry-agent on failure)\n15\t5. Mark PRD review + commit the status change\n16\t6. Push the branch and open a PR\n17\t\n18\tSpecialized workflows (``ui-component``, ``planning``, etc.) will ship\n19\tas siblings of this directory with different prompts, task lists, and\n20\tpredicates — but they all share this overall shape. Shared SDLC,\n21\tpluggable implementation.\n22\t\"\"\"\n23\t\n24\tfrom __future__ import annotations\n25\t\n26\tfrom darkfactory.workflow import AgentTask, BuiltIn, ShellTask, Workflow\n27\t\n28\t\n29\tdef _applies_to_everything(prd, prds):  # type: ignore[no-untyped-def]\n30\t    \"\"\"Catchall predicate — the default workflow matches every PRD.\n31\t\n32\t    Kept as a module-level named function (not a lambda) so ``list-workflows``\n33\t    can describe it and mypy's strict mode doesn't complain about lambda\n34\t    type annotations.\n35\t    \"\"\"\n36\t    return True\n37\t\n38\t\n39\tworkflow = Workflow(\n40\t    name=\"default\",\n41\t    description=(\n42\t        \"General-purpose PRD implementation — the fallback workflow for \"\n43\t        \"any PRD that doesn't match a more specific predicate.\"\n44\t    ),\n45\t    applies_to=_applies_to_everything,\n46\t    priority=0,  # catchall: lowest priority\n47\t    tasks=[\n48\t        # ----- setup phase -----\n49\t        BuiltIn(\"ensure_worktree\"),\n50\t        BuiltIn(\"set_status\", kwargs={\"to\": \"in-progress\"}),\n51\t        BuiltIn(\n52\t            \"commit\",\n53\t            kwargs={\"message\": \"chore(prd): {prd_id} start work\"},\n54\t        ),\n55\t        # ----- agent implementation -----\n56\t        AgentTask(\n57\t            name=\"implement\",\n58\t            prompts=[\"prompts/role.md\", \"prompts/task.md\"],\n59\t            tools=[\n60\t                # Read/write code and search\n61\t                \"Read\",\n62\t                \"Edit\",\n63\t                \"Write\",\n64\t                \"Glob\",\n65\t                \"Grep\",\n66\t                # Build/test commands\n67\t                \"Bash(cargo:*)\",\n68\t                \"Bash(pnpm:*)\",\n69\t                \"Bash(just:*)\",\n70\t                # Git: the agent only stages and inspects. Commit, push, and\n71\t                # PR creation are owned by the harness builtins — see role.md.\n72\t                # Deliberately no Bash(git commit:*) so the agent can't bypass\n73\t                # the harness's commit step.\n74\t                \"Bash(git add:*)\",\n75\t                \"Bash(git status:*)\",\n76\t                \"Bash(git diff:*)\",\n77\t                \"Bash(git log:*)\",\n78\t            ],\n79\t            model_from_capability=True,\n80\t            retries=1,\n81\t            verify_prompts=[\"prompts/verify.md\"],\n82\t        ),\n83\t        # ----- verification phase -----\n84\t        # test/lint failures trigger one retry_agent cycle each: the\n85\t        # runner composes the verify prompt with the failed output bound\n86\t        # to {{CHECK_OUTPUT}}, re-invokes the agent once, and re-runs\n87\t        # the failing check.\n88\t        ShellTask(\"test\", cmd=\"just test\", on_failure=\"retry_agent\"),\n89\t        ShellTask(\"format\", cmd=\"just format\", on_failure=\"fail\"),\n90\t        ShellTask(\"lint\", cmd=\"just lint format-check\", on_failure=\"retry_agent\"),\n91\t        ShellTask(\"typecheck\", cmd=\"just typecheck\", on_failure=\"retry_agent\"),\n92\t        # ----- teardown phase -----\n93\t        # set_status BEFORE the final commit so the review-status change\n94\t        # lands in the commit that gets pushed. Doing set_status after\n95\t        # commit leaves the status mutation uncommitted and the pushed\n96\t        # branch (and merged PR) shows status: in-progress instead of\n97\t        # review.\n98\t        BuiltIn(\"set_status\", kwargs={\"to\": \"review\"}),\n99\t        BuiltIn(\n100\t            \"commit\",\n101\t            kwargs={\"message\": \"chore(prd): {prd_id} ready for review\"},\n102\t        ),\n103\t        BuiltIn(\"push_branch\"),\n104\t        BuiltIn(\"create_pr\"),\n105\t    ],\n106\t)\n107\t\n[result-id: r7]"}]},"parent_tool_use_id":"toolu_017x74usEsvHbE9fPYD9WHc8","session_id":"139194c3-2b15-46fb-ae47-01a4e87ddf0a","uuid":"3c397096-1b5b-4ed0-bc92-0230406016fc","timestamp":"2026-04-08T14:41:32.267Z"}
