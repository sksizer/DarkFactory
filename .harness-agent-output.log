{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AjkVCPJrs1n93NcUnjgzzs","type":"tool_result","content":"500\tdef cmd_undecomposed(args: argparse.Namespace) -> int:\n501\t    prds = _load(args.prd_dir)\n502\t    candidates = [\n503\t        prd\n504\t        for prd in prds.values()\n505\t        if prd.kind in (\"epic\", \"feature\")\n506\t        and prd.status == \"ready\"\n507\t        and not containment.is_fully_decomposed(prd, prds)\n508\t    ]\n509\t    candidates.sort(key=lambda p: parse_id_sort_key(p.id))\n510\t    if not candidates:\n511\t        print(\"(no undecomposed epics/features)\")\n512\t        return 0\n513\t    for prd in candidates:\n514\t        print(f\"{prd.id:14} [{prd.kind}]  {prd.title}\")\n515\t    return 0\n516\t\n517\t\n518\tdef cmd_conflicts(args: argparse.Namespace) -> int:\n519\t    prds = _load(args.prd_dir)\n520\t    if args.prd_id not in prds:\n521\t        raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n522\t    prd = prds[args.prd_id]\n523\t    repo_root = _find_repo_root(args.prd_dir)\n524\t    conflicts = impacts.find_conflicts(prd, prds, repo_root)\n525\t\n526\t    # Use effective_impacts so containers show their aggregated view\n527\t    # (union of descendants) rather than an empty declared list.\n528\t    try:\n529\t        effective = impacts.effective_impacts(prd, prds)\n530\t    except ValueError as exc:\n531\t        raise SystemExit(str(exc))\n532\t\n533\t    if args.json:\n534\t        print(\n535\t            json.dumps(\n536\t                {\n537\t                    \"id\": prd.id,\n538\t                    \"effective_impacts\": effective,\n539\t                    \"conflicts\": [\n540\t                        {\"id\": other_id, \"files\": sorted(files)}\n541\t                        for other_id, files in conflicts\n542\t                    ],\n543\t                },\n544\t                indent=2,\n545\t            )\n546\t        )\n547\t        return 0\n548\t\n549\t    if not effective:\n550\t        kids = containment.children(prd.id, prds)\n551\t        if kids:\n552\t            print(\n553\t                f\"{prd.id} is a container with {len(kids)} children that \"\n554\t                \"have no declared impacts yet\"\n555\t            )\n556\t        else:\n557\t            print(f\"{prd.id} has no declared impacts; cannot compute overlaps\")\n558\t        return 0\n559\t    if not conflicts:\n560\t        print(f\"{prd.id} has no impact conflicts with other PRDs\")\n561\t        print(f\"  (effective impact set: {len(effective)} pattern(s))\")\n562\t        return 0\n563\t\n564\t    print(f\"{prd.id} conflicts:\")\n565\t    for other_id, files in conflicts:\n566\t        print(f\"  {other_id}:\")\n567\t        for f in sorted(files):\n568\t            print(f\"    {f}\")\n569\t    return 0\n570\t\n571\t\n572\tdef cmd_list_workflows(args: argparse.Namespace) -> int:\n573\t    \"\"\"List all loaded workflows with priority and description.\"\"\"\n574\t    workflows = _load_workflows_or_fail(args.workflows_dir)\n575\t    if not workflows:\n576\t        print(\"(no workflows loaded)\")\n577\t        return 0\n578\t\n579\t    # Sort by descending priority then alphabetically for stable display.\n580\t    sorted_wfs = sorted(\n581\t        workflows.values(),\n582\t        key=lambda w: (-w.priority, w.name),\n583\t    )\n584\t\n585\t    if args.json:\n586\t        payload = [\n587\t            {\n588\t                \"name\": w.name,\n589\t                \"priority\": w.priority,\n590\t                \"description\": w.description,\n591\t                \"task_count\": len(w.tasks),\n592\t                \"workflow_dir\": str(w.workflow_dir) if w.workflow_dir else None,\n593\t            }\n594\t            for w in sorted_wfs\n595\t        ]\n596\t        print(json.dumps(payload, indent=2))\n597\t        return 0\n598\t\n599\t    for w in sorted_wfs:\n600\t        # Header line: name, priority, task count\n601\t        print(f\"{w.name:20} priority={w.priority:<3} tasks={len(w.tasks)}\")\n602\t        if w.description:\n603\t            # Indent description under the header\n604\t            for line in w.description.splitlines():\n605\t                print(f\"  {line}\")\n606\t        print()\n607\t    return 0\n608\t\n609\t\n610\tdef cmd_assign(args: argparse.Namespace) -> int:\n611\t    \"\"\"Compute the workflow assignment for every PRD, optionally persist.\n612\t\n613\t    Output is a table of ``PRD-id -> workflow-name``. With ``--write``,\n614\t    the resolved workflow name is persisted into each PRD's frontmatter\n615\t    (only for PRDs that don't already have an explicit workflow field —\n616\t    the command is idempotent on re-run).\n617\t    \"\"\"\n618\t    prds = _load(args.prd_dir)\n619\t    workflows = _load_workflows_or_fail(args.workflows_dir)\n620\t\n621\t    try:\n622\t        assignments = assign.assign_all(prds, workflows)\n623\t    except KeyError as exc:\n624\t        raise SystemExit(str(exc))\n625\t\n626\t    if args.json:\n627\t        payload = [\n628\t            {\n629\t                \"id\": prd_id,\n630\t                \"workflow\": wf.name,\n631\t                \"explicit\": prds[prd_id].workflow is not None,\n632\t            }\n633\t            for prd_id, wf in sorted(\n634\t                assignments.items(),\n635\t                key=lambda kv: parse_id_sort_key(kv[0]),\n636\t            )\n637\t        ]\n638\t        print(json.dumps(payload, indent=2))\n639\t        return 0\n640\t\n641\t    # Human-readable table. Mark explicit assignments with a `*`.\n642\t    print(f\"{'PRD':14} {'Workflow':20} Source\")\n643\t    print(\"-\" * 50)\n644\t    for prd_id in sorted(assignments.keys(), key=parse_id_sort_key):\n645\t        wf = assignments[prd_id]\n646\t        source = \"explicit\" if prds[prd_id].workflow else \"predicate\"\n647\t        print(f\"{prd_id:14} {wf.name:20} {source}\")\n648\t\n649\t    if args.write:\n[result-id: r15]"}]},"p