{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LfriYLwwvUzK73EPbiT6KQ","type":"tool_result","content":"1\t\"\"\"Built-in task primitives — real implementations.\n2\t\n3\tBuilt-ins are the deterministic SDLC operations that every workflow\n4\treferences by name: create a worktree, set a PRD's status, make a\n5\tcommit, push a branch, open a PR. They live here (not in individual\n6\tworkflow modules) because they're shared — every workflow uses the\n7\tsame ``commit`` primitive, not a bespoke one.\n8\t\n9\tWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n10\t\n11\t    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n12\t\n13\tThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\n14\tregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\n15\tplus any formatted kwargs.\n16\t\n17\t**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\n18\tanything destructive. In dry-run, we log what we WOULD do at INFO\n19\tlevel and return. This is what powers ``prd plan`` and the default\n20\t``prd run`` (without ``--execute``).\n21\t\n22\t**Subprocess discipline**: all shell commands use ``subprocess.run``\n23\twith an explicit argv list (never ``shell=True``), capture output,\n24\tand check the return code. Git and gh invocations go through\n25\t:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\n26\thandling and dry-run support.\n27\t\"\"\"\n28\t\n29\tfrom __future__ import annotations\n30\t\n31\timport logging\n32\timport re\n33\timport subprocess\n34\tfrom pathlib import Path\n35\tfrom typing import Callable\n36\t\n37\tfrom filelock import FileLock, Timeout\n38\t\n39\tfrom . import prd as prd_module\n40\tfrom .workflow import ExecutionContext, Status\n41\t\n42\t_log = logging.getLogger(__name__)\n43\t\n44\tBuiltInFunc = Callable[..., None]\n45\t\"\"\"Signature every built-in shares: takes ``ExecutionContext`` plus **kwargs, returns None.\n46\t\n47\tReturn value is always ``None`` — built-ins communicate results by\n48\tmutating the context (setting ``ctx.worktree_path``, ``ctx.pr_url``, etc.)\n49\tand signal failure by raising an exception. This keeps the dispatch\n50\tuniform in the runner.\n51\t\"\"\"\n52\t\n53\t\n54\tBUILTINS: dict[str, BuiltInFunc] = {}\n55\t\"\"\"Global registry mapping built-in name to its implementing function.\n56\t\n57\tPopulated at import time via the :func:`builtin` decorator. The runner\n58\tlooks up names in this dict when dispatching a\n59\t:class:`~darkfactory.workflow.BuiltIn` task. Workflows never touch this\n60\tdict directly — they reference built-ins by name only.\n61\t\"\"\"\n62\t\n63\t\n64\tdef builtin(name: str) -> Callable[[BuiltInFunc], BuiltInFunc]:\n65\t    \"\"\"Decorator that registers a function in :data:`BUILTINS`.\n66\t\n67\t    Rejects duplicate registrations with ``ValueError`` to catch typos\n68\t    and accidental overrides during development.\n69\t    \"\"\"\n70\t\n71\t    def decorator(func: BuiltInFunc) -> BuiltInFunc:\n72\t        if name in BUILTINS:\n73\t            raise ValueError(f\"duplicate builtin registration for {name!r}\")\n74\t        BUILTINS[name] = func\n75\t        return func\n76\t\n77\t    return decorator\n78\t\n79\t\n80\t# ---------- internal helpers ----------\n81\t\n82\t\n83\tdef _run(\n84\t    ctx: ExecutionContext,\n85\t    cmd: list[str],\n86\t    *,\n87\t    check: bool = True,\n88\t    capture: bool = False,\n89\t) -> subprocess.CompletedProcess[str]:\n90\t    \"\"\"Run a subprocess command inside ``ctx.cwd`` with dry-run support.\n91\t\n92\t    In dry-run mode, logs the command at INFO level and returns a fake\n93\t    ``CompletedProcess`` with exit code 0. In live mode, runs the\n94\t    command for real and raises ``subprocess.CalledProcessError`` on\n95\t    non-zero exit when ``check=True``.\n96\t\n97\t    Using an explicit argv list (not a shell string) prevents shell\n98\t    injection entirely — callers don't get to interpolate variables\n99\t    into a command line, they build the argv themselves.\n100\t    \"\"\"\n101\t    if ctx.dry_run:\n102\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n103\t        return subprocess.CompletedProcess(args=cmd, returncode=0, stdout=\"\", stderr=\"\")\n104\t\n105\t    return subprocess.run(\n106\t        cmd,\n107\t        cwd=str(ctx.cwd),\n108\t        check=check,\n109\t        capture_output=capture,\n110\t        text=True,\n111\t    )\n112\t\n113\t\n114\tdef _worktree_target(ctx: ExecutionContext) -> Path:\n115\t    \"\"\"Compute the worktree path for this PRD under ``.worktrees/``.\n116\t\n117\t    Separated out so tests can assert the path without a whole\n118\t    subprocess invocation.\n119\t    \"\"\"\n120\t    return ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}-{ctx.prd.slug}\"\n121\t\n122\t\n123\tdef _branch_exists_local(repo_root: Path, branch: str) -> bool:\n124\t    \"\"\"Return True if ``branch`` exists in the local repo's refs.\"\"\"\n125\t    result = subprocess.run(\n126\t        [\n127\t            \"git\",\n128\t            \"-C\",\n129\t            str(repo_root),\n130\t            \"rev-parse\",\n131\t            \"--verify\",\n132\t            \"--quiet\",\n133\t            f\"refs/heads/{branch}\",\n134\t        ],\n135\t        capture_output=True,\n136\t        text=True,\n137\t    )\n138\t    return result.returncode == 0\n139\t\n140\t\n141\tdef _branch_exists_remote(repo_root: Path, branch: str) -> bool:\n142\t    \"\"\"Return True if ``branch`` exists on origin.\n143\t\n144\t    Best-effort: returns False (and logs a warning) on timeout or any\n145\t    subprocess error so the caller can fall back to the local check.\n146\t    \"\"\"\n147\t    try:\n148\t        result = subprocess.run(\n149\t            [\n150\t                \"git\",\n151\t                \"-C\",\n152\t                str(repo_root),\n153\t                \"ls-remote\",\n154\t                \"--exit-code\",\n155\t                \"origin\",\n156\t                f\"refs/heads/{branch}\",\n157\t            ],\n158\t            capture_output=True,\n159\t            text=True,\n160\t            timeout=10,\n161\t        )\n162\t    except subprocess.TimeoutExpired:\n163\t        _log.warning(\n164\t            \"git ls-remote timed out checking remote branch %r — skipping remote check\",\n165\t            branch,\n166\t        )\n167\t        return False\n168\t    except Exception as exc:\n169\t        _log.warning(\n170\t            \"git ls-remote failed checking remote branch %r (%s) — skipping remote check\",\n171\t            branch,\n172\t            exc,\n173\t        )\n174\t        return False\n175\t    return result.returncode == 0\n176\t\n177\t\n178\t_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n179\t\n180\t\n181\tdef _extract_acceptance_criteria(body: str) -> list[str]:\n182\t    \"\"\"Pull acceptance criteria lines out of a PRD body.\n183\t\n184\t    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n185\t    Returns a list of the criterion strings (without the checkbox\n186\t    prefix). Used by ``create_pr`` to build the PR body's checklist.\n187\t    \"\"\"\n188\t    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n189\t\n190\t\n191\tdef _pr_body(ctx: ExecutionContext) -> str:\n192\t    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n193\t    prd = ctx.prd\n194\t    lines: list[str] = [\n195\t        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n196\t        \"\",\n197\t    ]\n198\t\n199\t    acs = _extract_acceptance_criteria(prd.body)\n200\t    if acs:\n201\t        lines.append(\"## Acceptance criteria\")\n202\t        lines.append(\"\")\n203\t        for ac in acs:\n204\t            lines.append(f\"- [ ] {ac}\")\n205\t        lines.append(\"\")\n206\t\n207\t    lines.append(\"---\")\n208\t    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n209\t    return \"\\n\".join(lines)\n210\t\n211\t\n212\t# ---------- built-in implementations ----------\n213\t\n214\t\n215\t@builtin(\"ensure_worktree\")\n216\tdef ensure_worktree(ctx: ExecutionContext) -> None:\n217\t    \"\"\"Create (or resume) a git worktree for this PRD.\n218\t\n219\t    Target path: ``{repo_root}/.worktrees/{prd_id}-{slug}``. Branch:\n220\t    ``prd/{prd_id}-{slug}`` created from ``ctx.base_ref``. If the\n221\t    worktree already exists (previous run resumed), reuses it without\n222\t    re-creating. Sets ``ctx.worktree_path`` and ``ctx.cwd`` on success.\n223\t\n224\t    In live mode, acquires a per-PRD advisory file lock at\n225\t    ``.worktrees/{prd_id}.lock`` before any mutation so two concurrent\n226\t    ``prd run`` invocations for the same PRD fail fast with a clear\n227\t    message instead of racing. The lock is auto-released by the kernel\n228\t    when the process exits; the runner also releases it explicitly at the\n229\t    end of the run (see ``_release_worktree_lock``).\n230\t    \"\"\"\n231\t    worktree_path = _worktree_target(ctx)\n232\t    branch = ctx.branch_name\n233\t\n234\t    if ctx.dry_run:\n235\t        # Dry-run produces no side effects, so no lock needed.\n236\t        ctx.logger.info(\n237\t            \"[dry-run] git worktree add -b %s %s %s\",\n238\t            branch,\n239\t            worktree_path,\n240\t            ctx.base_ref,\n241\t        )\n242\t        ctx.worktree_path = worktree_path\n243\t        ctx.cwd = worktree_path\n244\t        return\n245\t\n246\t    # Acquire the lock BEFORE the resume-check or any mutation.\n247\t    # The lock file lives at .worktrees/PRD-X.lock and is per-PRD.\n248\t    lock_path = ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}.lock\"\n249\t    lock_path.parent.mkdir(parents=True, exist_ok=True)\n250\t\n251\t    lock = FileLock(str(lock_path))\n252\t    try:\n253\t        lock.acquire(timeout=0)  # non-blocking\n254\t    except Timeout:\n255\t        raise RuntimeError(\n256\t            f\"{ctx.prd.id} is already being worked on by another `prd run` \"\n257\t            f\"process (lock held on {lock_path}). If that process died, \"\n258\t            f\"the lock will auto-release when its file handle is reclaimed. \"\n259\t            f\"On a stuck lock, delete {lock_path} manually.\"\n260\t        ) from None\n261\t\n262\t    ctx._worktree_lock = lock\n263\t\n264\t    # ---- existing logic below, now lock-protected ----\n265\t    if worktree_path.exists():\n266\t        ctx.logger.info(\"resuming existing worktree: %s\", worktree_path)\n267\t        ctx.worktree_path = worktree_path\n268\t        ctx.cwd = worktree_path\n269\t        return\n270\t\n271\t    local_exists = _branch_exists_local(ctx.repo_root, branch)\n272\t    remote_exists = _branch_exists_remote(ctx.repo_root, branch)\n273\t    if local_exists or remote_exists:\n274\t        # Release the lock before raising so the error state is clean.\n275\t        lock.release()\n276\t        ctx._worktree_lock = None\n277\t        raise RuntimeError(\n278\t            f\"branch {branch!r} already exists but worktree {worktree_path} is gone. \"\n279\t            f\"Run `prd cleanup {ctx.prd.id}` to release it.\"\n280\t        )\n281\t\n282\t    # git worktree add -b <branch> <path> <base>\n283\t    # Run from the repo root, not from ctx.cwd (which may not be a git dir yet).\n284\t    subprocess.run(\n285\t        [\n286\t            \"git\",\n287\t            \"-C\",\n288\t            str(ctx.repo_root),\n289\t            \"worktree\",\n290\t            \"add\",\n291\t            \"-b\",\n292\t            branch,\n293\t            str(worktree_path),\n294\t            ctx.base_ref,\n295\t        ],\n296\t        check=True,\n297\t        capture_output=True,\n298\t        text=True,\n299\t    )\n300\t\n301\t    ctx.worktree_path = worktree_path\n302\t    ctx.cwd = worktree_path\n303\t\n304\t\n305\t@builtin(\"set_status\")\n306\tdef set_status(ctx: ExecutionContext, *, to: Status) -> None:\n307\t    \"\"\"Rewrite the PRD's ``status:`` frontmatter field inside the worktree.\n308\t\n309\t    Targets the worktree's copy of the PRD file, never the source repo.\n310\t    The source repo's working tree must remain untouched by ``prd run`` —\n311\t    status transitions live on the PRD's worktree branch and only reach\n312\t    the source repo via PR merge (see PRD-213).\n313\t\n314\t    Uses :func:`darkfactory.prd.set_status_at`, which surgically rewrites\n315\t    only the ``status:`` and ``updated:`` lines so the resulting commit\n316\t    diff is two lines, not the whole frontmatter block.\n317\t    \"\"\"\n318\t    if ctx.dry_run:\n319\t        ctx.logger.info(\n320\t            \"[dry-run] set status of %s: %s -> %s (worktree=%s)\",\n321\t            ctx.prd.id,\n322\t            ctx.prd.status,\n323\t            to,\n324\t            ctx.worktree_path,\n325\t        )\n326\t        return\n327\t\n328\t    if ctx.worktree_path is None:\n329\t        raise RuntimeError(\n330\t            \"set_status requires a worktree; ensure_worktree must run first\"\n331\t        )\n332\t\n333\t    relative = ctx.prd.path.relative_to(ctx.repo_root)\n334\t    target = ctx.worktree_path / relative\n335\t    prd_module.set_status_at(target, to)\n336\t    # Mirror the field updates onto the in-memory PRD so subsequent\n337\t    # builtins see the new status without re-loading from disk.\n338\t    ctx.prd.status = to\n339\t    from datetime import date as _date\n340\t\n341\t    ctx.prd.updated = _date.today().isoformat()\n342\t\n343\t\n344\t@builtin(\"commit\")\n345\tdef commit(ctx: ExecutionContext, *, message: str) -> None:\n346\t    \"\"\"Stage all changes and make a commit inside the worktree.\n347\t\n348\t    ``message`` is format-string expanded against the context so\n349\t    ``\"chore(prd): {prd_id} start work\"`` becomes\n350\t    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n351\t    returns without erroring — workflows can safely commit after each\n352\t    logical step without worrying about whether anything changed.\n353\t    \"\"\"\n354\t    formatted = ctx.format_string(message)\n355\t\n356\t    if ctx.dry_run:\n357\t        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n358\t        return\n359\t\n360\t    # Stage everything\n361\t    subprocess.run(\n362\t        [\"git\", \"add\", \"-A\"],\n363\t        cwd=str(ctx.cwd),\n364\t        check=True,\n365\t        capture_output=True,\n366\t        text=True,\n367\t    )\n368\t\n369\t    # Check if there's anything to commit\n370\t    diff_result = subprocess.run(\n371\t        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n372\t        cwd=str(ctx.cwd),\n373\t        check=False,\n374\t        capture_output=True,\n375\t        text=True,\n376\t    )\n377\t    if diff_result.returncode == 0:\n378\t        # No staged changes — skip gracefully.\n379\t        ctx.logger.info(\"commit skipped: no changes to commit\")\n380\t        return\n381\t\n382\t    # Commit\n383\t    subprocess.run(\n384\t        [\"git\", \"commit\", \"-m\", formatted],\n385\t        cwd=str(ctx.cwd),\n386\t        check=True,\n387\t        capture_output=True,\n388\t        text=True,\n389\t    )\n390\t\n391\t\n392\t@builtin(\"push_branch\")\n393\tdef push_branch(ctx: ExecutionContext) -> None:\n394\t    \"\"\"Push the current branch to origin with upstream tracking.\n395\t\n396\t    Runs ``git push -u origin {branch}`` inside the worktree. Required\n397\t    before :func:`create_pr` because ``gh pr create --base`` needs the\n398\t    remote to exist.\n399\t    \"\"\"\n400\t    cmd = [\"git\", \"push\", \"-u\", \"origin\", ctx.branch_name]\n401\t\n402\t    if ctx.dry_run:\n403\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n404\t        return\n405\t\n406\t    subprocess.run(\n407\t        cmd,\n408\t        cwd=str(ctx.cwd),\n409\t        check=True,\n410\t        capture_output=True,\n411\t        text=True,\n412\t    )\n413\t\n414\t\n415\tdef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n416\t    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n417\t    if not tool_counts:\n418\t        return \"none\"\n419\t    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n420\t\n421\t\n422\tdef _format_invocations(ctx: ExecutionContext) -> str:\n423\t    \"\"\"Format agent invocation count from context.\"\"\"\n424\t    count = ctx.invoke_count\n425\t    if count == 0:\n426\t        return \"0\"\n427\t    if count == 1:\n428\t        return \"1\"\n429\t    return str(count)\n430\t\n431\t\n432\t@builtin(\"summarize_agent_run\")\n433\tdef summarize_agent_run(ctx: ExecutionContext) -> None:\n434\t    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n435\t    result = ctx.last_invoke_result\n436\t    if result is None:\n437\t        return\n438\t\n439\t    lines = [\n440\t        \"## Harness execution summary\",\n441\t        \"\",\n442\t        f\"- **Workflow:** {ctx.workflow.name}\",\n443\t        f\"- **Model:** {ctx.model or 'unknown'}\",\n444\t        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n445\t        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n446\t        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n447\t    ]\n448\t    ctx.run_summary = \"\\n\".join(lines)\n449\t\n450\t\n451\t@builtin(\"create_pr\")\n452\tdef create_pr(ctx: ExecutionContext) -> None:\n453\t    \"\"\"Open a pull request via ``gh pr create``.\n454\t\n455\t    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n456\t    acceptance criteria plus a link to the PRD file. Base branch:\n457\t    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n458\t    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n459\t    relative to ``ctx.repo_root``.\n460\t    \"\"\"\n461\t    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n462\t    body = _pr_body(ctx)\n463\t    if ctx.run_summary:\n464\t        body += \"\\n\\n\" + ctx.run_summary\n465\t\n466\t    if ctx.dry_run:\n467\t        ctx.logger.info(\n468\t            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n469\t            ctx.base_ref,\n470\t            title,\n471\t        )\n472\t        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n473\t        return\n474\t\n475\t    # Write the body to a temp file — passing long bodies via --body\n476\t    # can hit argv limits on some systems.\n477\t    import tempfile\n478\t\n479\t    with tempfile.NamedTemporaryFile(\n480\t        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n481\t    ) as body_file:\n482\t        body_file.write(body)\n483\t        body_path = body_file.name\n484\t\n485\t    try:\n486\t        result = subprocess.run(\n487\t            [\n488\t                \"gh\",\n489\t                \"pr\",\n490\t                \"create\",\n491\t                \"--base\",\n492\t                ctx.base_ref,\n493\t                \"--title\",\n494\t                title,\n495\t                \"--body-file\",\n496\t                body_path,\n497\t            ],\n498\t            cwd=str(ctx.cwd),\n499\t            check=True,\n500\t            capture_output=True,\n501\t            text=True,\n502\t        )\n503\t    finally:\n504\t        Path(body_path).unlink(missing_ok=True)\n505\t\n506\t    # gh prints the PR URL to stdout on success.\n507\t    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n508\t    ctx.pr_url = url_line or None\n509\t\n510\t\n511\t@builtin(\"cleanup_worktree\")\n512\tdef cleanup_worktree(ctx: ExecutionContext) -> None:\n513\t    \"\"\"Remove the worktree after a successful run.\n514\t\n515\t    Idempotent — if the worktree is already gone, logs and returns.\n516\t    Normally skipped during chain execution so downstream worktrees\n517\t    can base on this branch; called explicitly via ``prd cleanup``\n518\t    after the whole chain is done.\n519\t    \"\"\"\n520\t    if ctx.worktree_path is None:\n521\t        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n522\t        return\n523\t\n524\t    if not ctx.worktree_path.exists():\n525\t        ctx.logger.info(\n526\t            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n527\t        )\n528\t        return\n529\t\n530\t    cmd = [\n531\t        \"git\",\n532\t        \"-C\",\n533\t        str(ctx.repo_root),\n534\t        \"worktree\",\n535\t        \"remove\",\n536\t        str(ctx.worktree_path),\n537\t    ]\n538\t\n539\t    if ctx.dry_run:\n540\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n541\t        return\n542\t\n543\t    subprocess.run(cmd, check=True, capture_output=True, text=True)\n544\t"}]},"parent_tool_use_id":null,"session_id":"486cefb7-8454-4ea9-8512-7a451e5c819b","uuid":"af46d027-3f2f-45d0-8641-a901a1a698e7","timestamp":"2026-04-08T16:23:18.298Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-224.6-commit-transcript/src/darkfactory/builtins.py","content":"\"\"\"Built-in task primitives — real implementations.\n\nBuilt-ins are the deterministic SDLC operations that every workflow\nreferences by name: create a worktree, set a PRD's status, make a\ncommit, push a branch, open a PR. They live here (not in individual\nworkflow modules) because they're shared — every workflow uses the\nsame ``commit`` primitive, not a bespoke one.\n\nWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n\n    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n\nThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\nregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\nplus any formatted kwargs.\n\n**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\nanything destructive. In dry-run, we log what we WOULD do at INFO\nlevel and return. This is what powers ``prd plan`` and the default\n``prd run`` (without ``--execute``).\n\n**Subprocess discipline**: all shell commands use ``subprocess.run``\nwith an explicit argv list (never ``shell=True``), capture output,\nand check the return code. Git and gh invocations go through\n:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\nhandling and dry-run support.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport re\nimport subprocess\nfrom pathlib import Path\nfrom typing import Callable\n\nfrom filelock import FileLock, Timeout\n\nfrom . import prd as prd_module\nfrom .workflow import ExecutionContext, Status\n\n_log = logging.getLogger(__name__)\n\nBuiltInFunc = Callable[..., None]\n\"\"\"Signature every built-in shares: takes ``ExecutionContext`` plus **kwargs, returns None.\n\nReturn value is always ``None`` — built-ins communicate results by\nmutating the context (setting ``ctx.worktree_path``, ``ctx.pr_url``, etc.)\nand signal failure by raising an exception. This keeps the dispatch\nuniform in the runner.\n\"\"\"\n\n\nBUILTINS: dict[str, BuiltInFunc] = {}\n\"\"\"Global registry mapping built-in name to its implementing function.\n\nPopulated at import time via the :func:`builtin` decorator. The runner\nlooks up names in this dict when dispatching a\n:class:`~darkfactory.workflow.BuiltIn` task. Workflows never touch this\ndict directly — they reference built-ins by name only.\n\"\"\"\n\n\ndef builtin(name: str) -> Callable[[BuiltInFunc], BuiltInFunc]:\n    \"\"\"Decorator that registers a function in :data:`BUILTINS`.\n\n    Rejects duplicate registrations with ``ValueError`` to catch typos\n    and accidental overrides during development.\n    \"\"\"\n\n    def decorator(func: BuiltInFunc) -> BuiltInFunc:\n        if name in BUILTINS:\n            raise ValueError(f\"duplicate builtin registration for {name!r}\")\n        BUILTINS[name] = func\n        return func\n\n    return decorator\n\n\n# ---------- internal helpers ----------\n\n\ndef _run(\n    ctx: ExecutionContext,\n    cmd: list[str],\n    *,\n    check: bool = True,\n    capture: bool = False,\n) -> subprocess.CompletedProcess[str]:\n    \"\"\"Run a subprocess command inside ``ctx.cwd`` with dry-run support.\n\n    In dry-run mode, logs the command at INFO level and returns a fake\n    ``CompletedProcess`` with exit code 0. In live mode, runs the\n    command for real and raises ``subprocess.CalledProcessError`` on\n    non-zero exit when ``check=True``.\n\n    Using an explicit argv list (not a shell string) prevents shell\n    injection entirely — callers don't get to interpolate variables\n    into a command line, they build the argv themselves.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return subprocess.CompletedProcess(args=cmd, returncode=0, stdout=\"\", stderr=\"\")\n\n    return subprocess.run(\n        cmd,\n        cwd=str(ctx.cwd),\n        check=check,\n        capture_output=capture,\n        text=True,\n    )\n\n\ndef _worktree_target(ctx: ExecutionContext) -> Path:\n    \"\"\"Compute the worktree path for this PRD under ``.worktrees/``.\n\n    Separated out so tests can assert the path without a whole\n    subprocess invocation.\n    \"\"\"\n    return ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}-{ctx.prd.slug}\"\n\n\ndef _branch_exists_local(repo_root: Path, branch: str) -> bool:\n    \"\"\"Return True if ``branch`` exists in the local repo's refs.\"\"\"\n    result = subprocess.run(\n        [\n            \"git\",\n            \"-C\",\n            str(repo_root),\n            \"rev-parse\",\n            \"--verify\",\n            \"--quiet\",\n            f\"refs/heads/{branch}\",\n        ],\n        capture_output=True,\n        text=True,\n    )\n    return result.returncode == 0\n\n\ndef _branch_exists_remote(repo_root: Path, branch: str) -> bool:\n    \"\"\"Return True if ``branch`` exists on origin.\n\n    Best-effort: returns False (and logs a warning) on timeout or any\n    subprocess error so the caller can fall back to the local check.\n    \"\"\"\n    try:\n        result = subprocess.run(\n            [\n                \"git\",\n                \"-C\",\n                str(repo_root),\n                \"ls-remote\",\n                \"--exit-code\",\n                \"origin\",\n                f\"refs/heads/{branch}\",\n            ],\n            capture_output=True,\n            text=True,\n            timeout=10,\n        )\n    except subprocess.TimeoutExpired:\n        _log.warning(\n            \"git ls-remote timed out checking remote branch %r — skipping remote check\",\n            branch,\n        )\n        return False\n    except Exception as exc:\n        _log.warning(\n            \"git ls-remote failed checking remote branch %r (%s) — skipping remote check\",\n            branch,\n            exc,\n        )\n        return False\n    return result.returncode == 0\n\n\n_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n\n\ndef _extract_acceptance_criteria(body: str) -> list[str]:\n    \"\"\"Pull acceptance criteria lines out of a PRD body.\n\n    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n    Returns a list of the criterion strings (without the checkbox\n    prefix). Used by ``create_pr`` to build the PR body's checklist.\n    \"\"\"\n    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n\n\ndef _pr_body(ctx: ExecutionContext) -> str:\n    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n    prd = ctx.prd\n    lines: list[str] = [\n        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n        \"\",\n    ]\n\n    acs = _extract_acceptance_criteria(prd.body)\n    if acs:\n        lines.append(\"## Acceptance criteria\")\n        lines.append(\"\")\n        for ac in acs:\n            lines.append(f\"- [ ] {ac}\")\n        lines.append(\"\")\n\n    lines.append(\"---\")\n    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n    return \"\\n\".join(lines)\n\n\n# ---------- built-in implementations ----------\n\n\n@builtin(\"ensure_worktree\")\ndef ensure_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Create (or resume) a git worktree for this PRD.\n\n    Target path: ``{repo_root}/.worktrees/{prd_id}-{slug}``. Branch:\n    ``prd/{prd_id}-{slug}`` created from ``ctx.base_ref``. If the\n    worktree already exists (previous run resumed), reuses it without\n    re-creating. Sets ``ctx.worktree_path`` and ``ctx.cwd`` on success.\n\n    In live mode, acquires a per-PRD advisory file lock at\n    ``.worktrees/{prd_id}.lock`` before any mutation so two concurrent\n    ``prd run`` invocations for the same PRD fail fast with a clear\n    message instead of racing. The lock is auto-released by the kernel\n    when the process exits; the runner also releases it explicitly at the\n    end of the run (see ``_release_worktree_lock``).\n    \"\"\"\n    worktree_path = _worktree_target(ctx)\n    branch = ctx.branch_name\n\n    if ctx.dry_run:\n        # Dry-run produces no side effects, so no lock needed.\n        ctx.logger.info(\n            \"[dry-run] git worktree add -b %s %s %s\",\n            branch,\n            worktree_path,\n            ctx.base_ref,\n        )\n        ctx.worktree_path = worktree_path\n        ctx.cwd = worktree_path\n        return\n\n    # Acquire the lock BEFORE the resume-check or any mutation.\n    # The lock file lives at .worktrees/PRD-X.lock and is per-PRD.\n    lock_path = ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}.lock\"\n    lock_path.parent.mkdir(parents=True, exist_ok=True)\n\n    lock = FileLock(str(lock_path))\n    try:\n        lock.acquire(timeout=0)  # non-blocking\n    except Timeout:\n        raise RuntimeError(\n            f\"{ctx.prd.id} is already being worked on by another `prd run` \"\n            f\"process (lock held on {lock_path}). If that process died, \"\n            f\"the lock will auto-release when its file handle is reclaimed. \"\n            f\"On a stuck lock, delete {lock_path} manually.\"\n        ) from None\n\n    ctx._worktree_lock = lock\n\n    # ---- existing logic below, now lock-protected ----\n    if worktree_path.exists():\n        ctx.logger.info(\"resuming existing worktree: %s\", worktree_path)\n        ctx.worktree_path = worktree_path\n        ctx.cwd = worktree_path\n        return\n\n    local_exists = _branch_exists_local(ctx.repo_root, branch)\n    remote_exists = _branch_exists_remote(ctx.repo_root, branch)\n    if local_exists or remote_exists:\n        # Release the lock before raising so the error state is clean.\n        lock.release()\n        ctx._worktree_lock = None\n        raise RuntimeError(\n            f\"branch {branch!r} already exists but worktree {worktree_path} is gone. \"\n            f\"Run `prd cleanup {ctx.prd.id}` to release it.\"\n        )\n\n    # git worktree add -b <branch> <path> <base>\n    # Run from the repo root, not from ctx.cwd (which may not be a git dir yet).\n    subprocess.run(\n        [\n            \"git\",\n            \"-C\",\n            str(ctx.repo_root),\n            \"worktree\",\n            \"add\",\n            \"-b\",\n            branch,\n            str(worktree_path),\n            ctx.base_ref,\n        ],\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n    ctx.worktree_path = worktree_path\n    ctx.cwd = worktree_path\n\n\n@builtin(\"set_status\")\ndef set_status(ctx: ExecutionContext, *, to: Status) -> None:\n    \"\"\"Rewrite the PRD's ``status:`` frontmatter field inside the worktree.\n\n    Targets the worktree's copy of the PRD file, never the source repo.\n    The source repo's working tree must remain untouched by ``prd run`` —\n    status transitions live on the PRD's worktree branch and only reach\n    the source repo via PR merge (see PRD-213).\n\n    Uses :func:`darkfactory.prd.set_status_at`, which surgically rewrites\n    only the ``status:`` and ``updated:`` lines so the resulting commit\n    diff is two lines, not the whole frontmatter block.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\n            \"[dry-run] set status of %s: %s -> %s (worktree=%s)\",\n            ctx.prd.id,\n            ctx.prd.status,\n            to,\n            ctx.worktree_path,\n        )\n        return\n\n    if ctx.worktree_path is None:\n        raise RuntimeError(\n            \"set_status requires a worktree; ensure_worktree must run first\"\n        )\n\n    relative = ctx.prd.path.relative_to(ctx.repo_root)\n    target = ctx.worktree_path / relative\n    prd_module.set_status_at(target, to)\n    # Mirror the field updates onto the in-memory PRD so subsequent\n    # builtins see the new status without re-loading from disk.\n    ctx.prd.status = to\n    from datetime import date as _date\n\n    ctx.prd.updated = _date.today().isoformat()\n\n\n@builtin(\"commit\")\ndef commit(ctx: ExecutionContext, *, message: str) -> None:\n    \"\"\"Stage all changes and make a commit inside the worktree.\n\n    ``message`` is format-string expanded against the context so\n    ``\"chore(prd): {prd_id} start work\"`` becomes\n    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n    returns without erroring — workflows can safely commit after each\n    logical step without worrying about whether anything changed.\n    \"\"\"\n    formatted = ctx.format_string(message)\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n        return\n\n    # Stage everything\n    subprocess.run(\n        [\"git\", \"add\", \"-A\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n    # Check if there's anything to commit\n    diff_result = subprocess.run(\n        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n        cwd=str(ctx.cwd),\n        check=False,\n        capture_output=True,\n        text=True,\n    )\n    if diff_result.returncode == 0:\n        # No staged changes — skip gracefully.\n        ctx.logger.info(\"commit skipped: no changes to commit\")\n        return\n\n    # Commit\n    subprocess.run(\n        [\"git\", \"commit\", \"-m\", formatted],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n\n@builtin(\"push_branch\")\ndef push_branch(ctx: ExecutionContext) -> None:\n    \"\"\"Push the current branch to origin with upstream tracking.\n\n    Runs ``git push -u origin {branch}`` inside the worktree. Required\n    before :func:`create_pr` because ``gh pr create --base`` needs the\n    remote to exist.\n    \"\"\"\n    cmd = [\"git\", \"push\", \"-u\", \"origin\", ctx.branch_name]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(\n        cmd,\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n\ndef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n    if not tool_counts:\n        return \"none\"\n    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n\n\ndef _format_invocations(ctx: ExecutionContext) -> str:\n    \"\"\"Format agent invocation count from context.\"\"\"\n    count = ctx.invoke_count\n    if count == 0:\n        return \"0\"\n    if count == 1:\n        return \"1\"\n    return str(count)\n\n\n@builtin(\"summarize_agent_run\")\ndef summarize_agent_run(ctx: ExecutionContext) -> None:\n    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n    result = ctx.last_invoke_result\n    if result is None:\n        return\n\n    lines = [\n        \"## Harness execution summary\",\n        \"\",\n        f\"- **Workflow:** {ctx.workflow.name}\",\n        f\"- **Model:** {ctx.model or 'unknown'}\",\n        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n    ]\n    ctx.run_summary = \"\\n\".join(lines)\n\n\n@builtin(\"create_pr\")\ndef create_pr(ctx: ExecutionContext) -> None:\n    \"\"\"Open a pull request via ``gh pr create``.\n\n    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n    acceptance criteria plus a link to the PRD file. Base branch:\n    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n    relative to ``ctx.repo_root``.\n    \"\"\"\n    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n    body = _pr_body(ctx)\n    if ctx.run_summary:\n        body += \"\\n\\n\" + ctx.run_summary\n\n    if ctx.dry_run:\n        ctx.logger.info(\n            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n            ctx.base_ref,\n            title,\n        )\n        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n        return\n\n    # Write the body to a temp file — passing long bodies via --body\n    # can hit argv limits on some systems.\n    import tempfile\n\n    with tempfile.NamedTemporaryFile(\n        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n    ) as body_file:\n        body_file.write(body)\n        body_path = body_file.name\n\n    try:\n        result = subprocess.run(\n            [\n                \"gh\",\n                \"pr\",\n                \"create\",\n                \"--base\",\n                ctx.base_ref,\n                \"--title\",\n                title,\n                \"--body-file\",\n                body_path,\n            ],\n            cwd=str(ctx.cwd),\n            check=True,\n            capture_output=True,\n            text=True,\n        )\n    finally:\n        Path(body_path).unlink(missing_ok=True)\n\n    # gh prints the PR URL to stdout on success.\n    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n    ctx.pr_url = url_line or None\n\n\n@builtin(\"cleanup_worktree\")\ndef cleanup_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Remove the worktree after a successful run.\n\n    Idempotent — if the worktree is already gone, logs and returns.\n    Normally skipped during chain execution so downstream worktrees\n    can base on this branch; called explicitly via ``prd cleanup``\n    after the whole chain is done.\n    \"\"\"\n    if ctx.worktree_path is None:\n        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n        return\n\n    if not ctx.worktree_path.exists():\n        ctx.logger.info(\n            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n        )\n        return\n\n    cmd = [\n        \"git\",\n        \"-C\",\n        str(ctx.repo_root),\n        \"worktree\",\n        \"remove\",\n        str(ctx.worktree_path),\n    ]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(cmd, check=True, capture_output=True, text=True)\n","numLines":544,"startLine":1,"totalLines":544}}}
{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01EmeoaSgChCNRwns39dzzTE","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01HiCZTNJ4tSNnLHEbr6PAj9","name":"Read","input":{"file_path":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-224.6-commit-transcript/src/darkfactory/runner.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1639,"cache_read_input_tokens":19065,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1639},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"486cefb7-8454-4ea9-8512-7a451e5c819b","uuid":"acbe6d66-7475-4f08-b58b-4a56cbbd8d31"}
