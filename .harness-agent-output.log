{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G6ZEm7RgpgTzNZCGBscyDG","type":"tool_result","content":"648\t\n649\tdef test_ensure_worktree_resumes_when_both_branch_and_worktree_exist(\n650\t    tmp_git_repo: Path,\n651\t) -> None:\n652\t    \"\"\"AC-3: Resuming (worktree dir exists, branch exists) works as before.\"\"\"\n653\t    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n654\t    prd_dir.mkdir(parents=True)\n655\t    write_prd(prd_dir, \"PRD-215\", \"resume-guard\")\n656\t    prds = load_all(prd_dir)\n657\t\n658\t    ctx = ExecutionContext(\n659\t        prd=prds[\"PRD-215\"],\n660\t        repo_root=tmp_git_repo,\n661\t        workflow=Workflow(name=\"default\"),\n662\t        base_ref=\"main\",\n663\t        branch_name=\"prd/PRD-215-resume-guard\",\n664\t        cwd=tmp_git_repo,\n665\t        dry_run=False,\n666\t    )\n667\t    builtins.ensure_worktree(ctx)\n668\t    first_path = ctx.worktree_path\n669\t    assert first_path is not None and first_path.exists()\n670\t\n671\t    # Release the lock so the second context can acquire it (simulating\n672\t    # a new process that resumes the run).\n673\t    assert ctx._worktree_lock is not None\n674\t    ctx._worktree_lock.release()\n675\t    ctx._worktree_lock = None\n676\t\n677\t    # Second call with same branch + existing worktree: should resume, not error.\n678\t    ctx2 = ExecutionContext(\n679\t        prd=prds[\"PRD-215\"],\n680\t        repo_root=tmp_git_repo,\n681\t        workflow=Workflow(name=\"default\"),\n682\t        base_ref=\"main\",\n683\t        branch_name=\"prd/PRD-215-resume-guard\",\n684\t        cwd=tmp_git_repo,\n685\t        dry_run=False,\n686\t    )\n687\t    builtins.ensure_worktree(ctx2)  # Must not raise\n688\t    assert ctx2.worktree_path == first_path\n689\t    # Release lock to avoid leaking it after the test.\n690\t    if ctx2._worktree_lock is not None:\n691\t        ctx2._worktree_lock.release()\n692\t        ctx2._worktree_lock = None\n693\t\n694\t\n695\tdef test_ensure_worktree_remote_timeout_falls_back_to_local(\n696\t    tmp_git_repo: Path, caplog: pytest.LogCaptureFixture\n697\t) -> None:\n698\t    \"\"\"AC-4: When git ls-remote times out, guard falls back to local check and logs warning.\"\"\"\n699\t    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n700\t    prd_dir.mkdir(parents=True)\n701\t    write_prd(prd_dir, \"PRD-215\", \"timeout-test\")\n702\t    prds = load_all(prd_dir)\n703\t\n704\t    ctx = ExecutionContext(\n705\t        prd=prds[\"PRD-215\"],\n706\t        repo_root=tmp_git_repo,\n707\t        workflow=Workflow(name=\"default\"),\n708\t        base_ref=\"main\",\n709\t        branch_name=\"prd/PRD-215-timeout-test\",\n710\t        cwd=tmp_git_repo,\n711\t        dry_run=False,\n712\t    )\n713\t\n714\t    # Simulate ls-remote timeout — worktree and local branch don't exist,\n715\t    # so the guard should not fire despite the timeout.\n716\t    original_run = subprocess.run\n717\t\n718\t    from typing import Any\n719\t\n720\t    def fake_run(*args: Any, **kwargs: Any) -> Any:\n721\t        cmd = args[0] if args else kwargs.get(\"args\")\n722\t        if isinstance(cmd, list) and \"ls-remote\" in cmd:\n723\t            raise subprocess.TimeoutExpired(cmd, 10)\n724\t        return original_run(*args, **kwargs)\n725\t\n726\t    with caplog.at_level(logging.WARNING, logger=\"darkfactory\"):\n727\t        with patch(\"darkfactory.builtins.subprocess.run\", side_effect=fake_run):\n728\t            builtins.ensure_worktree(ctx)\n729\t\n730\t    assert ctx.worktree_path is not None\n731\t    assert any(\"timed out\" in rec.message for rec in caplog.records)\n732\t\n733\t\n734\tdef test_branch_exists_local_true(tmp_git_repo: Path) -> None:\n735\t    \"\"\"_branch_exists_local returns True when the branch exists.\"\"\"\n736\t    subprocess.run(\n737\t        [\"git\", \"-C\", str(tmp_git_repo), \"branch\", \"test-local-branch\"],\n738\t        check=True,\n739\t        capture_output=True,\n740\t    )\n741\t    assert _branch_exists_local(tmp_git_repo, \"test-local-branch\") is True\n742\t\n743\t\n744\tdef test_branch_exists_local_false(tmp_git_repo: Path) -> None:\n745\t    \"\"\"_branch_exists_local returns False when the branch does not exist.\"\"\"\n746\t    assert _branch_exists_local(tmp_git_repo, \"no-such-branch-xyz\") is False\n747\t\n748\t\n749\tdef test_branch_exists_remote_timeout_returns_false(\n750\t    tmp_git_repo: Path, caplog: pytest.LogCaptureFixture\n751\t) -> None:\n752\t    \"\"\"AC-4: _branch_exists_remote returns False and logs a warning on timeout.\"\"\"\n753\t    timeout_exc = subprocess.TimeoutExpired([\"git\"], 10)\n754\t    with caplog.at_level(logging.WARNING, logger=\"darkfactory\"):\n755\t        with patch(\"darkfactory.builtins.subprocess.run\", side_effect=timeout_exc):\n756\t            result = _branch_exists_remote(tmp_git_repo, \"prd/PRD-215-some-branch\")\n757\t\n758\t    assert result is False\n759\t    assert any(\"timed out\" in rec.message for rec in caplog.records)\n760\t\n761\t\n762\tdef test_ensure_worktree_guard_stubbed_subprocess(tmp_path: Path) -> None:\n763\t    \"\"\"AC-5: Stubs subprocess.run to simulate branch-exists case and asserts the error.\"\"\"\n764\t    prd_dir = tmp_path / \"prds\"\n765\t    prd_dir.mkdir()\n766\t    write_prd(prd_dir, \"PRD-215\", \"stub-test\")\n767\t    prds = load_all(prd_dir)\n768\t\n769\t    ctx = ExecutionContext(\n770\t        prd=prds[\"PRD-215\"],\n771\t        repo_root=tmp_path,\n772\t        workflow=Workflow(name=\"default\"),\n773\t        base_ref=\"main\",\n774\t        branch_name=\"prd/PRD-215-stub-test\",\n775\t        cwd=tmp_path,\n776\t        dry_run=False,\n777\t    )\n778\t\n779\t    # Patch helpers directly: local branch exists, no worktree on disk.\n780\t    with patch(\"darkfactory.builtins._branch_exists_local\", return_value=True):\n781\t        with patch(\"darkfactory.builtins._branch_exists_remote\", return_value=False):\n782\t            with pytest.raises(RuntimeError, match=\"already exists\"):\n783\t                builtins.ensure_worktree(ctx)\n784\t\n785\t\n786\t# ---------- process lock ----------\n787\t\n788\t\n789\tdef test_ensure_worktree_acquires_lock(tmp_git_repo: Path) -> None:\n790\t    \"\"\"AC-1/AC-8: After ensure_worktree, ctx._worktree_lock is set and lock file exists.\"\"\"\n791\t    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n792\t    prd_dir.mkdir(parents=True)\n793\t    write_prd(prd_dir, \"PRD-217\", \"lock-acquire\")\n794\t    prds = load_all(prd_dir)\n795\t\n796\t    ctx = ExecutionContext(\n797\t        prd=prds[\"PRD-217\"],\n798\t        repo_root=tmp_git_repo,\n799\t        workflow=Workflow(name=\"default\"),\n800\t        base_ref=\"main\",\n801\t        branch_name=\"prd/PRD-217-lock-acquire\",\n802\t        cwd=tmp_git_repo,\n803\t        dry_run=False,\n804\t    )\n805\t    builtins.ensure_worktree(ctx)\n806\t\n807\t    assert ctx._worktree_lock is not None\n808\t    lock_path = tmp_git_repo / \".worktrees\" / \"PRD-217.lock\"\n809\t    assert lock_path.exists()\n810\t\n811\t    # Cleanup\n812\t    ctx._worktree_lock.release()\n813\t    ctx._worktree_lock = None\n814\t\n815\t\n816\tdef test_ensure_worktree_refuses_when_locked(tmp_git_repo: Path) -> None:\n817\t    \"\"\"AC-1: A second concurrent call raises RuntimeError naming the lock file.\"\"\"\n818\t    from filelock import FileLock as _FileLock\n819\t\n820\t    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n821\t    prd_dir.mkdir(parents=True)\n822\t    write_prd(prd_dir, \"PRD-217\", \"lock-refuse\")\n823\t    prds = load_all(prd_dir)\n824\t\n825\t    lock_path = tmp_git_repo / \".worktrees\" / \"PRD-217.lock\"\n826\t    lock_path.parent.mkdir(parents=True, exist_ok=True)\n827\t\n828\t    # Hold the lock externally to simulate another process.\n829\t    external_lock = _FileLock(str(lock_path))\n830\t    external_lock.acquire()\n831\t    try:\n832\t        ctx = ExecutionContext(\n833\t            prd=prds[\"PRD-217\"],\n834\t            repo_root=tmp_git_repo,\n835\t            workflow=Workflow(name=\"default\"),\n836\t            base_ref=\"main\",\n837\t            branch_name=\"prd/PRD-217-lock-refuse\",\n838\t            cwd=tmp_git_repo,\n839\t            dry_run=False,\n840\t        )\n841\t        with pytest.raises(RuntimeError, match=\"already being worked on\"):\n842\t            builtins.ensure_worktree(ctx)\n843\t        # Context should not have a lock set since acquisition failed.\n844\t        assert ctx._worktree_lock is None\n845\t    finally:\n846\t        external_lock.release()\n847\t\n848\t\n849\tdef test_ensure_worktree_dry_run_no_lock(tmp_path: Path) -> None:\n850\t    \"\"\"AC-2/AC-6: Dry-run path does not create or acquire the lock.\"\"\"\n851\t    ctx = _make_dry_run_ctx(tmp_path)\n852\t    builtins.ensure_worktree(ctx)\n853\t\n854\t    assert ctx._worktree_lock is None\n855\t    lock_path = tmp_path / \".worktrees\" / \"PRD-070.lock\"\n856\t    assert not lock_path.exists()\n857\t\n858\t\n859\tdef test_ensure_worktree_releases_on_branch_guard_raise(tmp_git_repo: Path) -> None:\n860\t    \"\"\"AC-4: When the branch-exists guard fires, lock is released before raising.\"\"\"\n861\t    from filelock import FileLock as _FileLock\n862\t\n863\t    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n864\t    prd_dir.mkdir(parents=True)\n865\t    write_prd(prd_dir, \"PRD-217\", \"lock-guard\")\n866\t    prds = load_all(prd_dir)\n867\t\n868\t    ctx = ExecutionContext(\n869\t        prd=prds[\"PRD-217\"],\n870\t        repo_root=tmp_git_repo,\n871\t        workflow=Workflow(name=\"default\"),\n872\t        base_ref=\"main\",\n873\t        branch_name=\"prd/PRD-217-lock-guard\",\n874\t        cwd=tmp_git_repo,\n875\t        dry_run=False,\n876\t    )\n877\t\n878\t    with patch(\"darkfactory.builtins._branch_exists_local\", return_value=True):\n879\t        with patch(\"darkfactory.builtins._branch_exists_remote\", return_value=False):\n880\t            with pytest.raises(RuntimeError, match=\"already exists\"):\n881\t                builtins.ensure_worktree(ctx)\n882\t\n883\t    # Lock must be released — context should not hold it.\n884\t    assert ctx._worktree_lock is None\n885\t\n886\t    # We should be able to acquire the lock immediately after the failed call.\n887\t    lock_path = tmp_git_repo / \".worktrees\" / \"PRD-217.lock\"\n888\t    probe = _FileLock(str(lock_path))\n889\t    probe.acquire(timeout=0)  # raises Timeout if still locked\n890\t    probe.release()\n891\t\n892\t\n893\tdef test_runner_releases_lock_on_success(tmp_git_repo: Path) -> None:\n894\t    \"\"\"AC-5: run_workflow releases the lock on the context when the run completes.\"\"\"\n895\t    from filelock import FileLock as _FileLock\n896\t\n897\t    from darkfactory.runner import run_workflow\n898\t    from darkfactory.workflow import BuiltIn\n899\t\n900\t    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n901\t    prd_dir.mkdir(parents=True)\n902\t    write_prd(prd_dir, \"PRD-217\", \"runner-success\")\n903\t    prds = load_all(prd_dir)\n904\t\n905\t    wf = Workflow(name=\"default\", tasks=[BuiltIn(\"ensure_worktree\")])\n906\t    result = run_workflow(\n907\t        prds[\"PRD-217\"], wf, tmp_git_repo, base_ref=\"main\", dry_run=False\n908\t    )\n909\t    assert result.success is True\n910\t\n911\t    # After run_workflow returns, the lock should be released.\n912\t    lock_path = tmp_git_repo / \".worktrees\" / \"PRD-217.lock\"\n913\t    probe = _FileLock(str(lock_path))\n914\t    probe.acquire(timeout=0)\n915\t    probe.release()\n916\t\n917\t\n918\tdef test_runner_releases_lock_on_exception(tmp_git_repo: Path) -> None:\n919\t    \"\"\"AC-5: run_workflow releases the lock even when a task raises mid-run.\"\"\"\n920\t    from filelock import FileLock as _FileLock\n921\t\n922\t    from darkfactory.runner import run_workflow\n923\t    from darkfactory.workflow import BuiltIn, ShellTask\n924\t\n925\t    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n926\t    prd_dir.mkdir(parents=True)\n927\t    write_prd(prd_dir, \"PRD-217\", \"runner-exception\")\n928\t    prds = load_all(prd_dir)\n929\t\n930\t    # Workflow acquires the lock then immediately fails via a shell task.\n931\t    wf = Workflow(\n932\t        name=\"default\",\n933\t        tasks=[\n934\t            BuiltIn(\"ensure_worktree\"),\n935\t            ShellTask(\"fail\", cmd=\"false\", on_failure=\"fail\"),\n936\t        ],\n937\t    )\n938\t    result = run_workflow(\n939\t        prds[\"PRD-217\"], wf, tmp_git_repo, base_ref=\"main\", dry_run=False\n940\t    )\n941\t    assert result.success is False\n942\t\n943\t    # Lock must be released despite the failure.\n944\t    lock_path = tmp_git_repo / \".worktrees\" / \"PRD-217.lock\"\n945\t    probe = _FileLock(str(lock_path))\n946\t    probe.acquire(timeout=0)\n947\t    probe.release()\n948\t\n949\t\n950\tdef test_lock_auto_releases_on_subprocess_exit(tmp_path: Path) -> None:\n951\t    \"\"\"AC-3: A lock held by a subprocess is released when that process exits.\"\"\"\n952\t    import sys as _sys\n953\t\n954\t    from filelock import FileLock as _FileLock\n955\t\n956\t    lock_path = tmp_path / \"auto-release.lock\"\n957\t\n958\t    # Launch a child process that acquires the lock and exits normally.\n959\t    child = subprocess.run(\n960\t        [\n961\t            _sys.executable,\n962\t            \"-c\",\n963\t            f\"from filelock import FileLock; FileLock(r'{lock_path}').acquire()\",\n964\t        ],\n965\t        timeout=10,\n966\t    )\n967\t    assert child.returncode == 0\n968\t\n969\t    # After the child exits, the lock file handle is reclaimed by the kernel.\n970\t    # We must be able to acquire it immediately.\n971\t    probe = _FileLock(str(lock_path))\n972\t    probe.acquire(timeout=1)\n973\t    probe.release()\n974\t"}]},"parent_tool_use_id":null,"session_id":"52744e12-d8b3-437c-a43e-6547c29dff12","uuid":"cfc47c6e-9173-4fd4-b0e2-987d9ccf602f","timestamp":"2026-04-08T16:18:30.127Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-224.3-summarize-agent-run/tests/test_builtins.py","content":"\ndef test_ensure_worktree_resumes_when_both_branch_and_worktree_exist(\n    tmp_git_repo: Path,\n) -> None:\n    \"\"\"AC-3: Resuming (worktree dir exists, branch exists) works as before.\"\"\"\n    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n    prd_dir.mkdir(parents=True)\n    write_prd(prd_dir, \"PRD-215\", \"resume-guard\")\n    prds = load_all(prd_dir)\n\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-215\"],\n        repo_root=tmp_git_repo,\n        workflow=Workflow(name=\"default\"),\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-215-resume-guard\",\n        cwd=tmp_git_repo,\n        dry_run=False,\n    )\n    builtins.ensure_worktree(ctx)\n    first_path = ctx.worktree_path\n    assert first_path is not None and first_path.exists()\n\n    # Release the lock so the second context can acquire it (simulating\n    # a new process that resumes the run).\n    assert ctx._worktree_lock is not None\n    ctx._worktree_lock.release()\n    ctx._worktree_lock = None\n\n    # Second call with same branch + existing worktree: should resume, not error.\n    ctx2 = ExecutionContext(\n        prd=prds[\"PRD-215\"],\n        repo_root=tmp_git_repo,\n        workflow=Workflow(name=\"default\"),\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-215-resume-guard\",\n        cwd=tmp_git_repo,\n        dry_run=False,\n    )\n    builtins.ensure_worktree(ctx2)  # Must not raise\n    assert ctx2.worktree_path == first_path\n    # Release lock to avoid leaking it after the test.\n    if ctx2._worktree_lock is not None:\n        ctx2._worktree_lock.release()\n        ctx2._worktree_lock = None\n\n\ndef test_ensure_worktree_remote_timeout_falls_back_to_local(\n    tmp_git_repo: Path, caplog: pytest.LogCaptureFixture\n) -> None:\n    \"\"\"AC-4: When git ls-remote times out, guard falls back to local check and logs warning.\"\"\"\n    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n    prd_dir.mkdir(parents=True)\n    write_prd(prd_dir, \"PRD-215\", \"timeout-test\")\n    prds = load_all(prd_dir)\n\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-215\"],\n        repo_root=tmp_git_repo,\n        workflow=Workflow(name=\"default\"),\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-215-timeout-test\",\n        cwd=tmp_git_repo,\n        dry_run=False,\n    )\n\n    # Simulate ls-remote timeout — worktree and local branch don't exist,\n    # so the guard should not fire despite the timeout.\n    original_run = subprocess.run\n\n    from typing import Any\n\n    def fake_run(*args: Any, **kwargs: Any) -> Any:\n        cmd = args[0] if args else kwargs.get(\"args\")\n        if isinstance(cmd, list) and \"ls-remote\" in cmd:\n            raise subprocess.TimeoutExpired(cmd, 10)\n        return original_run(*args, **kwargs)\n\n    with caplog.at_level(logging.WARNING, logger=\"darkfactory\"):\n        with patch(\"darkfactory.builtins.subprocess.run\", side_effect=fake_run):\n            builtins.ensure_worktree(ctx)\n\n    assert ctx.worktree_path is not None\n    assert any(\"timed out\" in rec.message for rec in caplog.records)\n\n\ndef test_branch_exists_local_true(tmp_git_repo: Path) -> None:\n    \"\"\"_branch_exists_local returns True when the branch exists.\"\"\"\n    subprocess.run(\n        [\"git\", \"-C\", str(tmp_git_repo), \"branch\", \"test-local-branch\"],\n        check=True,\n        capture_output=True,\n    )\n    assert _branch_exists_local(tmp_git_repo, \"test-local-branch\") is True\n\n\ndef test_branch_exists_local_false(tmp_git_repo: Path) -> None:\n    \"\"\"_branch_exists_local returns False when the branch does not exist.\"\"\"\n    assert _branch_exists_local(tmp_git_repo, \"no-such-branch-xyz\") is False\n\n\ndef test_branch_exists_remote_timeout_returns_false(\n    tmp_git_repo: Path, caplog: pytest.LogCaptureFixture\n) -> None:\n    \"\"\"AC-4: _branch_exists_remote returns False and logs a warning on timeout.\"\"\"\n    timeout_exc = subprocess.TimeoutExpired([\"git\"], 10)\n    with caplog.at_level(logging.WARNING, logger=\"darkfactory\"):\n        with patch(\"darkfactory.builtins.subprocess.run\", side_effect=timeout_exc):\n            result = _branch_exists_remote(tmp_git_repo, \"prd/PRD-215-some-branch\")\n\n    assert result is False\n    assert any(\"timed out\" in rec.message for rec in caplog.records)\n\n\ndef test_ensure_worktree_guard_stubbed_subprocess(tmp_path: Path) -> None:\n    \"\"\"AC-5: Stubs subprocess.run to simulate branch-exists case and asserts the error.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-215\", \"stub-test\")\n    prds = load_all(prd_dir)\n\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-215\"],\n        repo_root=tmp_path,\n        workflow=Workflow(name=\"default\"),\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-215-stub-test\",\n        cwd=tmp_path,\n        dry_run=False,\n    )\n\n    # Patch helpers directly: local branch exists, no worktree on disk.\n    with patch(\"darkfactory.builtins._branch_exists_local\", return_value=True):\n        with patch(\"darkfactory.builtins._branch_exists_remote\", return_value=False):\n            with pytest.raises(RuntimeError, match=\"already exists\"):\n                builtins.ensure_worktree(ctx)\n\n\n# ---------- process lock ----------\n\n\ndef test_ensure_worktree_acquires_lock(tmp_git_repo: Path) -> None:\n    \"\"\"AC-1/AC-8: After ensure_worktree, ctx._worktree_lock is set and lock file exists.\"\"\"\n    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n    prd_dir.mkdir(parents=True)\n    write_prd(prd_dir, \"PRD-217\", \"lock-acquire\")\n    prds = load_all(prd_dir)\n\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-217\"],\n        repo_root=tmp_git_repo,\n        workflow=Workflow(name=\"default\"),\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-217-lock-acquire\",\n        cwd=tmp_git_repo,\n        dry_run=False,\n    )\n    builtins.ensure_worktree(ctx)\n\n    assert ctx._worktree_lock is not None\n    lock_path = tmp_git_repo / \".worktrees\" / \"PRD-217.lock\"\n    assert lock_path.exists()\n\n    # Cleanup\n    ctx._worktree_lock.release()\n    ctx._worktree_lock = None\n\n\ndef test_ensure_worktree_refuses_when_locked(tmp_git_repo: Path) -> None:\n    \"\"\"AC-1: A second concurrent call raises RuntimeError naming the lock file.\"\"\"\n    from filelock import FileLock as _FileLock\n\n    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n    prd_dir.mkdir(parents=True)\n    write_prd(prd_dir, \"PRD-217\", \"lock-refuse\")\n    prds = load_all(prd_dir)\n\n    lock_path = tmp_git_repo / \".worktrees\" / \"PRD-217.lock\"\n    lock_path.parent.mkdir(parents=True, exist_ok=True)\n\n    # Hold the lock externally to simulate another process.\n    external_lock = _FileLock(str(lock_path))\n    external_lock.acquire()\n    try:\n        ctx = ExecutionContext(\n            prd=prds[\"PRD-217\"],\n            repo_root=tmp_git_repo,\n            workflow=Workflow(name=\"default\"),\n            base_ref=\"main\",\n            branch_name=\"prd/PRD-217-lock-refuse\",\n            cwd=tmp_git_repo,\n            dry_run=False,\n        )\n        with pytest.raises(RuntimeError, match=\"already being worked on\"):\n            builtins.ensure_worktree(ctx)\n        # Context should not have a lock set since acquisition failed.\n        assert ctx._worktree_lock is None\n    finally:\n        external_lock.release()\n\n\ndef test_ensure_worktree_dry_run_no_lock(tmp_path: Path) -> None:\n    \"\"\"AC-2/AC-6: Dry-run path does not create or acquire the lock.\"\"\"\n    ctx = _make_dry_run_ctx(tmp_path)\n    builtins.ensure_worktree(ctx)\n\n    assert ctx._worktree_lock is None\n    lock_path = tmp_path / \".worktrees\" / \"PRD-070.lock\"\n    assert not lock_path.exists()\n\n\ndef test_ensure_worktree_releases_on_branch_guard_raise(tmp_git_repo: Path) -> None:\n    \"\"\"AC-4: When the branch-exists guard fires, lock is released before raising.\"\"\"\n    from filelock import FileLock as _FileLock\n\n    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n    prd_dir.mkdir(parents=True)\n    write_prd(prd_dir, \"PRD-217\", \"lock-guard\")\n    prds = load_all(prd_dir)\n\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-217\"],\n        repo_root=tmp_git_repo,\n        workflow=Workflow(name=\"default\"),\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-217-lock-guard\",\n        cwd=tmp_git_repo,\n        dry_run=False,\n    )\n\n    with patch(\"darkfactory.builtins._branch_exists_local\", return_value=True):\n        with patch(\"darkfactory.builtins._branch_exists_remote\", return_value=False):\n            with pytest.raises(RuntimeError, match=\"already exists\"):\n                builtins.ensure_worktree(ctx)\n\n    # Lock must be released — context should not hold it.\n    assert ctx._worktree_lock is None\n\n    # We should be able to acquire the lock immediately after the failed call.\n    lock_path = tmp_git_repo / \".worktrees\" / \"PRD-217.lock\"\n    probe = _FileLock(str(lock_path))\n    probe.acquire(timeout=0)  # raises Timeout if still locked\n    probe.release()\n\n\ndef test_runner_releases_lock_on_success(tmp_git_repo: Path) -> None:\n    \"\"\"AC-5: run_workflow releases the lock on the context when the run completes.\"\"\"\n    from filelock import FileLock as _FileLock\n\n    from darkfactory.runner import run_workflow\n    from darkfactory.workflow import BuiltIn\n\n    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n    prd_dir.mkdir(parents=True)\n    write_prd(prd_dir, \"PRD-217\", \"runner-success\")\n    prds = load_all(prd_dir)\n\n    wf = Workflow(name=\"default\", tasks=[BuiltIn(\"ensure_worktree\")])\n    result = run_workflow(\n        prds[\"PRD-217\"], wf, tmp_git_repo, base_ref=\"main\", dry_run=False\n    )\n    assert result.success is True\n\n    # After run_workflow returns, the lock should be released.\n    lock_path = tmp_git_repo / \".worktrees\" / \"PRD-217.lock\"\n    probe = _FileLock(str(lock_path))\n    probe.acquire(timeout=0)\n    probe.release()\n\n\ndef test_runner_releases_lock_on_exception(tmp_git_repo: Path) -> None:\n    \"\"\"AC-5: run_workflow releases the lock even when a task raises mid-run.\"\"\"\n    from filelock import FileLock as _FileLock\n\n    from darkfactory.runner import run_workflow\n    from darkfactory.workflow import BuiltIn, ShellTask\n\n    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n    prd_dir.mkdir(parents=True)\n    write_prd(prd_dir, \"PRD-217\", \"runner-exception\")\n    prds = load_all(prd_dir)\n\n    # Workflow acquires the lock then immediately fails via a shell task.\n    wf = Workflow(\n        name=\"default\",\n        tasks=[\n            BuiltIn(\"ensure_worktree\"),\n            ShellTask(\"fail\", cmd=\"false\", on_failure=\"fail\"),\n        ],\n    )\n    result = run_workflow(\n        prds[\"PRD-217\"], wf, tmp_git_repo, base_ref=\"main\", dry_run=False\n    )\n    assert result.success is False\n\n    # Lock must be released despite the failure.\n    lock_path = tmp_git_repo / \".worktrees\" / \"PRD-217.lock\"\n    probe = _FileLock(str(lock_path))\n    probe.acquire(timeout=0)\n    probe.release()\n\n\ndef test_lock_auto_releases_on_subprocess_exit(tmp_path: Path) -> None:\n    \"\"\"AC-3: A lock held by a subprocess is released when that process exits.\"\"\"\n    import sys as _sys\n\n    from filelock import FileLock as _FileLock\n\n    lock_path = tmp_path / \"auto-release.lock\"\n\n    # Launch a child process that acquires the lock and exits normally.\n    child = subprocess.run(\n        [\n            _sys.executable,\n            \"-c\",\n            f\"from filelock import FileLock; FileLock(r'{lock_path}').acquire()\",\n        ],\n        timeout=10,\n    )\n    assert child.returncode == 0\n\n    # After the child exits, the lock file handle is reclaimed by the kernel.\n    # We must be able to acquire it immediately.\n    probe = _FileLock(str(lock_path))\n    probe.acquire(timeout=1)\n    probe.release()\n","numLines":327,"startLine":648,"totalLines":974}}}
