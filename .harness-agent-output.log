f\"WARN:  {warn}\", file=sys.stderr)\n292\t\n293\t    if errors:\n294\t        print(f\"\\n{len(errors)} error(s), {len(warnings)} warning(s)\", file=sys.stderr)\n295\t        return 1\n296\t    print(f\"OK: {len(prds)} PRDs valid ({len(warnings)} warning(s))\")\n297\t    return 0\n298\t\n299\t\n300\tdef _print_tree(\n301\t    prd: PRD, prds: dict[str, PRD], prefix: str = \"\", is_last: bool = True\n302\t) -> None:\n303\t    \"\"\"Recursively print a containment tree branch.\"\"\"\n304\t    connector = \"└── \" if is_last else \"├── \"\n305\t    print(f\"{prefix}{connector}{prd.id}  [{prd.kind}/{prd.status}]  {prd.title}\")\n306\t    extension = \"    \" if is_last else \"│   \"\n307\t    kids = containment.children(prd.id, prds)\n308\t    for i, kid in enumerate(kids):\n309\t        _print_tree(kid, prds, prefix + extension, i == len(kids) - 1)\n310\t\n311\t\n312\tdef cmd_tree(args: argparse.Namespace) -> int:\n313\t    prds = _load(args.prd_dir)\n314\t    if args.prd_id:\n315\t        prd = prds.get(args.prd_id)\n316\t        if prd is None:\n317\t            raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n318\t        print(f\"{prd.id}  [{prd.kind}/{prd.status}]  {prd.title}\")\n319\t        kids = containment.children(prd.id, prds)\n320\t        for i, kid in enumerate(kids):\n321\t            _print_tree(kid, prds, \"\", i == len(kids) - 1)\n322\t    else:\n323\t        for root in containment.roots(prds):\n324\t            print(f\"{root.id}  [{root.kind}/{root.status}]  {root.title}\")\n325\t            kids = containment.children(root.id, prds)\n326\t            for i, kid in enumerate(kids):\n327\t                _print_tree(kid, prds, \"\", i == len(kids) - 1)\n328\t            print()\n329\t    return 0\n330\t\n331\t\n332\tdef cmd_children(args: argparse.Namespace) -> int:\n333\t    prds = _load(args.prd_dir)\n334\t    if args.prd_id not in prds:\n335\t        raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n336\t    kids = containment.children(args.prd_id, prds)\n337\t    if not kids:\n338\t        print(\"(no children)\")\n339\t        return 0\n340\t    for kid in kids:\n341\t        print(f\"{kid.id:14} [{kid.kind}/{kid.status}]  {kid.title}\")\n342\t    return 0\n343\t\n344\t\n345\tdef cmd_orphans(args: argparse.Namespace) -> int:\n346\t    prds = _load(args.prd_dir)\n347\t    rs = containment.roots(prds)\n348\t    for prd in rs:\n349\t        print(f\"{prd.id:14} [{prd.kind}/{prd.status}]  {prd.title}\")\n350\t    return 0\n351\t\n352\t\n353\tdef cmd_undecomposed(args: argparse.Namespace) -> int:\n354\t    prds = _load(args.prd_dir)\n355\t    candidates = [\n356\t        prd\n357\t        for prd in prds.values()\n358\t        if prd.kind in (\"epic\", \"feature\")\n359\t        and prd.status == \"ready\"\n360\t        and not containment.is_fully_decomposed(prd, prds)\n361\t    ]\n362\t    candidates.sort(key=lambda p: parse_id_sort_key(p.id))\n363\t    if not candidates:\n364\t        print(\"(no undecomposed epics/features)\")\n365\t        return 0\n366\t    for prd in candidates:\n367\t        print(f\"{prd.id:14} [{prd.kind}]  {prd.title}\")\n368\t    return 0\n369\t\n370\t\n371\tdef cmd_conflicts(args: argparse.Namespace) -> int:\n372\t    prds = _load(args.prd_dir)\n373\t    if args.prd_id not in prds:\n374\t        raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n375\t    prd = prds[args.prd_id]\n376\t    repo_root = _find_repo_root(args.prd_dir)\n377\t    conflicts = impacts.find_conflicts(prd, prds, repo_root)\n378\t\n379\t    # Use effective_impacts so containers show their aggregated view\n380\t    # (union of descendants) rather than an empty declared list.\n381\t    try:\n382\t        effective = impacts.effective_impacts(prd, prds)\n383\t    except ValueError as exc:\n384\t        raise SystemExit(str(exc))\n385\t\n386\t    if args.json:\n387\t        print(\n388\t            json.dumps(\n389\t                {\n390\t                    \"id\": prd.id,\n391\t                    \"effective_impacts\": effective,\n392\t                    \"conflicts\": [\n393\t                        {\"id\": other_id, \"files\": sorted(files)}\n394\t                        for other_id, files in conflicts\n395\t                    ],\n396\t                },\n397\t                indent=2,\n398\t            )\n399\t        )"}]},"parent_tool_use_id":null,"session_id":"5fe3385a-af4a-4c43-9135-e737209c79ba","uuid":"c859be7e-f4b9-455f-8217-e8dadd9f942c","timestamp":"2026-04-08T12:45:52.029Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-510-prd-new-subcommand/src/darkfactory/cli.py","content":"        files = impacts.tracked_files(repo_root)\n    except Exception:  # noqa: BLE001 — best-effort outside a git repo\n        files = []\n\n    if files:\n        ready = [p for p in prds.values() if p.status == \"ready\"]\n        for i, a in enumerate(ready):\n            for b in ready[i + 1 :]:\n                # Skip if there's an explicit dep relation in either direction.\n                if b.id in a.depends_on or a.id in b.depends_on:\n                    continue\n                try:\n                    overlap = impacts.impacts_overlap(a, b, files, prds)\n                except ValueError:\n                    # effective_impacts refused — already reported by the\n                    # container-has-impacts check above. Skip silently\n                    # here so we don't double-report.\n                    continue\n                if overlap:\n                    warnings.append(\n                        f\"{a.id} and {b.id} have overlapping impacts \"\n                        f\"({len(overlap)} files) but no explicit dependency\"\n                    )\n\n    # 7. Undeclared impacts on leaves (informational)\n    undeclared = [\n        p.id\n        for p in prds.values()\n        if p.status == \"ready\"\n        and not p.impacts\n        and not containment.children(p.id, prds)  # leave