an\",\n            \"PRD-100\",\n        ]\n    )\n    assert exit_code == 0\n    payload = json.loads(capsys.readouterr().out)\n    assert payload[\"workflow\"][\"name\"] == \"planning\"\n    # The agent task should resolve to opus\n    agent_tasks = [t for t in payload[\"tasks\"] if \"agent:\" in t]\n    assert len(agent_tasks) == 1\n    assert \"model=opus\" in agent_tasks[0]\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":270,"cache_read_input_tokens":54504,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":270},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"139194c3-2b15-46fb-ae47-01a4e87ddf0a","uuid":"20474fed-f382-4048-a5b8-c7e8341de940"}
