{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01EfG6xDmoCbegeuVyi4JsMJ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01CEcPMHwNQfsT8XDTmdz4jQ","name":"Edit","input":{"replace_all":false,"file_path":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-224.3-summarize-agent-run/src/darkfactory/builtins.py","old_string":"@builtin(\"create_pr\")\ndef create_pr(ctx: ExecutionContext) -> None:","new_string":"def _format_tool_counts(tool_counts: dict[str, int]) -> str:\n    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n    if not tool_counts:\n        return \"none\"\n    return \", \".join(\n        f\"{name}×{count}\" for name, count in sorted(tool_counts.items())\n    )\n\n\ndef _format_invocations(ctx: ExecutionContext) -> str:\n    \"\"\"Format agent invocation count from context.\"\"\"\n    count = ctx.invoke_count\n    if count == 0:\n        return \"0\"\n    if count == 1:\n        return \"1\"\n    return str(count)\n\n\n@builtin(\"summarize_agent_run\")\ndef summarize_agent_run(ctx: ExecutionContext) -> None:\n    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n    result = ctx.last_invoke_result\n    if result is None:\n        return\n\n    lines = [\n        \"## Harness execution summary\",\n        \"\",\n        f\"- **Workflow:** {ctx.workflow.name}\",\n        f\"- **Model:** {ctx.model or 'unknown'}\",\n        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n    ]\n    ctx.run_summary = \"\\n\".join(lines)\n\n\n@builtin(\"create_pr\")\ndef create_pr(ctx: ExecutionContext) -> None:"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":399,"cache_read_input_tokens":57339,"cache_creation":{