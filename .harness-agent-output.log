{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JeeEedXmmWNP5HKu4MYmw6","type":"tool_result","content":"600\t\n601\t\n602\tdef _resolve_base_ref(explicit: str | None, repo_root: Path) -> str:\n603\t    \"\"\"Determine the git base ref for a new workflow branch.\n604\t\n605\t    Explicit override (``--base``) wins. Otherwise defaults to the\n606\t    current HEAD of the repo — the idea being that a ``run-chain``\n607\t    starts from whatever branch the user is sitting on.\n608\t    \"\"\"\n609\t    if explicit:\n610\t        return explicit\n611\t    try:\n612\t        result = subprocess.run(\n613\t            [\"git\", \"-C\", str(repo_root), \"rev-parse\", \"--abbrev-ref\", \"HEAD\"],\n614\t            check=True,\n615\t            capture_output=True,\n616\t            text=True,\n617\t        )\n618\t        return result.stdout.strip() or \"main\"\n619\t    except subprocess.CalledProcessError:\n620\t        return \"main\"\n621\t\n622\t\n623\tdef _check_runnable(prd: PRD, prds: dict[str, PRD]) -> str | None:\n624\t    \"\"\"Return an error string if the PRD can't be run, else None.\"\"\"\n625\t    if prd.status == \"done\":\n626\t        return f\"{prd.id} is already done\"\n627\t    if prd.status == \"cancelled\":\n628\t        return f\"{prd.id} is cancelled\"\n629\t    if not graph.is_actionable(prd, prds):\n630\t        missing = graph.missing_deps(prd, prds)\n631\t        if missing:\n632\t            return f\"{prd.id} depends on missing PRDs: {', '.join(missing)}\"\n633\t        unfinished = [\n634\t            dep_id\n635\t            for dep_id in prd.depends_on\n636\t            if dep_id in prds and prds[dep_id].status != \"done\"\n637\t        ]\n638\t        if unfinished:\n639\t            return f\"{prd.id} has unfinished dependencies: \" + \", \".join(\n640\t                f\"{d} ({prds[d].status})\" for d in unfinished\n641\t            )\n642\t        return f\"{prd.id} status is {prd.status!r}, not 'ready'\"\n643\t    if not containment.is_runnable(prd, prds):\n644\t        return (\n645\t            f\"{prd.id} is an epic/feature with children; \"\n646\t            \"use the planning workflow or run its task descendants instead\"\n647\t        )\n648\t    return None\n649\t\n650\t\n651\tdef cmd_plan(args: argparse.Namespace) -> int:\n652\t    \"\"\"Show the execution plan for a PRD without touching anything.\n653\t\n654\t    Resolves the workflow, computes the branch name + base ref + model,\n655\t    and prints the ordered task list with descriptions. No git\n656\t    operations, no subprocess, no agent invocation.\n657\t    \"\"\"\n658\t    prds = _load(args.prd_dir)\n659\t    if args.prd_id not in prds:\n660\t        raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n661\t    prd = prds[args.prd_id]\n662\t\n663\t    workflows = _load_workflows_or_fail(args.workflows_dir)\n664\t\n665\t    # Resolve workflow (respecting --workflow override).\n666\t    if args.workflow:\n667\t        if args.workflow not in workflows:\n668\t            raise SystemExit(f\"unknown workflow: {args.workflow}\")\n669\t        workflow = workflows[args.workflow]\n670\t    else:\n671\t        try:\n672\t            workflow = assign.assign_workflow(prd, prds, workflows)\n673\t        except KeyError as exc:\n674\t            raise SystemExit(str(exc))\n675\t\n676\t    branch = _compute_branch_name(prd)\n677\t    repo_root = _find_repo_root(args.prd_dir)\n678\t    base_ref = _resolve_base_ref(args.base, repo_root)\n679\t\n680\t    # Note any runnability issues as warnings (plan still shows, but\n681\t    # the user gets a heads-up that `prd run --execute` would refuse).\n682\t    runnable_error = _check_runnable(prd, prds)\n683\t\n684\t    if args.json:\n685\t        payload: dict[str, object] = {\n686\t            \"prd\": {\n687\t                \"id\": prd.id,\n688\t                \"title\": prd.title,\n689\t                \"kind\": prd.kind,\n690\t                \"status\": prd.status,\n691\t                \"capability\": prd.capability,\n692\t            },\n693\t            \"workflow\": {\n694\t                \"name\": workflow.name,\n695\t                \"description\": workflow.description,\n696\t                \"priority\": workflow.priority,\n697\t            },\n698\t            \"branch\": branch,\n699\t            \"base_ref\": base_ref,\n700\t            \"default_model\": capability_to_model(prd.capability),\n701\t            \"tasks\": [_describe_task(task, prd, args.model) for task in workflow.tasks],\n702\t            \"runnable_error\": runnable_error,\n703\t        }\n704\t        print(json.dumps(payload, indent=2))\n705\t        return 0\n706\t\n707\t    print(f\"# Plan for {prd.id}: {prd.title}\")\n708\t    print()\n709\t    print(f\"  kind:       {prd.kind}\")\n710\t    print(f\"  status:     {prd.status}\")\n711\t    print(\n712\t        f\"  capability: {prd.capability} -> default model {capability_to_model(prd.capability)}\"\n713\t    )\n714\t    print()\n715\t    print(f\"  workflow:   {workflow.name} (priority {workflow.priority})\")\n716\t    if workflow.description:\n717\t        print(f\"  — {workflow.description}\")\n718\t    print()\n719\t    print(f\"  branch:     {branch}\")\n720\t    print(f\"  base ref:   {base_ref}\")\n721\t    print()\n722\t    print(f\"  tasks ({len(workflow.tasks)}):\")\n723\t    for i, task in enumerate(workflow.tasks, start=1):\n724\t        print(f\"    {i:>2}. {_describe_task(task, prd, args.model)}\")\n725\t\n726\t    if runnable_error:\n727\t        print()\n728\t        print(f\"  ⚠ NOT RUNNABLE: {runnable_error}\")\n729\t        print(\"    (`prd run --execute` would refuse this PRD)\")\n730\t    return 0\n731\t\n732\t\n733\tdef cmd_run(args: argparse.Namespace) -> int:\n734\t    \"\"\"Run a workflow against a PRD. Defaults to dry-run; opt in via --execute.\n735\t\n736\t    In dry-run mode, this is effectively a more detailed version of\n737\t    ``prd plan`` — it walks the runner's dispatch loop but each task\n738\t    only logs what it would do. With ``--execute``, the runner actually\n739\t    creates the worktree, invokes the agent, runs checks, pushes, and\n740\t    creates the PR.\n741\t    \"\"\"\n742\t    prds = _load(args.prd_dir)\n743\t    if args.prd_id not in prds:\n744\t        raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n745\t    prd = prds[args.prd_id]\n746\t\n747\t    workflows = _load_workflows_or_fail(args.workflows_dir)\n748\t\n749\t    # Resolve workflow.\n750\t    if args.workflow:\n751\t        if args.workflow not in workflows:\n752\t            raise SystemExit(f\"unknown workflow: {args.workflow}\")\n753\t        workflow = workflows[args.workflow]\n754\t    else:\n755\t        try:\n756\t            workflow = assign.assign_workflow(prd, prds, workflows)\n757\t        except KeyError as exc:\n758\t            raise SystemExit(str(exc))\n759\t\n760\t    # Runnability check only applies when actually executing. Dry-run\n761\t    # should be allowed on any PRD for discovery.\n762\t    if args.execute:\n763\t        err = _check_runnable(prd, prds)\n764\t        if err:\n765\t            raise SystemExit(f\"cannot run: {err}\")\n766\t\n767\t    repo_root = _find_repo_root(args.prd_dir)\n768\t    base_ref = _resolve_base_ref(args.base, repo_root)\n769\t\n770\t    dry_run = not args.execute\n771\t\n772\t    if dry_run:\n773\t        print(f\"# Dry-run: {prd.id} via workflow {workflow.name!r}\")\n774\t    else:\n775\t        print(f\"# Executing: {prd.id} via workflow {workflow.name!r}\")\n776\t\n777\t    result = run_workflow(\n778\t        prd=prd,\n779\t        workflow=workflow,\n780\t        repo_root=repo_root,\n781\t        base_ref=base_ref,\n782\t        dry_run=dry_run,\n783\t        model_override=args.model,\n784\t    )\n785\t\n786\t    print()\n787\t    print(\"  Steps:\")\n788\t    for step in result.steps:\n789\t        marker = \"✓\" if step.success else \"✗\"\n790\t        detail = f\" — {step.detail}\" if step.detail else \"\"\n791\t        print(f\"    {marker} [{step.kind}] {step.name}{detail}\")\n792\t\n793\t    print()\n794\t    if result.success:\n795\t        print(\"  Result: ✓ success\")\n796\t        if result.pr_url:\n797\t            print(f\"  PR:     {result.pr_url}\")\n798\t        return 0\n799\t    else:"}]},"parent_tool_use_id":null,"session_id":"5fe3385a-af4a-4c43-9135-e737209c79ba","uuid":"3f59bf87-28f2-4ab9-ab5f-633bebaeb428","timestamp":"2026-04-08T12:45:57.986Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-510-prd-new-subcommand/src/darkfactory/cli.py","content":"\n\ndef _resolve_base_ref(explicit: str | None, repo_root: Path) -> str:\n    \"\"\"Determine the git base ref for a new workflow branch.\n\n    Explicit override (``--base``) wins. Otherwise defaults to the\n    current HEAD of the repo — the idea being that a ``run-chain``\n    starts from whatever branch the user is sitting on.\n    \"\"\"\n    if explicit:\n        return explicit\n    try:\n        result = subprocess.run(\n            [\"git\", \"-C\", str(repo_root), \"rev-parse\", \"--abbrev-ref\", \"HEAD\"],\n            check=True,\n            capture_output=True,\n            text=True,\n        )\n        return result.stdout.strip() or \"main\"\n    except subprocess.CalledProcessError:\n        return \"main\"\n\n\ndef _check_runnable(prd: PRD, prds: dict[str, PRD]) -> str | None:\n    \"\"\"Return an error string if the PRD can't be run, else None.\"\"\"\n    if prd.status == \"done\":\n        return f\"{prd.id} is already done\"\n    if prd.status == \"cancelled\":\n        return f\"{prd.id} is cancelled\"\n    if not graph.is_actionable(prd, prds):\n        missing = graph.missing_deps(prd, prds)\n        if missing:\n            return f\"{prd.id} depends on missing PRDs: {', '.join(missing)}\"\n        unfinished = [\n            dep_id\n            for dep_id in prd.depends_on\n            if dep_id in prds and prds[dep_id].status != \"done\"\n        ]\n        if unfinished:\n            return f\"{prd.id} has unfinished dependencies: \" + \", \".join(\n                f\"{d} ({prds[d].status})\" for d in unfinished\n            )\n        return f\"{prd.id} status is {prd.status!r}, not 'ready'\"\n    if not containment.is_runnable(prd, prds):\n        return (\n            f\"{prd.id} is an epic/feature with children; \"\n            \"use the planning workflow or run its task descendants instead\"\n        )\n    return None\n\n\ndef cmd_plan(args: argparse.Namespace) -> int:\n    \"\"\"Show the execution plan for a PRD without touching anything.\n\n    Resolves the workflow, computes the branch name + base ref + model,\n    and prints the ordered task list with descriptions. No git\n    operations, no subprocess, no agent invocation.\n    \"\"\"\n    prds = _load(args.prd_dir)\n    if args.prd_id not in prds:\n        raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n    prd = prds[args.prd_id]\n\n    workflows = _load_workflows_or_fail(args.workflows_dir)\n\n    # Resolve workflow (respecting --workflow override).\n    if args.workflow:\n        if args.workflow not in workflows:\n            raise SystemExit(f\"unknown workflow: {args.workflow}\")\n        workflow = workflows[args.workflow]\n    else:\n        try:\n            workflow = assign.assign_workflow(prd, prds, workflows)\n        except KeyError as exc:\n            raise SystemExit(str(exc))\n\n    branch = _compute_branch_name(prd)\n    repo_root = _find_repo_root(args.prd_dir)\n    base_ref = _resolve_base_ref(args.base, repo_root)\n\n    # Note any runnability issues as warnings (plan still shows, but\n    # the user gets a heads-up that `prd run --execute` would refuse).\n    runnable_error = _check_runnable(prd, prds)\n\n    if args.json:\n        payload: dict[str, object] = {\n            \"prd\": {\n                \"id\": prd.id,\n                \"title\": prd.title,\n                \"kind\": prd.kind,\n                \"status\": prd.status,\n                \"capability\": prd.capability,\n            },\n            \"workflow\": {\n                \"name\": workflow.name,\n                \"description\": workflow.description,\n                \"priority\": workflow.priority,\n            },\n            \"branch\": branch,\n            \"base_ref\": base_ref,\n            \"default_model\": capability_to_model(prd.capability),\n            \"tasks\": [_describe_task(task, prd, args.model) for task in workflow.tasks],\n            \"runnable_error\": runnable_error,\n        }\n        print(json.dumps(payload, indent=2))\n        return 0\n\n    print(f\"# Plan for {prd.id}: {prd.title}\")\n    print()\n    print(f\"  kind:       {prd.kind}\")\n    print(f\"  status:     {prd.status}\")\n    print(\n        f\"  capability: {prd.capability} -> default model {capability_to_model(prd.capability)}\"\n    )\n    print()\n    print(f\"  workflow:   {workflow.name} (priority {workflow.priority})\")\n    if workflow.description:\n        print(f\"  — {workflow.description}\")\n    print()\n    print(f\"  branch:     {branch}\")\n    print(f\"  base ref:   {base_ref}\")\n    print()\n    print(f\"  tasks ({len(workflow.tasks)}):\")\n    for i, task in enumerate(workflow.tasks, start=1):\n        print(f\"    {i:>2}. {_describe_task(task, prd, args.model)}\")\n\n    if runnable_error:\n        print()\n        print(f\"  ⚠ NOT RUNNABLE: {runnable_error}\")\n        print(\"    (`prd run --execute` would refuse this PRD)\")\n    return 0\n\n\ndef cmd_run(args: argparse.Namespace) -> int:\n    \"\"\"Run a workflow against a PRD. Defaults to dry-run; opt in via --execute.\n\n    In dry-run mode, this is effectively a more detailed version of\n    ``prd plan`` — it walks the runner's dispatch loop but each task\n    only logs what it would do. With ``--execute``, the runner actually\n    creates the worktree, invokes the agent, runs checks, pushes, and\n    creates the PR.\n    \"\"\"\n    prds = _load(args.prd_dir)\n    if args.prd_id not in prds:\n        raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n    prd = prds[args.prd_id]\n\n    workflows = _load_workflows_or_fail(args.workflows_dir)\n\n    # Resolve workflow.\n    if args.workflow:\n        if args.workflow not in workflows:\n            raise SystemExit(f\"unknown workflow: {args.workflow}\")\n        workflow = workflows[args.workflow]\n    else:\n        try:\n            workflow = assign.assign_workflow(prd, prds, workflows)\n        except KeyError as exc:\n            raise SystemExit(str(exc))\n\n    # Runnability check only applies when actually executing. Dry-run\n    # should be allowed on any PRD for discovery.\n    if args.execute:\n        err = _check_runnable(prd, prds)\n        if err:\n            raise SystemExit(f\"cannot run: {err}\")\n\n    repo_root = _find_repo_root(args.prd_dir)\n    base_ref = _resolve_base_ref(args.base, repo_root)\n\n    dry_run = not args.execute\n\n    if dry_run:\n        print(f\"# Dry-run: {prd.id} via workflow {workflow.name!r}\")\n    else:\n        print(f\"# Executing: {prd.id} via workflow {workflow.name!r}\")\n\n    result = run_workflow(\n        prd=prd,\n        workflow=workflow,\n        repo_root=repo_root,\n        base_ref=base_ref,\n        dry_run=dry_run,\n        model_override=args.model,\n    )\n\n    print()\n    print(\"  Steps:\")\n    for step in result.steps:\n        marker = \"✓\" if step.success else \"✗\"\n        detail = f\" — {step.detail}\" if step.detail else \"\"\n        print(f\"    {marker} [{step.kind}] {step.name}{detail}\")\n\n    print()\n    if result.success:\n        print(\"  Result: ✓ success\")\n        if result.pr_url:\n            print(f\"  PR:     {result.pr_url}\")\n        return 0\n    else:","numLines":200,"startLine":600,"totalLines":989}}}
