{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014VM9NryBFj7ehFRLa9u1H5","type":"tool_result","content":"100\t        repo_root=tmp_path,\n101\t        workflow=Workflow(name=\"default\"),\n102\t        base_ref=\"main\",\n103\t        branch_name=\"prd/PRD-070-my-task\",\n104\t    )\n105\t    target = _worktree_target(ctx)\n106\t    assert target == tmp_path / \".worktrees\" / \"PRD-070-my-task\"\n107\t\n108\t\n109\tdef test_extract_acceptance_criteria_basic() -> None:\n110\t    body = \"\"\"\n111\t## Acceptance Criteria\n112\t\n113\t- [ ] AC-1: the widget exists\n114\t- [ ] AC-2: the widget does thing\n115\t- [ ] AC-3: the widget handles edge case\n116\t\"\"\"\n117\t    acs = _extract_acceptance_criteria(body)\n118\t    assert len(acs) == 3\n119\t    assert \"AC-1: the widget exists\" in acs\n120\t    assert \"AC-2: the widget does thing\" in acs\n121\t\n122\t\n123\tdef test_extract_acceptance_criteria_with_indent() -> None:\n124\t    \"\"\"Indented AC lines should still match.\"\"\"\n125\t    body = \"  - [ ] AC-1: indented\\n- [ ] AC-2: not indented\\n\"\n126\t    acs = _extract_acceptance_criteria(body)\n127\t    assert len(acs) == 2\n128\t\n129\t\n130\tdef test_extract_acceptance_criteria_ignores_non_ac_checkboxes() -> None:\n131\t    \"\"\"Only lines matching the AC-N pattern should be picked up.\"\"\"\n132\t    body = \"\"\"\n133\t- [ ] AC-1: this one counts\n134\t- [ ] Not an AC-formatted line\n135\t- [ ] AC-2: this one too\n136\t\"\"\"\n137\t    acs = _extract_acceptance_criteria(body)\n138\t    assert len(acs) == 2\n139\t\n140\t\n141\tdef test_extract_acceptance_criteria_ignores_checked() -> None:\n142\t    \"\"\"Already-completed ACs ([x]) should not be extracted — only open ones.\"\"\"\n143\t    body = \"- [x] AC-1: already done\\n- [ ] AC-2: still open\\n\"\n144\t    acs = _extract_acceptance_criteria(body)\n145\t    assert len(acs) == 1\n146\t    assert \"AC-2\" in acs[0]\n147\t\n148\t\n149\tdef test_pr_body_includes_prd_path_and_acs(tmp_path: Path) -> None:\n150\t    prd_dir = tmp_path / \"prds\"\n151\t    prd_dir.mkdir()\n152\t    write_prd(\n153\t        prd_dir,\n154\t        \"PRD-070\",\n155\t        \"my-task\",\n156\t        body=\"# Title\\n\\n## Acceptance Criteria\\n\\n- [ ] AC-1: test it\\n\",\n157\t    )\n158\t    prds = load_all(prd_dir)\n159\t\n160\t    ctx = ExecutionContext(\n161\t        prd=prds[\"PRD-070\"],\n162\t        repo_root=tmp_path,\n163\t        workflow=Workflow(name=\"default\"),\n164\t        base_ref=\"main\",\n165\t        branch_name=\"prd/PRD-070-my-task\",\n166\t    )\n167\t    body = _pr_body(ctx)\n168\t    assert \"prds/PRD-070-my-task.md\" in body\n169\t    assert \"AC-1: test it\" in body\n170\t    assert \"default\" in body  # workflow name in footer\n171\t\n172\t\n173\t# ---------- dry-run behavior ----------\n174\t\n175\t\n176\tdef _make_dry_run_ctx(tmp_path: Path) -> ExecutionContext:\n177\t    \"\"\"Build an ExecutionContext with dry_run=True for safe testing.\"\"\"\n178\t    prd_dir = tmp_path / \"prds\"\n179\t    prd_dir.mkdir()\n180\t    write_prd(prd_dir, \"PRD-070\", \"task\")\n181\t    prds = load_all(prd_dir)\n182\t\n183\t    return ExecutionContext(\n184\t        prd=prds[\"PRD-070\"],\n185\t        repo_root=tmp_path,\n186\t        workflow=Workflow(name=\"default\"),\n187\t        base_ref=\"main\",\n188\t        branch_name=\"prd/PRD-070-task\",\n189\t        cwd=tmp_path,\n190\t        dry_run=True,\n191\t    )\n192\t\n193\t\n194\tdef test_dry_run_ensure_worktree_logs_and_returns(\n195\t    tmp_path: Path, caplog: pytest.LogCaptureFixture\n196\t) -> None:\n197\t    ctx = _make_dry_run_ctx(tmp_path)\n198\t    with caplog.at_level(logging.INFO, logger=\"darkfactory\"):\n199\t        builtins.ensure_worktree(ctx)\n200\t    # Should not have actually created a worktree\n201\t    assert not (tmp_path / \".worktrees\" / \"PRD-070-task\").exists()\n202\t    # But should have set the target path on ctx\n203\t    assert ctx.worktree_path == tmp_path / \".worktrees\" / \"PRD-070-task\"\n204\t    # And logged the command\n205\t    assert any(\"git\" in rec.message for rec in caplog.records)\n206\t\n207\t\n208\tdef test_dry_run_set_status_does_not_mutate(tmp_path: Path) -> None:\n209\t    ctx = _make_dry_run_ctx(tmp_path)\n210\t    original_status = ctx.prd.status\n211\t    builtins.set_status(ctx, to=\"in-progress\")\n212\t    # File should be untouched\n213\t    reloaded = load_all(tmp_path / \"prds\")\n214\t    assert reloaded[\"PRD-070\"].status == original_status\n215\t\n216\t\n217\tdef test_dry_run_commit_does_not_subprocess(tmp_path: Path) -> None:\n218\t    ctx = _make_dry_run_ctx(tmp_path)\n219\t    with patch(\"subprocess.run\") as mock_run:\n220\t        builtins.commit(ctx, message=\"chore(prd): {prd_id} dry\")\n221\t        mock_run.assert_not_called()\n222\t\n223\t\n224\tdef test_dry_run_push_does_not_subprocess(tmp_path: Path) -> None:\n225\t    ctx = _make_dry_run_ctx(tmp_path)\n226\t    with patch(\"subprocess.run\") as mock_run:\n227\t        builtins.push_branch(ctx)\n228\t        mock_run.assert_not_called()\n229\t\n230\t\n231\tdef test_dry_run_create_pr_does_not_subprocess(tmp_path: Path) -> None:\n232\t    ctx = _make_dry_run_ctx(tmp_path)\n233\t    with patch(\"subprocess.run\") as mock_run:\n234\t        builtins.create_pr(ctx)\n235\t        mock_run.assert_not_called()\n236\t    # But should set a placeholder pr_url\n237\t    assert ctx.pr_url is not None\n238\t\n239\t\n240\t# ---------- real git operations (tmp repo fixtures) ----------\n241\t\n242\t\n243\t@pytest.fixture\n244\tdef tmp_git_repo(tmp_path: Path) -> Path:\n245\t    \"\"\"Initialize a bare-bones git repo with an initial commit at tmp_path/repo.\"\"\"\n246\t    repo = tmp_path / \"repo\"\n247\t    repo.mkdir()\n248\t    subprocess.run([\"git\", \"init\", \"-q\", \"-b\", \"main\"], cwd=repo, check=True)\n249\t    subprocess.run(\n250\t        [\"git\", \"config\", \"user.email\", \"test@example.com\"], cwd=repo, check=True\n251\t    )\n252\t    subprocess.run([\"git\", \"config\", \"user.name\", \"Test\"], cwd=repo, check=True)\n253\t    (repo / \"README.md\").write_text(\"initial\\n\")\n254\t    subprocess.run([\"git\", \"add\", \"README.md\"], cwd=repo, check=True)\n255\t    subprocess.run(\n256\t        [\"git\", \"commit\", \"-q\", \"-m\", \"initial\"],\n257\t        cwd=repo,\n258\t        check=True,\n259\t    )\n260\t    return repo\n261\t\n262\t\n263\tdef test_ensure_worktree_creates_worktree(tmp_git_repo: Path) -> None:\n264\t    \"\"\"A real git repo should get a real worktree directory + branch.\"\"\"\n265\t    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n266\t    prd_dir.mkdir(parents=True)\n267\t    write_prd(prd_dir, \"PRD-070\", \"wt-test\")\n268\t    prds = load_all(prd_dir)\n269\t\n270\t    ctx = ExecutionContext(\n271\t        prd=prds[\"PRD-070\"],\n272\t        repo_root=tmp_git_repo,\n273\t        workflow=Workflow(name=\"default\"),\n274\t        base_ref=\"main\",\n275\t        branch_name=\"prd/PRD-070-wt-test\",\n276\t        cwd=tmp_git_repo,\n277\t        dry_run=False,\n278\t    )\n279\t\n280\t    builtins.ensure_worktree(ctx)\n281\t\n282\t    expected = tmp_git_repo / \".worktrees\" / \"PRD-070-wt-test\"\n283\t    assert expected.exists()\n284\t    assert (expected / \".git\").exists()  # worktree marker file\n285\t    assert ctx.worktree_path == expected\n286\t    assert ctx.cwd == expected\n287\t\n288\t\n289\tdef test_ensure_worktree_resumes_existing(tmp_git_repo: Path) -> None:\n290\t    \"\"\"Second call to ensure_worktree with same PRD should reuse, not re-create.\"\"\"\n291\t    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n292\t    prd_dir.mkdir(parents=True)\n293\t    write_prd(prd_dir, \"PRD-070\", \"resume-test\")\n294\t    prds = load_all(prd_dir)\n295\t\n296\t    ctx = ExecutionContext(\n297\t        prd=prds[\"PRD-070\"],\n298\t        repo_root=tmp_git_repo,\n299\t        workflow=Workflow(name=\"default\"),"}]},"parent_tool_use_id":null,"session_id":"486cefb7-8454-4ea9-8512-7a451e5c819b","uuid":"200ee8b5-9a66-452d-9e24-6265c8c93263","timestamp":"2026-04-08T16:23:31.881Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-224.6-commit-transcript/tests/test_builtins.py","content":"        repo_root=tmp_path,\n        workflow=Workflow(name=\"default\"),\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-070-my-task\",\n    )\n    target = _worktree_target(ctx)\n    assert target == tmp_path / \".worktrees\" / \"PRD-070-my-task\"\n\n\ndef test_extract_acceptance_criteria_basic() -> None:\n    body = \"\"\"\n## Acceptance Criteria\n\n- [ ] AC-1: the widget exists\n- [ ] AC-2: the widget does thing\n- [ ] AC-3: the widget handles edge case\n\"\"\"\n    acs = _extract_acceptance_criteria(body)\n    assert len(acs) == 3\n    assert \"AC-1: the widget exists\" in acs\n    assert \"AC-2: the widget does thing\" in acs\n\n\ndef test_extract_acceptance_criteria_with_indent() -> None:\n    \"\"\"Indented AC lines should still match.\"\"\"\n    body = \"  - [ ] AC-1: indented\\n- [ ] AC-2: not indented\\n\"\n    acs = _extract_acceptance_criteria(body)\n    assert len(acs) == 2\n\n\ndef test_extract_acceptance_criteria_ignores_non_ac_checkboxes() -> None:\n    \"\"\"Only lines matching the AC-N pattern should be picked up.\"\"\"\n    body = \"\"\"\n- [ ] AC-1: this one counts\n- [ ] Not an AC-formatted line\n- [ ] AC-2: this one too\n\"\"\"\n    acs = _extract_acceptance_criteria(body)\n    assert len(acs) == 2\n\n\ndef test_extract_acceptance_criteria_ignores_checked() -> None:\n    \"\"\"Already-completed ACs ([x]) should not be extracted — only open ones.\"\"\"\n    body = \"- [x] AC-1: already done\\n- [ ] AC-2: still open\\n\"\n    acs = _extract_acceptance_criteria(body)\n    assert len(acs) == 1\n    assert \"AC-2\" in acs[0]\n\n\ndef test_pr_body_includes_prd_path_and_acs(tmp_path: Path) -> None:\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(\n        prd_dir,\n        \"PRD-070\",\n        \"my-task\",\n        body=\"# Title\\n\\n## Acceptance Criteria\\n\\n- [ ] AC-1: test it\\n\",\n    )\n    prds = load_all(prd_dir)\n\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-070\"],\n        repo_root=tmp_path,\n        workflow=Workflow(name=\"default\"),\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-070-my-task\",\n    )\n    body = _pr_body(ctx)\n    assert \"prds/PRD-070-my-task.md\" in body\n    assert \"AC-1: test it\" in body\n    assert \"default\" in body  # workflow name in footer\n\n\n# ---------- dry-run behavior ----------\n\n\ndef _make_dry_run_ctx(tmp_path: Path) -> ExecutionContext:\n    \"\"\"Build an ExecutionContext with dry_run=True for safe testing.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"task\")\n    prds = load_all(prd_dir)\n\n    return ExecutionContext(\n        prd=prds[\"PRD-070\"],\n        repo_root=tmp_path,\n        workflow=Workflow(name=\"default\"),\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-070-task\",\n        cwd=tmp_path,\n        dry_run=True,\n    )\n\n\ndef test_dry_run_ensure_worktree_logs_and_returns(\n    tmp_path: Path, caplog: pytest.LogCaptureFixture\n) -> None:\n    ctx = _make_dry_run_ctx(tmp_path)\n    with caplog.at_level(logging.INFO, logger=\"darkfactory\"):\n        builtins.ensure_worktree(ctx)\n    # Should not have actually created a worktree\n    assert not (tmp_path / \".worktrees\" / \"PRD-070-task\").exists()\n    # But should have set the target path on ctx\n    assert ctx.worktree_path == tmp_path / \".worktrees\" / \"PRD-070-task\"\n    # And logged the command\n    assert any(\"git\" in rec.message for rec in caplog.records)\n\n\ndef test_dry_run_set_status_does_not_mutate(tmp_path: Path) -> None:\n    ctx = _make_dry_run_ctx(tmp_path)\n    original_status = ctx.prd.status\n    builtins.set_status(ctx, to=\"in-progress\")\n    # File should be untouched\n    reloaded = load_all(tmp_path / \"prds\")\n    assert reloaded[\"PRD-070\"].status == original_status\n\n\ndef test_dry_run_commit_does_not_subprocess(tmp_path: Path) -> None:\n    ctx = _make_dry_run_ctx(tmp_path)\n    with patch(\"subprocess.run\") as mock_run:\n        builtins.commit(ctx, message=\"chore(prd): {prd_id} dry\")\n        mock_run.assert_not_called()\n\n\ndef test_dry_run_push_does_not_subprocess(tmp_path: Path) -> None:\n    ctx = _make_dry_run_ctx(tmp_path)\n    with patch(\"subprocess.run\") as mock_run:\n        builtins.push_branch(ctx)\n        mock_run.assert_not_called()\n\n\ndef test_dry_run_create_pr_does_not_subprocess(tmp_path: Path) -> None:\n    ctx = _make_dry_run_ctx(tmp_path)\n    with patch(\"subprocess.run\") as mock_run:\n        builtins.create_pr(ctx)\n        mock_run.assert_not_called()\n    # But should set a placeholder pr_url\n    assert ctx.pr_url is not None\n\n\n# ---------- real git operations (tmp repo fixtures) ----------\n\n\n@pytest.fixture\ndef tmp_git_repo(tmp_path: Path) -> Path:\n    \"\"\"Initialize a bare-bones git repo with an initial commit at tmp_path/repo.\"\"\"\n    repo = tmp_path / \"repo\"\n    repo.mkdir()\n    subprocess.run([\"git\", \"init\", \"-q\", \"-b\", \"main\"], cwd=repo, check=True)\n    subprocess.run(\n        [\"git\", \"config\", \"user.email\", \"test@example.com\"], cwd=repo, check=True\n    )\n    subprocess.run([\"git\", \"config\", \"user.name\", \"Test\"], cwd=repo, check=True)\n    (repo / \"README.md\").write_text(\"initial\\n\")\n    subprocess.run([\"git\", \"add\", \"README.md\"], cwd=repo, check=True)\n    subprocess.run(\n        [\"git\", \"commit\", \"-q\", \"-m\", \"initial\"],\n        cwd=repo,\n        check=True,\n    )\n    return repo\n\n\ndef test_ensure_worktree_creates_worktree(tmp_git_repo: Path) -> None:\n    \"\"\"A real git repo should get a real worktree directory + branch.\"\"\"\n    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n    prd_dir.mkdir(parents=True)\n    write_prd(prd_dir, \"PRD-070\", \"wt-test\")\n    prds = load_all(prd_dir)\n\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-070\"],\n        repo_root=tmp_git_repo,\n        workflow=Workflow(name=\"default\"),\n        base_ref=\"main\",\n        branch_name=\"prd/PRD-070-wt-test\",\n        cwd=tmp_git_repo,\n        dry_run=False,\n    )\n\n    builtins.ensure_worktree(ctx)\n\n    expected = tmp_git_repo / \".worktrees\" / \"PRD-070-wt-test\"\n    assert expected.exists()\n    assert (expected / \".git\").exists()  # worktree marker file\n    assert ctx.worktree_path == expected\n    assert ctx.cwd == expected\n\n\ndef test_ensure_worktree_resumes_existing(tmp_git_repo: Path) -> None:\n    \"\"\"Second call to ensure_worktree with same PRD should reuse, not re-create.\"\"\"\n    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n    prd_dir.mkdir(parents=True)\n    write_prd(prd_dir, \"PRD-070\", \"resume-test\")\n    prds = load_all(prd_dir)\n\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-070\"],\n        repo_root=tmp_git_repo,\n        workflow=Workflow(name=\"default\"),","numLines":200,"startLine":100,"totalLines":1133}}}
