{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019dpjqAmRtZu9bDqPkZR9Q1","type":"tool_result","content":"1\t\"\"\"Extraction workflow — for PRDs that operate on a separate target repo.\n2\t\n3\tUsed by the darkfactory extraction (PRD-500..505): the work happens in\n4\ta *different* repo on disk, so the pumice ``just test`` / ``just lint``\n5\tshell steps from the default workflow don't apply. The agent is\n6\tresponsible for whatever verification matters in the target repo.\n7\t\n8\tPredicate matches any PRD tagged ``extraction``. Priority 5 — above\n9\tdefault (0), below specialized workflows like ui-component (10).\n10\t\"\"\"\n11\t\n12\tfrom __future__ import annotations\n13\t\n14\tfrom darkfactory.workflow import AgentTask, BuiltIn, Workflow\n15\t\n16\t\n17\tdef _is_extraction(prd, prds):  # type: ignore[no-untyped-def]\n18\t    return \"extraction\" in prd.tags\n19\t\n20\t\n21\tworkflow = Workflow(\n22\t    name=\"extraction\",\n23\t    description=(\n24\t        \"Repo-extraction workflow — for PRDs whose work happens in a \"\n25\t        \"separate target repository (no pumice test/lint phase).\"\n26\t    ),\n27\t    applies_to=_is_extraction,\n28\t    priority=5,\n29\t    tasks=[\n30\t        BuiltIn(\"ensure_worktree\"),\n31\t        BuiltIn(\"set_status\", kwargs={\"to\": \"in-progress\"}),\n32\t        BuiltIn(\n33\t            \"commit\",\n34\t            kwargs={\"message\": \"chore(prd): {prd_id} start work\"},\n35\t        ),\n36\t        AgentTask(\n37\t            name=\"implement\",\n38\t            prompts=[\"prompts/role.md\", \"prompts/task.md\"],\n39\t            tools=[\n40\t                \"Read\",\n41\t                \"Edit\",\n42\t                \"Write\",\n43\t                \"Glob\",\n44\t                \"Grep\",\n45\t                # Broad bash for filesystem + git + gh against the target repo\n46\t                \"Bash\",\n47\t            ],\n48\t            model_from_capability=True,\n49\t            retries=1,\n50\t            verify_prompts=[\"prompts/verify.md\"],\n51\t        ),\n52\t        # No test/lint ShellTasks — the agent verifies in the target repo.\n53\t        BuiltIn(\n54\t            \"commit\",\n55\t            kwargs={\"message\": \"chore(prd): {prd_id} ready for review\"},\n56\t        ),\n57\t        BuiltIn(\"set_status\", kwargs={\"to\": \"review\"}),\n58\t        BuiltIn(\"push_branch\"),\n59\t        BuiltIn(\"create_pr\"),\n60\t    ],\n61\t)\n62\t"}]},"parent_tool_use_id":null,"session_id":"139194c3-2b15-46fb-ae47-01a4e87ddf0a","uuid":"137cec70-d3da-4d97-9b30-c16c91b6dd3d","timestamp":"2026-04-08T14:43:47.659Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-228-planning-workflow-initial/workflows/extraction/workflow.py","content":"\"\"\"Extraction workflow — for PRDs that operate on a separate target repo.\n\nUsed by the darkfactory extraction (PRD-500..505): the work happens in\na *different* repo on disk, so the pumice ``just test`` / ``just lint``\nshell steps from the default workflow don't apply. The agent is\nresponsible for whatever verification matters in the target repo.\n\nPredicate matches any PRD tagged ``extraction``. Priority 5 — above\ndefault (0), below specialized workflows like ui-component (10).\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom darkfactory.workflow import AgentTask, BuiltIn, Workflow\n\n\ndef _is_extraction(prd, prds):  # type: ignore[no-untyped-def]\n    return \"extraction\" in prd.tags\n\n\nworkflow = Workflow(\n    name=\"extraction\",\n    description=(\n        \"Repo-extraction workflow — for PRDs whose work happens in a \"\n        \"separate target repository (no pumice test/lint phase).\"\n    ),\n    applies_to=_is_extraction,\n    priority=5,\n    tasks=[\n        BuiltIn(\"ensure_worktree\"),\n        BuiltIn(\"set_status\", kwargs={\"to\": \"in-progress\"}),\n        BuiltIn(\n            \"commit\",\n            kwargs={\"message\": \"chore(prd): {prd_id} start work\"},\n        ),\n        AgentTask(\n            name=\"implement\",\n            prompts=[\"prompts/role.md\", \"prompts/task.md\"],\n            tools=[\n                \"Read\",\n                \"Edit\",\n                \"Write\",\n                \"Glob\",\n                \"Grep\",\n                # Broad bash for filesystem + git + gh against the target repo\n                \"Bash\",\n            ],\n            model_from_capability=True,\n            retries=1,\n            verify_prompts=[\"prompts/verify.md\"],\n        ),\n        # No test/lint ShellTasks — the agent verifies in the target repo.\n        BuiltIn(\n            \"commit\",\n            kwargs={\"message\": \"chore(prd): {prd_id} ready for review\"},\n        ),\n        BuiltIn(\"set_status\", kwargs={\"to\": \"review\"}),\n        BuiltIn(\"push_branch\"),\n        BuiltIn(\"create_pr\"),\n    ],\n)\n","numLines":62,"startLine":1,"totalLines":62}}}
