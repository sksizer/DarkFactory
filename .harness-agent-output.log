{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JZT6eiqMd64jVMULFyQuzt","type":"tool_result","content":"100\t    if not prd_dir.exists():\n101\t        raise SystemExit(f\"PRD directory not found: {prd_dir}\")\n102\t    return load_all(prd_dir)\n103\t\n104\t\n105\t# ---------- subcommand implementations ----------\n106\t\n107\t\n108\tdef _slugify(title: str) -> str:\n109\t    \"\"\"Convert a title to kebab-case slug.\"\"\"\n110\t    slug = re.sub(r\"[^a-zA-Z0-9\\s-]\", \"\", title.lower())\n111\t    slug = re.sub(r\"\\s+\", \"-\", slug.strip())\n112\t    return slug or \"untitled\"\n113\t\n114\t\n115\tdef _next_flat_prd_id(prds: dict[str, PRD]) -> str:\n116\t    \"\"\"Find the next unused flat PRD id (PRD-NNN) above the existing max.\"\"\"\n117\t    flat_ids = [\n118\t        int(pid.removeprefix(\"PRD-\")) for pid in prds if re.match(r\"^PRD-\\d+$\", pid)\n119\t    ]\n120\t    next_n = (max(flat_ids) + 1) if flat_ids else 1\n121\t    return f\"PRD-{next_n:03d}\"\n122\t\n123\t\n124\tDRAFT_TEMPLATE_BODY = \"\"\"# {title}\n125\t\n126\t## Summary\n127\t\n128\t<!-- 1-3 sentence elevator pitch. What does this deliver and why does it matter? -->\n129\t\n130\t## Motivation\n131\t\n132\t<!-- What problem does this solve? Who benefits? What happens if we don't build it? -->\n133\t\n134\t## Requirements\n135\t\n136\t### Functional\n137\t\n138\t1. ...\n139\t\n140\t### Non-Functional\n141\t\n142\t1. ...\n143\t\n144\t## Technical Approach\n145\t\n146\t<!-- High-level design: affected modules, data flow, key libraries. -->\n147\t\n148\t## Acceptance Criteria\n149\t\n150\t- [ ] AC-1: ...\n151\t\n152\t## Open Questions\n153\t\n154\t<!-- Tag each with OPEN | RESOLVED | DEFERRED -->\n155\t\n156\t## References\n157\t\n158\t\"\"\"\n159\t\n160\t\n161\tdef cmd_new(args: argparse.Namespace) -> int:\n162\t    prds = load_all(args.prd_dir) if args.prd_dir.exists() else {}\n163\t\n164\t    # Pick ID\n165\t    if args.id:\n166\t        if not PRD_ID_RE.match(args.id):\n167\t            raise SystemExit(f\"invalid PRD id: {args.id!r}\")\n168\t        if args.id in prds:\n169\t            raise SystemExit(f\"PRD id {args.id!r} already exists\")\n170\t        new_id = args.id\n171\t    else:\n172\t        new_id = _next_flat_prd_id(prds)\n173\t\n174\t    slug = _slugify(args.title)\n175\t    filename = f\"{new_id}-{slug}.md\"\n176\t    path = args.prd_dir / filename\n177\t    if path.exists():\n178\t        raise SystemExit(f\"file already exists: {path}\")\n179\t\n180\t    today = date.today().isoformat()\n181\t    frontmatter = {\n182\t        \"id\": new_id,\n183\t        \"title\": args.title,\n184\t        \"kind\": args.kind,\n185\t        \"status\": \"draft\",\n186\t        \"priority\": args.priority,\n187\t        \"effort\": args.effort,\n188\t        \"capability\": args.capability,\n189\t        \"parent\": None,\n190\t        \"depends_on\": [],\n191\t        \"blocks\": [],\n192\t        \"impacts\": [],\n193\t        \"workflow\": None,\n194\t        \"assignee\": None,\n195\t        \"reviewers\": [],\n196\t        \"target_version\": None,\n197\t        \"created\": today,\n198\t        \"updated\": today,\n199\t        \"tags\": [],\n200\t    }\n201\t\n202\t    body = DRAFT_TEMPLATE_BODY.format(title=args.title)\n203\t    content = f\"---\\n{dump_frontmatter(frontmatter)}---\\n\\n{body}\"\n204\t\n205\t    args.prd_dir.mkdir(parents=True, exist_ok=True)\n206\t    path.write_text(content, encoding=\"utf-8\")\n207\t    print(f\"Created {path}\")\n208\t\n209\t    if args.open:\n210\t        editor = os.environ.get(\"EDITOR\", \"\")\n211\t        if editor:\n212\t            subprocess.run([editor, str(path)], check=False)\n213\t\n214\t    return 0\n215\t\n216\t\n217\tdef cmd_status(args: argparse.Namespace) -> int:\n218\t    prds = _load(args.prd_dir)\n219\t    counts = Counter(prd.status for prd in prds.values())\n220\t    actionable = sorted(\n221\t        (prd for prd in prds.values() if graph.is_actionable(prd,