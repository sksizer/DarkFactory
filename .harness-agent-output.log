{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XKdmTGiSEkgdneESc2QUGm","type":"tool_result","content":"1\t\"\"\"Containment tree operations.\n2\t\n3\tThe containment relationship is encoded in each PRD's ``parent`` field\n4\t(a single PRD id or None). The whole set forms a forest: each PRD has at\n5\tmost one parent, and there can be multiple roots. This is orthogonal to\n6\tthe dependency DAG (``depends_on``/``blocks``).\n7\t\"\"\"\n8\t\n9\tfrom __future__ import annotations\n10\t\n11\tfrom .prd import PRD, parse_id_sort_key\n12\t\n13\t\n14\tdef children(prd_id: str, prds: dict[str, PRD]) -> list[PRD]:\n15\t    \"\"\"Direct children of ``prd_id`` (PRDs whose ``parent`` matches), naturally sorted.\"\"\"\n16\t    matched = [p for p in prds.values() if p.parent == prd_id]\n17\t    matched.sort(key=lambda p: parse_id_sort_key(p.id))\n18\t    return matched\n19\t\n20\t\n21\tdef descendants(prd_id: str, prds: dict[str, PRD]) -> list[PRD]:\n22\t    \"\"\"All transitive children, BFS order.\"\"\"\n23\t    out: list[PRD] = []\n24\t    queue = children(prd_id, prds)\n25\t    while queue:\n26\t        node = queue.pop(0)\n27\t        out.append(node)\n28\t        queue.extend(children(node.id, prds))\n29\t    return out\n30\t\n31\t\n32\tdef ancestors(prd_id: str, prds: dict[str, PRD]) -> list[PRD]:\n33\t    \"\"\"Walk up the parent chain. Returns parents in order from immediate to root.\"\"\"\n34\t    out: list[PRD] = []\n35\t    seen: set[str] = set()\n36\t    current = prds.get(prd_id)\n37\t    while current and current.parent and current.parent not in seen:\n38\t        seen.add(current.parent)\n39\t        parent = prds.get(current.parent)\n40\t        if parent is None:\n41\t            break\n42\t        out.append(parent)\n43\t        current = parent\n44\t    return out\n45\t\n46\t\n47\tdef roots(prds: dict[str, PRD]) -> list[PRD]:\n48\t    \"\"\"Top-level PRDs (no parent), naturally sorted.\"\"\"\n49\t    rs = [p for p in prds.values() if p.parent is None]\n50\t    rs.sort(key=lambda p: parse_id_sort_key(p.id))\n51\t    return rs\n52\t\n53\t\n54\tdef is_leaf(prd: PRD, prds: dict[str, PRD]) -> bool:\n55\t    \"\"\"True if ``prd`` has no children.\"\"\"\n56\t    return not children(prd.id, prds)\n57\t\n58\t\n59\tdef is_fully_decomposed(prd: PRD, prds: dict[str, PRD]) -> bool:\n60\t    \"\"\"True if ``prd`` has at least one ``task``-kind descendant.\n61\t\n62\t    An epic or feature with no task descendants is considered not yet\n63\t    decomposed and is a candidate for the planning workflow.\n64\t    \"\"\"\n65\t    return any(d.kind == \"task\" for d in descendants(prd.id, prds))\n66\t\n67\t\n68\tdef is_runnable(prd: PRD, prds: dict[str, PRD]) -> bool:\n69\t    \"\"\"True if ``prd`` can be executed by an implementation workflow.\n70\t\n71\t    A PRD is runnable when it is itself a task OR a leaf in the containment\n72\t    tree (no children to delegate to). Epics and features with children are\n73\t    NOT runnable; they are decomposed via the planning workflow instead.\n74\t    \"\"\"\n75\t    if prd.kind == \"task\":\n76\t        return True\n77\t    return is_leaf(prd, prds)\n78\t\n[result-id: r5]"}]},"parent_tool_use_id":"toolu_017x74usEsvHbE9fPYD9WHc8","session_id":"139194c3-2b15-46fb-ae47-01a4e87ddf0a","uuid":"fc7ab783-ab28-4e20-8947-799dba83ee74","timestamp":"2026-04-08T14:41:31.701Z"}
