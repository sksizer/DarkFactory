{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UhEdHVRc2Mx9jQUXaDr3Dj","type":"tool_result","content":"380\tdef resolve_style_config(\n381\t    *,\n382\t    theme: str | None = None,\n383\t    icon_set: str | None = None,\n384\t    no_color: bool = False,\n385\t    repo_root: Path | None = None,\n386\t) -> StyleConfig:\n387\t    \"\"\"Merge all config sources into a single :class:`StyleConfig`.\n388\t\n389\t    Precedence (highest wins):\n390\t\n391\t    1. CLI flags (*theme*, *icon_set*, *no_color*)\n392\t    2. Environment variables (``DARKFACTORY_THEME``, ``DARKFACTORY_ICON_SET``,\n393\t       ``NO_COLOR``)\n394\t    3. Project config — ``<repo_root>/.darkfactory/config.toml``\n395\t    4. User config — ``~/.config/darkfactory/config.toml``\n396\t    5. Built-in defaults (dark theme, ascii icons, color enabled)\n397\t\n398\t    Color is also automatically suppressed when stdout is not a TTY (unless\n399\t    an explicit ``--no-color`` flag or ``NO_COLOR`` env var was set and the\n400\t    caller already passes ``no_color=True``).\n401\t    \"\"\"\n402\t    config: dict[str, Any] = {\"theme\": \"dark\", \"icon_set\": None, \"no_color\": False}\n403\t\n404\t    # Layer 4: user config\n405\t    user_cfg = Path.home() / \".config\" / \"darkfactory\" / \"config.toml\"\n406\t    _merge_toml_file(config, user_cfg)\n407\t\n408\t    # Layer 3: project config (overrides user)\n409\t    if repo_root is not None:\n410\t        project_cfg = repo_root / \".darkfactory\" / \"config.toml\"\n411\t        _merge_toml_file(config, project_cfg)\n412\t\n413\t    # Layer 2: environment variables\n414\t    if os.environ.get(\"NO_COLOR\") is not None:\n415\t        config[\"no_color\"] = True\n416\t    env_theme = os.environ.get(\"DARKFACTORY_THEME\")\n417\t    if env_theme:\n418\t        config[\"theme\"] = env_theme\n419\t    env_icon_set = os.environ.get(\"DARKFACTORY_ICON_SET\")\n420\t    if env_icon_set:\n421\t        config[\"icon_set\"] = env_icon_set\n422\t\n423\t    # Layer 1: CLI flags (highest priority)\n424\t    if no_color:\n425\t        config[\"no_color\"] = True\n426\t    if theme is not None:\n427\t        config[\"theme\"] = theme\n428\t    if icon_set is not None:\n429\t        config[\"icon_set\"] = icon_set\n430\t\n431\t    # Resolve icon set: explicit config > Nerd Font detection > ascii default\n432\t    resolved_icon_set: str = config.get(\"icon_set\") or \"\"\n433\t    if not resolved_icon_set:\n434\t        detected = detect_nerdfont()\n435\t        resolved_icon_set = \"nerdfont\" if detected is True else \"ascii\"\n436\t\n437\t    # Suppress color when stdout is not a TTY (unless already disabled above)\n438\t    no_color_final = bool(config[\"no_color\"])\n439\t    if not no_color_final and not sys.stdout.isatty():\n440\t        no_color_final = True\n441\t\n442\t    return StyleConfig(\n443\t        theme_name=str(config.get(\"theme\", \"dark\")),\n444\t        icon_set_name=resolved_icon_set,\n445\t        no_color=no_color_final,\n446\t    )\n447\t\n448\t\n449\t# ---------------------------------------------------------------------------\n[result-id: r9]"}]},"parent_tool_use_id":"toolu_0116YA4rYY4LKmQQwBSbMtgQ","session_id":"939fc375-8ed1-4dc0-8515-8b3ee2d79451","uuid":"d7059fd2-143d-4fc9-b0c1-8ba15ab5dbd4","timestamp":"2026-04-09T02:38:05.092Z"}
