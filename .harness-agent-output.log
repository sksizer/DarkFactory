0\"],\n297\t        repo_root=tmp_git_repo,\n298\t        workflow=Workflow(name=\"default\"),\n299\t        base_ref=\"main\",\n300\t        branch_name=\"prd/PRD-070-resume-test\",\n301\t        cwd=tmp_git_repo,\n302\t        dry_run=False,\n303\t    )\n304\t    builtins.ensure_worktree(ctx)\n305\t    first_path = ctx.worktree_path\n306\t    assert first_path is not None\n307\t\n308\t    # Touch a file in the worktree to prove we're reusing it\n309\t    (first_path / \"marker.txt\").write_text(\"first run\\n\")\n310\t\n311\t    # Release the lock so the second context can acquire it (simulating\n312\t    # a new process that resumes an interrupted run).\n313\t    assert ctx._worktree_lock is not None\n314\t    ctx._worktree_lock.release()\n315\t    ctx._worktree_lock = None\n316\t\n317\t    # Reset the context and call again\n318\t    ctx2 = ExecutionContext(\n319\t        prd=prds[\"PRD-070\"],\n320\t        repo_root=tmp_git_repo,\n321\t        workflow=Workflow(name=\"default\"),\n322\t        base_ref=\"main\",\n323\t        branch_name=\"prd/PRD-070-resume-test\",\n324\t        cwd=tmp_git_repo,\n325\t        dry_run=False,\n326\t    )\n327\t    builtins.ensure_worktree(ctx2)\n328\t    assert ctx2.worktree_path == first_path\n329\t    assert (first_path / \"marker.txt\").read_text() == \"first run\\n\"\n330\t    # Release the lock acquired by ctx2 to avoid leaking it after the test.\n331\t    if ctx2._worktree_lock is not None:\n332\t        ctx2._worktree_lock.release()\n333\t        ctx2._worktree_lock = None\n334\t\n335\t\n336\tdef test_commit_stages_and_commits(tmp_git_repo: Path) -> None:\n337\t    \"\"\"commit() should git-add-all and commit a message inside the worktree.\"\"\"\n338\t    prd_dir = tmp_git_repo / \"docs\" / \"prd\"\n339\t    prd_dir.mkdir(parents=True)\n340\t    write_prd(prd_dir, \"PRD-070\", \"commit-test\")\n341\t    prds = load_all(prd_dir)\n342\t\n343\t    # Create the worktree first\n344\t    ctx = ExecutionContext(\n345\t        