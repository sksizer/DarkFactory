{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01K2UDFrTvap7xi4siwXC9u6","type":"tool_result","content":"0\t\"\"\"Tests for ``prd normalize`` CLI subcommand.\"\"\"\n1\t\n2\tfrom __future__ import annotations\n3\t\n4\tfrom pathlib import Path\n5\t\n6\timport pytest\n7\t\n8\tfrom darkfactory.cli import main\n9\t\n10\tfrom .conftest import write_prd\n11\t\n12\t\n13\t# ---------------------------------------------------------------------------\n14\t# Helpers\n15\t# ---------------------------------------------------------------------------\n16\t\n17\t\n18\tdef _prd_with_unsorted_tags(prd_dir: Path, prd_id: str = \"PRD-070\") -> Path:\n19\t    \"\"\"Write a PRD whose tags block is intentionally out of order.\"\"\"\n20\t    slug = prd_id.lower().replace(\"-\", \"\")\n21\t    path = prd_dir / f\"{prd_id}-{slug}.md\"\n22\t    path.write_text(\n23\t        \"---\\n\"\n24\t        f'id: \"{prd_id}\"\\n'\n25\t        f'title: \"Test {prd_id}\"\\n'\n26\t        \"kind: task\\n\"\n27\t        \"status: ready\\n\"\n28\t        \"priority: medium\\n\"\n29\t        \"effort: s\\n\"\n30\t        \"capability: simple\\n\"\n31\t        \"parent: null\\n\"\n32\t        \"depends_on: []\\n\"\n33\t        \"blocks: []\\n\"\n34\t        \"impacts: []\\n\"\n35\t        \"workflow: null\\n\"\n36\t        \"created: 2026-04-06\\n\"\n37\t        \"updated: 2026-04-06\\n\"\n38\t        \"tags:\\n\"\n39\t        \"  - zebra\\n\"\n40\t        \"  - apple\\n\"\n41\t        \"---\\n\"\n42\t        \"\\n\"\n43\t        \"# Body\\n\",\n44\t        encoding=\"utf-8\",\n45\t    )\n46\t    return path\n47\t\n48\t\n49\tdef _prd_canonical(prd_dir: Path, prd_id: str = \"PRD-070\") -> Path:\n50\t    \"\"\"Write a PRD whose list fields are already in canonical order.\"\"\"\n51\t    slug = prd_id.lower().replace(\"-\", \"\")\n52\t    path = prd_dir / f\"{prd_id}-{slug}.md\"\n53\t    path.write_text(\n54\t        \"---\\n\"\n55\t        f'id: \"{prd_id}\"\\n'\n56\t        f'title: \"