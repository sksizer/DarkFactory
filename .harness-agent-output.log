n149\t    prd_dir = tmp_path / \"prds\"\n150\t    prd_dir.mkdir()\n151\t    write_prd(\n152\t        prd_dir,\n153\t        \"PRD-070\",\n154\t        \"my-task\",\n155\t        body=\"# Title\\n\\n## Acceptance Criteria\\n\\n- [ ] AC-1: test it\\n\",\n156\t    )\n157\t    prds = load_all(prd_dir)\n158\t\n159\t    ctx = ExecutionContext(\n160\t        prd=prds[\"PRD-070\"],\n161\t        repo_root=tmp_path,\n162\t        workflow=Workflow(name=\"default\"),\n163\t        base_ref=\"main\",\n164\t        branch_name=\"prd/PRD-070-my-task\",\n165\t    )\n166\t    body = _pr_body(ctx)\n167\t    assert \"prds/PRD-070-my-task.md\" in body\n168\t    assert \"AC-1: test it\" in body\n169\t    assert \"default\" in body  # workflow name in footer\n170\t\n171\t\n172\t# ---------- dry-run behavior ----------\n173\t\n174\t\n175\tdef _make_dry_run_ctx(tmp_path: Path) -> ExecutionContext:\n176\t    \"\"\"Build an ExecutionContext with dry_run=True for safe testing.\"\"\"\n177\t    prd_dir = tmp_path / \"prds\"\n178\t    prd_dir.mkdir()\n179\t    write_prd(prd_dir, \"PRD-070\", \"task\")\n180\t    prds = load_all(prd_dir)\n181\t\n182\t    return ExecutionContext(\n183\t        prd=prds[\"PRD-070\"],\n184\t        repo_root=tmp_path,\n185\t        workflow=Workflow(name=\"default\"),\n186\t        base_ref=\"main\",\n187\t        branch_name=\"prd/PRD-070-task\",\n188\t        cwd=tmp_path,\n189\t        dry_run=True,\n190\t    )\n191\t\n192\t\n193\tdef test_dry_run_ensure_worktree_logs_and_returns(\n194\t    tmp_path: Path, caplog: pytest.LogCaptureFixture\n195\t) -> None:\n196\t    ctx = _make_dry_run_ctx(tmp_path)\n197\t    with caplog.at_level(logging.INFO, logger=\"darkfactory\"):\n198\t        builtins.ensure_worktree(ctx)\n199\t    # Should not have actually created a worktree\n200\t    assert not (tmp_path / \".worktrees\" / \"PRD-070-task\").exists()\n201\t    # But should have set the target path on ctx\n202\t    assert ctx.worktree_path == tmp_path / \".worktrees\" / \"PRD-070-task\"\n203\t    # And logged the command\n204\t    assert any(\"git\" in rec.message for rec in caplog.records)\n205\t\n206\t\n207\tdef test_dry_run_set_status_does_not_mutate(tmp_path: Path) -> None:\n208\t    ctx = _make_dry_run_ctx(tmp_path)\n209\t    original_status = ctx.prd.status\n210\t    builtins.set_status(ctx, to=\"in-progress\")\n211\t    # File should be untouched\n212\t    reloaded = load_all(tmp_path / \"prds\")\n213\t    assert reloaded[\"PRD-070\"].status == original_status\n214\t\n215\t\n216\tdef test_dry_run_commit_does_not_subprocess(tmp_path: Path) -> None:\n217\t    ctx = _make_dry_run_ctx(tmp_path)\n218\t    with patch(\"subprocess.run\") as mock_run:\n219\t        builtins.commit(ctx, message=\"chore(prd): {prd_id} dry\")\n220\t        mock_run.assert_not_called()\n221\t\n222\t\n223\tdef test_dry_run_push_does_not_subprocess(tmp_path: Path) -> None:\n224\t    ctx = _make_dry_run_ctx(tmp_path)\n225\t    with patch(\"subprocess.run\") as mock_run:\n226\t        builtins.push_branch(ctx)\n227\t        mock_run.assert_not_called()\n228\t\n229\t\n230\tdef test_dry_run_create_pr_does_not_subprocess(tmp_path: Path) -> None:\n231\t    ctx = _make_dry_run_ctx(tmp_path)\n232\t    with patch(\"subprocess.run\") as mock_run:\n233\t        builtins.create_pr(ctx)\n234\t        mock_run.assert_not_called()\n235\t    # But should set a placeholder pr_url\n236\t    assert ctx.pr_url is not None\n237\t\n238\t\n239\t# ---------- real git operations (tmp repo fixtures) ----------\n240\t\n241\t\n242\t@pytest.fixture\n243\tdef tmp_git_repo(tmp_path: Path) -> Path:\n244\t    \"\"\"Initialize a bare-bones git repo with an initial commit at tmp_path/repo.\"\"\"\n245\t    repo = tmp_path / \"repo\"\n246\t    repo.mkdir()\n247\t    subprocess.run([\"git\", \"init\", \"-q\", \"-b\", \"main\"], cwd=repo, check=True)\n248\t    subprocess.run(\n249\t        [\"git\", \"config\", \"user.email\", \"test@example.com\"], cwd=repo, check=True"}]},"parent_tool_use_id":