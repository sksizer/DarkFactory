{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015RnomfxzbZcjB5EgW68caN","type":"tool_result","content":"1\t\"\"\"Integration tests for `prd plan` and `prd run` CLI subcommands.\n2\t\n3\tEnd-to-end tests that exercise the full argparse -> assign -> runner\n4\tchain against fixture PRD directories and workflow directories. The\n5\tactual agent invocation is mocked so tests don't spawn subprocesses.\n6\t\"\"\"\n7\t\n8\tfrom __future__ import annotations\n9\t\n10\timport json\n11\timport os\n12\timport subprocess\n13\tfrom pathlib import Path\n14\tfrom unittest.mock import patch\n15\t\n16\timport pytest\n17\t\n18\tfrom darkfactory.cli import _resolve_base_ref, main\n19\t\n20\tfrom .conftest import write_prd\n21\t\n22\t\n23\tdef _write_workflow_with_prompts(workflows_dir: Path, name: str = \"default\") -> None:\n24\t    \"\"\"Create a minimal workflow with prompt files for end-to-end tests.\n25\t\n26\t    The generated workflow's ``workflow.name`` matches the directory\n27\t    name, so callers can create multiple distinct workflows in the same\n28\t    directory without collision.\n29\t    \"\"\"\n30\t    wf = workflows_dir / name\n31\t    (wf / \"prompts\").mkdir(parents=True)\n32\t    (wf / \"prompts\" / \"role.md\").write_text(\"# Role\\n\")\n33\t    (wf / \"prompts\" / \"task.md\").write_text(\"# Task\\n{{PRD_ID}}\\n\")\n34\t    (wf / \"prompts\" / \"verify.md\").write_text(\"Fix:\\n{{CHECK_OUTPUT}}\\n\")\n35\t    (wf / \"workflow.py\").write_text(\n36\t        f'''\"\"\"Fixture {name} workflow.\"\"\"\n37\tfrom darkfactory.workflow import AgentTask, BuiltIn, ShellTask, Workflow\n38\t\n39\t\n40\tdef _applies(prd, prds):\n41\t    return True\n42\t\n43\t\n44\tworkflow = Workflow(\n45\t    name=\"{name}\",\n46\t    description=\"Test {name}\",\n47\t    applies_to=_applies,\n48\t    priority=0,\n49\t    tasks=[\n50\t        BuiltIn(\"set_status\", kwargs={{\"to\": \"in-progress\"}}),\n51\t        AgentTask(prompts=[\"prompts/role.md\", \"prompts/task.md\"]),\n52\t        ShellTask(\"test\", cmd=\"echo test\"),\n53\t        BuiltIn(\"set_status\", kwargs={{\"to\": \"review\"}}),\n54\t    ],\n55\t)\n56\t'''\n57\t    )\n58\t\n59\t\n60\tdef _init_git_repo(path: Path) -> None:\n61\t    \"\"\"Minimal git init so ``_find_repo_root`` can locate the tmp dir.\n62\t\n63\t    The harness's CLI walks up from ``--prd-dir`` looking for ``.git``\n64\t    to use as the repo root; without this, plan/run commands raise\n65\t    ``SystemExit``. We use a bare `.git` directory rather than a full\n66\t    ``git init`` because none of the tests in this file actually need\n67\t    a functioning git repo — they mock subprocess calls where necessary.\n68\t    \"\"\"\n69\t    (path / \".git\").mkdir(exist_ok=True)\n70\t\n71\t\n72\t# ---------- plan ----------\n73\t\n74\t\n75\tdef test_plan_shows_workflow_and_tasks(\n76\t    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n77\t) -> None:\n78\t    _init_git_repo(tmp_path)\n79\t    workflows_dir = tmp_path / \"workflows\"\n80\t    _write_workflow_with_prompts(workflows_dir)\n81\t\n82\t    prd_dir = tmp_path / \"prds\"\n83\t    prd_dir.mkdir()\n84\t    write_prd(prd_dir, \"PRD-070\", \"my-task\", capability=\"simple\")\n85\t\n86\t    exit_code = main(\n87\t        [\n88\t            \"--prd-dir\",\n89\t            str(prd_dir),\n90\t            \"--workflows-dir\",\n91\t            str(workflows_dir),\n92\t            \"plan\",\n93\t            \"PRD-070\",\n94\t        ]\n95\t    )\n96\t    assert exit_code == 0\n97\t    out = capsys.readouterr().out\n98\t    assert \"PRD-070\" in out\n99\t    assert \"default\" in out\n100\t    assert \"sonnet\" in out  # simple capability -> sonnet\n101\t    # Task list rendered\n102\t    assert \"set_status\" in out\n103\t    assert \"test\" in out\n104\t    # Branch name\n105\t    assert \"prd/PRD-070-my-task\" in out\n106\t\n107\t\n108\tdef test_plan_json_output(tmp_path: Path, capsys: pytest.CaptureFixture[str]) -> None:\n109\t    _init_git_repo(tmp_path)\n110\t    workflows_dir = tmp_path / \"workflows\"\n111\t    _write_workflow_with_prompts(workflows_dir)\n112\t\n113\t    prd_dir = tmp_path / \"prds\"\n114\t    prd_dir.mkdir()\n115\t    write_prd(prd_dir, \"PRD-070\", \"task\", capability=\"complex\")\n116\t\n117\t    main(\n118\t        [\n119\t            \"--prd-dir\",\n120\t            str(prd_dir),\n121\t            \"--workflows-dir\",\n122\t            str(workflows_dir),\n123\t            \"--json\",\n124\t            \"plan\",\n125\t            \"PRD-070\",\n126\t        ]\n127\t    )\n128\t    payload = json.loads(capsys.readouterr().out)\n129\t    assert payload[\"prd\"][\"id\"] == \"PRD-070\"\n130\t    assert payload[\"workflow\"][\"name\"] == \"default\"\n131\t    assert payload[\"default_model\"] == \"opus\"  # complex -> opus\n132\t    assert \"tasks\" in payload\n133\t    assert len(payload[\"tasks\"]) == 4\n134\t\n135\t\n136\tdef test_plan_flags_not_runnable_done_prd(\n137\t    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n138\t) -> None:\n139\t    _init_git_repo(tmp_path)\n140\t    workflows_dir = tmp_path / \"workflows\"\n141\t    _write_workflow_with_prompts(workflows_dir)\n142\t\n143\t    prd_dir = tmp_path / \"prds\"\n144\t    prd_dir.mkdir()\n145\t    write_prd(prd_dir, \"PRD-070\", \"done-task\", status=\"done\")\n146\t\n147\t    main(\n148\t        [\n149\t            \"--prd-dir\",\n150\t            str(prd_dir),\n151\t            \"--workflows-dir\",\n152\t            str(workflows_dir),\n153\t            \"plan\",\n154\t            \"PRD-070\",\n155\t        ]\n156\t    )\n157\t    out = capsys.readouterr().out\n158\t    assert \"NOT RUNNABLE\" in out\n159\t    assert \"already done\" in out\n160\t\n161\t\n162\tdef test_plan_workflow_override(\n163\t    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n164\t) -> None:\n165\t    \"\"\"--workflow pins an explicit workflow, bypassing assignment.\"\"\"\n166\t    _init_git_repo(tmp_path)\n167\t    workflows_dir = tmp_path / \"workflows\"\n168\t    _write_workflow_with_prompts(workflows_dir, name=\"default\")\n169\t    _write_workflow_with_prompts(workflows_dir, name=\"special\")\n170\t\n171\t    prd_dir = tmp_path / \"prds\"\n172\t    prd_dir.mkdir()\n173\t    write_prd(prd_dir, \"PRD-070\", \"task\")\n174\t\n175\t    main(\n176\t        [\n177\t            \"--prd-dir\",\n178\t            str(prd_dir),\n179\t            \"--workflows-dir\",\n180\t            str(workflows_dir),\n181\t            \"plan\",\n182\t            \"PRD-070\",\n183\t            \"--workflow\",\n184\t            \"special\",\n185\t        ]\n186\t    )\n187\t    out = capsys.readouterr().out\n188\t    assert \"special\" in out\n189\t\n190\t\n191\tdef test_plan_unknown_prd_errors(tmp_path: Path) -> None:\n192\t    workflows_dir = tmp_path / \"workflows\"\n193\t    _write_workflow_with_prompts(workflows_dir)\n194\t    prd_dir = tmp_path / \"prds\"\n195\t    prd_dir.mkdir()\n196\t    write_prd(prd_dir, \"PRD-001\", \"exists\")\n197\t\n198\t    with pytest.raises(SystemExit, match=\"unknown PRD\"):\n199\t        main(\n200\t            [\n201\t                \"--prd-dir\",\n202\t                str(prd_dir),\n203\t                \"--workflows-dir\",\n204\t                str(workflows_dir),\n205\t                \"plan\",\n206\t                \"PRD-999\",\n207\t            ]\n208\t        )\n209\t\n210\t\n211\tdef test_plan_unknown_workflow_errors(tmp_path: Path) -> None:\n212\t    workflows_dir = tmp_path / \"workflows\"\n213\t    _write_workflow_with_prompts(workflows_dir)\n214\t    prd_dir = tmp_path / \"prds\"\n215\t    prd_dir.mkdir()\n216\t    write_prd(prd_dir, \"PRD-070\", \"task\")\n217\t\n218\t    with pytest.raises(SystemExit, match=\"unknown workflow\"):\n219\t        main(\n220\t            [\n221\t                \"--prd-dir\",\n222\t                str(prd_dir),\n223\t                \"--workflows-dir\",\n224\t                str(workflows_dir),\n225\t                \"plan\",\n226\t                \"PRD-070\",\n227\t                \"--workflow\",\n228\t                \"nonexistent\",\n229\t            ]\n230\t        )\n231\t\n232\t\n233\t# ---------- run (dry-run) ----------\n234\t\n235\t\n236\tdef test_run_dry_run_default(\n237\t    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n238\t) -> None:\n239\t    \"\"\"`prd run` without --execute is a dry-run and doesn't touch anything.\"\"\"\n240\t    _init_git_repo(tmp_path)\n241\t    workflows_dir = tmp_path / \"workflows\"\n242\t    _write_workflow_with_prompts(workflows_dir)\n243\t\n244\t    prd_dir = tmp_path / \"prds\"\n245\t    prd_dir.mkdir()\n246\t    write_prd(prd_dir, \"PRD-070\", \"task\")\n247\t\n248\t    exit_code = main(\n249\t        [\n250\t            \"--prd-dir\",\n251\t            str(prd_dir),\n252\t            \"--workflows-dir\",\n253\t            str(workflows_dir),\n254\t            \"run\",\n255\t            \"PRD-070\",\n256\t        ]\n257\t    )\n258\t    assert exit_code == 0\n259\t    out = capsys.readouterr().out\n260\t    assert \"Dry-run\" in out\n261\t    # All 4 tasks dispatched\n262\t    assert \"set_status\" in out\n263\t    assert \"implement\" in out\n264\t    assert \"test\" in out\n265\t    assert \"✓ success\" in out\n266\t\n267\t\n268\tdef test_run_dry_run_no_subprocess(tmp_path: Path) -> None:\n269\t    \"\"\"Dry-run shouldn't actually invoke subprocess at any point.\"\"\"\n270\t    _init_git_repo(tmp_path)\n271\t    workflows_dir = tmp_path / \"workflows\"\n272\t    _write_workflow_with_prompts(workflows_dir)\n273\t\n274\t    prd_dir = tmp_path / \"prds\"\n275\t    prd_dir.mkdir()\n276\t    write_prd(prd_dir, \"PRD-070\", \"task\")\n277\t\n278\t    with patch(\"subprocess.run\") as mock_run:\n279\t        # Allow _resolve_base_ref to run git rev-parse (it's OK if it does)\n280\t        # but make it a no-op\n281\t        mock_run.return_value = subprocess.CompletedProcess(\n282\t            args=[\"git\"], returncode=0, stdout=\"main\\n\", stderr=\"\"\n283\t        )\n284\t        main(\n285\t            [\n286\t                \"--prd-dir\",\n287\t                str(prd_dir),\n288\t                \"--workflows-dir\",\n289\t                str(workflows_dir),\n290\t                \"run\",\n291\t                \"PRD-070\",\n292\t            ]\n293\t        )\n294\t        # _resolve_base_ref may have called it once; the dispatch loop\n295\t        # itself should not have.\n296\t        assert mock_run.call_count <= 1\n297\t\n298\t\n299\t# ---------- run (execute path, with runnability gate) ----------\n300\t\n301\t\n302\tdef test_run_execute_refuses_done_prd(tmp_path: Path) -> None:\n303\t    _init_git_repo(tmp_path)\n304\t    workflows_dir = tmp_path / \"workflows\"\n305\t    _write_workflow_with_prompts(workflows_dir)\n306\t\n307\t    prd_dir = tmp_path / \"prds\"\n308\t    prd_dir.mkdir()\n309\t    write_prd(prd_dir, \"PRD-070\", \"done\", status=\"done\")\n310\t\n311\t    with pytest.raises(SystemExit, match=\"already done\"):\n312\t        main(\n313\t            [\n314\t                \"--prd-dir\",\n315\t                str(prd_dir),\n316\t                \"--workflows-dir\",\n317\t                str(workflows_dir),\n318\t                \"run\",\n319\t                \"PRD-070\",\n320\t                \"--execute\",\n321\t            ]\n322\t        )\n323\t\n324\t\n325\tdef test_run_execute_refuses_draft_prd(tmp_path: Path) -> None:\n326\t    _init_git_repo(tmp_path)\n327\t    workflows_dir = tmp_path / \"workflows\"\n328\t    _write_workflow_with_prompts(workflows_dir)\n329\t\n330\t    prd_dir = tmp_path / \"prds\"\n331\t    prd_dir.mkdir()\n332\t    write_prd(prd_dir, \"PRD-070\", \"draft\", status=\"draft\")\n333\t\n334\t    with pytest.raises(SystemExit, match=\"not 'ready'\"):\n335\t        main(\n336\t            [\n337\t                \"--prd-dir\",\n338\t                str(prd_dir),\n339\t                \"--workflows-dir\",\n340\t                str(workflows_dir),\n341\t                \"run\",\n342\t                \"PRD-070\",\n343\t                \"--execute\",\n344\t            ]\n345\t        )\n346\t\n347\t\n348\tdef test_run_execute_refuses_unfinished_deps(tmp_path: Path) -> None:\n349\t    _init_git_repo(tmp_path)\n350\t    workflows_dir = tmp_path / \"workflows\"\n351\t    _write_workflow_with_prompts(workflows_dir)\n352\t\n353\t    prd_dir = tmp_path / \"prds\"\n354\t    prd_dir.mkdir()\n355\t    write_prd(prd_dir, \"PRD-070\", \"dep\", status=\"ready\")  # dependency still ready\n356\t    write_prd(\n357\t        prd_dir,\n358\t        \"PRD-071\",\n359\t        \"target\",\n360\t        status=\"ready\",\n361\t        depends_on=[\"PRD-070\"],\n362\t    )\n363\t\n364\t    with pytest.raises(SystemExit, match=\"unfinished\"):\n365\t        main(\n366\t            [\n367\t                \"--prd-dir\",\n368\t                str(prd_dir),\n369\t                \"--workflows-dir\",\n370\t                str(workflows_dir),\n371\t                \"run\",\n372\t                \"PRD-071\",\n373\t                \"--execute\",\n374\t            ]\n375\t        )\n376\t\n377\t\n378\tdef test_run_execute_exits_nonzero_on_workflow_failure(\n379\t    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n380\t) -> None:\n381\t    \"\"\"When the runner returns failure, `prd run --execute` exits 1.\"\"\"\n382\t    _init_git_repo(tmp_path)\n383\t    workflows_dir = tmp_path / \"workflows\"\n384\t    # Write a workflow that will fail in its shell task\n385\t    wf = workflows_dir / \"default\"\n386\t    (wf / \"prompts\").mkdir(parents=True)\n387\t    (wf / \"prompts\" / \"task.md\").write_text(\"# Task\\n\")\n388\t    (wf / \"workflow.py\").write_text(\n389\t        '''\"\"\"Failing fixture workflow.\"\"\"\n390\tfrom darkfactory.workflow import ShellTask, Workflow\n391\t\n392\tworkflow = Workflow(\n393\t    name=\"default\",\n394\t    applies_to=lambda prd, prds: True,\n395\t    priority=0,\n396\t    tasks=[ShellTask(\"fail\", cmd=\"false\", on_failure=\"fail\")],\n397\t)\n398\t'''\n399\t    )\n400\t\n401\t    prd_dir = tmp_path / \"prds\"\n402\t    prd_dir.mkdir()\n403\t    write_prd(prd_dir, \"PRD-070\", \"task\", status=\"ready\")\n404\t\n405\t    with patch(\"darkfactory.cli._resolve_base_ref\", return_value=\"main\"):\n406\t        exit_code = main(\n407\t            [\n408\t                \"--prd-dir\",\n409\t                str(prd_dir),\n410\t                \"--workflows-dir\",\n411\t                str(workflows_dir),\n412\t                \"run\",\n413\t                \"PRD-070\",\n414\t                \"--execute\",\n415\t            ]\n416\t        )\n417\t    assert exit_code == 1\n418\t    out = capsys.readouterr().out\n419\t    assert \"FAILED\" in out\n420\t\n421\t\n422\t# ---------- _resolve_base_ref unit tests ----------\n423\t\n424\t\n425\tdef test_resolve_base_ref_explicit_wins(tmp_path: Path) -> None:\n426\t    \"\"\"Explicit --base flag has highest priority.\"\"\"\n427\t    _init_git_repo(tmp_path)\n428\t    result = _resolve_base_ref(\"custom-branch\", tmp_path)\n429\t    assert result == \"custom-branch\"\n430\t\n431\t\n432\tdef test_resolve_base_ref_env_var_override(tmp_path: Path, monkeypatch) -> None:\n433\t    \"\"\"DARKFACTORY_BASE_REF environment variable is used when no explicit arg.\"\"\"\n434\t    _init_git_repo(tmp_path)\n435\t    monkeypatch.setenv(\"DARKFACTORY_BASE_REF\", \"staging\")\n436\t    result = _resolve_base_ref(None, tmp_path)\n437\t    assert result == \"staging\"\n438\t\n439\t\n440\tdef test_resolve_base_ref_defaults_to_main(tmp_path: Path) -> None:\n441\t    \"\"\"Defaults to 'main' when it exists locally.\"\"\"\n442\t    _init_git_repo(tmp_path)\n443\t\n444\t    # Mock subprocess to say main exists but master doesn't\n445\t    def mock_run(cmd, **kwargs):\n446\t        if \"refs/heads/main\" in str(cmd):\n447\t            return subprocess.CompletedProcess(\n448\t                args=cmd, returncode=0, stdout=\"\", stderr=\"\"\n449\t            )\n450\t        return subprocess.CompletedProcess(args=cmd, returncode=1, stdout=\"\", stderr=\"\")\n451\t\n452\t    with patch(\"darkfactory.cli.subprocess.run\", side_effect=mock_run):\n453\t        result = _resolve_base_ref(None, tmp_path)\n454\t        assert result == \"main\"\n455\t\n456\t\n457\tdef test_resolve_base_ref_falls_back_to_master(tmp_path: Path) -> None:\n458\t    \"\"\"Falls back to 'master' when 'main' doesn't exist locally.\"\"\"\n459\t    _init_git_repo(tmp_path)\n460\t\n461\t    # Mock subprocess to say master exists but main doesn't\n462\t    def mock_run(cmd, **kwargs):\n463\t        if \"refs/heads/master\" in str(cmd):\n464\t            return subprocess.CompletedProcess(\n465\t                args=cmd, returncode=0, stdout=\"\", stderr=\"\"\n466\t            )\n467\t        return subprocess.CompletedProcess(args=cmd, returncode=1, stdout=\"\", stderr=\"\")\n468\t\n469\t    with patch(\"darkfactory.cli.subprocess.run\", side_effect=mock_run):\n470\t        result = _resolve_base_ref(None, tmp_path)\n471\t        assert result == \"master\"\n472\t\n473\t\n474\tdef test_resolve_base_ref_falls_back_to_origin_head(tmp_path: Path) -> None:\n475\t    \"\"\"Falls back to origin/HEAD when neither main nor master exist locally.\"\"\"\n476\t    _init_git_repo(tmp_path)\n477\t\n478\t    # Mock subprocess to check refs fail, but symbolic-ref succeeds\n479\t    def mock_run(cmd, **kwargs):\n480\t        if \"symbolic-ref\" in str(cmd):\n481\t            return subprocess.CompletedProcess(\n482\t                args=cmd,\n483\t                returncode=0,\n484\t                stdout=\"refs/remotes/origin/develop\\n\",\n485\t                stderr=\"\",\n486\t            )\n487\t        # All branch checks fail\n488\t        return subprocess.CompletedProcess(args=cmd, returncode=1, stdout=\"\", stderr=\"\")\n489\t\n490\t    with patch(\"darkfactory.cli.subprocess.run\", side_effect=mock_run):\n491\t        result = _resolve_base_ref(None, tmp_path)\n492\t        assert result == \"develop\"\n493\t\n494\t\n495\tdef test_resolve_base_ref_last_resort_main(tmp_path: Path) -> None:\n496\t    \"\"\"Last resort fallback is 'main' when all else fails.\"\"\"\n497\t    _init_git_repo(tmp_path)\n498\t\n499\t    # Mock subprocess so all calls return failure\n500\t    def mock_run_all_fail(cmd, **kwargs):\n501\t        # For check=True calls (symbolic-ref), raise exception\n502\t        if \"symbolic-ref\" in str(cmd):\n503\t            raise subprocess.CalledProcessError(1, cmd)\n504\t        # For other calls, return failure status\n505\t        return subprocess.CompletedProcess(args=cmd, returncode=1, stdout=\"\", stderr=\"\")\n506\t\n507\t    with patch(\"darkfactory.cli.subprocess.run\", side_effect=mock_run_all_fail):\n508\t        result = _resolve_base_ref(None, tmp_path)\n509\t        assert result == \"main\"\n510\t\n511\t\n512\tdef test_resolve_base_ref_explicit_overrides_env(tmp_path: Path, monkeypatch) -> None:\n513\t    \"\"\"Explicit --base flag overrides environment variable.\"\"\"\n514\t    _init_git_repo(tmp_path)\n515\t    monkeypatch.setenv(\"DARKFACTORY_BASE_REF\", \"staging\")\n516\t    result = _resolve_base_ref(\"explicit-branch\", tmp_path)\n517\t    assert result == \"explicit-branch\"\n518\t\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"b2629f03-4a3a-479c-81cd-58b754a9f711","uuid":"d8a8a885-4cb4-4f44-8d96-fa634f2b3424","timestamp":"2026-04-08T16:42:48.183Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-544-base-ref-defaults-main/tests/test_cli_run.py","content":"\"\"\"Integration tests for `prd plan` and `prd run` CLI subcommands.\n\nEnd-to-end tests that exercise the full argparse -> assign -> runner\nchain against fixture PRD directories and workflow directories. The\nactual agent invocation is mocked so tests don't spawn subprocesses.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport os\nimport subprocess\nfrom pathlib import Path\nfrom unittest.mock import patch\n\nimport pytest\n\nfrom darkfactory.cli import _resolve_base_ref, main\n\nfrom .conftest import write_prd\n\n\ndef _write_workflow_with_prompts(workflows_dir: Path, name: str = \"default\") -> None:\n    \"\"\"Create a minimal workflow with prompt files for end-to-end tests.\n\n    The generated workflow's ``workflow.name`` matches the directory\n    name, so callers can create multiple distinct workflows in the same\n    directory without collision.\n    \"\"\"\n    wf = workflows_dir / name\n    (wf / \"prompts\").mkdir(parents=True)\n    (wf / \"prompts\" / \"role.md\").write_text(\"# Role\\n\")\n    (wf / \"prompts\" / \"task.md\").write_text(\"# Task\\n{{PRD_ID}}\\n\")\n    (wf / \"prompts\" / \"verify.md\").write_text(\"Fix:\\n{{CHECK_OUTPUT}}\\n\")\n    (wf / \"workflow.py\").write_text(\n        f'''\"\"\"Fixture {name} workflow.\"\"\"\nfrom darkfactory.workflow import AgentTask, BuiltIn, ShellTask, Workflow\n\n\ndef _applies(prd, prds):\n    return True\n\n\nworkflow = Workflow(\n    name=\"{name}\",\n    description=\"Test {name}\",\n    applies_to=_applies,\n    priority=0,\n    tasks=[\n        BuiltIn(\"set_status\", kwargs={{\"to\": \"in-progress\"}}),\n        AgentTask(prompts=[\"prompts/role.md\", \"prompts/task.md\"]),\n        ShellTask(\"test\", cmd=\"echo test\"),\n        BuiltIn(\"set_status\", kwargs={{\"to\": \"review\"}}),\n    ],\n)\n'''\n    )\n\n\ndef _init_git_repo(path: Path) -> None:\n    \"\"\"Minimal git init so ``_find_repo_root`` can locate the tmp dir.\n\n    The harness's CLI walks up from ``--prd-dir`` looking for ``.git``\n    to use as the repo root; without this, plan/run commands raise\n    ``SystemExit``. We use a bare `.git` directory rather than a full\n    ``git init`` because none of the tests in this file actually need\n    a functioning git repo — they mock subprocess calls where necessary.\n    \"\"\"\n    (path / \".git\").mkdir(exist_ok=True)\n\n\n# ---------- plan ----------\n\n\ndef test_plan_shows_workflow_and_tasks(\n    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n) -> None:\n    _init_git_repo(tmp_path)\n    workflows_dir = tmp_path / \"workflows\"\n    _write_workflow_with_prompts(workflows_dir)\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"my-task\", capability=\"simple\")\n\n    exit_code = main(\n        [\n            \"--prd-dir\",\n            str(prd_dir),\n            \"--workflows-dir\",\n            str(workflows_dir),\n            \"plan\",\n            \"PRD-070\",\n        ]\n    )\n    assert exit_code == 0\n    out = capsys.readouterr().out\n    assert \"PRD-070\" in out\n    assert \"default\" in out\n    assert \"sonnet\" in out  # simple capability -> sonnet\n    # Task list rendered\n    assert \"set_status\" in out\n    assert \"test\" in out\n    # Branch name\n    assert \"prd/PRD-070-my-task\" in out\n\n\ndef test_plan_json_output(tmp_path: Path, capsys: pytest.CaptureFixture[str]) -> None:\n    _init_git_repo(tmp_path)\n    workflows_dir = tmp_path / \"workflows\"\n    _write_workflow_with_prompts(workflows_dir)\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"task\", capability=\"complex\")\n\n    main(\n        [\n            \"--prd-dir\",\n            str(prd_dir),\n            \"--workflows-dir\",\n            str(workflows_dir),\n            \"--json\",\n            \"plan\",\n            \"PRD-070\",\n        ]\n    )\n    payload = json.loads(capsys.readouterr().out)\n    assert payload[\"prd\"][\"id\"] == \"PRD-070\"\n    assert payload[\"workflow\"][\"name\"] == \"default\"\n    assert payload[\"default_model\"] == \"opus\"  # complex -> opus\n    assert \"tasks\" in payload\n    assert len(payload[\"tasks\"]) == 4\n\n\ndef test_plan_flags_not_runnable_done_prd(\n    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n) -> None:\n    _init_git_repo(tmp_path)\n    workflows_dir = tmp_path / \"workflows\"\n    _write_workflow_with_prompts(workflows_dir)\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"done-task\", status=\"done\")\n\n    main(\n        [\n            \"--prd-dir\",\n            str(prd_dir),\n            \"--workflows-dir\",\n            str(workflows_dir),\n            \"plan\",\n            \"PRD-070\",\n        ]\n    )\n    out = capsys.readouterr().out\n    assert \"NOT RUNNABLE\" in out\n    assert \"already done\" in out\n\n\ndef test_plan_workflow_override(\n    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n) -> None:\n    \"\"\"--workflow pins an explicit workflow, bypassing assignment.\"\"\"\n    _init_git_repo(tmp_path)\n    workflows_dir = tmp_path / \"workflows\"\n    _write_workflow_with_prompts(workflows_dir, name=\"default\")\n    _write_workflow_with_prompts(workflows_dir, name=\"special\")\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"task\")\n\n    main(\n        [\n            \"--prd-dir\",\n            str(prd_dir),\n            \"--workflows-dir\",\n            str(workflows_dir),\n            \"plan\",\n            \"PRD-070\",\n            \"--workflow\",\n            \"special\",\n        ]\n    )\n    out = capsys.readouterr().out\n    assert \"special\" in out\n\n\ndef test_plan_unknown_prd_errors(tmp_path: Path) -> None:\n    workflows_dir = tmp_path / \"workflows\"\n    _write_workflow_with_prompts(workflows_dir)\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-001\", \"exists\")\n\n    with pytest.raises(SystemExit, match=\"unknown PRD\"):\n        main(\n            [\n                \"--prd-dir\",\n                str(prd_dir),\n                \"--workflows-dir\",\n                str(workflows_dir),\n                \"plan\",\n                \"PRD-999\",\n            ]\n        )\n\n\ndef test_plan_unknown_workflow_errors(tmp_path: Path) -> None:\n    workflows_dir = tmp_path / \"workflows\"\n    _write_workflow_with_prompts(workflows_dir)\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"task\")\n\n    with pytest.raises(SystemExit, match=\"unknown workflow\"):\n        main(\n            [\n                \"--prd-dir\",\n                str(prd_dir),\n                \"--workflows-dir\",\n                str(workflows_dir),\n                \"plan\",\n                \"PRD-070\",\n                \"--workflow\",\n                \"nonexistent\",\n            ]\n        )\n\n\n# ---------- run (dry-run) ----------\n\n\ndef test_run_dry_run_default(\n    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n) -> None:\n    \"\"\"`prd run` without --execute is a dry-run and doesn't touch anything.\"\"\"\n    _init_git_repo(tmp_path)\n    workflows_dir = tmp_path / \"workflows\"\n    _write_workflow_with_prompts(workflows_dir)\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"task\")\n\n    exit_code = main(\n        [\n            \"--prd-dir\",\n            str(prd_dir),\n            \"--workflows-dir\",\n            str(workflows_dir),\n            \"run\",\n            \"PRD-070\",\n        ]\n    )\n    assert exit_code == 0\n    out = capsys.readouterr().out\n    assert \"Dry-run\" in out\n    # All 4 tasks dispatched\n    assert \"set_status\" in out\n    assert \"implement\" in out\n    assert \"test\" in out\n    assert \"✓ success\" in out\n\n\ndef test_run_dry_run_no_subprocess(tmp_path: Path) -> None:\n    \"\"\"Dry-run shouldn't actually invoke subprocess at any point.\"\"\"\n    _init_git_repo(tmp_path)\n    workflows_dir = tmp_path / \"workflows\"\n    _write_workflow_with_prompts(workflows_dir)\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"task\")\n\n    with patch(\"subprocess.run\") as mock_run:\n        # Allow _resolve_base_ref to run git rev-parse (it's OK if it does)\n        # but make it a no-op\n        mock_run.return_value = subprocess.CompletedProcess(\n            args=[\"git\"], returncode=0, stdout=\"main\\n\", stderr=\"\"\n        )\n        main(\n            [\n                \"--prd-dir\",\n                str(prd_dir),\n                \"--workflows-dir\",\n                str(workflows_dir),\n                \"run\",\n                \"PRD-070\",\n            ]\n        )\n        # _resolve_base_ref may have called it once; the dispatch loop\n        # itself should not have.\n        assert mock_run.call_count <= 1\n\n\n# ---------- run (execute path, with runnability gate) ----------\n\n\ndef test_run_execute_refuses_done_prd(tmp_path: Path) -> None:\n    _init_git_repo(tmp_path)\n    workflows_dir = tmp_path / \"workflows\"\n    _write_workflow_with_prompts(workflows_dir)\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"done\", status=\"done\")\n\n    with pytest.raises(SystemExit, match=\"already done\"):\n        main(\n            [\n                \"--prd-dir\",\n                str(prd_dir),\n                \"--workflows-dir\",\n                str(workflows_dir),\n                \"run\",\n                \"PRD-070\",\n                \"--execute\",\n            ]\n        )\n\n\ndef test_run_execute_refuses_draft_prd(tmp_path: Path) -> None:\n    _init_git_repo(tmp_path)\n    workflows_dir = tmp_path / \"workflows\"\n    _write_workflow_with_prompts(workflows_dir)\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"draft\", status=\"draft\")\n\n    with pytest.raises(SystemExit, match=\"not 'ready'\"):\n        main(\n            [\n                \"--prd-dir\",\n                str(prd_dir),\n                \"--workflows-dir\",\n                str(workflows_dir),\n                \"run\",\n                \"PRD-070\",\n                \"--execute\",\n            ]\n        )\n\n\ndef test_run_execute_refuses_unfinished_deps(tmp_path: Path) -> None:\n    _init_git_repo(tmp_path)\n    workflows_dir = tmp_path / \"workflows\"\n    _write_workflow_with_prompts(workflows_dir)\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"dep\", status=\"ready\")  # dependency still ready\n    write_prd(\n        prd_dir,\n        \"PRD-071\",\n        \"target\",\n        status=\"ready\",\n        depends_on=[\"PRD-070\"],\n    )\n\n    with pytest.raises(SystemExit, match=\"unfinished\"):\n        main(\n            [\n                \"--prd-dir\",\n                str(prd_dir),\n                \"--workflows-dir\",\n                str(workflows_dir),\n                \"run\",\n                \"PRD-071\",\n                \"--execute\",\n            ]\n        )\n\n\ndef test_run_execute_exits_nonzero_on_workflow_failure(\n    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n) -> None:\n    \"\"\"When the runner returns failure, `prd run --execute` exits 1.\"\"\"\n    _init_git_repo(tmp_path)\n    workflows_dir = tmp_path / \"workflows\"\n    # Write a workflow that will fail in its shell task\n    wf = workflows_dir / \"default\"\n    (wf / \"prompts\").mkdir(parents=True)\n    (wf / \"prompts\" / \"task.md\").write_text(\"# Task\\n\")\n    (wf / \"workflow.py\").write_text(\n        '''\"\"\"Failing fixture workflow.\"\"\"\nfrom darkfactory.workflow import ShellTask, Workflow\n\nworkflow = Workflow(\n    name=\"default\",\n    applies_to=lambda prd, prds: True,\n    priority=0,\n    tasks=[ShellTask(\"fail\", cmd=\"false\", on_failure=\"fail\")],\n)\n'''\n    )\n\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"task\", status=\"ready\")\n\n    with patch(\"darkfactory.cli._resolve_base_ref\", return_value=\"main\"):\n        exit_code = main(\n            [\n                \"--prd-dir\",\n                str(prd_dir),\n                \"--workflows-dir\",\n                str(workflows_dir),\n                \"run\",\n                \"PRD-070\",\n                \"--execute\",\n            ]\n        )\n    assert exit_code == 1\n    out = capsys.readouterr().out\n    assert \"FAILED\" in out\n\n\n# ---------- _resolve_base_ref unit tests ----------\n\n\ndef test_resolve_base_ref_explicit_wins(tmp_path: Path) -> None:\n    \"\"\"Explicit --base flag has highest priority.\"\"\"\n    _init_git_repo(tmp_path)\n    result = _resolve_base_ref(\"custom-branch\", tmp_path)\n    assert result == \"custom-branch\"\n\n\ndef test_resolve_base_ref_env_var_override(tmp_path: Path, monkeypatch) -> None:\n    \"\"\"DARKFACTORY_BASE_REF environment variable is used when no explicit arg.\"\"\"\n    _init_git_repo(tmp_path)\n    monkeypatch.setenv(\"DARKFACTORY_BASE_REF\", \"staging\")\n    result = _resolve_base_ref(None, tmp_path)\n    assert result == \"staging\"\n\n\ndef test_resolve_base_ref_defaults_to_main(tmp_path: Path) -> None:\n    \"\"\"Defaults to 'main' when it exists locally.\"\"\"\n    _init_git_repo(tmp_path)\n\n    # Mock subprocess to say main exists but master doesn't\n    def mock_run(cmd, **kwargs):\n        if \"refs/heads/main\" in str(cmd):\n            return subprocess.CompletedProcess(\n                args=cmd, returncode=0, stdout=\"\", stderr=\"\"\n            )\n        return subprocess.CompletedProcess(args=cmd, returncode=1, stdout=\"\", stderr=\"\")\n\n    with patch(\"darkfactory.cli.subprocess.run\", side_effect=mock_run):\n        result = _resolve_base_ref(None, tmp_path)\n        assert result == \"main\"\n\n\ndef test_resolve_base_ref_falls_back_to_master(tmp_path: Path) -> None:\n    \"\"\"Falls back to 'master' when 'main' doesn't exist locally.\"\"\"\n    _init_git_repo(tmp_path)\n\n    # Mock subprocess to say master exists but main doesn't\n    def mock_run(cmd, **kwargs):\n        if \"refs/heads/master\" in str(cmd):\n            return subprocess.CompletedProcess(\n                args=cmd, returncode=0, stdout=\"\", stderr=\"\"\n            )\n        return subprocess.CompletedProcess(args=cmd, returncode=1, stdout=\"\", stderr=\"\")\n\n    with patch(\"darkfactory.cli.subprocess.run\", side_effect=mock_run):\n        result = _resolve_base_ref(None, tmp_path)\n        assert result == \"master\"\n\n\ndef test_resolve_base_ref_falls_back_to_origin_head(tmp_path: Path) -> None:\n    \"\"\"Falls back to origin/HEAD when neither main nor master exist locally.\"\"\"\n    _init_git_repo(tmp_path)\n\n    # Mock subprocess to check refs fail, but symbolic-ref succeeds\n    def mock_run(cmd, **kwargs):\n        if \"symbolic-ref\" in str(cmd):\n            return subprocess.CompletedProcess(\n                args=cmd,\n                returncode=0,\n                stdout=\"refs/remotes/origin/develop\\n\",\n                stderr=\"\",\n            )\n        # All branch checks fail\n        return subprocess.CompletedProcess(args=cmd, returncode=1, stdout=\"\", stderr=\"\")\n\n    with patch(\"darkfactory.cli.subprocess.run\", side_effect=mock_run):\n        result = _resolve_base_ref(None, tmp_path)\n        assert result == \"develop\"\n\n\ndef test_resolve_base_ref_last_resort_main(tmp_path: Path) -> None:\n    \"\"\"Last resort fallback is 'main' when all else fails.\"\"\"\n    _init_git_repo(tmp_path)\n\n    # Mock subprocess so all calls return failure\n    def mock_run_all_fail(cmd, **kwargs):\n        # For check=True calls (symbolic-ref), raise exception\n        if \"symbolic-ref\" in str(cmd):\n            raise subprocess.CalledProcessError(1, cmd)\n        # For other calls, return failure status\n        return subprocess.CompletedProcess(args=cmd, returncode=1, stdout=\"\", stderr=\"\")\n\n    with patch(\"darkfactory.cli.subprocess.run\", side_effect=mock_run_all_fail):\n        result = _resolve_base_ref(None, tmp_path)\n        assert result == \"main\"\n\n\ndef test_resolve_base_ref_explicit_overrides_env(tmp_path: Path, monkeypatch) -> None:\n    \"\"\"Explicit --base flag overrides environment variable.\"\"\"\n    _init_git_repo(tmp_path)\n    monkeypatch.setenv(\"DARKFACTORY_BASE_REF\", \"staging\")\n    result = _resolve_base_ref(\"explicit-branch\", tmp_path)\n    assert result == \"explicit-branch\"\n","numLines":518,"startLine":1,"totalLines":518}}}
