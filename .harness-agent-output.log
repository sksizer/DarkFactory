{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015ogSixq1SgGZCCVtHiKfGh","type":"tool_result","content":"1\t\"\"\"Default workflow — the catchall implementation recipe for any PRD.\n2\t\n3\tMatches every PRD (``applies_to`` returns True, ``priority=0``), so\n4\tthe assignment logic uses this workflow whenever no other workflow's\n5\tpredicate fires and the PRD's frontmatter doesn't pin something\n6\tspecific.\n7\t\n8\tThe task list is the canonical SDLC shape every implementation workflow\n9\tfollows:\n10\t\n11\t1. Create the worktree\n12\t2. Mark PRD in-progress + commit the status change\n13\t3. Invoke Claude Code to write the actual implementation\n14\t4. Run the project's test + lint commands (with retry-agent on failure)\n15\t5. Mark PRD review + commit the status change\n16\t6. Push the branch and open a PR\n17\t\n18\tSpecialized workflows (``ui-component``, ``planning``, etc.) will ship\n19\tas siblings of this directory with different prompts, task lists, and\n20\tpredicates — but they all share this overall shape. Shared SDLC,\n21\tpluggable implementation.\n22\t\"\"\"\n23\t\n24\tfrom __future__ import annotations\n25\t\n26\tfrom darkfactory.workflow import AgentTask, BuiltIn, ShellTask, Workflow\n27\t\n28\t\n29\tdef _applies_to_everything(prd, prds):  # type: ignore[no-untyped-def]\n30\t    \"\"\"Catchall predicate — the default workflow matches every PRD.\n31\t\n32\t    Kept as a module-level named function (not a lambda) so ``list-workflows``\n33\t    can describe it and mypy's strict mode doesn't complain about lambda\n34\t    type annotations.\n35\t    \"\"\"\n36\t    return True\n37\t\n38\t\n39\tworkflow = Workflow(\n40\t    name=\"default\",\n41\t    description=(\n42\t        \"General-purpose PRD implementation — the fallback workflow for \"\n43\t        \"any PRD that doesn't match a more specific predicate.\"\n44\t    ),\n45\t    applies_to=_applies_to_everything,\n46\t    priority=0,  # catchall: lowest priority\n47\t    tasks=[\n48\t        # ----- setup phase -----\n49\t        BuiltIn(\"ensure_worktree\"),\n50\t        BuiltIn(\"set_status\", kwargs={\"to\": \"in-progress\"}),\n51\t        BuiltIn(\n52\t            \"commit\",\n53\t            kwargs={\"message\": \"chore(prd): {prd_id} start work\"},\n54\t        ),\n55\t        # ----- agent implementation -----\n56\t        AgentTask(\n57\t            name=\"implement\",\n58\t            prompts=[\"prompts/role.md\", \"prompts/task.md\"],\n59\t            tools=[\n60\t                # Read/write code and search\n61\t                \"Read\",\n62\t                \"Edit\",\n63\t                \"Write\",\n64\t                \"Glob\",\n65\t                \"Grep\",\n66\t                # Build/test commands\n67\t                \"Bash(cargo:*)\",\n68\t                \"Bash(pnpm:*)\",\n69\t                \"Bash(just:*)\",\n70\t                # Git: the agent only stages and inspects. Commit, push, and\n71\t                # PR creation are owned by the harness builtins — see role.md.\n72\t                # Deliberately no Bash(git commit:*) so the agent can't bypass\n73\t                # the harness's commit step.\n74\t                \"Bash(git add:*)\",\n75\t                \"Bash(git status:*)\",\n76\t                \"Bash(git diff:*)\",\n77\t                \"Bash(git log:*)\",\n78\t            ],\n79\t            model_from_capability=True,\n80\t            retries=1,\n81\t            verify_prompts=[\"prompts/verify.md\"],\n82\t        ),\n83\t        # ----- verification phase -----\n84\t        # test/lint failures trigger one retry_agent cycle each: the\n85\t        # runner composes the verify prompt with the failed output bound\n86\t        # to {{CHECK_OUTPUT}}, re-invokes the agent once, and re-runs\n87\t        # the failing check.\n88\t        ShellTask(\"test\", cmd=\"just test\", on_failure=\"retry_agent\"),\n89\t        ShellTask(\"format\", cmd=\"just format\", on_failure=\"fail\"),\n90\t        ShellTask(\"lint\", cmd=\"just lint format-check\", on_failure=\"retry_agent\"),\n91\t        ShellTask(\"typecheck\", cmd=\"just typecheck\", on_failure=\"retry_agent\"),\n92\t        # ----- teardown phase -----\n93\t        # set_status BEFORE the final commit so the review-status change\n94\t        # lands in the commit that gets pushed. Doing set_status after\n95\t        # commit leaves the status mutation uncommitted and the pushed\n96\t        # branch (and merged PR) shows status: in-progress instead of\n97\t        # review.\n98\t        BuiltIn(\"set_status\", kwargs={\"to\": \"review\"}),\n99\t        BuiltIn(\n100\t            \"commit\",\n101\t            kwargs={\"message\": \"chore(prd): {prd_id} ready for review\"},\n102\t        ),\n103\t        BuiltIn(\"push_branch\"),\n104\t        BuiltIn(\"summarize_agent_run\"),\n105\t        BuiltIn(\"create_pr\"),\n106\t    ],\n107\t)\n108\t"}]},"parent_tool_use_id":null,"session_id":"486cefb7-8454-4ea9-8512-7a451e5c819b","uuid":"5cd83768-c808-4662-aa26-d69a6c0cbc6e","timestamp":"2026-04-08T16:23:32.334Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-224.6-commit-transcript/workflows/default/workflow.py","content":"\"\"\"Default workflow — the catchall implementation recipe for any PRD.\n\nMatches every PRD (``applies_to`` returns True, ``priority=0``), so\nthe assignment logic uses this workflow whenever no other workflow's\npredicate fires and the PRD's frontmatter doesn't pin something\nspecific.\n\nThe task list is the canonical SDLC shape every implementation workflow\nfollows:\n\n1. Create the worktree\n2. Mark PRD in-progress + commit the status change\n3. Invoke Claude Code to write the actual implementation\n4. Run the project's test + lint commands (with retry-agent on failure)\n5. Mark PRD review + commit the status change\n6. Push the branch and open a PR\n\nSpecialized workflows (``ui-component``, ``planning``, etc.) will ship\nas siblings of this directory with different prompts, task lists, and\npredicates — but they all share this overall shape. Shared SDLC,\npluggable implementation.\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom darkfactory.workflow import AgentTask, BuiltIn, ShellTask, Workflow\n\n\ndef _applies_to_everything(prd, prds):  # type: ignore[no-untyped-def]\n    \"\"\"Catchall predicate — the default workflow matches every PRD.\n\n    Kept as a module-level named function (not a lambda) so ``list-workflows``\n    can describe it and mypy's strict mode doesn't complain about lambda\n    type annotations.\n    \"\"\"\n    return True\n\n\nworkflow = Workflow(\n    name=\"default\",\n    description=(\n        \"General-purpose PRD implementation — the fallback workflow for \"\n        \"any PRD that doesn't match a more specific predicate.\"\n    ),\n    applies_to=_applies_to_everything,\n    priority=0,  # catchall: lowest priority\n    tasks=[\n        # ----- setup phase -----\n        BuiltIn(\"ensure_worktree\"),\n        BuiltIn(\"set_status\", kwargs={\"to\": \"in-progress\"}),\n        BuiltIn(\n            \"commit\",\n            kwargs={\"message\": \"chore(prd): {prd_id} start work\"},\n        ),\n        # ----- agent implementation -----\n        AgentTask(\n            name=\"implement\",\n            prompts=[\"prompts/role.md\", \"prompts/task.md\"],\n            tools=[\n                # Read/write code and search\n                \"Read\",\n                \"Edit\",\n                \"Write\",\n                \"Glob\",\n                \"Grep\",\n                # Build/test commands\n                \"Bash(cargo:*)\",\n                \"Bash(pnpm:*)\",\n                \"Bash(just:*)\",\n                # Git: the agent only stages and inspects. Commit, push, and\n                # PR creation are owned by the harness builtins — see role.md.\n                # Deliberately no Bash(git commit:*) so the agent can't bypass\n                # the harness's commit step.\n                \"Bash(git add:*)\",\n                \"Bash(git status:*)\",\n                \"Bash(git diff:*)\",\n                \"Bash(git log:*)\",\n            ],\n            model_from_capability=True,\n            retries=1,\n            verify_prompts=[\"prompts/verify.md\"],\n        ),\n        # ----- verification phase -----\n        # test/lint failures trigger one retry_agent cycle each: the\n        # runner composes the verify prompt with the failed output bound\n        # to {{CHECK_OUTPUT}}, re-invokes the agent once, and re-runs\n        # the failing check.\n        ShellTask(\"test\", cmd=\"just test\", on_failure=\"retry_agent\"),\n        ShellTask(\"format\", cmd=\"just format\", on_failure=\"fail\"),\n        ShellTask(\"lint\", cmd=\"just lint format-check\", on_failure=\"retry_agent\"),\n        ShellTask(\"typecheck\", cmd=\"just typecheck\", on_failure=\"retry_agent\"),\n        # ----- teardown phase -----\n        # set_status BEFORE the final commit so the review-status change\n        # lands in the commit that gets pushed. Doing set_status after\n        # commit leaves the status mutation uncommitted and the pushed\n        # branch (and merged PR) shows status: in-progress instead of\n        # review.\n        BuiltIn(\"set_status\", kwargs={\"to\": \"review\"}),\n        BuiltIn(\n            \"commit\",\n            kwargs={\"message\": \"chore(prd): {prd_id} ready for review\"},\n        ),\n        BuiltIn(\"push_branch\"),\n        BuiltIn(\"summarize_agent_run\"),\n        BuiltIn(\"create_pr\"),\n    ],\n)\n","numLines":108,"startLine":1,"totalLines":108}}}
