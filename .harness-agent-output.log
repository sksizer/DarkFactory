{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F4v6Ac3VeZgLfjCMFEcMDn","type":"tool_result","content":"100\t    )\n101\t\n102\t\n103\tdef _load(prd_dir: Path) -> dict[str, PRD]:\n104\t    if not prd_dir.exists():\n105\t        raise SystemExit(f\"PRD directory not found: {prd_dir}\")\n106\t    return load_all(prd_dir)\n107\t\n108\t\n109\t# ---------- subcommand implementations ----------\n110\t\n111\t\n112\tdef _slugify(title: str) -> str:\n113\t    \"\"\"Convert a title to kebab-case slug.\"\"\"\n114\t    slug = re.sub(r\"[^a-zA-Z0-9\\s-]\", \"\", title.lower())\n115\t    slug = re.sub(r\"\\s+\", \"-\", slug.strip())\n116\t    return slug or \"untitled\"\n117\t\n118\t\n119\tdef _next_flat_prd_id(prds: dict[str, PRD]) -> str:\n120\t    \"\"\"Find the next unused flat PRD id (PRD-NNN) above the existing max.\"\"\"\n121\t    flat_ids = [\n122\t        int(pid.removeprefix(\"PRD-\")) for pid in prds if re.match(r\"^PRD-\\d+$\", pid)\n123\t    ]\n124\t    next_n = (max(flat_ids) + 1) if flat_ids else 1\n125\t    return f\"PRD-{next_n:03d}\"\n126\t\n127\t\n128\tDRAFT_TEMPLATE_BODY = \"\"\"# {title}\n129\t\n130\t## Summary\n131\t\n132\t<!-- 1-3 sentence elevator pitch. What does this deliver and why does it matter? -->\n133\t\n134\t## Motivation\n135\t\n136\t<!-- What problem does this solve? Who benefits? What happens if we don't build it? -->\n137\t\n138\t## Requirements\n139\t\n140\t### Functional\n141\t\n142\t1. ...\n143\t\n144\t### Non-Functional\n145\t\n146\t1. ...\n147\t\n148\t## Technical Approach\n149\t\n150\t<!-- High-level design: affected modules, data flow, key libraries. -->\n151\t\n152\t## Acceptance Criteria\n153\t\n154\t- [ ] AC-1: ...\n155\t\n156\t## Open Questions\n157\t\n158\t<!-- Tag each with OPEN | RESOLVED | DEFERRED -->\n159\t\n160\t## References\n161\t\n162\t\"\"\"\n163\t\n164\t\n165\tdef cmd_new(args: argparse.Namespace) -> int:\n166\t    prds = load_all(args.prd_dir) if args.prd_dir.exists() else {}\n167\t\n168\t    # Pick ID\n169\t    if args.id:\n170\t        if not PRD_ID_RE.match(args.id):\n171\t            raise SystemExit(f\"invalid PRD id: {args.id!r}\")\n172\t        if args.id in prds:\n173\t            raise SystemExit(f\"PRD id {args.id!r} already exists\")\n174\t        new_id = args.id\n175\t    else:\n176\t        new_id = _next_flat_prd_id(prds)\n177\t\n178\t    slug = _slugify(args.title)\n179\t    filename = f\"{new_id}-{slug}.md\"\n180\t    path = args.prd_dir / filename\n181\t    if path.exists():\n182\t        raise SystemExit(f\"file already exists: {path}\")\n183\t\n184\t    today = date.today().isoformat()\n185\t    frontmatter = {\n186\t        \"id\": new_id,\n187\t        \"title\": args.title,\n188\t        \"kind\": args.kind,\n189\t        \"status\": \"draft\",\n190\t        \"priority\": args.priority,\n191\t        \"effort\": args.effort,\n192\t        \"capability\": args.capability,\n193\t        \"parent\": None,\n194\t        \"depends_on\": [],\n195\t        \"blocks\": [],\n196\t        \"impacts\": [],\n197\t        \"workflow\": None,\n198\t        \"assignee\": None,\n199\t        \"reviewers\": [],\n200\t        \"target_version\": None,\n201\t        \"created\": today,\n202\t        \"updated\": today,\n203\t        \"tags\": [],\n204\t    }\n205\t\n206\t    body = DRAFT_TEMPLATE_BODY.format(title=args.title)\n207\t    content = f\"---\\n{dump_frontmatter(frontmatter)}---\\n\\n{body}\"\n208\t\n209\t    args.prd_dir.mkdir(parents=True, exist_ok=True)\n210\t    path.write_text(content, encoding=\"utf-8\")\n211\t    print(f\"Created {path}\")\n212\t\n213\t    if args.open:\n214\t        editor = os.environ.get(\"EDITOR\", \"\")\n215\t        if editor:\n216\t            subprocess.run([editor, str(path)], check=False)\n217\t\n218\t    return 0\n219\t\n220\t\n221\tdef cmd_status(args: argparse.Namespace) -> int:\n222\t    prds = _load(args.prd_dir)\n223\t    counts = Counter(prd.status for prd in prds.values())\n224\t    actionable = sorted(\n225\t        (prd for prd in prds.values() if graph.is_actionable(prd, prds)),\n226\t        key=_action_sort_key,\n227\t    )\n228\t    runnable = [prd for prd in actionable if containment.is_runnable(prd, prds)]\n229\t\n230\t    if args.json:\n231\t        out = {\n232\t            \"total\": len(prds),\n233\t            \"by_status\": dict(counts),\n234\t            \"actionable\": len(actionable),\n235\t            \"runnable\": len(runnable),\n236\t            \"next\": [\n237\t                {\n238\t                    \"id\": p.id,\n239\t                    \"title\": p.title,\n240\t                    \"priority\": p.priority,\n241\t                    \"effort\": p.effort,\n242\t                }\n243\t                for p in runnable[:5]\n244\t            ],\n245\t        }\n246\t        print(json.dumps(out, indent=2))\n247\t        return 0\n248\t\n249\t    print(f\"PRDs — {len(prds)} total\")\n250\t    for status in (\n251\t        \"done\",\n252\t        \"review\",\n253\t        \"in-progress\",\n254\t        \"ready\",\n255\t        \"blocked\",\n256\t        \"draft\",\n257\t        \"cancelled\",\n258\t    ):\n259\t        n = counts.get(status, 0)\n260\t        if n:\n261\t            print(f\"  {status:14} {n}\")\n262\t    print(f\"\\n  actionable: {len(actionable)}   runnable: {len(runnable)}\")\n263\t    if runnable:\n264\t        print(\"\\nNext runnable (top 5):\")\n265\t        for prd in runnable[:5]:\n266\t            print(\n267\t                f\"  {prd.id:14} [{prd.kind}/{prd.effort}/{prd.capability}]  {prd.title}\"\n268\t            )\n269\t    return 0\n270\t\n271\t\n272\tdef cmd_next(args: argparse.Namespace) -> int:\n273\t    prds = _load(args.prd_dir)\n274\t    actionable = sorted(\n275\t        (prd for prd in prds.values() if graph.is_actionable(prd, prds)),\n276\t        key=_action_sort_key,\n277\t    )\n278\t    actionable = [prd for prd in actionable if containment.is_runnable(prd, prds)]\n279\t    if args.capability:\n280\t        wanted = {c.strip() for c in args.capability.split(\",\")}\n281\t        actionable = [prd for prd in actionable if prd.capability in wanted]\n282\t    actionable = actionable[: args.limit]\n283\t\n284\t    if args.json:\n285\t        print(\n286\t            json.dumps(\n287\t                [\n288\t                    {\n289\t                        \"id\": p.id,\n290\t                        \"title\": p.title,\n291\t                        \"priority\": p.priority,\n292\t                        \"effort\": p.effort,\n293\t                        \"capability\": p.capability,\n294\t                        \"kind\": p.kind,\n295\t                    }\n296\t                    for p in actionable\n297\t                ],\n298\t                indent=2,\n299\t            )\n300\t        )\n301\t        return 0\n302\t\n303\t    if not actionable:\n304\t        print(\"(no actionable PRDs match)\")\n305\t        return 0\n306\t    for prd in actionable:\n307\t        print(\n308\t            f\"{prd.id:14} [{prd.priority}/{prd.effort}/{prd.capability}]  {prd.title}\"\n309\t        )\n310\t    return 0\n311\t\n312\t\n313\tdef cmd_validate(args: argparse.Namespace) -> int:\n314\t    prds = _load(args.prd_dir)\n315\t    errors: list[str] = []\n316\t    warnings: list[str] = []\n317\t\n318\t    # 1. Filename ↔ id consistency\n319\t    for prd in prds.values():\n320\t        if not prd.path.name.startswith(f\"{prd.id}-\"):\n321\t            errors.append(f\"{prd.path.name}: id {prd.id!r} does not match filename\")\n322\t\n323\t    # 2. Missing dep references\n324\t    for prd in prds.values():\n325\t        for dep_id in prd.depends_on:\n326\t            if dep_id not in prds:\n327\t                errors.append(f\"{prd.id}: depends_on references unknown {dep_id}\")\n328\t        for blk_id in prd.blocks:\n329\t            if blk_id not in prds:\n330\t                errors.append(f\"{prd.id}: blocks references unknown {blk_id}\")\n331\t        if prd.parent and prd.parent not in prds:\n332\t            errors.append(f\"{prd.id}: parent references unknown {prd.parent}\")\n333\t\n334\t    # 3. Cycles in dependency DAG\n335\t    g = graph.build_graph(prds)\n336\t    cycles = graph.detect_cycles(g)\n337\t    for cycle in cycles:\n338\t        errors.append(f\"dependency cycle: {' -> '.join(cycle)} -> {cycle[0]}\")\n339\t\n340\t    # 4. Containment tree cycles\n341\t    for prd in prds.values():\n342\t        seen = {prd.id}\n343\t        cur = prd\n344\t        while cur.parent:\n345\t            if cur.parent in seen:\n346\t                errors.append(f\"{prd.id}: containment cycle via parent chain\")\n347\t                break\n348\t            seen.add(cur.parent)\n349\t            nxt = prds.get(cur.parent)\n350\t            if nxt is None:\n351\t                break\n352\t            cur = nxt\n353\t\n354\t    # 5. Container PRDs must have empty impacts.\n355\t    # The leaf-only rule (see impacts.py) gives us a single source of\n356\t    # truth: containers' effective impacts are computed from their\n357\t    # descendants, so declared impacts on a container would be a\n358\t    # divergent second source that could silently drift.\n359\t    for prd in prds.values():\n360\t        kids = containment.children(prd.id, prds)\n361\t        if kids and prd.impacts:\n362\t            errors.append(\n363\t                f\"{prd.id}: container PRD (has {len(kids)} children) \"\n364\t                f\"must have impacts: [] — declared impacts on containers \"\n365\t                f\"create divergence with the computed descendant union \"\n366\t                f\"(got {prd.impacts!r})\"\n367\t            )\n368\t\n369\t    # 6. Impact overlap warnings (ready PRDs only).\n370\t    # Uses effective_impacts (aggregated for containers) and exempts\n371\t    # parent/child pairs (containment is not conflict).\n372\t    try:\n373\t        repo_root = _find_repo_root(args.prd_dir)\n374\t        files = impacts.tracked_files(repo_root)\n375\t    except Exception:  # noqa: BLE001 — best-effort outside a git repo\n376\t        files = []\n377\t\n378\t    if files:\n379\t        ready = [p for p in prds.values() if p.status == \"ready\"]\n380\t        for i, a in enumerate(ready):\n381\t            for b in ready[i + 1 :]:\n382\t                # Skip if there's an explicit dep relation in either direction.\n383\t                if b.id in a.depends_on or a.id in b.depends_on:\n384\t                    continue\n385\t                try:\n386\t                    overlap = impacts.impacts_overlap(a, b, files, prds)\n387\t                except ValueError:\n388\t                    # effective_impacts refused — already reported by the\n389\t                    # container-has-impacts check above. Skip silently\n390\t                    # here so we don't double-report.\n391\t                    continue\n392\t                if overlap:\n393\t                    warnings.append(\n394\t                        f\"{a.id} and {b.id} have overlapping impacts \"\n395\t                        f\"({len(overlap)} files) but no explicit dependency\"\n396\t                    )\n397\t\n398\t    # 7. Undeclared impacts on leaves (informational)\n399\t    undeclared = [\n[result-id: r9]"}]},"parent_tool_use_id":"toolu_017x74usEsvHbE9fPYD9WHc8","session_id":"139194c3-2b15-46fb-ae47-01a4e87ddf0a","uuid":"45146e17-1066-4b74-9612-2dd0378dcaed","timestamp":"2026-04-08T14:41:35.137Z"}
