{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xkcfo2aN9bAeqE4Rn3fDAC","type":"tool_result","content":"400\t        return 0\n401\t\n402\t    if not effective:\n403\t        kids = containment.children(prd.id, prds)\n404\t        if kids:\n405\t            print(\n406\t                f\"{prd.id} is a container with {len(kids)} children that \"\n407\t                \"have no declared impacts yet\"\n408\t            )\n409\t        else:\n410\t            print(f\"{prd.id} has no declared impacts; cannot compute overlaps\")\n411\t        return 0\n412\t    if not conflicts:\n413\t        print(f\"{prd.id} has no impact conflicts with other PRDs\")\n414\t        print(f\"  (effective impact set: {len(effective)} pattern(s))\")\n415\t        return 0\n416\t\n417\t    print(f\"{prd.id} conflicts:\")\n418\t    for other_id, files in conflicts:\n419\t        print(f\"  {other_id}:\")\n420\t        for f in sorted(files):\n421\t            print(f\"    {f}\")\n422\t    return 0\n423\t\n424\t\n425\tdef cmd_list_workflows(args: argparse.Namespace) -> int:\n426\t    \"\"\"List all loaded workflows with priority and description.\"\"\"\n427\t    workflows = _load_workflows_or_fail(args.workflows_dir)\n428\t    if not workflows:\n429\t        print(\"(no workflows loaded)\")\n430\t        return 0\n431\t\n432\t    # Sort by descending priority then alphabetically for stable display.\n433\t    sorted_wfs = sorted(\n434\t        workflows.values(),\n435\t        key=lambda w: (-w.priority, w.name),\n436\t    )\n437\t\n438\t    if args.json:\n439\t        payload = [\n440\t            {\n441\t                \"name\": w.name,\n442\t                \"priority\": w.priority,\n443\t                \"description\": w.description,\n444\t                \"task_count\": len(w.tasks),\n445\t                \"workflow_dir\": str(w.workflow_dir) if w.workflow_dir else None,\n446\t            }\n447\t            for w in sorted_wfs\n448\t        ]\n449\t        print(json.dumps(payload, indent=2))\n450\t        return 0\n451\t\n452\t    for w in sorted_wfs:\n453\t        # Header line: name, priority, task count\n454\t        print(f\"{w.name:20} priority={w.priority:<3} tasks={len(w.tasks)}\")\n455\t        if w.description:\n456\t            # Indent description under the header\n457\t            for line in w.description.splitlines():\n458\t                print(f\"  {line}\")\n459\t        print()\n460\t    return 0\n461\t\n462\t\n463\tdef cmd_assign(args: argparse.Namespace) -> int:\n464\t    \"\"\"Compute the workflow assignment for every PRD, optionally persist.\n465\t\n466\t    Output is a table of ``PRD-id -> workflow-name``. With ``--write``,\n467\t    the resolved workflow name is persisted into each PRD's frontmatter\n468\t    (only for PRDs that don't already have an explicit workflow field —\n469\t    the command is idempotent on re-run).\n470\t    \"\"\"\n471\t    prds = _load(args.prd_dir)\n472\t    workflows = _load_workflows_or_fail(args.workflows_dir)\n473\t\n474\t    try:\n475\t        assignments = assign.assign_all(prds, workflows)\n476\t    except KeyError as exc:\n477\t        raise SystemExit(str(exc))\n478\t\n479\t    if args.json:\n480\t        payload = [\n481\t            {\n482\t                \"id\": prd_id,\n483\t                \"workflow\": wf.name,\n484\t                \"explicit\": prds[prd_id].workflow is not None,\n485\t            }\n486\t            for prd_id, wf in sorted(\n487\t                assignments.items(),\n488\t                key=lambda kv: parse_id_sort_key(kv[0]),\n489\t            )\n490\t        ]\n491\t        print(json.dumps(payload, indent=2))\n492\t        return 0\n493\t\n494\t    # Human-readable table. Mark explicit assignments with a `*`.\n495\t    print(f\"{'PRD':14} {'Workflow':20} Source\")\n496\t    print(\"-\" * 50)\n497\t    for prd_id in sorted(assignments.keys(), key=parse_id_sort_key):\n498\t        wf = assignments[prd_id]\n499\t        source = \"explicit\" if prds[prd_id].workflow else \"predicate\"\n500\t        print(f\"{prd_id:14} {wf.name:20} {source}\")\n501\t\n502\t    if args.write:\n503\t        written = 0\n504\t        for prd_id, wf in assignments.items():\n505\t            prd = prds[prd_id]\n506\t            if prd.workflow is None:\n507\t                set_workflow(prd, wf.name)\n508\t                written += 1\n509\t        print(f\"\\nPersisted {written} workflow assignments to frontmatter.\")\n510\t    return 0\n511\t\n512\t\n513\t#: List fields that ``prd normalize`` canonicalizes.\n514\t_NORMALIZABLE_FIELDS: tuple[str, ...] = (\"tags\", \"impacts\", \"depends_on\", \"blocks\")\n515\t\n516\t\n517\tdef _normalize_prd(prd: PRD, check_only: bool) -> bool:\n518\t    \"\"\"Normalize all list fields of a single PRD. Returns True if changed.\"\"\"\n519\t    changed = False\n520\t    for field in _NORMALIZABLE_FIELDS:\n521\t        raw = prd.raw_frontmatter.get(field)\n522\t        if raw is None:\n523\t            continue\n524\t        if not isinstance(raw, list):\n525\t            continue\n526\t        items = [str(v) for v in raw]\n527\t        try:\n528\t            if normalize_list_field_at(prd.path, field, items, write=not check_only):\n529\t                changed = True\n530\t        except ValueError as exc:\n531\t            print(f\"WARNING: {exc}\", file=sys.stderr)\n532\t    return changed\n533\t\n534\t\n535\tdef cmd_normalize(args: argparse.Namespace) -> int:\n536\t    \"\"\"Canonicalize list fields in one or all PRD files.\n537\t\n538\t    Sorts ``tags``, ``impacts``, ``depends_on``, and ``blocks`` into their\n539\t    canonical order (alphabetical for tags/impacts, natural PRD-ID order for\n540\t    the dependency fields) and rewrites only the affected lines on disk.\n541\t\n542\t    With ``--check``, prints how many files would change and exits non-zero\n543\t    without writing anything — suitable for CI.\n544\t    \"\"\"\n545\t    prds = _load(args.prd_dir)\n546\t\n547\t    if args.all:\n548\t        targets = sorted(prds.values(), key=lambda p: parse_id_sort_key(p.id))\n549\t    elif args.prd_id:\n550\t        if args.prd_id not in prds:\n551\t            raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n552\t        targets = [prds[args.prd_id]]\n553\t    else:\n554\t        raise SystemExit(\"specify a PRD id or --all\")\n555\t\n556\t    changed_count = 0\n557\t    for prd in targets:\n558\t        if _normalize_prd(prd, check_only=args.check):\n559\t            changed_count += 1\n560\t            if not args.check:\n561\t                print(f\"normalized: {prd.id}\")\n562\t\n563\t    if args.check:\n564\t        if changed_count:\n565\t            print(\n566\t                f\"{changed_count} file(s) would be changed\",\n567\t                file=sys.stderr,\n568\t            )\n569\t            return 1\n570\t        print(f\"OK: all {len(targets)} file(s) already canonical\")\n571\t        return 0\n572\t\n573\t    if changed_count:\n574\t        print(f\"Normalized {changed_count} of {len(targets)} file(s).\")\n575\t    else:\n576\t        print(f\"No changes — {len(targets)} file(s) already canonical.\")\n577\t    return 0\n578\t\n579\t\n580\tdef _describe_task(task: Task, ctx_prd: PRD, model_override: str | None) -> str:\n581\t    \"\"\"Produce a one-line human-readable description of a task for `prd plan`.\"\"\"\n582\t    if isinstance(task, BuiltIn):\n583\t        kwargs_str = (\n584\t            \" \" + \", \".join(f\"{k}={v!r}\" for k, v in task.kwargs.items())\n585\t            if task.kwargs\n586\t            else \"\"\n587\t        )\n588\t        return f\"builtin: {task.name}{kwargs_str}\"\n589\t    if isinstance(task, AgentTask):\n590\t        model = _pick_model(task, ctx_prd, override=model_override)\n591\t        prompts = \", \".join(task.prompts) or \"(none)\"\n592\t        tools_count = len(task.tools)\n593\t        return (\n594\t            f\"agent: {task.name} [model={model}, prompts={prompts}, \"\n595\t            f\"tools={tools_count}, retries={task.retries}]\"\n596\t        )\n597\t    if isinstance(task, ShellTask):\n598\t        return f\"shell: {task.name} ({task.on_failure}) -> {task.cmd}\"\n599\t    return f\"unknown task type: {type(task).__name__}\""}]},"parent_tool_use_id":null,"session_id":"5fe3385a-af4a-4c43-9135-e737209c79ba","uuid":"bf22e3e4-8e4d-448b-9c94-6800f31e7104","timestamp":"2026-04-08T12:45:54.998Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-510-prd-new-subcommand/src/darkfactory/cli.py","content":"        return 0\n\n    if not effective:\n        kids = containment.children(prd.id, prds)\n        if kids:\n            print(\n                f\"{prd.id} is a container with {len(kids)} children that \"\n                \"have no declared impacts yet\"\n            )\n        else:\n            print(f\"{prd.id} has no declared impacts; cannot compute overlaps\")\n        return 0\n    if not conflicts:\n        print(f\"{prd.id} has no impact conflicts with other PRDs\")\n        print(f\"  (effective impact set: {len(effective)} pattern(s))\")\n        return 0\n\n    print(f\"{prd.id} conflicts:\")\n    for other_id, files in conflicts:\n        print(f\"  {other_id}:\")\n        for f in sorted(files):\n            print(f\"    {f}\")\n    return 0\n\n\ndef cmd_list_workflows(args: argparse.Namespace) -> int:\n    \"\"\"List all loaded workflows with priority and description.\"\"\"\n    workflows = _load_workflows_or_fail(args.workflows_dir)\n    if not workflows:\n        print(\"(no workflows loaded)\")\n        return 0\n\n    # Sort by descending priority then alphabetically for stable display.\n    sorted_wfs = sorted(\n        workflows.values(),\n        key=lambda w: (-w.priority, w.name),\n    )\n\n    if args.json:\n        payload = [\n            {\n                \"name\": w.name,\n                \"priority\": w.priority,\n                \"description\": w.description,\n                \"task_count\": len(w.tasks),\n                \"workflow_dir\": str(w.workflow_dir) if w.workflow_dir else None,\n            }\n            for w in sorted_wfs\n        ]\n        print(json.dumps(payload, indent=2))\n        return 0\n\n    for w in sorted_wfs:\n        # Header line: name, priority, task count\n        print(f\"{w.name:20} priority={w.priority:<3} tasks={len(w.tasks)}\")\n        if w.description:\n            # Indent description under the header\n            for line in w.description.splitlines():\n                print(f\"  {line}\")\n        print()\n    return 0\n\n\ndef cmd_assign(args: argparse.Namespace) -> int:\n    \"\"\"Compute the workflow assignment for every PRD, optionally persist.\n\n    Output is a table of ``PRD-id -> workflow-name``. With ``--write``,\n    the resolved workflow name is persisted into each PRD's frontmatter\n    (only for PRDs that don't already have an explicit workflow field —\n    the command is idempotent on re-run).\n    \"\"\"\n    prds = _load(args.prd_dir)\n    workflows = _load_workflows_or_fail(args.workflows_dir)\n\n    try:\n        assignments = assign.assign_all(prds, workflows)\n    except KeyError as exc:\n        raise SystemExit(str(exc))\n\n    if args.json:\n        payload = [\n            {\n                \"id\": prd_id,\n                \"workflow\": wf.name,\n                \"explicit\": prds[prd_id].workflow is not None,\n            }\n            for prd_id, wf in sorted(\n                assignments.items(),\n                key=lambda kv: parse_id_sort_key(kv[0]),\n            )\n        ]\n        print(json.dumps(payload, indent=2))\n        return 0\n\n    # Human-readable table. Mark explicit assignments with a `*`.\n    print(f\"{'PRD':14} {'Workflow':20} Source\")\n    print(\"-\" * 50)\n    for prd_id in sorted(assignments.keys(), key=parse_id_sort_key):\n        wf = assignments[prd_id]\n        source = \"explicit\" if prds[prd_id].workflow else \"predicate\"\n        print(f\"{prd_id:14} {wf.name:20} {source}\")\n\n    if args.write:\n        written = 0\n        for prd_id, wf in assignments.items():\n            prd = prds[prd_id]\n            if prd.workflow is None:\n                set_workflow(prd, wf.name)\n                written += 1\n        print(f\"\\nPersisted {written} workflow assignments to frontmatter.\")\n    return 0\n\n\n#: List fields that ``prd normalize`` canonicalizes.\n_NORMALIZABLE_FIELDS: tuple[str, ...] = (\"tags\", \"impacts\", \"depends_on\", \"blocks\")\n\n\ndef _normalize_prd(prd: PRD, check_only: bool) -> bool:\n    \"\"\"Normalize all list fields of a single PRD. Returns True if changed.\"\"\"\n    changed = False\n    for field in _NORMALIZABLE_FIELDS:\n        raw = prd.raw_frontmatter.get(field)\n        if raw is None:\n            continue\n        if not isinstance(raw, list):\n            continue\n        items = [str(v) for v in raw]\n        try:\n            if normalize_list_field_at(prd.path, field, items, write=not check_only):\n                changed = True\n        except ValueError as exc:\n            print(f\"WARNING: {exc}\", file=sys.stderr)\n    return changed\n\n\ndef cmd_normalize(args: argparse.Namespace) -> int:\n    \"\"\"Canonicalize list fields in one or all PRD files.\n\n    Sorts ``tags``, ``impacts``, ``depends_on``, and ``blocks`` into their\n    canonical order (alphabetical for tags/impacts, natural PRD-ID order for\n    the dependency fields) and rewrites only the affected lines on disk.\n\n    With ``--check``, prints how many files would change and exits non-zero\n    without writing anything — suitable for CI.\n    \"\"\"\n    prds = _load(args.prd_dir)\n\n    if args.all:\n        targets = sorted(prds.values(), key=lambda p: parse_id_sort_key(p.id))\n    elif args.prd_id:\n        if args.prd_id not in prds:\n            raise SystemExit(f\"unknown PRD id: {args.prd_id}\")\n        targets = [prds[args.prd_id]]\n    else:\n        raise SystemExit(\"specify a PRD id or --all\")\n\n    changed_count = 0\n    for prd in targets:\n        if _normalize_prd(prd, check_only=args.check):\n            changed_count += 1\n            if not args.check:\n                print(f\"normalized: {prd.id}\")\n\n    if args.check:\n        if changed_count:\n            print(\n                f\"{changed_count} file(s) would be changed\",\n                file=sys.stderr,\n            )\n            return 1\n        print(f\"OK: all {len(targets)} file(s) already canonical\")\n        return 0\n\n    if changed_count:\n        print(f\"Normalized {changed_count} of {len(targets)} file(s).\")\n    else:\n        print(f\"No changes — {len(targets)} file(s) already canonical.\")\n    return 0\n\n\ndef _describe_task(task: Task, ctx_prd: PRD, model_override: str | None) -> str:\n    \"\"\"Produce a one-line human-readable description of a task for `prd plan`.\"\"\"\n    if isinstance(task, BuiltIn):\n        kwargs_str = (\n            \" \" + \", \".join(f\"{k}={v!r}\" for k, v in task.kwargs.items())\n            if task.kwargs\n            else \"\"\n        )\n        return f\"builtin: {task.name}{kwargs_str}\"\n    if isinstance(task, AgentTask):\n        model = _pick_model(task, ctx_prd, override=model_override)\n        prompts = \", \".join(task.prompts) or \"(none)\"\n        tools_count = len(task.tools)\n        return (\n            f\"agent: {task.name} [model={model}, prompts={prompts}, \"\n            f\"tools={tools_count}, retries={task.retries}]\"\n        )\n    if isinstance(task, ShellTask):\n        return f\"shell: {task.name} ({task.on_failure}) -> {task.cmd}\"\n    return f\"unknown task type: {type(task).__name__}\"","numLines":200,"startLine":400,"totalLines":989}}}
