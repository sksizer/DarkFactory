{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C1gkfA9sJEAUdMAB55AByb","type":"tool_result","content":"1\t\"\"\"Tests for the real builtin implementations.\n2\t\n3\tSplit into three categories:\n4\t\n5\t1. **Registry tests**: the @builtin decorator and BUILTINS dict still\n6\t   work as they did in the stub phase.\n7\t2. **Pure helper tests**: `_worktree_target`, `_extract_acceptance_criteria`,\n8\t   `_pr_body` are unit-testable without any I/O.\n9\t3. **Subprocess-touching tests**: use ``tmp_path`` + ``git init`` for a\n10\t   real tmp repo (for worktree + commit flows) or ``unittest.mock.patch``\n11\t   for ``push_branch`` and ``create_pr`` (since those hit origin/gh).\n12\t\n13\tDry-run mode is tested throughout to confirm builtins log but don't\n14\texecute.\n15\t\"\"\"\n16\t\n17\tfrom __future__ import annotations\n18\t\n19\timport logging\n20\timport subprocess\n21\tfrom pathlib import Path\n22\tfrom unittest.mock import patch\n23\t\n24\timport pytest\n25\t\n26\tfrom darkfactory import builtins\n27\tfrom darkfactory.builtins import (\n28\t    BUILTINS,\n29\t    _branch_exists_local,\n30\t    _branch_exists_remote,\n31\t    _extract_acceptance_criteria,\n32\t    _pr_body,\n33\t    _worktree_target,\n34\t    builtin,\n35\t)\n36\tfrom darkfactory.prd import load_all\n37\tfrom darkfactory.workflow import ExecutionContext, Workflow\n38\t\n39\tfrom .conftest import write_prd\n40\t\n41\t\n42\t# ---------- registry ----------\n43\t\n44\t\n45\tdef test_registry_populated_at_import() -> None:\n46\t    expected = {\n47\t        \"ensure_worktree\",\n48\t        \"set_status\",\n49\t        \"commit\",\n50\t        \"push_branch\",\n51\t        \"create_pr\",\n52\t        \"cleanup_worktree\",\n53\t    }\n54\t    assert expected <= set(BUILTINS.keys())\n55\t\n56\t\n57\tdef test_each_builtin_is_callable() -> None:\n58\t    for name, func in BUILTINS.items():\n59\t        assert callable(func), f\"{name!r} is not callable\"\n60\t\n61\t\n62\tdef test_builtin_decorator_registers_function() -> None:\n63\t    @builtin(\"_test_dynamic_one\")\n64\t    def _noop(ctx):  # type: ignore[no-untyped-def]\n65\t        return None\n66\t\n67\t    assert \"_test_dynamic_one\" in BUILTINS\n68\t    assert BUILTINS[\"_test_dynamic_one\"] is _noop\n69\t    del BUILTINS[\"_test_dynamic_one\"]\n70\t\n71\t\n72\tdef test_builtin_decorator_rejects_duplicates() -> None:\n73\t    @builtin(\"_test_dynamic_two\")\n74\t    def _first(ctx):  # type: ignore[no-untyped-def]\n75\t        return None\n76\t\n77\t    try:\n78\t        with pytest.raises(ValueError, match=\"duplicate builtin\"):\n79\t\n80\t            @builtin(\"_test_dynamic_two\")\n81\t            def _second(ctx):  # type: ignore[no-untyped-def]\n82\t                return None\n83\t\n84\t    finally:\n85\t        del BUILTINS[\"_test_dynamic_two\"]\n86\t\n87\t\n88\t# ---------- pure helpers ----------\n89\t\n90\t\n91\tdef test_worktree_target(tmp_path: Path) -> None:\n92\t    prd_dir = tmp_path / \"prds\"\n93\t    prd_dir.mkdir()\n94\t    write_prd(prd_dir, \"PRD-070\", \"my-task\")\n95\t    prds = load_all(prd_dir)\n96\t\n97\t    ctx = ExecutionContext(\n98\t        prd=prds[\"PRD-070\"],\n99\t        repo_root=tmp_path,\n100\t        workflow=Workflow(name=\"default\"),"}]},"parent_tool_use_id":null,"session_id":"52744e12-d8b3-437c-a43e-6547c29dff12","uuid":"478c8f18-0a10-40fe-85d2-e8eb91a66df5","timestamp":"2026-04-08T16:16:13.440Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-224.3-summarize-agent-run/tests/test_builtins.py","content":"\"\"\"Tests for the real builtin implementations.\n\nSplit into three categories:\n\n1. **Registry tests**: the @builtin decorator and BUILTINS dict still\n   work as they did in the stub phase.\n2. **Pure helper tests**: `_worktree_target`, `_extract_acceptance_criteria`,\n   `_pr_body` are unit-testable without any I/O.\n3. **Subprocess-touching tests**: use ``tmp_path`` + ``git init`` for a\n   real tmp repo (for worktree + commit flows) or ``unittest.mock.patch``\n   for ``push_branch`` and ``create_pr`` (since those hit origin/gh).\n\nDry-run mode is tested throughout to confirm builtins log but don't\nexecute.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport subprocess\nfrom pathlib import Path\nfrom unittest.mock import patch\n\nimport pytest\n\nfrom darkfactory import builtins\nfrom darkfactory.builtins import (\n    BUILTINS,\n    _branch_exists_local,\n    _branch_exists_remote,\n    _extract_acceptance_criteria,\n    _pr_body,\n    _worktree_target,\n    builtin,\n)\nfrom darkfactory.prd import load_all\nfrom darkfactory.workflow import ExecutionContext, Workflow\n\nfrom .conftest import write_prd\n\n\n# ---------- registry ----------\n\n\ndef test_registry_populated_at_import() -> None:\n    expected = {\n        \"ensure_worktree\",\n        \"set_status\",\n        \"commit\",\n        \"push_branch\",\n        \"create_pr\",\n        \"cleanup_worktree\",\n    }\n    assert expected <= set(BUILTINS.keys())\n\n\ndef test_each_builtin_is_callable() -> None:\n    for name, func in BUILTINS.items():\n        assert callable(func), f\"{name!r} is not callable\"\n\n\ndef test_builtin_decorator_registers_function() -> None:\n    @builtin(\"_test_dynamic_one\")\n    def _noop(ctx):  # type: ignore[no-untyped-def]\n        return None\n\n    assert \"_test_dynamic_one\" in BUILTINS\n    assert BUILTINS[\"_test_dynamic_one\"] is _noop\n    del BUILTINS[\"_test_dynamic_one\"]\n\n\ndef test_builtin_decorator_rejects_duplicates() -> None:\n    @builtin(\"_test_dynamic_two\")\n    def _first(ctx):  # type: ignore[no-untyped-def]\n        return None\n\n    try:\n        with pytest.raises(ValueError, match=\"duplicate builtin\"):\n\n            @builtin(\"_test_dynamic_two\")\n            def _second(ctx):  # type: ignore[no-untyped-def]\n                return None\n\n    finally:\n        del BUILTINS[\"_test_dynamic_two\"]\n\n\n# ---------- pure helpers ----------\n\n\ndef test_worktree_target(tmp_path: Path) -> None:\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-070\", \"my-task\")\n    prds = load_all(prd_dir)\n\n    ctx = ExecutionContext(\n        prd=prds[\"PRD-070\"],\n        repo_root=tmp_path,\n        workflow=Workflow(name=\"default\"),","numLines":100,"startLine":1,"totalLines":974}}}
