d}-{slug}.md\"\n    path.write_text(\n        \"---\\n\"\n        f'id: \"{prd_id}\"\\n'\n        f'title: \"Test {prd_id}\"\\n'\n        \"kind: task\\n\"\n        \"status: ready\\n\"\n        \"priority: medium\\n\"","numLines":60,"startLine":0,"totalLines":157}}}
