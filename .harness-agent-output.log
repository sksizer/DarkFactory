{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Umb66kEoEWZ5drk89t83oH","type":"tool_result","content":"1\t\"\"\"Built-in task primitives — real implementations.\n2\t\n3\tBuilt-ins are the deterministic SDLC operations that every workflow\n4\treferences by name: create a worktree, set a PRD's status, make a\n5\tcommit, push a branch, open a PR. They live here (not in individual\n6\tworkflow modules) because they're shared — every workflow uses the\n7\tsame ``commit`` primitive, not a bespoke one.\n8\t\n9\tWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n10\t\n11\t    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n12\t\n13\tThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\n14\tregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\n15\tplus any formatted kwargs.\n16\t\n17\t**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\n18\tanything destructive. In dry-run, we log what we WOULD do at INFO\n19\tlevel and return. This is what powers ``prd plan`` and the default\n20\t``prd run`` (without ``--execute``).\n21\t\n22\t**Subprocess discipline**: all shell commands use ``subprocess.run``\n23\twith an explicit argv list (never ``shell=True``), capture output,\n24\tand check the return code. Git and gh invocations go through\n25\t:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\n26\thandling and dry-run support.\n27\t\"\"\"\n28\t\n29\tfrom __future__ import annotations\n30\t\n31\timport logging\n32\timport re\n33\timport shutil\n34\timport subprocess\n35\tfrom datetime import datetime\n36\tfrom pathlib import Path\n37\tfrom typing import Callable\n38\t\n39\tfrom filelock import FileLock, Timeout\n40\t\n41\tfrom . import prd as prd_module\n42\tfrom .workflow import ExecutionContext, Status\n43\t\n44\t_log = logging.getLogger(__name__)\n45\t\n46\tBuiltInFunc = Callable[..., None]\n47\t\"\"\"Signature every built-in shares: takes ``ExecutionContext`` plus **kwargs, returns None.\n48\t\n49\tReturn value is always ``None`` — built-ins communicate results by\n50\tmutating the context (setting ``ctx.worktree_path``, ``ctx.pr_url``, etc.)\n51\tand signal failure by raising an exception. This keeps the dispatch\n52\tuniform in the runner.\n53\t\"\"\"\n54\t\n55\t\n56\tBUILTINS: dict[str, BuiltInFunc] = {}\n57\t\"\"\"Global registry mapping built-in name to its implementing function.\n58\t\n59\tPopulated at import time via the :func:`builtin` decorator. The runner\n60\tlooks up names in this dict when dispatching a\n61\t:class:`~darkfactory.workflow.BuiltIn` task. Workflows never touch this\n62\tdict directly — they reference built-ins by name only.\n63\t\"\"\"\n64\t\n65\t\n66\tdef builtin(name: str) -> Callable[[BuiltInFunc], BuiltInFunc]:\n67\t    \"\"\"Decorator that registers a function in :data:`BUILTINS`.\n68\t\n69\t    Rejects duplicate registrations with ``ValueError`` to catch typos\n70\t    and accidental overrides during development.\n71\t    \"\"\"\n72\t\n73\t    def decorator(func: BuiltInFunc) -> BuiltInFunc:\n74\t        if name in BUILTINS:\n75\t            raise ValueError(f\"duplicate builtin registration for {name!r}\")\n76\t        BUILTINS[name] = func\n77\t        return func\n78\t\n79\t    return decorator\n80\t\n81\t\n82\t# ---------- internal helpers ----------\n83\t\n84\t\n85\tdef _run(\n86\t    ctx: ExecutionContext,\n87\t    cmd: list[str],\n88\t    *,\n89\t    check: bool = True,\n90\t    capture: bool = False,\n91\t) -> subprocess.CompletedProcess[str]:\n92\t    \"\"\"Run a subprocess command inside ``ctx.cwd`` with dry-run support.\n93\t\n94\t    In dry-run mode, logs the command at INFO level and returns a fake\n95\t    ``CompletedProcess`` with exit code 0. In live mode, runs the\n96\t    command for real and raises ``subprocess.CalledProcessError`` on\n97\t    non-zero exit when ``check=True``.\n98\t\n99\t    Using an explicit argv list (not a shell string) prevents shell\n100\t    injection entirely — callers don't get to interpolate variables\n101\t    into a command line, they build the argv themselves.\n102\t    \"\"\"\n103\t    if ctx.dry_run:\n104\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n105\t        return subprocess.CompletedProcess(args=cmd, returncode=0, stdout=\"\", stderr=\"\")\n106\t\n107\t    return subprocess.run(\n108\t        cmd,\n109\t        cwd=str(ctx.cwd),\n110\t        check=check,\n111\t        capture_output=capture,\n112\t        text=True,\n113\t    )\n114\t\n115\t\n116\tdef _worktree_target(ctx: ExecutionContext) -> Path:\n117\t    \"\"\"Compute the worktree path for this PRD under ``.worktrees/``.\n118\t\n119\t    Separated out so tests can assert the path without a whole\n120\t    subprocess invocation.\n121\t    \"\"\"\n122\t    return ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}-{ctx.prd.slug}\"\n123\t\n124\t\n125\tdef _branch_exists_local(repo_root: Path, branch: str) -> bool:\n126\t    \"\"\"Return True if ``branch`` exists in the local repo's refs.\"\"\"\n127\t    result = subprocess.run(\n128\t        [\n129\t            \"git\",\n130\t            \"-C\",\n131\t            str(repo_root),\n132\t            \"rev-parse\",\n133\t            \"--verify\",\n134\t            \"--quiet\",\n135\t            f\"refs/heads/{branch}\",\n136\t        ],\n137\t        capture_output=True,\n138\t        text=True,\n139\t    )\n140\t    return result.returncode == 0\n141\t\n142\t\n143\tdef _branch_exists_remote(repo_root: Path, branch: str) -> bool:\n144\t    \"\"\"Return True if ``branch`` exists on origin.\n145\t\n146\t    Best-effort: returns False (and logs a warning) on timeout or any\n147\t    subprocess error so the caller can fall back to the local check.\n148\t    \"\"\"\n149\t    try:\n150\t        result = subprocess.run(\n151\t            [\n152\t                \"git\",\n153\t                \"-C\",\n154\t                str(repo_root),\n155\t                \"ls-remote\",\n156\t                \"--exit-code\",\n157\t                \"origin\",\n158\t                f\"refs/heads/{branch}\",\n159\t            ],\n160\t            capture_output=True,\n161\t            text=True,\n162\t            timeout=10,\n163\t        )\n164\t    except subprocess.TimeoutExpired:\n165\t        _log.warning(\n166\t            \"git ls-remote timed out checking remote branch %r — skipping remote check\",\n167\t            branch,\n168\t        )\n169\t        return False\n170\t    except Exception as exc:\n171\t        _log.warning(\n172\t            \"git ls-remote failed checking remote branch %r (%s) — skipping remote check\",\n173\t            branch,\n174\t            exc,\n175\t        )\n176\t        return False\n177\t    return result.returncode == 0\n178\t\n179\t\n180\t_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n181\t\n182\t\n183\tdef _extract_acceptance_criteria(body: str) -> list[str]:\n184\t    \"\"\"Pull acceptance criteria lines out of a PRD body.\n185\t\n186\t    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n187\t    Returns a list of the criterion strings (without the checkbox\n188\t    prefix). Used by ``create_pr`` to build the PR body's checklist.\n189\t    \"\"\"\n190\t    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n191\t\n192\t\n193\tdef _pr_body(ctx: ExecutionContext) -> str:\n194\t    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n195\t    prd = ctx.prd\n196\t    lines: list[str] = [\n197\t        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n198\t        \"\",\n199\t    ]\n200\t\n201\t    acs = _extract_acceptance_criteria(prd.body)\n202\t    if acs:\n203\t        lines.append(\"## Acceptance criteria\")\n204\t        lines.append(\"\")\n205\t        for ac in acs:\n206\t            lines.append(f\"- [ ] {ac}\")\n207\t        lines.append(\"\")\n208\t\n209\t    lines.append(\"---\")\n210\t    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n211\t    return \"\\n\".join(lines)\n212\t\n213\t\n214\t# ---------- built-in implementations ----------\n215\t\n216\t\n217\t@builtin(\"ensure_worktree\")\n218\tdef ensure_worktree(ctx: ExecutionContext) -> None:\n219\t    \"\"\"Create (or resume) a git worktree for this PRD.\n220\t\n221\t    Target path: ``{repo_root}/.worktrees/{prd_id}-{slug}``. Branch:\n222\t    ``prd/{prd_id}-{slug}`` created from ``ctx.base_ref``. If the\n223\t    worktree already exists (previous run resumed), reuses it without\n224\t    re-creating. Sets ``ctx.worktree_path`` and ``ctx.cwd`` on success.\n225\t\n226\t    In live mode, acquires a per-PRD advisory file lock at\n227\t    ``.worktrees/{prd_id}.lock`` before any mutation so two concurrent\n228\t    ``prd run`` invocations for the same PRD fail fast with a clear\n229\t    message instead of racing. The lock is auto-released by the kernel\n230\t    when the process exits; the runner also releases it explicitly at the\n231\t    end of the run (see ``_release_worktree_lock``).\n232\t    \"\"\"\n233\t    worktree_path = _worktree_target(ctx)\n234\t    branch = ctx.branch_name\n235\t\n236\t    if ctx.dry_run:\n237\t        # Dry-run produces no side effects, so no lock needed.\n238\t        ctx.logger.info(\n239\t            \"[dry-run] git worktree add -b %s %s %s\",\n240\t            branch,\n241\t            worktree_path,\n242\t            ctx.base_ref,\n243\t        )\n244\t        ctx.worktree_path = worktree_path\n245\t        ctx.cwd = worktree_path\n246\t        return\n247\t\n248\t    # Acquire the lock BEFORE the resume-check or any mutation.\n249\t    # The lock file lives at .worktrees/PRD-X.lock and is per-PRD.\n250\t    lock_path = ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}.lock\"\n251\t    lock_path.parent.mkdir(parents=True, exist_ok=True)\n252\t\n253\t    lock = FileLock(str(lock_path))\n254\t    try:\n255\t        lock.acquire(timeout=0)  # non-blocking\n256\t    except Timeout:\n257\t        raise RuntimeError(\n258\t            f\"{ctx.prd.id} is already being worked on by another `prd run` \"\n259\t            f\"process (lock held on {lock_path}). If that process died, \"\n260\t            f\"the lock will auto-release when its file handle is reclaimed. \"\n261\t            f\"On a stuck lock, delete {lock_path} manually.\"\n262\t        ) from None\n263\t\n264\t    ctx._worktree_lock = lock\n265\t\n266\t    # ---- existing logic below, now lock-protected ----\n267\t    if worktree_path.exists():\n268\t        ctx.logger.info(\"resuming existing worktree: %s\", worktree_path)\n269\t        ctx.worktree_path = worktree_path\n270\t        ctx.cwd = worktree_path\n271\t        return\n272\t\n273\t    local_exists = _branch_exists_local(ctx.repo_root, branch)\n274\t    remote_exists = _branch_exists_remote(ctx.repo_root, branch)\n275\t    if local_exists or remote_exists:\n276\t        # Release the lock before raising so the error state is clean.\n277\t        lock.release()\n278\t        ctx._worktree_lock = None\n279\t        raise RuntimeError(\n280\t            f\"branch {branch!r} already exists but worktree {worktree_path} is gone. \"\n281\t            f\"Run `prd cleanup {ctx.prd.id}` to release it.\"\n282\t        )\n283\t\n284\t    # git worktree add -b <branch> <path> <base>\n285\t    # Run from the repo root, not from ctx.cwd (which may not be a git dir yet).\n286\t    subprocess.run(\n287\t        [\n288\t            \"git\",\n289\t            \"-C\",\n290\t            str(ctx.repo_root),\n291\t            \"worktree\",\n292\t            \"add\",\n293\t            \"-b\",\n294\t            branch,\n295\t            str(worktree_path),\n296\t            ctx.base_ref,\n297\t        ],\n298\t        check=True,\n299\t        capture_output=True,\n300\t        text=True,\n301\t    )\n302\t\n303\t    ctx.worktree_path = worktree_path\n304\t    ctx.cwd = worktree_path\n305\t\n306\t\n307\t@builtin(\"set_status\")\n308\tdef set_status(ctx: ExecutionContext, *, to: Status) -> None:\n309\t    \"\"\"Rewrite the PRD's ``status:`` frontmatter field inside the worktree.\n310\t\n311\t    Targets the worktree's copy of the PRD file, never the source repo.\n312\t    The source repo's working tree must remain untouched by ``prd run`` —\n313\t    status transitions live on the PRD's worktree branch and only reach\n314\t    the source repo via PR merge (see PRD-213).\n315\t\n316\t    Uses :func:`darkfactory.prd.set_status_at`, which surgically rewrites\n317\t    only the ``status:`` and ``updated:`` lines so the resulting commit\n318\t    diff is two lines, not the whole frontmatter block.\n319\t    \"\"\"\n320\t    if ctx.dry_run:\n321\t        ctx.logger.info(\n322\t            \"[dry-run] set status of %s: %s -> %s (worktree=%s)\",\n323\t            ctx.prd.id,\n324\t            ctx.prd.status,\n325\t            to,\n326\t            ctx.worktree_path,\n327\t        )\n328\t        return\n329\t\n330\t    if ctx.worktree_path is None:\n331\t        raise RuntimeError(\n332\t            \"set_status requires a worktree; ensure_worktree must run first\"\n333\t        )\n334\t\n335\t    relative = ctx.prd.path.relative_to(ctx.repo_root)\n336\t    target = ctx.worktree_path / relative\n337\t    prd_module.set_status_at(target, to)\n338\t    # Mirror the field updates onto the in-memory PRD so subsequent\n339\t    # builtins see the new status without re-loading from disk.\n340\t    ctx.prd.status = to\n341\t    from datetime import date as _date\n342\t\n343\t    ctx.prd.updated = _date.today().isoformat()\n344\t\n345\t\n346\t@builtin(\"commit\")\n347\tdef commit(ctx: ExecutionContext, *, message: str) -> None:\n348\t    \"\"\"Stage all changes and make a commit inside the worktree.\n349\t\n350\t    ``message`` is format-string expanded against the context so\n351\t    ``\"chore(prd): {prd_id} start work\"`` becomes\n352\t    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n353\t    returns without erroring — workflows can safely commit after each\n354\t    logical step without worrying about whether anything changed.\n355\t    \"\"\"\n356\t    formatted = ctx.format_string(message)\n357\t    _scan_for_forbidden_attribution(\n358\t        formatted, source=f\"commit message for {ctx.prd.id}\"\n359\t    )\n360\t\n361\t    if ctx.dry_run:\n362\t        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n363\t        return\n364\t\n365\t    # Stage everything\n366\t    subprocess.run(\n367\t        [\"git\", \"add\", \"-A\"],\n368\t        cwd=str(ctx.cwd),\n369\t        check=True,\n370\t        capture_output=True,\n371\t        text=True,\n372\t    )\n373\t\n374\t    # Check if there's anything to commit\n375\t    diff_result = subprocess.run(\n376\t        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n377\t        cwd=str(ctx.cwd),\n378\t        check=False,\n379\t        capture_output=True,\n380\t        text=True,\n381\t    )\n382\t    if diff_result.returncode == 0:\n383\t        # No staged changes — skip gracefully.\n384\t        ctx.logger.info(\"commit skipped: no changes to commit\")\n385\t        return\n386\t\n387\t    # Commit\n388\t    subprocess.run(\n389\t        [\"git\", \"commit\", \"-m\", formatted],\n390\t        cwd=str(ctx.cwd),\n391\t        check=True,\n392\t        capture_output=True,\n393\t        text=True,\n394\t    )\n395\t\n396\t\n397\t@builtin(\"push_branch\")\n398\tdef push_branch(ctx: ExecutionContext) -> None:\n399\t    \"\"\"Push the current branch to origin with upstream tracking.\n400\t\n401\t    Runs ``git push -u origin {branch}`` inside the worktree. Required\n402\t    before :func:`create_pr` because ``gh pr create --base`` needs the\n403\t    remote to exist.\n404\t    \"\"\"\n405\t    cmd = [\"git\", \"push\", \"-u\", \"origin\", ctx.branch_name]\n406\t\n407\t    if ctx.dry_run:\n408\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n409\t        return\n410\t\n411\t    subprocess.run(\n412\t        cmd,\n413\t        cwd=str(ctx.cwd),\n414\t        check=True,\n415\t        capture_output=True,\n416\t        text=True,\n417\t    )\n418\t\n419\t\n420\tdef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n421\t    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n422\t    if not tool_counts:\n423\t        return \"none\"\n424\t    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n425\t\n426\t\n427\tdef _format_invocations(ctx: ExecutionContext) -> str:\n428\t    \"\"\"Format agent invocation count from context.\"\"\"\n429\t    count = ctx.invoke_count\n430\t    if count == 0:\n431\t        return \"0\"\n432\t    if count == 1:\n433\t        return \"1\"\n434\t    return str(count)\n435\t\n436\t\n437\t@builtin(\"summarize_agent_run\")\n438\tdef summarize_agent_run(ctx: ExecutionContext) -> None:\n439\t    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n440\t    result = ctx.last_invoke_result\n441\t    if result is None:\n442\t        return\n443\t\n444\t    lines = [\n445\t        \"## Harness execution summary\",\n446\t        \"\",\n447\t        f\"- **Workflow:** {ctx.workflow.name}\",\n448\t        f\"- **Model:** {ctx.model or 'unknown'}\",\n449\t        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n450\t        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n451\t        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n452\t    ]\n453\t    ctx.run_summary = \"\\n\".join(lines)\n454\t\n455\t\n456\t@builtin(\"commit_transcript\")\n457\tdef commit_transcript(ctx: ExecutionContext) -> None:\n458\t    \"\"\"Move agent transcript to .darkfactory/transcripts/ and stage it.\n459\t\n460\t    Source: ``.harness-agent-output.log`` written by the runner after each\n461\t    agent invocation. Destination:\n462\t    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n463\t\n464\t    Timestamps use the wall-clock at the time this builtin runs, which is\n465\t    unique enough for sequential runs. If no transcript exists (dry-run,\n466\t    or the runner didn't produce one), this is a no-op.\n467\t    \"\"\"\n468\t    src = ctx.cwd / \".harness-agent-output.log\"\n469\t    if not src.exists():\n470\t        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n471\t        return\n472\t\n473\t    if ctx.dry_run:\n474\t        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n475\t        dest = (\n476\t            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n477\t        )\n478\t        ctx.logger.info(\"[dry-run] move %s -> %s && git add\", src, dest)\n479\t        return\n480\t\n481\t    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n482\t    transcript_dir.mkdir(parents=True, exist_ok=True)\n483\t\n484\t    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n485\t    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n486\t\n487\t    shutil.move(str(src), str(dest))\n488\t\n489\t    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n490\t    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n491\t\n492\t\n493\t@builtin(\"create_pr\")\n494\tdef create_pr(ctx: ExecutionContext) -> None:\n495\t    \"\"\"Open a pull request via ``gh pr create``.\n496\t\n497\t    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n498\t    acceptance criteria plus a link to the PRD file. Base branch:\n499\t    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n500\t    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n501\t    relative to ``ctx.repo_root``.\n502\t    \"\"\"\n503\t    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n504\t    body = _pr_body(ctx)\n505\t    if ctx.run_summary:\n506\t        body += \"\\n\\n\" + ctx.run_summary\n507\t    _scan_for_forbidden_attribution(title, source=f\"PR title for {ctx.prd.id}\")\n508\t    _scan_for_forbidden_attribution(body, source=f\"PR body for {ctx.prd.id}\")\n509\t\n510\t    if ctx.dry_run:\n511\t        ctx.logger.info(\n512\t            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n513\t            ctx.base_ref,\n514\t            title,\n515\t        )\n516\t        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n517\t        return\n518\t\n519\t    # Write the body to a temp file — passing long bodies via --body\n520\t    # can hit argv limits on some systems.\n521\t    import tempfile\n522\t\n523\t    with tempfile.NamedTemporaryFile(\n524\t        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n525\t    ) as body_file:\n526\t        body_file.write(body)\n527\t        body_path = body_file.name\n528\t\n529\t    try:\n530\t        result = subprocess.run(\n531\t            [\n532\t                \"gh\",\n533\t                \"pr\",\n534\t                \"create\",\n535\t                \"--base\",\n536\t                ctx.base_ref,\n537\t                \"--title\",\n538\t                title,\n539\t                \"--body-file\",\n540\t                body_path,\n541\t            ],\n542\t            cwd=str(ctx.cwd),\n543\t            check=True,\n544\t            capture_output=True,\n545\t            text=True,\n546\t        )\n547\t    finally:\n548\t        Path(body_path).unlink(missing_ok=True)\n549\t\n550\t    # gh prints the PR URL to stdout on success.\n551\t    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n552\t    ctx.pr_url = url_line or None\n553\t\n554\t\n555\t# ----- attribution lint -----\n556\t#\n557\t# The harness MUST NOT credit Claude / Anthropic in commit messages, PR\n558\t# bodies, or run summaries. Default Claude Code commit flows tack on a\n559\t# ``Co-Authored-By: Claude ...`` trailer; subagents have been observed to\n560\t# do the same inside ``retry_agent`` cycles. We detect and reject those\n561\t# patterns loudly rather than silently stripping — silent stripping masks\n562\t# the underlying agent misbehaviour we want to notice and fix.\n563\t_FORBIDDEN_ATTRIBUTION_PATTERNS: tuple[re.Pattern[str], ...] = (\n564\t    re.compile(r\"Co-Authored-By:\\s*Claude\", re.IGNORECASE),\n565\t    re.compile(r\"Co-Authored-By:.*@anthropic\\.com\", re.IGNORECASE),\n566\t    re.compile(r\"Generated with .{0,20}Claude Code\", re.IGNORECASE),\n567\t    re.compile(r\"🤖 Generated with\", re.IGNORECASE),\n568\t)\n569\t\n570\t\n571\tdef _scan_for_forbidden_attribution(text: str, *, source: str) -> None:\n572\t    \"\"\"Raise ``RuntimeError`` if ``text`` contains any forbidden pattern.\n573\t\n574\t    ``source`` is a human label (e.g. ``\"commit PRD-544\"``) included in the\n575\t    error so failures point at the offending artifact. No-op on empty text.\n576\t    \"\"\"\n577\t    if not text:\n578\t        return\n579\t    for pattern in _FORBIDDEN_ATTRIBUTION_PATTERNS:\n580\t        match = pattern.search(text)\n581\t        if match:\n582\t            raise RuntimeError(\n583\t                f\"forbidden attribution pattern in {source}: {match.group(0)!r}. \"\n584\t                \"Claude/Anthropic must never be credited in commit messages, \"\n585\t                \"PR bodies, or run summaries — strip the trailer and retry.\"\n586\t            )\n587\t\n588\t\n589\t@builtin(\"lint_attribution\")\n590\tdef lint_attribution(ctx: ExecutionContext) -> None:\n591\t    \"\"\"Fail if any commit on the branch or the run summary credits Claude/Anthropic.\n592\t\n593\t    Scans:\n594\t\n595\t    - Every commit message in ``{base_ref}..HEAD`` on the current branch\n596\t    - ``ctx.run_summary`` (which feeds the PR body)\n597\t\n598\t    Intended to run after the agent + verification phases and before\n599\t    ``push_branch`` / ``create_pr``, so violations abort the workflow\n600\t    before anything lands on the remote or in a PR. Dry-run is a no-op\n601\t    because there are no real commits to scan.\n602\t    \"\"\"\n603\t    if ctx.dry_run:\n604\t        ctx.logger.info(\"[dry-run] lint_attribution: skipped\")\n605\t        return\n606\t\n607\t    _scan_for_forbidden_attribution(\n608\t        ctx.run_summary or \"\", source=f\"run summary for {ctx.prd.id}\"\n609\t    )\n610\t\n611\t    result = subprocess.run(\n612\t        [\"git\", \"log\", f\"{ctx.base_ref}..HEAD\", \"--format=%H%x00%B%x1e\"],\n613\t        cwd=str(ctx.cwd),\n614\t        check=True,\n615\t        capture_output=True,\n616\t        text=True,\n617\t    )\n618\t    # Record separator \\x1e between commits; field separator \\x00 between\n619\t    # sha and body. Keeps us robust against newlines in commit messages.\n620\t    for entry in result.stdout.split(\"\\x1e\"):\n621\t        entry = entry.strip()\n622\t        if not entry:\n623\t            continue\n624\t        sha, _, body = entry.partition(\"\\x00\")\n625\t        _scan_for_forbidden_attribution(\n626\t            body, source=f\"commit {sha[:12]} on {ctx.branch_name}\"\n627\t        )\n628\t\n629\t    ctx.logger.info(\"lint_attribution: clean\")\n630\t\n631\t\n632\t@builtin(\"cleanup_worktree\")\n633\tdef cleanup_worktree(ctx: ExecutionContext) -> None:\n634\t    \"\"\"Remove the worktree after a successful run.\n635\t\n636\t    Idempotent — if the worktree is already gone, logs and returns.\n637\t    Normally skipped during chain execution so downstream worktrees\n638\t    can base on this branch; called explicitly via ``prd cleanup``\n639\t    after the whole chain is done.\n640\t    \"\"\"\n641\t    if ctx.worktree_path is None:\n642\t        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n643\t        return\n644\t\n645\t    if not ctx.worktree_path.exists():\n646\t        ctx.logger.info(\n647\t            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n648\t        )\n649\t        return\n650\t\n651\t    cmd = [\n652\t        \"git\",\n653\t        \"-C\",\n654\t        str(ctx.repo_root),\n655\t        \"worktree\",\n656\t        \"remove\",\n657\t        str(ctx.worktree_path),\n658\t    ]\n659\t\n660\t    if ctx.dry_run:\n661\t        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n662\t        return\n663\t\n664\t    subprocess.run(cmd, check=True, capture_output=True, text=True)\n665\t"}]},"parent_tool_use_id":null,"session_id":"fdfb98d4-32e9-4fa7-a46c-bf4d30fd4fa2","uuid":"464ef4ec-161b-4636-9ca1-5283de6eff15","timestamp":"2026-04-09T02:18:08.111Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-549-builtins-package-split/src/darkfactory/builtins.py","content":"\"\"\"Built-in task primitives — real implementations.\n\nBuilt-ins are the deterministic SDLC operations that every workflow\nreferences by name: create a worktree, set a PRD's status, make a\ncommit, push a branch, open a PR. They live here (not in individual\nworkflow modules) because they're shared — every workflow uses the\nsame ``commit`` primitive, not a bespoke one.\n\nWorkflows reference built-ins by name via :class:`~darkfactory.workflow.BuiltIn`::\n\n    BuiltIn(\"commit\", kwargs={\"message\": \"chore(prd): {prd_id} start work\"})\n\nThe runner looks up ``\"commit\"`` in :data:`BUILTINS` and calls the\nregistered function with the :class:`~darkfactory.workflow.ExecutionContext`\nplus any formatted kwargs.\n\n**Dry-run mode**: every built-in checks ``ctx.dry_run`` before doing\nanything destructive. In dry-run, we log what we WOULD do at INFO\nlevel and return. This is what powers ``prd plan`` and the default\n``prd run`` (without ``--execute``).\n\n**Subprocess discipline**: all shell commands use ``subprocess.run``\nwith an explicit argv list (never ``shell=True``), capture output,\nand check the return code. Git and gh invocations go through\n:func:`_run_git` and :func:`_run_gh` helpers that centralize cwd\nhandling and dry-run support.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport logging\nimport re\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom pathlib import Path\nfrom typing import Callable\n\nfrom filelock import FileLock, Timeout\n\nfrom . import prd as prd_module\nfrom .workflow import ExecutionContext, Status\n\n_log = logging.getLogger(__name__)\n\nBuiltInFunc = Callable[..., None]\n\"\"\"Signature every built-in shares: takes ``ExecutionContext`` plus **kwargs, returns None.\n\nReturn value is always ``None`` — built-ins communicate results by\nmutating the context (setting ``ctx.worktree_path``, ``ctx.pr_url``, etc.)\nand signal failure by raising an exception. This keeps the dispatch\nuniform in the runner.\n\"\"\"\n\n\nBUILTINS: dict[str, BuiltInFunc] = {}\n\"\"\"Global registry mapping built-in name to its implementing function.\n\nPopulated at import time via the :func:`builtin` decorator. The runner\nlooks up names in this dict when dispatching a\n:class:`~darkfactory.workflow.BuiltIn` task. Workflows never touch this\ndict directly — they reference built-ins by name only.\n\"\"\"\n\n\ndef builtin(name: str) -> Callable[[BuiltInFunc], BuiltInFunc]:\n    \"\"\"Decorator that registers a function in :data:`BUILTINS`.\n\n    Rejects duplicate registrations with ``ValueError`` to catch typos\n    and accidental overrides during development.\n    \"\"\"\n\n    def decorator(func: BuiltInFunc) -> BuiltInFunc:\n        if name in BUILTINS:\n            raise ValueError(f\"duplicate builtin registration for {name!r}\")\n        BUILTINS[name] = func\n        return func\n\n    return decorator\n\n\n# ---------- internal helpers ----------\n\n\ndef _run(\n    ctx: ExecutionContext,\n    cmd: list[str],\n    *,\n    check: bool = True,\n    capture: bool = False,\n) -> subprocess.CompletedProcess[str]:\n    \"\"\"Run a subprocess command inside ``ctx.cwd`` with dry-run support.\n\n    In dry-run mode, logs the command at INFO level and returns a fake\n    ``CompletedProcess`` with exit code 0. In live mode, runs the\n    command for real and raises ``subprocess.CalledProcessError`` on\n    non-zero exit when ``check=True``.\n\n    Using an explicit argv list (not a shell string) prevents shell\n    injection entirely — callers don't get to interpolate variables\n    into a command line, they build the argv themselves.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return subprocess.CompletedProcess(args=cmd, returncode=0, stdout=\"\", stderr=\"\")\n\n    return subprocess.run(\n        cmd,\n        cwd=str(ctx.cwd),\n        check=check,\n        capture_output=capture,\n        text=True,\n    )\n\n\ndef _worktree_target(ctx: ExecutionContext) -> Path:\n    \"\"\"Compute the worktree path for this PRD under ``.worktrees/``.\n\n    Separated out so tests can assert the path without a whole\n    subprocess invocation.\n    \"\"\"\n    return ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}-{ctx.prd.slug}\"\n\n\ndef _branch_exists_local(repo_root: Path, branch: str) -> bool:\n    \"\"\"Return True if ``branch`` exists in the local repo's refs.\"\"\"\n    result = subprocess.run(\n        [\n            \"git\",\n            \"-C\",\n            str(repo_root),\n            \"rev-parse\",\n            \"--verify\",\n            \"--quiet\",\n            f\"refs/heads/{branch}\",\n        ],\n        capture_output=True,\n        text=True,\n    )\n    return result.returncode == 0\n\n\ndef _branch_exists_remote(repo_root: Path, branch: str) -> bool:\n    \"\"\"Return True if ``branch`` exists on origin.\n\n    Best-effort: returns False (and logs a warning) on timeout or any\n    subprocess error so the caller can fall back to the local check.\n    \"\"\"\n    try:\n        result = subprocess.run(\n            [\n                \"git\",\n                \"-C\",\n                str(repo_root),\n                \"ls-remote\",\n                \"--exit-code\",\n                \"origin\",\n                f\"refs/heads/{branch}\",\n            ],\n            capture_output=True,\n            text=True,\n            timeout=10,\n        )\n    except subprocess.TimeoutExpired:\n        _log.warning(\n            \"git ls-remote timed out checking remote branch %r — skipping remote check\",\n            branch,\n        )\n        return False\n    except Exception as exc:\n        _log.warning(\n            \"git ls-remote failed checking remote branch %r (%s) — skipping remote check\",\n            branch,\n            exc,\n        )\n        return False\n    return result.returncode == 0\n\n\n_AC_LINE_RE = re.compile(r\"^\\s*-\\s*\\[\\s*\\]\\s*(AC-\\d+.*)$\", re.MULTILINE)\n\n\ndef _extract_acceptance_criteria(body: str) -> list[str]:\n    \"\"\"Pull acceptance criteria lines out of a PRD body.\n\n    Looks for the standard ``- [ ] AC-N: ...`` checkbox format.\n    Returns a list of the criterion strings (without the checkbox\n    prefix). Used by ``create_pr`` to build the PR body's checklist.\n    \"\"\"\n    return [match.group(1).strip() for match in _AC_LINE_RE.finditer(body)]\n\n\ndef _pr_body(ctx: ExecutionContext) -> str:\n    \"\"\"Generate a PR body with a link to the PRD and an AC checklist.\"\"\"\n    prd = ctx.prd\n    lines: list[str] = [\n        f\"Implements `{prd.path.relative_to(ctx.repo_root)}`.\",\n        \"\",\n    ]\n\n    acs = _extract_acceptance_criteria(prd.body)\n    if acs:\n        lines.append(\"## Acceptance criteria\")\n        lines.append(\"\")\n        for ac in acs:\n            lines.append(f\"- [ ] {ac}\")\n        lines.append(\"\")\n\n    lines.append(\"---\")\n    lines.append(f\"Generated by the PRD harness workflow `{ctx.workflow.name}`.\")\n    return \"\\n\".join(lines)\n\n\n# ---------- built-in implementations ----------\n\n\n@builtin(\"ensure_worktree\")\ndef ensure_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Create (or resume) a git worktree for this PRD.\n\n    Target path: ``{repo_root}/.worktrees/{prd_id}-{slug}``. Branch:\n    ``prd/{prd_id}-{slug}`` created from ``ctx.base_ref``. If the\n    worktree already exists (previous run resumed), reuses it without\n    re-creating. Sets ``ctx.worktree_path`` and ``ctx.cwd`` on success.\n\n    In live mode, acquires a per-PRD advisory file lock at\n    ``.worktrees/{prd_id}.lock`` before any mutation so two concurrent\n    ``prd run`` invocations for the same PRD fail fast with a clear\n    message instead of racing. The lock is auto-released by the kernel\n    when the process exits; the runner also releases it explicitly at the\n    end of the run (see ``_release_worktree_lock``).\n    \"\"\"\n    worktree_path = _worktree_target(ctx)\n    branch = ctx.branch_name\n\n    if ctx.dry_run:\n        # Dry-run produces no side effects, so no lock needed.\n        ctx.logger.info(\n            \"[dry-run] git worktree add -b %s %s %s\",\n            branch,\n            worktree_path,\n            ctx.base_ref,\n        )\n        ctx.worktree_path = worktree_path\n        ctx.cwd = worktree_path\n        return\n\n    # Acquire the lock BEFORE the resume-check or any mutation.\n    # The lock file lives at .worktrees/PRD-X.lock and is per-PRD.\n    lock_path = ctx.repo_root / \".worktrees\" / f\"{ctx.prd.id}.lock\"\n    lock_path.parent.mkdir(parents=True, exist_ok=True)\n\n    lock = FileLock(str(lock_path))\n    try:\n        lock.acquire(timeout=0)  # non-blocking\n    except Timeout:\n        raise RuntimeError(\n            f\"{ctx.prd.id} is already being worked on by another `prd run` \"\n            f\"process (lock held on {lock_path}). If that process died, \"\n            f\"the lock will auto-release when its file handle is reclaimed. \"\n            f\"On a stuck lock, delete {lock_path} manually.\"\n        ) from None\n\n    ctx._worktree_lock = lock\n\n    # ---- existing logic below, now lock-protected ----\n    if worktree_path.exists():\n        ctx.logger.info(\"resuming existing worktree: %s\", worktree_path)\n        ctx.worktree_path = worktree_path\n        ctx.cwd = worktree_path\n        return\n\n    local_exists = _branch_exists_local(ctx.repo_root, branch)\n    remote_exists = _branch_exists_remote(ctx.repo_root, branch)\n    if local_exists or remote_exists:\n        # Release the lock before raising so the error state is clean.\n        lock.release()\n        ctx._worktree_lock = None\n        raise RuntimeError(\n            f\"branch {branch!r} already exists but worktree {worktree_path} is gone. \"\n            f\"Run `prd cleanup {ctx.prd.id}` to release it.\"\n        )\n\n    # git worktree add -b <branch> <path> <base>\n    # Run from the repo root, not from ctx.cwd (which may not be a git dir yet).\n    subprocess.run(\n        [\n            \"git\",\n            \"-C\",\n            str(ctx.repo_root),\n            \"worktree\",\n            \"add\",\n            \"-b\",\n            branch,\n            str(worktree_path),\n            ctx.base_ref,\n        ],\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n    ctx.worktree_path = worktree_path\n    ctx.cwd = worktree_path\n\n\n@builtin(\"set_status\")\ndef set_status(ctx: ExecutionContext, *, to: Status) -> None:\n    \"\"\"Rewrite the PRD's ``status:`` frontmatter field inside the worktree.\n\n    Targets the worktree's copy of the PRD file, never the source repo.\n    The source repo's working tree must remain untouched by ``prd run`` —\n    status transitions live on the PRD's worktree branch and only reach\n    the source repo via PR merge (see PRD-213).\n\n    Uses :func:`darkfactory.prd.set_status_at`, which surgically rewrites\n    only the ``status:`` and ``updated:`` lines so the resulting commit\n    diff is two lines, not the whole frontmatter block.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\n            \"[dry-run] set status of %s: %s -> %s (worktree=%s)\",\n            ctx.prd.id,\n            ctx.prd.status,\n            to,\n            ctx.worktree_path,\n        )\n        return\n\n    if ctx.worktree_path is None:\n        raise RuntimeError(\n            \"set_status requires a worktree; ensure_worktree must run first\"\n        )\n\n    relative = ctx.prd.path.relative_to(ctx.repo_root)\n    target = ctx.worktree_path / relative\n    prd_module.set_status_at(target, to)\n    # Mirror the field updates onto the in-memory PRD so subsequent\n    # builtins see the new status without re-loading from disk.\n    ctx.prd.status = to\n    from datetime import date as _date\n\n    ctx.prd.updated = _date.today().isoformat()\n\n\n@builtin(\"commit\")\ndef commit(ctx: ExecutionContext, *, message: str) -> None:\n    \"\"\"Stage all changes and make a commit inside the worktree.\n\n    ``message`` is format-string expanded against the context so\n    ``\"chore(prd): {prd_id} start work\"`` becomes\n    ``\"chore(prd): PRD-070 start work\"``. On an empty diff, logs and\n    returns without erroring — workflows can safely commit after each\n    logical step without worrying about whether anything changed.\n    \"\"\"\n    formatted = ctx.format_string(message)\n    _scan_for_forbidden_attribution(\n        formatted, source=f\"commit message for {ctx.prd.id}\"\n    )\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] git add -A && git commit -m %r\", formatted)\n        return\n\n    # Stage everything\n    subprocess.run(\n        [\"git\", \"add\", \"-A\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n    # Check if there's anything to commit\n    diff_result = subprocess.run(\n        [\"git\", \"diff\", \"--cached\", \"--quiet\"],\n        cwd=str(ctx.cwd),\n        check=False,\n        capture_output=True,\n        text=True,\n    )\n    if diff_result.returncode == 0:\n        # No staged changes — skip gracefully.\n        ctx.logger.info(\"commit skipped: no changes to commit\")\n        return\n\n    # Commit\n    subprocess.run(\n        [\"git\", \"commit\", \"-m\", formatted],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n\n@builtin(\"push_branch\")\ndef push_branch(ctx: ExecutionContext) -> None:\n    \"\"\"Push the current branch to origin with upstream tracking.\n\n    Runs ``git push -u origin {branch}`` inside the worktree. Required\n    before :func:`create_pr` because ``gh pr create --base`` needs the\n    remote to exist.\n    \"\"\"\n    cmd = [\"git\", \"push\", \"-u\", \"origin\", ctx.branch_name]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(\n        cmd,\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n\n\ndef _format_tool_counts(tool_counts: dict[str, int]) -> str:\n    \"\"\"Format tool counts as a compact inline string, e.g. 'Read×5, Edit×3'.\"\"\"\n    if not tool_counts:\n        return \"none\"\n    return \", \".join(f\"{name}×{count}\" for name, count in sorted(tool_counts.items()))\n\n\ndef _format_invocations(ctx: ExecutionContext) -> str:\n    \"\"\"Format agent invocation count from context.\"\"\"\n    count = ctx.invoke_count\n    if count == 0:\n        return \"0\"\n    if count == 1:\n        return \"1\"\n    return str(count)\n\n\n@builtin(\"summarize_agent_run\")\ndef summarize_agent_run(ctx: ExecutionContext) -> None:\n    \"\"\"Aggregate tool-call counts and write a markdown summary to ctx.run_summary.\"\"\"\n    result = ctx.last_invoke_result\n    if result is None:\n        return\n\n    lines = [\n        \"## Harness execution summary\",\n        \"\",\n        f\"- **Workflow:** {ctx.workflow.name}\",\n        f\"- **Model:** {ctx.model or 'unknown'}\",\n        f\"- **Agent invocations:** {_format_invocations(ctx)}\",\n        f\"- **Tools used:** {_format_tool_counts(result.tool_counts)}\",\n        f\"- **Sentinel:** {result.sentinel or 'none'}\",\n    ]\n    ctx.run_summary = \"\\n\".join(lines)\n\n\n@builtin(\"commit_transcript\")\ndef commit_transcript(ctx: ExecutionContext) -> None:\n    \"\"\"Move agent transcript to .darkfactory/transcripts/ and stage it.\n\n    Source: ``.harness-agent-output.log`` written by the runner after each\n    agent invocation. Destination:\n    ``.darkfactory/transcripts/{prd_id}-{timestamp}.log``.\n\n    Timestamps use the wall-clock at the time this builtin runs, which is\n    unique enough for sequential runs. If no transcript exists (dry-run,\n    or the runner didn't produce one), this is a no-op.\n    \"\"\"\n    src = ctx.cwd / \".harness-agent-output.log\"\n    if not src.exists():\n        ctx.logger.info(\"commit_transcript: no transcript found; skipping\")\n        return\n\n    if ctx.dry_run:\n        timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n        dest = (\n            ctx.cwd / \".darkfactory\" / \"transcripts\" / f\"{ctx.prd.id}-{timestamp}.log\"\n        )\n        ctx.logger.info(\"[dry-run] move %s -> %s && git add\", src, dest)\n        return\n\n    transcript_dir = ctx.cwd / \".darkfactory\" / \"transcripts\"\n    transcript_dir.mkdir(parents=True, exist_ok=True)\n\n    timestamp = datetime.now().strftime(\"%Y-%m-%dT%H-%M-%S\")\n    dest = transcript_dir / f\"{ctx.prd.id}-{timestamp}.log\"\n\n    shutil.move(str(src), str(dest))\n\n    subprocess.run([\"git\", \"add\", str(dest)], cwd=str(ctx.cwd), check=True)\n    ctx.logger.info(\"commit_transcript: staged %s\", dest.relative_to(ctx.cwd))\n\n\n@builtin(\"create_pr\")\ndef create_pr(ctx: ExecutionContext) -> None:\n    \"\"\"Open a pull request via ``gh pr create``.\n\n    Title: ``\"{prd_id}: {prd_title}\"``. Body: generated from the PRD's\n    acceptance criteria plus a link to the PRD file. Base branch:\n    ``ctx.base_ref``. On success, sets ``ctx.pr_url`` from the URL\n    printed by ``gh``. The PRD file must exist at ``ctx.prd.path``\n    relative to ``ctx.repo_root``.\n    \"\"\"\n    title = f\"{ctx.prd.id}: {ctx.prd.title}\"\n    body = _pr_body(ctx)\n    if ctx.run_summary:\n        body += \"\\n\\n\" + ctx.run_summary\n    _scan_for_forbidden_attribution(title, source=f\"PR title for {ctx.prd.id}\")\n    _scan_for_forbidden_attribution(body, source=f\"PR body for {ctx.prd.id}\")\n\n    if ctx.dry_run:\n        ctx.logger.info(\n            \"[dry-run] gh pr create --base %s --title %r --body <generated>\",\n            ctx.base_ref,\n            title,\n        )\n        ctx.pr_url = \"https://example.test/dry-run/pr/0\"\n        return\n\n    # Write the body to a temp file — passing long bodies via --body\n    # can hit argv limits on some systems.\n    import tempfile\n\n    with tempfile.NamedTemporaryFile(\n        mode=\"w\", suffix=\".md\", delete=False, encoding=\"utf-8\"\n    ) as body_file:\n        body_file.write(body)\n        body_path = body_file.name\n\n    try:\n        result = subprocess.run(\n            [\n                \"gh\",\n                \"pr\",\n                \"create\",\n                \"--base\",\n                ctx.base_ref,\n                \"--title\",\n                title,\n                \"--body-file\",\n                body_path,\n            ],\n            cwd=str(ctx.cwd),\n            check=True,\n            capture_output=True,\n            text=True,\n        )\n    finally:\n        Path(body_path).unlink(missing_ok=True)\n\n    # gh prints the PR URL to stdout on success.\n    url_line = result.stdout.strip().splitlines()[-1] if result.stdout.strip() else \"\"\n    ctx.pr_url = url_line or None\n\n\n# ----- attribution lint -----\n#\n# The harness MUST NOT credit Claude / Anthropic in commit messages, PR\n# bodies, or run summaries. Default Claude Code commit flows tack on a\n# ``Co-Authored-By: Claude ...`` trailer; subagents have been observed to\n# do the same inside ``retry_agent`` cycles. We detect and reject those\n# patterns loudly rather than silently stripping — silent stripping masks\n# the underlying agent misbehaviour we want to notice and fix.\n_FORBIDDEN_ATTRIBUTION_PATTERNS: tuple[re.Pattern[str], ...] = (\n    re.compile(r\"Co-Authored-By:\\s*Claude\", re.IGNORECASE),\n    re.compile(r\"Co-Authored-By:.*@anthropic\\.com\", re.IGNORECASE),\n    re.compile(r\"Generated with .{0,20}Claude Code\", re.IGNORECASE),\n    re.compile(r\"🤖 Generated with\", re.IGNORECASE),\n)\n\n\ndef _scan_for_forbidden_attribution(text: str, *, source: str) -> None:\n    \"\"\"Raise ``RuntimeError`` if ``text`` contains any forbidden pattern.\n\n    ``source`` is a human label (e.g. ``\"commit PRD-544\"``) included in the\n    error so failures point at the offending artifact. No-op on empty text.\n    \"\"\"\n    if not text:\n        return\n    for pattern in _FORBIDDEN_ATTRIBUTION_PATTERNS:\n        match = pattern.search(text)\n        if match:\n            raise RuntimeError(\n                f\"forbidden attribution pattern in {source}: {match.group(0)!r}. \"\n                \"Claude/Anthropic must never be credited in commit messages, \"\n                \"PR bodies, or run summaries — strip the trailer and retry.\"\n            )\n\n\n@builtin(\"lint_attribution\")\ndef lint_attribution(ctx: ExecutionContext) -> None:\n    \"\"\"Fail if any commit on the branch or the run summary credits Claude/Anthropic.\n\n    Scans:\n\n    - Every commit message in ``{base_ref}..HEAD`` on the current branch\n    - ``ctx.run_summary`` (which feeds the PR body)\n\n    Intended to run after the agent + verification phases and before\n    ``push_branch`` / ``create_pr``, so violations abort the workflow\n    before anything lands on the remote or in a PR. Dry-run is a no-op\n    because there are no real commits to scan.\n    \"\"\"\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] lint_attribution: skipped\")\n        return\n\n    _scan_for_forbidden_attribution(\n        ctx.run_summary or \"\", source=f\"run summary for {ctx.prd.id}\"\n    )\n\n    result = subprocess.run(\n        [\"git\", \"log\", f\"{ctx.base_ref}..HEAD\", \"--format=%H%x00%B%x1e\"],\n        cwd=str(ctx.cwd),\n        check=True,\n        capture_output=True,\n        text=True,\n    )\n    # Record separator \\x1e between commits; field separator \\x00 between\n    # sha and body. Keeps us robust against newlines in commit messages.\n    for entry in result.stdout.split(\"\\x1e\"):\n        entry = entry.strip()\n        if not entry:\n            continue\n        sha, _, body = entry.partition(\"\\x00\")\n        _scan_for_forbidden_attribution(\n            body, source=f\"commit {sha[:12]} on {ctx.branch_name}\"\n        )\n\n    ctx.logger.info(\"lint_attribution: clean\")\n\n\n@builtin(\"cleanup_worktree\")\ndef cleanup_worktree(ctx: ExecutionContext) -> None:\n    \"\"\"Remove the worktree after a successful run.\n\n    Idempotent — if the worktree is already gone, logs and returns.\n    Normally skipped during chain execution so downstream worktrees\n    can base on this branch; called explicitly via ``prd cleanup``\n    after the whole chain is done.\n    \"\"\"\n    if ctx.worktree_path is None:\n        ctx.logger.info(\"cleanup_worktree: no worktree path set, skipping\")\n        return\n\n    if not ctx.worktree_path.exists():\n        ctx.logger.info(\n            \"cleanup_worktree: %s already gone, skipping\", ctx.worktree_path\n        )\n        return\n\n    cmd = [\n        \"git\",\n        \"-C\",\n        str(ctx.repo_root),\n        \"worktree\",\n        \"remove\",\n        str(ctx.worktree_path),\n    ]\n\n    if ctx.dry_run:\n        ctx.logger.info(\"[dry-run] %s\", \" \".join(cmd))\n        return\n\n    subprocess.run(cmd, check=True, capture_output=True, text=True)\n","numLines":665,"startLine":1,"totalLines":665}}}
