{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LP9FgzUJnxjMJDqa3qiotP","type":"tool_result","content":"1\t\"\"\"Tests for ``prd new`` CLI subcommand.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\t\n5\tfrom pathlib import Path\n6\t\n7\timport pytest\n8\timport yaml\n9\t\n10\tfrom darkfactory.cli import _slugify, main\n11\t\n12\tfrom .conftest import write_prd\n13\t\n14\t\n15\t# ---------------------------------------------------------------------------\n16\t# _slugify unit tests\n17\t# ---------------------------------------------------------------------------\n18\t\n19\t\n20\tdef test_slugify_basic() -> None:\n21\t    assert _slugify(\"My feature\") == \"my-feature\"\n22\t\n23\t\n24\tdef test_slugify_punctuation() -> None:\n25\t    assert _slugify(\"Hello, World!\") == \"hello-world\"\n26\t\n27\t\n28\tdef test_slugify_multiple_spaces() -> None:\n29\t    assert _slugify(\"  lots   of   spaces  \") == \"lots-of-spaces\"\n30\t\n31\t\n32\tdef test_slugify_unicode() -> None:\n33\t    # Non-ASCII stripped, remaining ascii forms slug\n34\t    assert _slugify(\"café au lait\") == \"caf-au-lait\"\n35\t\n36\t\n37\tdef test_slugify_empty_title() -> None:\n38\t    assert _slugify(\"!!!\") == \"untitled\"\n39\t\n40\t\n41\tdef test_slugify_with_dashes() -> None:\n42\t    assert _slugify(\"my-existing-slug\") == \"my-existing-slug\"\n43\t\n44\t\n45\t# ---------------------------------------------------------------------------\n46\t# cmd_new integration tests\n47\t# ---------------------------------------------------------------------------\n48\t\n49\t\n50\tdef test_new_basic_creates_file(tmp_path: Path) -> None:\n51\t    \"\"\"Basic usage creates PRD-001-my-feature.md in an empty dir.\"\"\"\n52\t    prd_dir = tmp_path / \"prds\"\n53\t    rc = main([\"--prd-dir\", str(prd_dir), \"new\", \"My feature\"])\n54\t    assert rc == 0\n55\t    created = prd_dir / \"PRD-001-my-feature.md\"\n56\t    assert created.exists()\n57\t\n58\t\n59\tdef test_new_auto_id_increments(tmp_path: Path) -> None:\n60\t    \"\"\"Auto-id picks the number above the current max.\"\"\"\n61\t    prd_dir = tmp_path / \"prds\"\n62\t    prd_dir.mkdir()\n63\t    write_prd(prd_dir, \"PRD-005\", \"five\", title=\"Existing five\")\n64\t    write_prd(prd_dir, \"PRD-010\", \"ten\", title=\"Existing ten\")\n65\t\n66\t    rc = main([\"--prd-dir\", str(prd_dir), \"new\", \"Next thing\"])\n67\t    assert rc == 0\n68\t    assert (prd_dir / \"PRD-011-next-thing.md\").exists()\n69\t\n70\t\n71\tdef test_new_explicit_id(tmp_path: Path) -> None:\n72\t    \"\"\"--id pins the PRD id.\"\"\"\n73\t    prd_dir = tmp_path / \"prds\"\n74\t    rc = main([\"--prd-dir\", str(prd_dir), \"new\", \"Pinned\", \"--id\", \"PRD-500\"])\n75\t    assert rc == 0\n76\t    assert (prd_dir / \"PRD-500-pinned.md\").exists()\n77\t\n78\t\n79\tdef test_new_explicit_id_refused_if_exists(tmp_path: Path) -> None:\n80\t    \"\"\"--id refuses if the id already exists.\"\"\"\n81\t    prd_dir = tmp_path / \"prds\"\n82\t    prd_dir.mkdir()\n83\t    write_prd(prd_dir, \"PRD-042\", \"fortytwo\", title=\"Existing\")\n84\t\n85\t    with pytest.raises(SystemExit):\n86\t        main([\"--prd-dir\", str(prd_dir), \"new\", \"Duplicate\", \"--id\", \"PRD-042\"])\n87\t\n88\t\n89\tdef test_new_refuses_overwrite(tmp_path: Path) -> None:\n90\t    \"\"\"Refuses to overwrite an existing file.\n91\t\n92\t    Uses --id to pin the id so we know the exact filename that will be\n93\t    attempted, then pre-creates that file as a different PRD.\n94\t    \"\"\"\n95\t    prd_dir = tmp_path / \"prds\"\n96\t    prd_dir.mkdir()\n97\t    # Pre-create the exact output path as a valid PRD with a different id\n98\t    # so load_all succeeds but the file-exists guard fires.\n99\t    write_prd(prd_dir, \"PRD-099\", \"my-title\", title=\"Already here\")\n100\t\n101\t    with pytest.raises(SystemExit):\n102\t        main([\"--prd-dir\", str(prd_dir), \"new\", \"My title\", \"--id\", \"PRD-099\"])\n103\t\n104\t\n105\tdef test_new_frontmatter_is_valid(tmp_path: Path) -> None:\n106\t    \"\"\"Generated frontmatter has expected fields and passes basic checks.\"\"\"\n107\t    prd_dir = tmp_path / \"prds\"\n108\t    rc = main([\"--prd-dir\", str(prd_dir), \"new\", \"Check Fields\"])\n109\t    assert rc == 0\n110\t\n111\t    path = prd_dir / \"PRD-001-check-fields.md\"\n112\t    text = path.read_text(encoding=\"utf-8\")\n113\t\n114\t    # Extract frontmatter\n115\t    parts = text.split(\"---\\n\", 2)\n116\t    fm = yaml.safe_load(parts[1])\n117\t\n118\t    assert fm[\"id\"] == \"PRD-001\"\n119\t    assert fm[\"title\"] == \"Check Fields\"\n120\t    assert fm[\"status\"] == \"draft\"\n121\t    assert fm[\"depends_on\"] == []\n122\t    assert fm[\"blocks\"] == []\n123\t    assert fm[\"impacts\"] == []\n124\t    assert fm[\"parent\"] is None\n125\t    assert fm[\"workflow\"] is None\n126\t    assert \"created\" in fm\n127\t    assert \"updated\" in fm\n128\t    assert fm[\"created\"] == fm[\"updated\"]\n129\t\n130\t\n131\tdef test_new_frontmatter_kind_default(tmp_path: Path) -> None:\n132\t    \"\"\"Default kind is 'task'.\"\"\"\n133\t    prd_dir = tmp_path / \"prds\"\n134\t    main([\"--prd-dir\", str(prd_dir), \"new\", \"Kind Test\"])\n135\t    path = prd_dir / \"PRD-001-kind-test.md\"\n136\t    fm = yaml.safe_load(path.read_text(encoding=\"utf-8\").split(\"---\\n\", 2)[1])\n137\t    assert fm[\"kind\"] == \"task\"\n138\t\n139\t\n140\tdef test_new_frontmatter_custom_flags(tmp_path: Path) -> None:\n141\t    \"\"\"Custom --kind, --priority, --effort, --capability are respected.\"\"\"\n142\t    prd_dir = tmp_path / \"prds\"\n143\t    rc = main(\n144\t        [\n145\t            \"--prd-dir\",\n146\t            str(prd_dir),\n147\t            \"new\",\n148\t            \"Custom Flags\",\n149\t            \"--kind\",\n150\t            \"feature\",\n151\t            \"--priority\",\n152\t            \"high\",\n153\t            \"--effort\",\n154\t            \"l\",\n155\t            \"--capability\",\n156\t            \"complex\",\n157\t        ]\n158\t    )\n159\t    assert rc == 0\n160\t    path = prd_dir / \"PRD-001-custom-flags.md\"\n161\t    fm = yaml.safe_load(path.read_text(encoding=\"utf-8\").split(\"---\\n\", 2)[1])\n162\t    assert fm[\"kind\"] == \"feature\"\n163\t    assert fm[\"priority\"] == \"high\"\n164\t    assert fm[\"effort\"] == \"l\"\n165\t    assert fm[\"capability\"] == \"complex\"\n166\t\n167\t\n168\tdef test_new_body_has_standard_sections(tmp_path: Path) -> None:\n169\t    \"\"\"Generated body contains all standard sections.\"\"\"\n170\t    prd_dir = tmp_path / \"prds\"\n171\t    main([\"--prd-dir\", str(prd_dir), \"new\", \"Section Check\"])\n172\t    path = prd_dir / \"PRD-001-section-check.md\"\n173\t    body = path.read_text(encoding=\"utf-8\")\n174\t\n175\t    for section in [\n176\t        \"## Summary\",\n177\t        \"## Motivation\",\n178\t        \"## Requirements\",\n179\t        \"## Technical Approach\",\n180\t        \"## Acceptance Criteria\",\n181\t        \"## Open Questions\",\n182\t        \"## References\",\n183\t    ]:\n184\t        assert section in body, f\"Missing section: {section}\"\n185\t\n186\t\n187\tdef test_new_invalid_kind_rejected(tmp_path: Path) -> None:\n188\t    \"\"\"Invalid --kind value is rejected by argparse.\"\"\"\n189\t    prd_dir = tmp_path / \"prds\"\n190\t    with pytest.raises(SystemExit):\n191\t        main([\"--prd-dir\", str(prd_dir), \"new\", \"Bad Kind\", \"--kind\", \"bogus\"])\n192\t\n193\t\n194\tdef test_new_invalid_priority_rejected(tmp_path: Path) -> None:\n195\t    \"\"\"Invalid --priority value is rejected by argparse.\"\"\"\n196\t    prd_dir = tmp_path / \"prds\"\n197\t    with pytest.raises(SystemExit):\n198\t        main([\"--prd-dir\", str(prd_dir), \"new\", \"Bad Priority\", \"--priority\", \"urgent\"])\n199\t\n200\t\n201\tdef test_new_no_existing_prds_starts_at_001(tmp_path: Path) -> None:\n202\t    \"\"\"With zero existing PRDs, the first id is PRD-001.\"\"\"\n203\t    prd_dir = tmp_path / \"prds\"\n204\t    rc = main([\"--prd-dir\", str(prd_dir), \"new\", \"First Ever\"])\n205\t    assert rc == 0\n206\t    assert (prd_dir / \"PRD-001-first-ever.md\").exists()\n207\t\n208\t\n209\tdef test_new_validate_passes(\n210\t    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n211\t) -> None:\n212\t    \"\"\"Generated PRD passes `prd validate`.\"\"\"\n213\t    # validate calls _find_repo_root which needs a .git directory\n214\t    (tmp_path / \".git\").mkdir()\n215\t    prd_dir = tmp_path / \"prds\"\n216\t    main([\"--prd-dir\", str(prd_dir), \"new\", \"Validate Me\"])\n217\t\n218\t    rc = main([\"--prd-dir\", str(prd_dir), \"validate\"])\n219\t    assert rc == 0\n220\t"}]},"parent_tool_use_id":null,"session_id":"039dac53-8768-4168-80ec-28db6edffc9b","uuid":"b813556b-dbae-4b06-848f-2ae9c6e58574","timestamp":"2026-04-08T12:56:44.783Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-510-prd-new-subcommand/tests/test_cli_new.py","content":"\"\"\"Tests for ``prd new`` CLI subcommand.\"\"\"\n\nfrom __future__ import annotations\n\nfrom pathlib import Path\n\nimport pytest\nimport yaml\n\nfrom darkfactory.cli import _slugify, main\n\nfrom .conftest import write_prd\n\n\n# ---------------------------------------------------------------------------\n# _slugify unit tests\n# ---------------------------------------------------------------------------\n\n\ndef test_slugify_basic() -> None:\n    assert _slugify(\"My feature\") == \"my-feature\"\n\n\ndef test_slugify_punctuation() -> None:\n    assert _slugify(\"Hello, World!\") == \"hello-world\"\n\n\ndef test_slugify_multiple_spaces() -> None:\n    assert _slugify(\"  lots   of   spaces  \") == \"lots-of-spaces\"\n\n\ndef test_slugify_unicode() -> None:\n    # Non-ASCII stripped, remaining ascii forms slug\n    assert _slugify(\"café au lait\") == \"caf-au-lait\"\n\n\ndef test_slugify_empty_title() -> None:\n    assert _slugify(\"!!!\") == \"untitled\"\n\n\ndef test_slugify_with_dashes() -> None:\n    assert _slugify(\"my-existing-slug\") == \"my-existing-slug\"\n\n\n# ---------------------------------------------------------------------------\n# cmd_new integration tests\n# ---------------------------------------------------------------------------\n\n\ndef test_new_basic_creates_file(tmp_path: Path) -> None:\n    \"\"\"Basic usage creates PRD-001-my-feature.md in an empty dir.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    rc = main([\"--prd-dir\", str(prd_dir), \"new\", \"My feature\"])\n    assert rc == 0\n    created = prd_dir / \"PRD-001-my-feature.md\"\n    assert created.exists()\n\n\ndef test_new_auto_id_increments(tmp_path: Path) -> None:\n    \"\"\"Auto-id picks the number above the current max.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-005\", \"five\", title=\"Existing five\")\n    write_prd(prd_dir, \"PRD-010\", \"ten\", title=\"Existing ten\")\n\n    rc = main([\"--prd-dir\", str(prd_dir), \"new\", \"Next thing\"])\n    assert rc == 0\n    assert (prd_dir / \"PRD-011-next-thing.md\").exists()\n\n\ndef test_new_explicit_id(tmp_path: Path) -> None:\n    \"\"\"--id pins the PRD id.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    rc = main([\"--prd-dir\", str(prd_dir), \"new\", \"Pinned\", \"--id\", \"PRD-500\"])\n    assert rc == 0\n    assert (prd_dir / \"PRD-500-pinned.md\").exists()\n\n\ndef test_new_explicit_id_refused_if_exists(tmp_path: Path) -> None:\n    \"\"\"--id refuses if the id already exists.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    write_prd(prd_dir, \"PRD-042\", \"fortytwo\", title=\"Existing\")\n\n    with pytest.raises(SystemExit):\n        main([\"--prd-dir\", str(prd_dir), \"new\", \"Duplicate\", \"--id\", \"PRD-042\"])\n\n\ndef test_new_refuses_overwrite(tmp_path: Path) -> None:\n    \"\"\"Refuses to overwrite an existing file.\n\n    Uses --id to pin the id so we know the exact filename that will be\n    attempted, then pre-creates that file as a different PRD.\n    \"\"\"\n    prd_dir = tmp_path / \"prds\"\n    prd_dir.mkdir()\n    # Pre-create the exact output path as a valid PRD with a different id\n    # so load_all succeeds but the file-exists guard fires.\n    write_prd(prd_dir, \"PRD-099\", \"my-title\", title=\"Already here\")\n\n    with pytest.raises(SystemExit):\n        main([\"--prd-dir\", str(prd_dir), \"new\", \"My title\", \"--id\", \"PRD-099\"])\n\n\ndef test_new_frontmatter_is_valid(tmp_path: Path) -> None:\n    \"\"\"Generated frontmatter has expected fields and passes basic checks.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    rc = main([\"--prd-dir\", str(prd_dir), \"new\", \"Check Fields\"])\n    assert rc == 0\n\n    path = prd_dir / \"PRD-001-check-fields.md\"\n    text = path.read_text(encoding=\"utf-8\")\n\n    # Extract frontmatter\n    parts = text.split(\"---\\n\", 2)\n    fm = yaml.safe_load(parts[1])\n\n    assert fm[\"id\"] == \"PRD-001\"\n    assert fm[\"title\"] == \"Check Fields\"\n    assert fm[\"status\"] == \"draft\"\n    assert fm[\"depends_on\"] == []\n    assert fm[\"blocks\"] == []\n    assert fm[\"impacts\"] == []\n    assert fm[\"parent\"] is None\n    assert fm[\"workflow\"] is None\n    assert \"created\" in fm\n    assert \"updated\" in fm\n    assert fm[\"created\"] == fm[\"updated\"]\n\n\ndef test_new_frontmatter_kind_default(tmp_path: Path) -> None:\n    \"\"\"Default kind is 'task'.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    main([\"--prd-dir\", str(prd_dir), \"new\", \"Kind Test\"])\n    path = prd_dir / \"PRD-001-kind-test.md\"\n    fm = yaml.safe_load(path.read_text(encoding=\"utf-8\").split(\"---\\n\", 2)[1])\n    assert fm[\"kind\"] == \"task\"\n\n\ndef test_new_frontmatter_custom_flags(tmp_path: Path) -> None:\n    \"\"\"Custom --kind, --priority, --effort, --capability are respected.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    rc = main(\n        [\n            \"--prd-dir\",\n            str(prd_dir),\n            \"new\",\n            \"Custom Flags\",\n            \"--kind\",\n            \"feature\",\n            \"--priority\",\n            \"high\",\n            \"--effort\",\n            \"l\",\n            \"--capability\",\n            \"complex\",\n        ]\n    )\n    assert rc == 0\n    path = prd_dir / \"PRD-001-custom-flags.md\"\n    fm = yaml.safe_load(path.read_text(encoding=\"utf-8\").split(\"---\\n\", 2)[1])\n    assert fm[\"kind\"] == \"feature\"\n    assert fm[\"priority\"] == \"high\"\n    assert fm[\"effort\"] == \"l\"\n    assert fm[\"capability\"] == \"complex\"\n\n\ndef test_new_body_has_standard_sections(tmp_path: Path) -> None:\n    \"\"\"Generated body contains all standard sections.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    main([\"--prd-dir\", str(prd_dir), \"new\", \"Section Check\"])\n    path = prd_dir / \"PRD-001-section-check.md\"\n    body = path.read_text(encoding=\"utf-8\")\n\n    for section in [\n        \"## Summary\",\n        \"## Motivation\",\n        \"## Requirements\",\n        \"## Technical Approach\",\n        \"## Acceptance Criteria\",\n        \"## Open Questions\",\n        \"## References\",\n    ]:\n        assert section in body, f\"Missing section: {section}\"\n\n\ndef test_new_invalid_kind_rejected(tmp_path: Path) -> None:\n    \"\"\"Invalid --kind value is rejected by argparse.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    with pytest.raises(SystemExit):\n        main([\"--prd-dir\", str(prd_dir), \"new\", \"Bad Kind\", \"--kind\", \"bogus\"])\n\n\ndef test_new_invalid_priority_rejected(tmp_path: Path) -> None:\n    \"\"\"Invalid --priority value is rejected by argparse.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    with pytest.raises(SystemExit):\n        main([\"--prd-dir\", str(prd_dir), \"new\", \"Bad Priority\", \"--priority\", \"urgent\"])\n\n\ndef test_new_no_existing_prds_starts_at_001(tmp_path: Path) -> None:\n    \"\"\"With zero existing PRDs, the first id is PRD-001.\"\"\"\n    prd_dir = tmp_path / \"prds\"\n    rc = main([\"--prd-dir\", str(prd_dir), \"new\", \"First Ever\"])\n    assert rc == 0\n    assert (prd_dir / \"PRD-001-first-ever.md\").exists()\n\n\ndef test_new_validate_passes(\n    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n) -> None:\n    \"\"\"Generated PRD passes `prd validate`.\"\"\"\n    # validate calls _find_repo_root which needs a .git directory\n    (tmp_path / \".git\").mkdir()\n    prd_dir = tmp_path / \"prds\"\n    main([\"--prd-dir\", str(prd_dir), \"new\", \"Validate Me\"])\n\n    rc = main([\"--prd-dir\", str(prd_dir), \"validate\"])\n    assert rc == 0\n","numLines":220,"startLine":1,"totalLines":220}}}
