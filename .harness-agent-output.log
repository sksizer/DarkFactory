\nfrom __future__ import annotations\nimport logging\nimport shutil\nimport subprocess\nfrom datetime import datetime\nfrom darkfactory.builtins._registry import builtin\nfrom darkfactory.workflow import ExecutionContext\n\n_log = logging.getLogger(__name__)\n\n@builtin(\"commit_transcript\")\ndef commit_transcript(ctx: ExecutionContext) -> None: ...\n```\n\n### `src/darkfactory/builtins/commit_transcript_test.py`\n\n- No transcript file → logs and returns (no-op)\n- Dry-run with transcript file → logs intended move without executing\n- Successful run → creates transcript dir, moves file, calls `git add`\n\n## Acceptance Criteria\n\n- [ ] AC-1: `src/darkfactory/builtins/commit_transcript.py` contains the `commit_transcript` function.\n- [ ] AC-2: `commit_transcript_test.py` covers no-transcript skip, dry-run, and successful move+stage.\n- [ ] AC-3: `commit_transcript` is no longer defined in `builtins/__init__.py`.\n- [ ] AC-4: `from darkfactory.builtins import commit_transcript` still works.\n- [ ] AC-5: All tests pass. `just test`, `just lint`, `just typecheck`, `just format-check` all clean.\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":7649,"cache_read_input_tokens":44890,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7649},"output_tokens":65,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"fdfb98d4-32e9-4fa7-a46c-bf4d30fd4fa2","uuid":"857309d5-1384-481c-9da7-d42d4cc2bce6"}
