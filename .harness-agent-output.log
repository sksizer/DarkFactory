{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017CLWEVgHXXmBtPP9i8nvJN","type":"tool_result","content":"1\t\"\"\"Command-line interface for the darkfactory PRD harness.\n2\t\n3\tUsage::\n4\t\n5\t    uv run prd <subcommand> [options]\n6\t\n7\tDefaults: PRDs live in ``prds/`` and workflows in ``workflows/`` at the\n8\trepo root. Override via ``--prd-dir`` and ``--workflows-dir``.\n9\t\n10\tThis should have minimial logic; the subcommand implementations can call into\n11\tspecific modules for the heavy lifting.\n12\t\"\"\"\n13\t\n14\tfrom __future__ import annotations\n15\t\n16\timport argparse\n17\timport json\n18\timport logging\n19\timport os\n20\timport re\n21\timport subprocess\n22\timport sys\n23\tfrom collections import Counter\n24\tfrom datetime import date\n25\tfrom pathlib import Path\n26\tfrom typing import Any\n27\t\n28\tfrom . import assign, checks, containment, graph, impacts\n29\tfrom .checks import StaleWorktree, find_stale_worktrees, is_safe_to_remove\n30\tfrom .graph_execution import RunEvent, execute_graph, plan_execution\n31\tfrom .invoke import capability_to_model\n32\tfrom .loader import load_workflows\n33\tfrom .prd import (\n34\t    PRD,\n35\t    PRD_ID_RE,\n36\t    dump_frontmatter,\n37\t    load_all,\n38\t    normalize_list_field_at,\n39\t    parse_id_sort_key,\n40\t    set_workflow,\n41\t    update_frontmatter_field_at,\n42\t)\n43\tfrom .runner import _compute_branch_name, _pick_model, run_workflow\n44\tfrom .style import Element, Styler, resolve_style_config\n45\tfrom .workflow import AgentTask, BuiltIn, ShellTask, Task, Workflow\n46\t\n47\t# Priority/effort orderings used for sorting actionable lists.\n48\tPRIORITY_ORDER: dict[str, int] = {\"critical\": 0, \"high\": 1, \"medium\": 2, \"low\": 3}\n49\tEFFORT_ORDER: dict[str, int] = {\"xs\": 0, \"s\": 1, \"m\": 2, \"l\": 3, \"xl\": 4}\n50\tCAPABILITY_ORDER: dict[str, int] = {\n51\t    \"trivial\": 0,\n52\t    \"simple\": 1,\n53\t    \"moderate\": 2,\n54\t    \"complex\": 3,\n55\t}\n56\t\n57\t\n58\tdef _find_repo_root(start: Path) -> Path:\n59\t    \"\"\"Walk up from ``start`` until a ``.git`` directory is found.\"\"\"\n60\t    current = start.resolve()\n61\t    while current != current.parent:\n62\t        if (current / \".git\").exists():\n63\t            return current\n64\t        current = current.parent\n65\t    raise SystemExit(f\"could not locate git repo root from {start}\")\n66\t\n67\t\n68\tdef _default_prd_dir() -> Path:\n69\t    \"\"\"Locate ``prds/`` at the repo root.\n70\t\n71\t    darkfactory ships its own PRDs under ``prds/`` rather than the\n72\t    nested ``docs/prd/`` layout the harness used inside pumice.\n73\t    Overridable via ``--prd-dir`` for repos that prefer a different\n74\t    location.\n75\t    \"\"\"\n76\t    repo = _find_repo_root(Path.cwd())\n77\t    return repo / \"prds\"\n78\t\n79\t\n80\tdef _default_workflows_dir() -> Path:"}]},"parent_tool_use_id":null,"session_id":"c624da95-2731-4846-aba2-2f223265b79e","uuid":"0d279447-7997-4aef-aa33-92a85ac4c19f","timestamp":"2026-04-09T02:41:57.737Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-556-modularize-cli/src/darkfactory/cli.py","content":"\"\"\"Command-line interface for the darkfactory PRD harness.\n\nUsage::\n\n    uv run prd <subcommand> [options]\n\nDefaults: PRDs live in ``prds/`` and workflows in ``workflows/`` at the\nrepo root. Override via ``--prd-dir`` and ``--workflows-dir``.\n\nThis should have minimial logic; the subcommand implementations can call into\nspecific modules for the heavy lifting.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport logging\nimport os\nimport re\nimport subprocess\nimport sys\nfrom collections import Counter\nfrom datetime import date\nfrom pathlib import Path\nfrom typing import Any\n\nfrom . import assign, checks, containment, graph, impacts\nfrom .checks import StaleWorktree, find_stale_worktrees, is_safe_to_remove\nfrom .graph_execution import RunEvent, execute_graph, plan_execution\nfrom .invoke import capability_to_model\nfrom .loader import load_workflows\nfrom .prd import (\n    PRD,\n    PRD_ID_RE,\n    dump_frontmatter,\n    load_all,\n    normalize_list_field_at,\n    parse_id_sort_key,\n    set_workflow,\n    update_frontmatter_field_at,\n)\nfrom .runner import _compute_branch_name, _pick_model, run_workflow\nfrom .style import Element, Styler, resolve_style_config\nfrom .workflow import AgentTask, BuiltIn, ShellTask, Task, Workflow\n\n# Priority/effort orderings used for sorting actionable lists.\nPRIORITY_ORDER: dict[str, int] = {\"critical\": 0, \"high\": 1, \"medium\": 2, \"low\": 3}\nEFFORT_ORDER: dict[str, int] = {\"xs\": 0, \"s\": 1, \"m\": 2, \"l\": 3, \"xl\": 4}\nCAPABILITY_ORDER: dict[str, int] = {\n    \"trivial\": 0,\n    \"simple\": 1,\n    \"moderate\": 2,\n    \"complex\": 3,\n}\n\n\ndef _find_repo_root(start: Path) -> Path:\n    \"\"\"Walk up from ``start`` until a ``.git`` directory is found.\"\"\"\n    current = start.resolve()\n    while current != current.parent:\n        if (current / \".git\").exists():\n            return current\n        current = current.parent\n    raise SystemExit(f\"could not locate git repo root from {start}\")\n\n\ndef _default_prd_dir() -> Path:\n    \"\"\"Locate ``prds/`` at the repo root.\n\n    darkfactory ships its own PRDs under ``prds/`` rather than the\n    nested ``docs/prd/`` layout the harness used inside pumice.\n    Overridable via ``--prd-dir`` for repos that prefer a different\n    location.\n    \"\"\"\n    repo = _find_repo_root(Path.cwd())\n    return repo / \"prds\"\n\n\ndef _default_workflows_dir() -> Path:","numLines":80,"startLine":1,"totalLines":1795}}}
