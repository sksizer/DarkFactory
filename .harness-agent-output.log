{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PVfSnBrzTKN44SBX76AELR","type":"tool_result","content":"1\t\"\"\"Containment tree operations.\n2\t\n3\tThe containment relationship is encoded in each PRD's ``parent`` field\n4\t(a single PRD id or None). The whole set forms a forest: each PRD has at\n5\tmost one parent, and there can be multiple roots. This is orthogonal to\n6\tthe dependency DAG (``depends_on``/``blocks``).\n7\t\"\"\"\n8\t\n9\tfrom __future__ import annotations\n10\t\n11\tfrom .prd import PRD, parse_id_sort_key\n12\t\n13\t\n14\tdef children(prd_id: str, prds: dict[str, PRD]) -> list[PRD]:\n15\t    \"\"\"Direct children of ``prd_id`` (PRDs whose ``parent`` matches), naturally sorted.\"\"\"\n16\t    matched = [p for p in prds.values() if p.parent == prd_id]\n17\t    matched.sort(key=lambda p: parse_id_sort_key(p.id))\n18\t    return matched\n19\t\n20\t\n21\tdef descendants(prd_id: str, prds: dict[str, PRD]) -> list[PRD]:\n22\t    \"\"\"All transitive children, BFS order.\"\"\"\n23\t    out: list[PRD] = []\n24\t    queue = children(prd_id, prds)\n25\t    while queue:\n26\t        node = queue.pop(0)\n27\t        out.append(node)\n28\t        queue.extend(children(node.id, prds))\n29\t    return out\n30\t\n31\t\n32\tdef ancestors(prd_id: str, prds: dict[str, PRD]) -> list[PRD]:\n33\t    \"\"\"Walk up the parent chain. Returns parents in order from immediate to root.\"\"\"\n34\t    out: list[PRD] = []\n35\t    seen: set[str] = set()\n36\t    current = prds.get(prd_id)\n37\t    while current and current.parent and current.parent not in seen:\n38\t        seen.add(current.parent)\n39\t        parent = prds.get(current.parent)\n40\t        if parent is None:\n41\t            break\n42\t        out.append(parent)\n43\t        current = parent\n44\t    return out\n45\t\n46\t\n47\tdef roots(prds: dict[str, PRD]) -> list[PRD]:\n48\t    \"\"\"Top-level PRDs (no parent), naturally sorted.\"\"\"\n49\t    rs = [p for p in prds.values() if p.parent is None]\n50\t    rs.sort(key=lambda p: parse_id_sort_key(p.id))\n51\t    return rs\n52\t\n53\t\n54\tdef is_leaf(prd: PRD, prds: dict[str, PRD]) -> bool:\n55\t    \"\"\"True if ``prd`` has no children.\"\"\"\n56\t    return not children(prd.id, prds)\n57\t\n58\t\n59\tdef is_fully_decomposed(prd: PRD, prds: dict[str, PRD]) -> bool:\n60\t    \"\"\"True if ``prd`` has at least one ``task``-kind descendant.\n61\t\n62\t    An epic or feature with no task descendants is considered not yet\n63\t    decomposed and is a candidate for the planning workflow.\n64\t    \"\"\"\n65\t    return any(d.kind == \"task\" for d in descendants(prd.id, prds))\n66\t\n67\t\n68\tdef is_runnable(prd: PRD, prds: dict[str, PRD]) -> bool:\n69\t    \"\"\"True if ``prd`` can be executed by an implementation workflow.\n70\t\n71\t    A PRD is runnable when it is itself a task OR a leaf in the containment\n72\t    tree (no children to delegate to). Epics and features with children are\n73\t    NOT runnable; they are decomposed via the planning workflow instead.\n74\t    \"\"\"\n75\t    if prd.kind == \"task\":\n76\t        return True\n77\t    return is_leaf(prd, prds)\n78\t"}]},"parent_tool_use_id":null,"session_id":"139194c3-2b15-46fb-ae47-01a4e87ddf0a","uuid":"072e608f-8f12-4b2c-b555-1c6ffead239d","timestamp":"2026-04-08T14:43:34.334Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-228-planning-workflow-initial/src/darkfactory/containment.py","content":"\"\"\"Containment tree operations.\n\nThe containment relationship is encoded in each PRD's ``parent`` field\n(a single PRD id or None). The whole set forms a forest: each PRD has at\nmost one parent, and there can be multiple roots. This is orthogonal to\nthe dependency DAG (``depends_on``/``blocks``).\n\"\"\"\n\nfrom __future__ import annotations\n\nfrom .prd import PRD, parse_id_sort_key\n\n\ndef children(prd_id: str, prds: dict[str, PRD]) -> list[PRD]:\n    \"\"\"Direct children of ``prd_id`` (PRDs whose ``parent`` matches), naturally sorted.\"\"\"\n    matched = [p for p in prds.values() if p.parent == prd_id]\n    matched.sort(key=lambda p: parse_id_sort_key(p.id))\n    return matched\n\n\ndef descendants(prd_id: str, prds: dict[str, PRD]) -> list[PRD]:\n    \"\"\"All transitive children, BFS order.\"\"\"\n    out: list[PRD] = []\n    queue = children(prd_id, prds)\n    while queue:\n        node = queue.pop(0)\n        out.append(node)\n        queue.extend(children(node.id, prds))\n    return out\n\n\ndef ancestors(prd_id: str, prds: dict[str, PRD]) -> list[PRD]:\n    \"\"\"Walk up the parent chain. Returns parents in order from immediate to root.\"\"\"\n    out: list[PRD] = []\n    seen: set[str] = set()\n    current = prds.get(prd_id)\n    while current and current.parent and current.parent not in seen:\n        seen.add(current.parent)\n        parent = prds.get(current.parent)\n        if parent is None:\n            break\n        out.append(parent)\n        current = parent\n    return out\n\n\ndef roots(prds: dict[str, PRD]) -> list[PRD]:\n    \"\"\"Top-level PRDs (no parent), naturally sorted.\"\"\"\n    rs = [p for p in prds.values() if p.parent is None]\n    rs.sort(key=lambda p: parse_id_sort_key(p.id))\n    return rs\n\n\ndef is_leaf(prd: PRD, prds: dict[str, PRD]) -> bool:\n    \"\"\"True if ``prd`` has no children.\"\"\"\n    return not children(prd.id, prds)\n\n\ndef is_fully_decomposed(prd: PRD, prds: dict[str, PRD]) -> bool:\n    \"\"\"True if ``prd`` has at least one ``task``-kind descendant.\n\n    An epic or feature with no task descendants is considered not yet\n    decomposed and is a candidate for the planning workflow.\n    \"\"\"\n    return any(d.kind == \"task\" for d in descendants(prd.id, prds))\n\n\ndef is_runnable(prd: PRD, prds: dict[str, PRD]) -> bool:\n    \"\"\"True if ``prd`` can be executed by an implementation workflow.\n\n    A PRD is runnable when it is itself a task OR a leaf in the containment\n    tree (no children to delegate to). Epics and features with children are\n    NOT runnable; they are decomposed via the planning workflow instead.\n    \"\"\"\n    if prd.kind == \"task\":\n        return True\n    return is_leaf(prd, prds)\n","numLines":78,"startLine":1,"totalLines":78}}}
