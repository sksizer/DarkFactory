{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014fc5fy7rcosDpzDcgCvi53","type":"tool_result","content":"1\t\"\"\"Integration tests for `prd plan` and `prd run` CLI subcommands.\n2\t\n3\tEnd-to-end tests that exercise the full argparse -> assign -> runner\n4\tchain against fixture PRD directories and workflow directories. The\n5\tactual agent invocation is mocked so tests don't spawn subprocesses.\n6\t\"\"\"\n7\t\n8\tfrom __future__ import annotations\n9\t\n10\timport json\n11\timport subprocess\n12\tfrom pathlib import Path\n13\tfrom unittest.mock import patch\n14\t\n15\timport pytest\n16\t\n17\tfrom darkfactory.cli import main\n18\t\n19\tfrom .conftest import write_prd\n20\t\n21\t\n22\tdef _write_workflow_with_prompts(workflows_dir: Path, name: str = \"default\") -> None:\n23\t    \"\"\"Create a minimal workflow with prompt files for end-to-end tests.\n24\t\n25\t    The generated workflow's ``workflow.name`` matches the directory\n26\t    name, so callers can create multiple distinct workflows in the same\n27\t    directory without collision.\n28\t    \"\"\"\n29\t    wf = workflows_dir / name\n30\t    (wf / \"prompts\").mkdir(parents=True)\n31\t    (wf / \"prompts\" / \"role.md\").write_text(\"# Role\\n\")\n32\t    (wf / \"prompts\" / \"task.md\").write_text(\"# Task\\n{{PRD_ID}}\\n\")\n33\t    (wf / \"prompts\" / \"verify.md\").write_text(\"Fix:\\n{{CHECK_OUTPUT}}\\n\")\n34\t    (wf / \"workflow.py\").write_text(\n35\t        f'''\"\"\"Fixture {name} workflow.\"\"\"\n36\tfrom darkfactory.workflow import AgentTask, BuiltIn, ShellTask, Workflow\n37\t\n38\t\n39\tdef _applies(prd, prds):\n40\t    return True\n41\t\n42\t\n43\tworkflow = Workflow(\n44\t    name=\"{name}\",\n45\t    description=\"Test {name}\",\n46\t    applies_to=_applies,\n47\t    priority=0,\n48\t    tasks=[\n49\t        BuiltIn(\"set_status\", kwargs={{\"to\": \"in-progress\"}}),\n50\t        AgentTask(prompts=[\"prompts/role.md\", \"prompts/task.md\"]),\n51\t        ShellTask(\"test\", cmd=\"echo test\"),\n52\t        BuiltIn(\"set_status\", kwargs={{\"to\": \"review\"}}),\n53\t    ],\n54\t)\n55\t'''\n56\t    )\n57\t\n58\t\n59\tdef _init_git_repo(path: Path) -> None:\n60\t    \"\"\"Minimal git init so ``_find_repo_root`` can locate the tmp dir.\n61\t\n62\t    The harness's CLI walks up from ``--prd-dir`` looking for ``.git``\n63\t    to use as the repo root; without this, plan/run commands raise\n64\t    ``SystemExit``. We use a bare `.git` directory rather than a full\n65\t    ``git init`` because none of the tests in this file actually need\n66\t    a functioning git repo — they mock subprocess calls where necessary.\n67\t    \"\"\"\n68\t    (path / \".git\").mkdir(exist_ok=True)\n69\t\n70\t\n71\t# ---------- plan ----------\n72\t\n73\t\n74\tdef test_plan_shows_workflow_and_tasks(\n75\t    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n76\t) -> None:\n77\t    _init_git_repo(tmp_path)\n78\t    workflows_dir = tmp_path / \"workflows\"\n79\t    _write_workflow_with_prompts(workflows_dir)\n80\t"}]},"parent_tool_use_id":null,"session_id":"139194c3-2b15-46fb-ae47-01a4e87ddf0a","uuid":"da1e9064-0df9-462a-94a2-b94ee5c8589b","timestamp":"2026-04-08T14:46:57.334Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/sksizer2/Developer/DarkFactory/.worktrees/PRD-228-planning-workflow-initial/tests/test_cli_run.py","content":"\"\"\"Integration tests for `prd plan` and `prd run` CLI subcommands.\n\nEnd-to-end tests that exercise the full argparse -> assign -> runner\nchain against fixture PRD directories and workflow directories. The\nactual agent invocation is mocked so tests don't spawn subprocesses.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport subprocess\nfrom pathlib import Path\nfrom unittest.mock import patch\n\nimport pytest\n\nfrom darkfactory.cli import main\n\nfrom .conftest import write_prd\n\n\ndef _write_workflow_with_prompts(workflows_dir: Path, name: str = \"default\") -> None:\n    \"\"\"Create a minimal workflow with prompt files for end-to-end tests.\n\n    The generated workflow's ``workflow.name`` matches the directory\n    name, so callers can create multiple distinct workflows in the same\n    directory without collision.\n    \"\"\"\n    wf = workflows_dir / name\n    (wf / \"prompts\").mkdir(parents=True)\n    (wf / \"prompts\" / \"role.md\").write_text(\"# Role\\n\")\n    (wf / \"prompts\" / \"task.md\").write_text(\"# Task\\n{{PRD_ID}}\\n\")\n    (wf / \"prompts\" / \"verify.md\").write_text(\"Fix:\\n{{CHECK_OUTPUT}}\\n\")\n    (wf / \"workflow.py\").write_text(\n        f'''\"\"\"Fixture {name} workflow.\"\"\"\nfrom darkfactory.workflow import AgentTask, BuiltIn, ShellTask, Workflow\n\n\ndef _applies(prd, prds):\n    return True\n\n\nworkflow = Workflow(\n    name=\"{name}\",\n    description=\"Test {name}\",\n    applies_to=_applies,\n    priority=0,\n    tasks=[\n        BuiltIn(\"set_status\", kwargs={{\"to\": \"in-progress\"}}),\n        AgentTask(prompts=[\"prompts/role.md\", \"prompts/task.md\"]),\n        ShellTask(\"test\", cmd=\"echo test\"),\n        BuiltIn(\"set_status\", kwargs={{\"to\": \"review\"}}),\n    ],\n)\n'''\n    )\n\n\ndef _init_git_repo(path: Path) -> None:\n    \"\"\"Minimal git init so ``_find_repo_root`` can locate the tmp dir.\n\n    The harness's CLI walks up from ``--prd-dir`` looking for ``.git``\n    to use as the repo root; without this, plan/run commands raise\n    ``SystemExit``. We use a bare `.git` directory rather than a full\n    ``git init`` because none of the tests in this file actually need\n    a functioning git repo — they mock subprocess calls where necessary.\n    \"\"\"\n    (path / \".git\").mkdir(exist_ok=True)\n\n\n# ---------- plan ----------\n\n\ndef test_plan_shows_workflow_and_tasks(\n    tmp_path: Path, capsys: pytest.CaptureFixture[str]\n) -> None:\n    _init_git_repo(tmp_path)\n    workflows_dir = tmp_path / \"workflows\"\n    _write_workflow_with_prompts(workflows_dir)\n","numLines":80,"startLine":1,"totalLines":419}}}
