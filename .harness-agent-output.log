{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VnohDRqcud36ryv1pU1npq","type":"tool_result","content":"1\t\"\"\"Command-line interface for the darkfactory PRD harness.\n2\t\n3\tUsage::\n4\t\n5\t    uv run prd <subcommand> [options]\n6\t\n7\tDefaults: PRDs live in ``prds/`` and workflows in ``workflows/`` at the\n8\trepo root. Override via ``--prd-dir`` and ``--workflows-dir``.\n9\t\n10\tThis should have minimial logic; the subcommand implementations can call into\n11\tspecific modules for the heavy lifting.\n12\t\"\"\"\n13\t\n14\tfrom __future__ import annotations\n15\t\n16\timport argparse\n17\timport json\n18\timport logging\n19\timport os\n20\timport re\n21\timport subprocess\n22\timport sys\n23\tfrom collections import Counter\n24\tfrom datetime import date\n25\tfrom pathlib import Path\n26\tfrom typing import Any\n27\t\n28\tfrom . import assign, checks, containment, graph, impacts\n29\tfrom .checks import StaleWorktree, find_stale_worktrees, is_safe_to_remove\n30\tfrom .graph_execution import RunEvent, execute_graph, plan_execution\n31\tfrom .invoke import capability_to_model\n32\tfrom .loader import load_workflows\n33\tfrom .prd import (\n34\t    PRD,\n35\t    PRD_ID_RE,\n36\t    dump_frontmatter,\n37\t    load_all,\n38\t    normalize_list_field_at,\n39\t    parse_id_sort_key,\n40\t    set_workflow,\n41\t    update_frontmatter_field_at,\n42\t)\n43\tfrom .runner import _compute_branch_name, _pick_model, run_workflow\n44\tfrom .style import Element, Styler, resolve_style_config\n45\tfrom .workflow import AgentTask, BuiltIn, ShellTask, Task, Workflow\n46\t\n47\t# Priority/effort orderings used for sorting actionable lists.\n48\tPRIORITY_ORDER: dict[str, int] = {\"critical\": 0, \"high\": 1, \"medium\": 2, \"low\": 3}\n49\tEFFORT_ORDER: dict[str, int] = {\"xs\": 0, \"s\": 1, \"m\": 2, \"l\": 3, \"xl\": 4}\n50\tCAPABILITY_ORDER: dict[str, int] = {\n51\t    \"trivial\": 0,\n52\t    \"simple\": 1,\n53\t    \"moderate\": 2,\n54\t    \"complex\": 3,\n55\t}\n56\t\n57\t\n58\tdef _find_repo_root(start: Path) -> Path:\n59\t    \"\"\"Walk up from ``start`` until a ``.git`` directory is found.\"\"\"\n60\t    current = start.resolve()\n61\t    while current != current.parent:\n62\t        if (current / \".git\").exists():\n63\t            return current\n64\t        current = current.parent\n65\t    raise SystemExit(f\"could not locate git repo root from {start}\")\n66\t\n67\t\n68\tdef _default_prd_dir() -> Path:\n69\t    \"\"\"Locate ``prds/`` at the repo root.\n70\t\n71\t    darkfactory ships its own PRDs under ``prds/`` rather than the\n72\t    nested ``docs/prd/`` layout the harness used inside pumice.\n73\t    Overridable via ``--prd-dir`` for repos that prefer a different\n74\t    location.\n75\t    \"\"\"\n76\t    repo = _find_repo_root(Path.cwd())\n77\t    return repo / \"prds\"\n78\t\n79\t\n80\tdef _default_workflows_dir() -> Path:\n81\t    \"\"\"Locate ``workflows/`` at the repo root.\n82\t\n83\t    All built-in workflows ship under this path. Overridable via\n84\t    ``--workflows-dir``.\n85\t    \"\"\"\n86\t    repo = _find_repo_root(Path.cwd())\n87\t    return repo / \"workflows\"\n88\t\n89\t\n90\tdef _load_workflows_or_fail(workflows_dir: Path) -> dict[str, Workflow]:\n91\t    \"\"\"Load workflows with a user-friendly error if the directory is missing.\"\"\"\n92\t    if not workflows_dir.exists():\n93\t        raise SystemExit(f\"workflows directory not found: {workflows_dir}\")\n94\t    return load_workflows(workflows_dir)\n95\t\n96\t\n97\tdef _action_sort_key(prd: PRD) -> tuple[int, int, tuple[int, ...]]:\n98\t    \"\"\"Sort key for actionable lists: priority, effort, natural id.\"\"\"\n99\t    return (\n100\t        PRIORITY_ORDER.get(prd.priority, 99),\n101\t        EFFORT_ORDER.get(prd.effort, 99),\n102\t        parse_id_sort_key(prd.id),\n103\t    )\n104\t\n105\t\n106\tdef _load(prd_dir: Path) -> dict[str, PRD]:\n107\t    if not prd_dir.exists():\n108\t        raise SystemExit(f\"PRD directory not found: {prd_dir}\")\n109\t    return load_all(prd_dir)\n110\t\n111\t\n112\t# ---------- subcommand implementations ----------\n113\t\n114\t\n115\tdef _slugify(title: str) -> str:\n116\t    \"\"\"Convert a title to kebab-case slug.\"\"\"\n117\t    slug = re.sub(r\"[^a-zA-Z0-9\\s-]\", \"\", title.lower())\n118\t    slug = re.sub(r\"\\s+\", \"-\", slug.strip())\n119\t    return slug or \"untitled\"\n120\t\n[result-id: r3]"}]},"parent_tool_use_id":"toolu_0116YA4rYY4LKmQQwBSbMtgQ","session_id":"939fc375-8ed1-4dc0-8515-8b3ee2d79451","uuid":"0a3dcd9a-6ddc-4ab0-9627-4a301280062c","timestamp":"2026-04-09T02:37:44.380Z"}
